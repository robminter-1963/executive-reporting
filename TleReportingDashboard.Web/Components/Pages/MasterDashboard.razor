            || await AdminAccess.HasAnyAdminAccessAsync(_userEmail);
        if (isAdmin)
        {
            // Sentinel role — admins bypass per-company grants entirely.
            // Used by UI gating to show every affordance regardless of role.
            _userRoleForCompany = UserRoles.Admin;
        }
        else if (hasAdminAccess)
        {
            // Section-scoped admin (System Support et al.). The user's
            // own role drives feature gating elsewhere; we don't elevate
            // them to UserRoles.Admin here. UI affordances that need
            // admin behavior should check AdminAccessService.CanAccess
            // for the specific section they care about.
            _userRoleForCompany = UserRoles.Editor;
