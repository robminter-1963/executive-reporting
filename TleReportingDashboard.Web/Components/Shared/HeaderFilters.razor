@inject ICodeSetService CodeSetService
@inject ILookupValueService LookupValueService

<MudPaper Elevation="0" Style="border: 1px solid #E8EAED; border-radius: 4px;" Class="pa-3">
    <MudStack Row AlignItems="AlignItems.Center" Spacing="2" Wrap="Wrap.Wrap">
        @* Date controls: quick-range presets row stacked above the
           Date Range / clear-button row. The presets cover the ~90% of
           viewer clicks (Today / 7d / 30d / MTD / QTD / YTD) so the
           calendar picker becomes the escape hatch for ranges the
           presets don't cover. Buttons (not chips) — standalone MudChips
           with OnClick have triggered the documented dialog-input-freeze
           pattern before, and outlined small buttons read identically
           for a one-tap action. *@
        <MudStack Spacing="1">
            <MudStack Row AlignItems="AlignItems.Center" Spacing="1" Wrap="Wrap.Wrap">
                <MudText Typo="Typo.caption" Color="Color.Secondary"
                         Style="margin-right: 4px;">Quick range:</MudText>
                <MudButton Variant="Variant.Outlined" Size="Size.Small"
                           OnClick="@(() => ApplyDatePreset("today"))">Today</MudButton>
                <MudButton Variant="Variant.Outlined" Size="Size.Small"
                           OnClick="@(() => ApplyDatePreset("7d"))">Last 7d</MudButton>
                <MudButton Variant="Variant.Outlined" Size="Size.Small"
                           OnClick="@(() => ApplyDatePreset("30d"))">Last 30d</MudButton>
                <MudButton Variant="Variant.Outlined" Size="Size.Small"
                           OnClick="@(() => ApplyDatePreset("mtd"))">MTD</MudButton>
                <MudButton Variant="Variant.Outlined" Size="Size.Small"
                           OnClick="@(() => ApplyDatePreset("lastmonth"))">Last month</MudButton>
                <MudButton Variant="Variant.Outlined" Size="Size.Small"
                           OnClick="@(() => ApplyDatePreset("qtd"))">QTD</MudButton>
                <MudButton Variant="Variant.Outlined" Size="Size.Small"
                           OnClick="@(() => ApplyDatePreset("ytd"))">YTD</MudButton>
            </MudStack>
            <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
                <MudDateRangePicker @bind-DateRange="_dateRange" @bind-DateRange:after="OnDateRangeAfterChanged"
                                    Label="Date Range" Variant="Variant.Outlined"
                                    Margin="Margin.Dense" Style="max-width: 260px;"
                                    PickerVariant="PickerVariant.Dialog"
                                    ShowToolbar="false" />
                <MudIconButton Icon="@Icons.Material.Outlined.Close" Size="Size.Small"
                               Color="Color.Default" OnClick="ClearDateRange"
                               Style="@(_dateRange is null ? "visibility: hidden;" : "")"
                               title="Clear date range" />
            </MudStack>
        </MudStack>

        @{
            var dateField = DateFields.FirstOrDefault(f => f.Id == _selectedDateField);
            var dateFieldTooltip = dateField is null
                ? string.Empty
                : ComposeSourceTooltip(dateField.SourceTable, dateField.SourceColumn, dateField.SqlExpression ?? string.Empty);
        }
        <MudTooltip Text="@dateFieldTooltip" Placement="Placement.Top"
                    Disabled="@string.IsNullOrEmpty(dateFieldTooltip)">
            <MudSelect T="string" @bind-Value="_selectedDateField" Label="Date Field" Variant="Variant.Outlined"
                       Margin="Margin.Dense" Style="max-width: 180px;" Dense>
                @foreach (var field in DateFields)
                {
                    <MudSelectItem Value="@field.Id">@field.Label</MudSelectItem>
                }
            </MudSelect>
        </MudTooltip>

        @foreach (var filter in _activeFilters)
        {
            var filterTooltip = ComposeSourceTooltip(filter.SourceTable, filter.SourceColumn, filter.SqlExpression);
            <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
                <MudTooltip Text="@filterTooltip" Placement="Placement.Top"
                            Disabled="@string.IsNullOrEmpty(filterTooltip)">
                    @if (filter.CodeSetValues.Any())
                    {
                        @* Enumerated field — multi-select dropdown *@
                        <MudSelect T="string" MultiSelection MultiSelectionTextFunc="@(vals => $"{vals.Count()} selected")"
                                   SelectedValues="filter.SelectedValues"
                                   SelectedValuesChanged="@(vals => OnMultiSelectChanged(filter, vals))"
                                   Label="@filter.Label" Variant="Variant.Outlined"
                                   Margin="Margin.Dense" Style="min-width: 200px; max-width: 280px;" Dense>
                            @foreach (var csv in filter.CodeSetValues.OrderBy(x => x.Description, StringComparer.OrdinalIgnoreCase))
                            {
                                @* Value sent to the query: Code when the field has a FilterColumn
                                   (admin wants WHERE to compare against the lookup's value column),
                                   otherwise Description (legacy behavior — WHERE compares against
                                   the field's own column, which typically stores the description). *@
                                <MudSelectItem T="string" Value="@(filter.UseCodeAsValue ? csv.Code : csv.Description)">@csv.Description</MudSelectItem>
                            }
                        </MudSelect>
                    }
                    else
                    {
                        @* Free-text field *@
                        <MudTextField @bind-Value="filter.Value" Label="@filter.Label" Variant="Variant.Outlined"
                                      Margin="Margin.Dense" Style="max-width: 180px;"
                                      DebounceInterval="500" OnDebounceIntervalElapsed="() => EmitFilters()" />
                    }
                </MudTooltip>
                <MudIconButton Icon="@Icons.Material.Outlined.Close" Size="Size.Small"
                               OnClick="() => RemoveFilter(filter.FieldId)"
                               title="Remove filter" />
            </MudStack>
        }

        <MudMenu Icon="@Icons.Material.Outlined.Add" Variant="Variant.Text" Color="Color.Primary"
                 Dense Size="Size.Small" Label="Add Filter">
            @foreach (var field in FilterableFields)
            {
                @if (!_activeFilters.Any(f => f.FieldId == field.Id))
                {
                    var menuTooltip = ComposeSourceTooltip(field.SourceTable, field.SourceColumn, field.SqlExpression ?? string.Empty);
                    <MudMenuItem OnClick="() => AddFilter(field)">
                        <MudTooltip Text="@menuTooltip" Placement="Placement.Right"
                                    Disabled="@string.IsNullOrEmpty(menuTooltip)">
                            <span>
                                @field.Label
                                @* "list" chip flags fields that will surface a
                                   multi-select chip picker rather than a free-
                                   text input — either CodeSet-backed (Empower)
                                   or FilterLookup-backed (generic table). *@
                                @if (field.CodeSetId.HasValue || !string.IsNullOrWhiteSpace(field.LookupTypeId))
                                {
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Info"
                                             Style="font-size: 0.6rem; margin-left: 4px;">list</MudChip>
                                }
                            </span>
                        </MudTooltip>
                    </MudMenuItem>
                }
            }
        </MudMenu>

        @if (Filters.Any() || _activeFilters.Any())
        {
            <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Secondary"
                       OnClick="ClearFilters">
                Clear Filters
            </MudButton>
        }
    </MudStack>
</MudPaper>

@code {
    [Parameter] public Dictionary<string, object?> Filters { get; set; } = new();
    [Parameter] public List<DomainGroup> Domains { get; set; } = new();
    [Parameter] public EventCallback<Dictionary<string, object?>> OnFiltersChanged { get; set; }

    // ConnectionId is required by ILookupValueService to resolve which
    // data DB to query for a filter-pickable Lookup's values. When unset
    // (legacy callers that don't pass it), lookup-backed fields silently
    // degrade to the free-text input — same fallback as a missing CodeSet.
    [Parameter] public Guid? ConnectionId { get; set; }

    private DateRange? _dateRange;
    private string _selectedDateField = string.Empty;
    private List<ActiveFilter> _activeFilters = new();

    protected override async Task OnParametersSetAsync()
    {
        // Sync _activeFilters from the incoming Filters parameter (e.g., from a saved report).
        // Idempotent: skip any FieldId already in _activeFilters so re-renders triggered by
        // the user's own EmitFilters don't duplicate entries the user just created.
        if (!Domains.Any() || !Filters.Any()) return;
        var allFields = Domains.SelectMany(d => d.Fields).ToList();

        foreach (var kvp in Filters)
        {
            if (kvp.Value is null) continue;

            // Handle date range filters
            if (kvp.Key.EndsWith("_start"))
            {
                var dateFieldId = kvp.Key[..^6];
                if (string.IsNullOrEmpty(_selectedDateField)) _selectedDateField = dateFieldId;
                var dateVal = ParseDate(kvp.Value);
                _dateRange ??= new DateRange();
                _dateRange = new DateRange(_dateRange.Start ?? dateVal, _dateRange.End);
                continue;
            }
            if (kvp.Key.EndsWith("_end"))
            {
                var dateFieldId = kvp.Key[..^4];
                if (string.IsNullOrEmpty(_selectedDateField)) _selectedDateField = dateFieldId;
                var dateVal = ParseDate(kvp.Value);
                _dateRange ??= new DateRange();
                _dateRange = new DateRange(_dateRange.Start, _dateRange.End ?? dateVal);
                continue;
            }

            // Regular or multi-select filter — skip if user already added it interactively
            if (_activeFilters.Any(f => f.FieldId == kvp.Key)) continue;

            var field = allFields.FirstOrDefault(f => f.Id == kvp.Key);
            if (field is null) continue;

            var filter = new ActiveFilter
            {
                FieldId = field.Id,
                Label = field.Label,
                CodeSetId = field.CodeSetId,
                SourceTable = field.SourceTable,
                SourceColumn = field.SourceColumn,
                SqlExpression = field.SqlExpression ?? string.Empty,
                UseCodeAsValue = !string.IsNullOrWhiteSpace(field.FilterColumn)
            };

            // Load codeset values if enumerated. CodeSetId takes precedence
            // when both are set (an admin oversight; nothing in the model
            // prevents both at once). LookupTypeId is the new generic
            // table-backed source; only consult it when there's no CodeSet.
            if (field.CodeSetId.HasValue)
            {
                filter.CodeSetValues = await CodeSetService.GetCodeSetValuesAsync(field.CodeSetId.Value);
            }
            else if (!string.IsNullOrWhiteSpace(field.LookupTypeId) && ConnectionId is Guid cid)
            {
                filter.CodeSetValues = await LookupValueService.GetFilterValuesAsync(cid, field.LookupTypeId);
            }

            // Restore selected values
            var valueList = ExtractStringList(kvp.Value);
            if (valueList is not null)
            {
                filter.SelectedValues = new HashSet<string>(valueList);
            }
            else
            {
                filter.Value = kvp.Value?.ToString() ?? string.Empty;
            }

            _activeFilters.Add(filter);
        }
    }

    private static DateTime? ParseDate(object? val)
    {
        if (val is DateTime dt) return dt;
        if (val is DateTimeOffset dto) return dto.DateTime;
        if (val is System.Text.Json.JsonElement je && je.TryGetDateTime(out var jdt)) return jdt;
        if (DateTime.TryParse(val?.ToString(), out var parsed)) return parsed;
        return null;
    }

    private static List<string>? ExtractStringList(object? value)
    {
        if (value is List<string> list) return list;
        if (value is IEnumerable<string> enumerable) return enumerable.ToList();
        if (value is System.Text.Json.JsonElement je && je.ValueKind == System.Text.Json.JsonValueKind.Array)
            return je.EnumerateArray().Select(e => e.GetString() ?? "").Where(s => s.Length > 0).ToList();
        return null;
    }

    private IEnumerable<FieldDefinition> DateFields =>
        Domains.SelectMany(d => d.Fields).Where(f =>
            f.DataType.Equals("date", StringComparison.OrdinalIgnoreCase) ||
            f.DataType.Equals("datetime", StringComparison.OrdinalIgnoreCase));

    private IEnumerable<FieldDefinition> FilterableFields =>
        Domains.SelectMany(d => d.Fields).Where(f =>
            f.DataType.Equals("text", StringComparison.OrdinalIgnoreCase) ||
            f.DataType.Equals("string", StringComparison.OrdinalIgnoreCase) ||
            f.DataType.Equals("varchar", StringComparison.OrdinalIgnoreCase) ||
            f.DataType.Equals("integer", StringComparison.OrdinalIgnoreCase) ||
            f.DataType.Equals("int", StringComparison.OrdinalIgnoreCase));

    private async Task OnDateRangeAfterChanged()
    {
        await EmitFilters();
    }

    private async Task ClearDateRange()
    {
        _dateRange = null;
        await EmitFilters();
    }

    // Quick-range presets above the calendar picker. Each preset sets a
    // (start, end) inclusive of today (so "Last 7d" = today + 6 prior days,
    // matching how viewers describe it verbally). Time-of-day is left at
    // midnight — the underlying date-filter translator handles inclusive
    // end-of-day on its own (DateOperatorId="custom_range" semantics).
    private async Task ApplyDatePreset(string key)
    {
        var today = DateTime.Today;
        DateTime start;
        DateTime end = today;
        switch (key)
        {
            case "today":
                start = today;
                break;
            case "7d":
                // "Last 7 days" reads as today + 6 prior days = a 7-day window.
                start = today.AddDays(-6);
                break;
            case "30d":
                start = today.AddDays(-29);
                break;
            case "mtd":
                start = new DateTime(today.Year, today.Month, 1);
                break;
            case "lastmonth":
                // Full previous calendar month, regardless of today's day-of-month.
                var firstThisMonth = new DateTime(today.Year, today.Month, 1);
                end = firstThisMonth.AddDays(-1);
                start = new DateTime(end.Year, end.Month, 1);
                break;
            case "qtd":
                // Calendar quarters: Jan-Mar, Apr-Jun, Jul-Sep, Oct-Dec.
                var quarterStartMonth = ((today.Month - 1) / 3) * 3 + 1;
                start = new DateTime(today.Year, quarterStartMonth, 1);
                break;
            case "ytd":
                start = new DateTime(today.Year, 1, 1);
                break;
            default:
                return;
        }
        _dateRange = new DateRange(start, end);
        await EmitFilters();
    }

    private async Task AddFilter(FieldDefinition field)
    {
        if (_activeFilters.Any(f => f.FieldId == field.Id)) return;

        var filter = new ActiveFilter
        {
            FieldId = field.Id,
            Label = field.Label,
            Value = string.Empty,
            CodeSetId = field.CodeSetId,
            SourceTable = field.SourceTable,
            SourceColumn = field.SourceColumn,
            SqlExpression = field.SqlExpression ?? string.Empty,
            UseCodeAsValue = !string.IsNullOrWhiteSpace(field.FilterColumn)
        };

        // Load codeset values if this is an enumerated field. Same
        // precedence rule as OnParametersSetAsync above: CodeSet wins,
        // FilterLookup is the new generic fallback.
        if (field.CodeSetId.HasValue)
        {
            filter.CodeSetValues = await CodeSetService.GetCodeSetValuesAsync(field.CodeSetId.Value);
        }
        else if (!string.IsNullOrWhiteSpace(field.LookupTypeId) && ConnectionId is Guid cid)
        {
            filter.CodeSetValues = await LookupValueService.GetFilterValuesAsync(cid, field.LookupTypeId);
        }

        _activeFilters.Add(filter);
    }

    // Coalesce rapid-fire multi-select clicks into a single query.
    // Without this, picking N items in a list dropdown fires N queries
    // — the parent re-runs the report on every check/uncheck. The
    // debounce keeps the dropdown UI live (filter.SelectedValues
    // updates immediately so checkmarks render in real time) but
    // delays the query emit until the user pauses for ~500ms.
    private CancellationTokenSource? _multiDebounceCts;

    private async Task OnMultiSelectChanged(ActiveFilter filter, IEnumerable<string> values)
    {
        filter.SelectedValues = new HashSet<string>(values);
        StateHasChanged();

        _multiDebounceCts?.Cancel();
        _multiDebounceCts = new CancellationTokenSource();
        var ct = _multiDebounceCts.Token;
        try
        {
            await Task.Delay(500, ct);
            await EmitFilters();
        }
        catch (TaskCanceledException) { /* superseded by a later click */ }
    }

    private async Task RemoveFilter(string fieldId)
    {
        _activeFilters.RemoveAll(f => f.FieldId == fieldId);
        await EmitFilters();
    }

    private async Task ClearFilters()
    {
        _activeFilters.Clear();
        _dateRange = null;
        _selectedDateField = string.Empty;
        await OnFiltersChanged.InvokeAsync(new Dictionary<string, object?>());
    }

    private async Task EmitFilters()
    {
        var filters = new Dictionary<string, object?>();

        if (_dateRange is not null && !string.IsNullOrEmpty(_selectedDateField))
        {
            if (_dateRange.Start.HasValue)
                filters[$"{_selectedDateField}_start"] = _dateRange.Start.Value;
            if (_dateRange.End.HasValue)
                filters[$"{_selectedDateField}_end"] = _dateRange.End.Value;
        }

        foreach (var filter in _activeFilters)
        {
            if (filter.CodeSetValues.Any() && filter.SelectedValues.Any())
            {
                // Multi-select: pass as List<string> for IN clause
                filters[filter.FieldId] = filter.SelectedValues.ToList();
            }
            else if (!string.IsNullOrWhiteSpace(filter.Value))
            {
                filters[filter.FieldId] = filter.Value;
            }
        }

        await OnFiltersChanged.InvokeAsync(filters);
    }

    private class ActiveFilter
    {
        public string FieldId { get; set; } = string.Empty;
        public string Label { get; set; } = string.Empty;
        public string Value { get; set; } = string.Empty;
        public int? CodeSetId { get; set; }
        public List<CodeSetValue> CodeSetValues { get; set; } = new();
        public HashSet<string> SelectedValues { get; set; } = new();
        // True when the field has a FilterColumn set (alternate column for
        // the WHERE comparison). Picker emits the LookupType's value column
        // (Code) instead of the display column (Description) so the WHERE
        // can compare against FilterColumn. False = legacy behavior:
        // picker emits Description and the WHERE matches the field's own
        // expression.
        public bool UseCodeAsValue { get; set; }
        // Source identifiers, populated at capture time and surfaced as
        // tooltips so admins can tell which underlying table/column a
        // filter actually targets — same Label can come from multiple
        // tables (e.g. lead.loan_type__c vs opportunity.loan_type__c) and
        // picking the wrong one silently changes which rows the report
        // sees.
        public string SourceTable { get; set; } = string.Empty;
        public string SourceColumn { get; set; } = string.Empty;
        public string SqlExpression { get; set; } = string.Empty;
    }

    // Composes a one-line tooltip for a field. Prefers <table>.<column>;
    // falls back to the raw SqlExpression for derived fields (CASE WHENs,
    // CAST chains, etc.) so the tooltip still says something useful for
    // admin-authored expressions. Empty input yields empty tooltip — the
    // caller suppresses MudTooltip in that case.
    private static string ComposeSourceTooltip(string sourceTable, string sourceColumn, string sqlExpression)
    {
        if (!string.IsNullOrWhiteSpace(sourceTable) && !string.IsNullOrWhiteSpace(sourceColumn))
            return $"{sourceTable}.{sourceColumn}";
        if (!string.IsNullOrWhiteSpace(sqlExpression))
            return sqlExpression.Length > 200 ? sqlExpression[..200] + "…" : sqlExpression;
        return string.Empty;
    }
}
