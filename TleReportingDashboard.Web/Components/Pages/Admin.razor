@page "/admin"
@rendermode InteractiveServer
@implements IDisposable
@inject EditorModeState EditorMode
@inject IAdminService AdminService
@inject IAdminAccessService AdminAccess
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS

<PageTitle>Admin - Executive Reporting Suite</PageTitle>

@* Plain <div> as the scroll container, not the MudStack. MudStack
   uses display:flex internally, and flex children default to
   min-height: auto — combining that with overflow-y:auto on the same
   element lets children overflow without triggering the scroll. A
   plain block-level div sidesteps the flex sizing trap.
   The bounded height accounts for the global app bar (64px). Each
   child Admin*Tab.razor should NOT add its own scroll wrapper —
   that would create a second scrollbar inside this one. *@
<div style="height: calc(100vh - 64px); overflow-y: auto; padding: 0; margin-left: 15px;">
<MudStack Spacing="3">
    <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
        @* Back arrow uses the browser history when there's something to
           go back to (the natural picker → dashboard → admin flow lands
           the user back on the dashboard or picker as expected). When
           there's no history — bookmarked direct nav to /admin, or a
           fresh tab — fall back to the all-companies picker (/?all=1).
           A System Support user landing directly on /admin previously
           had no path back to the picker; this restores it. *@
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                       title="Back"
                       OnClick="GoBack" />
        @* Explicit shortcut to the all-companies picker — reachable
           regardless of browser history state. Useful for System
           Support users who jump between admin sections and the
           picker repeatedly. *@
        <MudTooltip Text="All companies">
            <MudIconButton Icon="@Icons.Material.Filled.Apps"
                           OnClick="@(() => Navigation.NavigateTo("/?all=1"))" />
        </MudTooltip>
        <MudText Typo="Typo.h5" Style="font-weight: 600;">Admin</MudText>
        @if (_isFullAdmin)
        {
            <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Outlined"
                     Icon="@Icons.Material.Filled.Shield"
                     Style="font-size: 0.65rem; height: 22px;">
                GLOBAL ADMIN
            </MudChip>
        }
        else
        {
            @* Non-admin badge — clarifies that the user only has section-
               scoped access (e.g. System Support). The chip color shifts
               to differentiate it from the global-admin chip. *@
            <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined"
                     Icon="@Icons.Material.Filled.LockPerson"
                     Style="font-size: 0.65rem; height: 22px;">
                LIMITED ACCESS
            </MudChip>
        }
        <MudSpacer />
        @if (_isFullAdmin)
        {
            <MudTooltip Text="Preview the proposed ad-hoc filter UX — nothing persists">
                <MudButton Variant="Variant.Outlined" Color="Color.Warning"
                           StartIcon="@Icons.Material.Filled.Science"
                           OnClick="@(() => Navigation.NavigateTo("/prototype/filters"))">
                    Filter Prototype
                </MudButton>
            </MudTooltip>
        }
        @if (_allowedSections.Contains(AdminSections.SchemaBuilder))
        {
            <MudTooltip Text="Schema Builder — edit per-company field catalog">
                <MudButton Variant="Variant.Outlined" Color="Color.Default"
                           StartIcon="@Icons.Material.Filled.DataObject"
                           OnClick="@(() => Navigation.NavigateTo("/admin/schema-builder"))">
                    Schema Builder
                </MudButton>
            </MudTooltip>
        }
    </MudStack>
    <MudText Typo="Typo.body2" Color="Color.Secondary">
        Set up companies, their data-source connections, and users (with per-company role grants). Changes take effect immediately.
    </MudText>

    @if (!_accessGranted)
    {
        <MudAlert Severity="Severity.Error">
            Your role doesn't grant access to any admin sections. Contact a global admin if you need access.
        </MudAlert>
    }
    else
    {
        <MudTabs @bind-ActivePanelIndex="_activeTab" Elevation="0" Rounded ApplyEffectsToContainer>
            @* Each tab gates on the section key. Tabs the role can't reach
               are hidden entirely so the editor never lands on one. The
               component-level guard inside each tab is a backstop. *@
            @if (_allowedSections.Contains(AdminSections.Companies))
            {
                <MudTabPanel Text="Companies" Icon="@Icons.Material.Filled.Business">
                    <AdminCompaniesTab />
                </MudTabPanel>
            }
            @if (_allowedSections.Contains(AdminSections.DbConnections))
            {
                <MudTabPanel Text="DB Connections" Icon="@Icons.Material.Filled.Storage">
                    <AdminConnectionsTab />
                </MudTabPanel>
            }
            @if (_allowedSections.Contains(AdminSections.Users))
            {
                <MudTabPanel Text="Users" Icon="@Icons.Material.Filled.ManageAccounts">
                    <AdminUsersTab CurrentUserEmail="@_currentUserEmail" />
                </MudTabPanel>
            }
            @if (_allowedSections.Contains(AdminSections.Roles))
            {
                <MudTabPanel Text="Roles" Icon="@Icons.Material.Filled.Badge">
                    <AdminRolesTab CurrentUserEmail="@_currentUserEmail" CanEditAdminSections="@_isFullAdmin" />
                </MudTabPanel>
            }
            @if (_allowedSections.Contains(AdminSections.TeamBuilder))
            {
                <MudTabPanel Text="Team Builder" Icon="@Icons.Material.Filled.Groups">
                    <AdminTeamBuilderTab CurrentUserEmail="@_currentUserEmail" />
                </MudTabPanel>
            }
            @if (_allowedSections.Contains(AdminSections.Schedules))
            {
                <MudTabPanel Text="Schedules" Icon="@Icons.Material.Filled.Schedule">
                    <AdminSchedulesTab CurrentUserEmail="@_currentUserEmail"
                                       CurrentUserId="@_currentUserId" />
                </MudTabPanel>
            }
            @if (_allowedSections.Contains(AdminSections.SchemaHistory))
            {
                <MudTabPanel Text="Schema History" Icon="@Icons.Material.Filled.History">
                    <AdminSchemaHistoryTab />
                </MudTabPanel>
            }
            @if (_allowedSections.Contains(AdminSections.Promotion))
            {
                <MudTabPanel Text="Promotion" Icon="@Icons.Material.Filled.Sync">
                    <AdminPromotionTab CurrentUserEmail="@_currentUserEmail" />
                </MudTabPanel>
            }
            @if (_allowedSections.Contains(AdminSections.Theme))
            {
                <MudTabPanel Text="Theme" Icon="@Icons.Material.Filled.Palette">
                    <AdminThemeTab CurrentUserEmail="@_currentUserEmail" />
                </MudTabPanel>
            }
            @if (_allowedSections.Contains(AdminSections.AppSettings))
            {
                <MudTabPanel Text="App Settings" Icon="@Icons.Material.Filled.Tune">
                    <AdminAppSettingsTab CurrentUserEmail="@_currentUserEmail" />
                </MudTabPanel>
            }
            @if (_allowedSections.Contains(AdminSections.ColumnWidths))
            {
                <MudTabPanel Text="Column Widths" Icon="@Icons.Material.Filled.ViewColumn">
                    <AdminColumnWidthsTab CurrentUserEmail="@_currentUserEmail" />
                </MudTabPanel>
            }
        </MudTabs>
    }
</MudStack>
</div>

@code {
    private bool _accessGranted;
    // True for global admins (everything visible). False for limited-access
    // roles like System Support — they see only the tabs / buttons their
    // role allows. Drives the chip color in the header and the visibility
    // of the Filter Prototype button.
    private bool _isFullAdmin;
    private IReadOnlySet<string> _allowedSections =
        new HashSet<string>(StringComparer.OrdinalIgnoreCase);
    private int _activeTab;
    private string _currentUserEmail = string.Empty;
    // Schedule owner-id requires a stable identifier — "oid" claim (Azure
    // AD object id) when present, falls back to the email so the dev-stub
    // auth still produces a non-empty value. Used by the Schedules tab.
    private string _currentUserId = string.Empty;
    private IDisposable? _editorScope;

    protected override async Task OnInitializedAsync()
    {
        _editorScope = EditorMode.Enter();

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _currentUserEmail = authState.User.FindFirst("preferred_username")?.Value
            ?? authState.User.FindFirst("email")?.Value
            ?? authState.User.Identity?.Name
            ?? string.Empty;
        _currentUserId = authState.User.FindFirst("oid")?.Value
            ?? authState.User.Identity?.Name
            ?? _currentUserEmail;

        _isFullAdmin = AdminService.IsGlobalAdmin(_currentUserEmail);
        _allowedSections = await AdminAccess.GetAllowedSectionsAsync(_currentUserEmail);
        _accessGranted = _allowedSections.Count > 0;
    }

    // Browser-history-aware back. Mirrors ReportLibrary.GoBack so the
    // affordance behaves the same way across the app: prefer "the page
    // the user came from" when one exists, fall back to the all-
    // companies picker otherwise. Without the fallback, System Support
    // users who land directly on /admin (bookmarked, fresh tab, etc.)
    // had no path back to the picker.
    private async Task GoBack()
    {
        var hasHistory = await JS.InvokeAsync<bool>("eval", "window.history.length > 1");
        if (hasHistory)
            await JS.InvokeVoidAsync("history.back");
        else
            Navigation.NavigateTo("/?all=1");
    }

    public void Dispose()
    {
        _editorScope?.Dispose();
        _editorScope = null;
    }
}
