@inject IJSRuntime JS
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.Code" />
            <MudText Typo="Typo.h6">Generated SQL Query</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="2" Style="min-width: 700px;">
            @* Execution-error banner. Surfaced when the dialog is opened on a
               tile that failed at run time — the SQL block below shows what
               was sent (or attempted) so admins can debug invalid SQL or
               source-DB rejections without tailing logs. *@
            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <MudAlert Severity="Severity.Error" Dense Variant="Variant.Outlined"
                          Icon="@Icons.Material.Filled.ErrorOutline">
                    <MudText Typo="Typo.subtitle2" Style="font-weight: 600;">Query failed</MudText>
                    <pre style="margin: 4px 0 0 0; white-space: pre-wrap; font-family: inherit; font-size: 0.85rem;">@ErrorMessage</pre>
                </MudAlert>
            }

            @* Row-level-scoping banner. Warning color when scoping force-
               matched to zero rows (admin has something to fix); info color
               when scoping resolved successfully (useful to confirm the
               predicate and owner column). *@
            @if (!string.IsNullOrEmpty(ScopingNote))
            {
                <MudAlert Severity="@(ScopingForceNoMatch ? Severity.Warning : Severity.Info)" Dense Variant="Variant.Outlined">
                    @ScopingNote
                </MudAlert>
            }

            @* Client-side filter note — describes any in-memory filter the
               caller applies after the query runs (e.g. the detail view
               narrowing rows to the tile group the user clicked). Separate
               from the SQL so the admin can see the full picture. *@
            @if (!string.IsNullOrEmpty(ClientSideFilter))
            {
                <MudAlert Severity="Severity.Info" Dense Variant="Variant.Outlined"
                          Icon="@Icons.Material.Filled.FilterAlt">
                    <strong>After the query:</strong> @ClientSideFilter
                </MudAlert>
            }

            @if (HasDetail)
            {
                @* Two tabs when the caller passed a detail-view query too —
                   Table vs Detail. Each tab has its own Copy button so the
                   one you're looking at is the one you copy. *@
                <MudTabs ActivePanelIndex="_activeIndex" ActivePanelIndexChanged="i => _activeIndex = i"
                         Elevation="0" Rounded>
                    <MudTabPanel Text="Table View" Icon="@Icons.Material.Filled.TableChart">
                        @RenderSqlBlock(Sql, Parameters)
                    </MudTabPanel>
                    <MudTabPanel Text="Detail View" Icon="@Icons.Material.Filled.ZoomIn">
                        @RenderSqlBlock(DetailSql ?? string.Empty, DetailParameters)
                    </MudTabPanel>
                </MudTabs>
            }
            else
            {
                @RenderSqlBlock(Sql, Parameters)
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close">Close</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Outlined"
                   StartIcon="@Icons.Material.Filled.ContentCopy" OnClick="CopyActiveToClipboard">
            Copy SQL
        </MudButton>
        @* Inlined-values copy — substitutes each @parameter with a SQL
           literal so the result pastes directly into SSMS / pgAdmin.
           Booleans land as 1/0 (SQL Server bit-friendly); Postgres users
           with strict boolean comparisons may need a one-character tweak. *@
        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Filled.ContentPaste"
                   OnClick="CopyActiveWithValuesToClipboard">
            Copy SQL with values
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance? MudDialog { get; set; }
    [Parameter] public string Sql { get; set; } = string.Empty;
    [Parameter] public Dictionary<string, object?>? Parameters { get; set; }
    // Optional — the SQL the DetailViewer would execute for the same report.
    // When populated, the dialog renders tabbed panels and the copy button
    // respects the active tab.
    [Parameter] public string? DetailSql { get; set; }
    [Parameter] public Dictionary<string, object?>? DetailParameters { get; set; }
    // Row-level-scoping note from the resolver. When set, the dialog shows
    // a banner above the SQL explaining why the predicate landed where it
    // did — especially useful for the ForceNoMatch case where the query
    // returned zero rows on purpose.
    [Parameter] public string? ScopingNote { get; set; }
    [Parameter] public bool ScopingForceNoMatch { get; set; }
    // In-memory filter applied after the query — e.g. the detail view
    // narrowing to the clicked tile group. Plain text, rendered in its own
    // banner so the full row-selection story is visible (SQL plus the
    // post-query filter = the rows the grid actually shows).
    [Parameter] public string? ClientSideFilter { get; set; }
    // When the caller opens the dialog for a tile/report that errored out
    // at execution, this carries the source-DB error message. Rendered as
    // a red banner above the SQL so the admin sees the failure context
    // alongside the query.
    [Parameter] public string? ErrorMessage { get; set; }

    private int _activeIndex;

    private bool HasDetail => !string.IsNullOrEmpty(DetailSql);

    private RenderFragment RenderSqlBlock(string sql, Dictionary<string, object?>? parameters) => @<MudStack Spacing="2">
        <MudPaper Elevation="0" Style="border: 1px solid #E8EAED; border-radius: 4px; max-height: 500px; overflow: auto; background: #1E1E1E;">
            <pre style="padding: 16px; margin: 0; color: #D4D4D4; font-family: 'Consolas', 'Courier New', monospace; font-size: 0.85rem; white-space: pre-wrap; word-wrap: break-word;">@sql</pre>
        </MudPaper>
        @if (parameters is not null && parameters.Count > 0)
        {
            <MudText Typo="Typo.subtitle2" Style="font-weight: 600;">Parameters</MudText>
            <MudPaper Elevation="0" Style="border: 1px solid #E8EAED; border-radius: 4px;">
                <MudSimpleTable Dense Hover Style="background: transparent;">
                    <thead>
                        <tr>
                            <th style="text-align: left;">Name</th>
                            <th style="text-align: left;">Value</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in parameters)
                        {
                            <tr>
                                <td><code>@p.Key</code></td>
                                <td>@(p.Value?.ToString() ?? "<null>")</td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>
            </MudPaper>
        }
    </MudStack>;

    private void Close() => MudDialog?.Close();

    private async Task CopyActiveToClipboard()
    {
        var sql = HasDetail && _activeIndex == 1 ? (DetailSql ?? string.Empty) : Sql;
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", sql);
        Snackbar.Add("SQL copied to clipboard.", Severity.Success);
    }

    private async Task CopyActiveWithValuesToClipboard()
    {
        var sql        = HasDetail && _activeIndex == 1 ? (DetailSql ?? string.Empty) : Sql;
        var parameters = HasDetail && _activeIndex == 1 ? DetailParameters             : Parameters;
        var inlined    = InlineParameters(sql, parameters);
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", inlined);
        Snackbar.Add("SQL copied with values inlined.", Severity.Success);
    }

    // Substitute every @parameter reference in the SQL with the value it
    // would bind to, formatted as a SQL literal. Word-boundary regex so a
    // match on @__af_1 doesn't also chew up the prefix of @__af_10.
    // Parameters not in the dictionary are left untouched.
    private static string InlineParameters(string sql, Dictionary<string, object?>? parameters)
    {
        if (string.IsNullOrEmpty(sql) || parameters is null || parameters.Count == 0)
            return sql;
        return System.Text.RegularExpressions.Regex.Replace(
            sql,
            @"@\w+",
            match =>
            {
                var name = match.Value;
                if (!parameters.TryGetValue(name, out var value)) return name;
                return FormatLiteral(value);
            });
    }

    // Render a parameter value as a portable SQL literal. The values that
    // hit this method come from ADO.NET DbParameter.Value, so the .NET
    // runtime types decide formatting. Both pgAdmin and SSMS accept the
    // forms below for the columns they target most often.
    private static string FormatLiteral(object? value)
    {
        if (value is null) return "NULL";
        return value switch
        {
            bool b                        => b ? "1" : "0",
            DateTime dt                   => $"'{dt:yyyy-MM-dd HH:mm:ss.fff}'",
            DateTimeOffset dto            => $"'{dto:yyyy-MM-dd HH:mm:ss.fffzzz}'",
            DateOnly d                    => $"'{d:yyyy-MM-dd}'",
            TimeOnly t                    => $"'{t:HH:mm:ss.fff}'",
            Guid g                        => $"'{g}'",
            byte[] bytes                  => "0x" + Convert.ToHexString(bytes),
            byte or sbyte or short or ushort or int or uint or long or ulong
                                          => Convert.ToString(value, System.Globalization.CultureInfo.InvariantCulture)!,
            decimal or double or float    => Convert.ToString(value, System.Globalization.CultureInfo.InvariantCulture)!,
            string s                      => $"'{s.Replace("'", "''")}'",
            _                             => $"'{value.ToString()!.Replace("'", "''")}'"
        };
    }
}
