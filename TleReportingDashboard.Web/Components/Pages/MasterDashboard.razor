        {
            company = await CompanyRegistry.GetByCodeAsync(CompanyCode);
        }
        if (company is null)
        {
            Navigation.NavigateTo("/?all=1", replace: true);
            return;
        }

        var isAdmin = AdminService.IsAdmin(_userEmail);
        // Roles with any admin-section access (Administrator, System
        // Support, etc.) bypass the per-company grant check too — they
        // need to navigate into any company to do administrative work.
        // Same model as the picker; keeps the two surfaces consistent.
