<style>
    .tile-resize-handle {
        position: absolute;
        right: 0;
        bottom: 0;
        width: 16px;
        height: 16px;
        cursor: nwse-resize;
        z-index: 20;
        background: linear-gradient(135deg, transparent 50%, #1A73E8 50%);
        border-radius: 0 0 4px 0;
        opacity: 0.6;
    }
    .tile-resize-handle:hover {
        opacity: 1;
    }
    .mud-tabs .mud-tab {
        text-transform: none !important;
        /* Tighten the tab strip — MudBlazor's default min-height is 48px,
           which feels tall on a dashboard where every pixel above the
           tiles is overhead. 36px keeps text + the active-tab underline
           comfortably visible without crowding the content below. */
        min-height: 36px !important;
        padding: 4px 12px !important;
    }
    .mud-tabs .mud-tabs-toolbar {
        min-height: 36px !important;
    }
    /* Don't constrain the inner bar — let it follow its content (the
       individual .mud-tab buttons sized above) instead of carrying its
       own default 48px floor that'd add unwanted vertical space. */
    .mud-tabs .mud-tabs-tabbar-inner {
        min-height: 0 !important;
    }
    /* Responsive: tiles can't exceed viewport width and shrink freely down
       to whatever their content's natural min-width is. The inline width
       (ColSpan * 60) is treated as the preferred width; max-width: 100%
       caps it to the available space. The 300px hard floor that used to
       live here was the chain-breaker preventing the inner table from
       shrinking past a certain point — removed so text columns can
       actually flex with the tile. The tile's title bar already
       ellipsises (flex: 1; min-width: 0; text-overflow: ellipsis). */
    .master-tile {
        max-width: 100%;
        /* Round the outer wrapper too so the edit-mode outline / resize-mode
           outline track the rounded inner MudPaper instead of cutting square
           corners across the rounded shadow underneath. */
        border-radius: 12px;
    }
    .master-tile-edit {
        outline: 2px dashed #DADCE0;
        outline-offset: -2px;
        border-radius: 12px;
    }
    .master-tile.tile-resizing {
        outline: 2px solid #1A73E8 !important;
        opacity: 0.9;
        border-radius: 12px;
    }
    .master-tile.master-tile-dragging {
        opacity: 0.4;
    }
    .master-tile.master-tile-droptarget {
        outline: 3px solid #1A73E8 !important;
        outline-offset: -3px;
    }
    /* Per-tile grid header row: dodger blue background, white text (including
       sort icons and the sortable header buttons MudDataGrid renders). Scoped
       to .master-tile so the Report Library and other grids aren't affected. */
    .master-tile thead th,
    .master-tile .mud-table-head th,
    .master-tile .mud-table-cell-header {
        font-weight: bold !important;
        white-space: nowrap !important;
    }
    .master-tile thead th .mud-button-root,
    .master-tile .mud-table-head .mud-button-root,
    .master-tile .mud-table-sort-label,
    .master-tile .mud-table-sort-label .mud-icon-root {
        color: #FFFFFF !important;
    }
    /* Body cells: nowrap + overflow: hidden + ellipsis so long data values
       truncate with the ellipsis character instead of wrapping over multiple rows.
       The ellipsis rule must also hit the inner MudText wrapper (rendered as p or
       span), otherwise the text overflows the inner element silently without
       producing the ellipsis. display: block + max-width: 100% makes text-overflow
       actually fire on the inner element. */
    .master-tile tbody td,
    .master-tile .mud-table-cell:not(.mud-table-cell-header) {
        white-space: nowrap !important;
        overflow: hidden !important;
        text-overflow: ellipsis !important;
        /* No max-width here — under table-layout: fixed the column widths come from
           the <col>/th definitions; max-width: 0 would override the explicit widths
           set on count/pct/measure/extras and collapse those cells to zero. */
    }
    .master-tile tbody td .mud-typography,
    .master-tile tbody td p,
    .master-tile tbody td span,
    .master-tile tbody td div {
        max-width: 100%;
        white-space: nowrap !important;
        overflow: hidden !important;
        text-overflow: ellipsis !important;
        text-align: inherit;   /* pick up text-align from the parent cell */
    }
    .master-tile tbody td .mud-typography,
    .master-tile tbody td p {
        display: block;
    }
    /* No horizontal scrollbar inside a tile — if content is wider than the tile,
       clip it silently. Combined with the ellipsis on body cells above, the
       Campaign column (or whichever is flexible) shrinks and cells truncate. */
    .master-tile .mud-table-container {
        overflow-x: hidden !important;
    }
    /* Excludes .dash-summary-table — that table needs table-layout: fixed
       to clip overflowing text columns; under auto layout it sizes to its
       widest content and overflows the wrap (no scrollbar, content clipped
       off the right edge). */
    .master-tile table:not(.dash-summary-table) {
        table-layout: auto;
        width: 100%;
    }
    /* Tighter cell padding inside tiles — 4px top/bottom, 6px left/right. */
    .master-tile .mud-table-cell {
        padding: 4px 6px !important;
    }
    /* Darker hover on tile data rows for better visual feedback. */
    .master-tile tbody tr:hover td {
        background-color: #E0E0E0 !important;
    }
</style>

@code {
