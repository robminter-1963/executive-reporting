@page "/quick"
@rendermode InteractiveServer
@inject IReportService ReportService
@inject IQueryService QueryService
@inject ISchemaService SchemaService
@inject ISchemaConfigStore SchemaStore
@inject ICustomPrimaryTableService CustomPrimaryTableSvc
@inject ICompanyRegistry CompanyRegistry
@inject ICompanyConnectionAdminService ConnectionAdminSvc
@inject IUserManagementService UserManagement
@inject IAdminService AdminService
@inject IAdminAccessService AdminAccess
@inject IQueryScopeResolver ScopeResolver
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject ILogger<QuickReport> Logger

@using TleReportingDashboard.Web.Models
@using TleReportingDashboard.Web.Services

<PageTitle>New report - Executive Reporting Suite</PageTitle>

@*  Quick Report — the "Simple mode" entry point.
    Goal: a user picks a subject (data Domain), checks a few fields,
    optionally narrows to a date range, hits Run, and gets results.
    Everything else (tables, joins, lookups, sort, paging) is handled
    by the same QueryService the Builder uses; the user never sees
    those concepts.

    Skeleton (top → bottom):
      1. Company + Connection picker — auto-select when only one option
      2. Subject (Domain) picker — single-select chip strip
      3. Field checklist — flat list of the picked subject's fields
      4. Date range — pick a date field + a preset (This Month default)
      5. Run + Save — inline results below; Save persists to My Reports

    Inline results render in the same ReportGrid used everywhere else
    so the table behavior (sort, page, copy) matches what users see
    after Save → open from Library. *@

<MudMainContent Style="padding: 0; margin-left: 15px;">
    <MudStack Spacing="3" Class="pa-2">
        <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
            <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                <MudIconButton Icon="@Icons.Material.Outlined.ArrowBack"
                               OnClick="@(() => Navigation.NavigateTo("/reports"))"
                               title="Back to reports" />
                <MudText Typo="Typo.h6" Style="font-weight: 600;">New report — quick</MudText>
                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info"
                         Icon="@Icons.Material.Outlined.AutoAwesome">
                    Simple mode
                </MudChip>
            </MudStack>
            <MudButton Variant="Variant.Text" Color="Color.Default"
                       StartIcon="@Icons.Material.Outlined.Tune"
                       OnClick="@(() => Navigation.NavigateTo("/builder"))">
                Switch to advanced
            </MudButton>
        </MudStack>

        @if (_initLoading)
        {
            <QueryProgress Active="true" />
        }
        else if (!_companies.Any())
        {
            <EmptyState Icon="@Icons.Material.Outlined.NoAccounts"
                        Heading="No data sources available"
                        Body="You don't have access to any companies yet. Ask an admin to grant you access." />
        }
        else
        {
            @* ── Step 1: Where (company + connection) ── *@
            @if (_companies.Count > 1 || _connections.Count > 1)
            {
                <MudPaper Elevation="0" Class="pa-3" Style="border: 1px solid #DADCE0; border-radius: 4px;">
                    <MudText Typo="Typo.subtitle2" Style="margin-bottom: 8px;">Where</MudText>
                    <MudStack Row Spacing="2" Wrap="Wrap.Wrap">
                        @if (_companies.Count > 1)
                        {
                            <MudSelect T="Guid?" Value="_selectedCompanyId" ValueChanged="OnCompanyChanged"
                                       Label="Company" Variant="Variant.Outlined" Margin="Margin.Dense" Dense
                                       Style="min-width: 240px;">
                                @foreach (var c in _companies)
                                {
                                    <MudSelectItem T="Guid?" Value="@((Guid?)c.Id)">@c.Name</MudSelectItem>
                                }
                            </MudSelect>
                        }
                        @if (_connections.Count > 1)
                        {
                            <MudSelect T="Guid?" Value="_selectedConnectionId" ValueChanged="OnConnectionChanged"
                                       Label="Data source" Variant="Variant.Outlined" Margin="Margin.Dense" Dense
                                       Style="min-width: 240px;">
                                @foreach (var conn in _connections)
                                {
                                    <MudSelectItem T="Guid?" Value="@((Guid?)conn.Id)">@conn.Name</MudSelectItem>
                                }
                            </MudSelect>
                        }
                    </MudStack>
                </MudPaper>
            }

            @* ── Step 2: What (subject = domain) ── *@
            <MudPaper Elevation="0" Class="pa-3" Style="border: 1px solid #DADCE0; border-radius: 4px;">
                <MudText Typo="Typo.subtitle2" Style="margin-bottom: 4px;">What do you want a report on?</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary" Style="display: block; margin-bottom: 12px;">
                    Pick a subject — we'll show the fields available for it.
                </MudText>
                @if (_domains.Any())
                {
                    <MudStack Row Spacing="1" Wrap="Wrap.Wrap">
                        @foreach (var d in _domains)
                        {
                            var isSel = string.Equals(d.Name, _selectedDomain, StringComparison.OrdinalIgnoreCase);
                            <MudChip T="string" Size="Size.Medium"
                                     Variant="@(isSel ? Variant.Filled : Variant.Outlined)"
                                     Color="@(isSel ? Color.Primary : Color.Default)"
                                     OnClick="@(() => OnDomainChanged(d.Name))">
                                @d.Name <MudText Typo="Typo.caption" Color="Color.Inherit" Style="opacity: 0.7; margin-left: 4px;">@d.Fields.Count</MudText>
                            </MudChip>
                        }
                    </MudStack>
                }
                else
                {
                    <MudText Typo="Typo.body2" Color="Color.Secondary">No subjects defined for this data source.</MudText>
                }
            </MudPaper>

            @* ── Step 3: Which columns ── *@
            @if (!string.IsNullOrEmpty(_selectedDomain) && _activeDomainFields.Any())
            {
                <MudPaper Elevation="0" Class="pa-3" Style="border: 1px solid #DADCE0; border-radius: 4px;">
                    <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Style="margin-bottom: 8px;">
                        <MudText Typo="Typo.subtitle2">Pick the columns to include</MudText>
                        <MudStack Row Spacing="1">
                            <MudButton Variant="Variant.Text" Size="Size.Small"
                                       StartIcon="@Icons.Material.Outlined.DoneAll"
                                       OnClick="SelectAllFields">Select all</MudButton>
                            <MudButton Variant="Variant.Text" Size="Size.Small"
                                       StartIcon="@Icons.Material.Outlined.RemoveDone"
                                       OnClick="ClearAllFields">Clear</MudButton>
                        </MudStack>
                    </MudStack>
                    <MudTextField T="string" Value="_fieldSearch" ValueChanged="OnFieldSearchChanged"
                                  Placeholder="Search columns..."
                                  Variant="Variant.Outlined" Margin="Margin.Dense" Dense
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Outlined.Search"
                                  Style="max-width: 320px; margin-bottom: 8px;" />
                    <div class="quick-field-grid">
                        @foreach (var f in FilteredDomainFields)
                        {
                            var fid = f.Id;
                            var checkedNow = _selectedFieldIds.Contains(fid);
                            <label class="quick-field-row">
                                <MudCheckBox T="bool" Value="@checkedNow"
                                             ValueChanged="@((bool v) => OnFieldToggled(fid, v))"
                                             Size="Size.Small" Dense Color="Color.Primary" />
                                <span class="quick-field-label">@f.Label</span>
                                @if (!string.IsNullOrWhiteSpace(f.Description))
                                {
                                    <span class="quick-field-desc">@f.Description</span>
                                }
                            </label>
                        }
                    </div>
                </MudPaper>
            }

            @* ── Step 4: Optional date range ── *@
            @if (!string.IsNullOrEmpty(_selectedDomain) && _activeDateFields.Any())
            {
                <MudPaper Elevation="0" Class="pa-3" Style="border: 1px solid #DADCE0; border-radius: 4px;">
                    <MudText Typo="Typo.subtitle2" Style="margin-bottom: 4px;">Narrow by date (optional)</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Style="display: block; margin-bottom: 12px;">
                        Limit results to a date range. Leave blank to include everything.
                    </MudText>
                    <MudStack Row Spacing="2" Wrap="Wrap.Wrap" AlignItems="AlignItems.Center">
                        <MudSelect T="string" Value="_dateFieldId" ValueChanged="OnDateFieldChanged"
                                   Label="Date column" Variant="Variant.Outlined" Margin="Margin.Dense" Dense
                                   Style="min-width: 220px;">
                            <MudSelectItem T="string" Value="@string.Empty">— No date filter —</MudSelectItem>
                            @foreach (var df in _activeDateFields)
                            {
                                <MudSelectItem T="string" Value="@df.Id">@df.Label</MudSelectItem>
                            }
                        </MudSelect>
                        @if (!string.IsNullOrEmpty(_dateFieldId))
                        {
                            <MudSelect T="string" Value="_datePreset" ValueChanged="OnDatePresetChanged"
                                       Label="Range" Variant="Variant.Outlined" Margin="Margin.Dense" Dense
                                       Style="min-width: 200px;">
                                @foreach (var p in DatePresets)
                                {
                                    <MudSelectItem T="string" Value="@p.Key">@p.Label</MudSelectItem>
                                }
                            </MudSelect>
                        }
                    </MudStack>
                </MudPaper>
            }

            @* ── Step 5: Run + Save ── *@
            <MudStack Row Spacing="2" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Outlined.PlayArrow"
                           Disabled="@(!CanRun || _isRunning)"
                           OnClick="RunQueryAsync">
                    @(_isRunning ? "Running..." : "Run (full results)")
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Default"
                           StartIcon="@Icons.Material.Outlined.Save"
                           Disabled="@(_queryData is null || _isSaving)"
                           OnClick="OpenSaveDialog">
                    Save report
                </MudButton>
                @* Live preview toggle — when on, every field/filter
                   change auto-runs a small preview (first 50 rows)
                   after a short debounce. Off when the user wants to
                   compose without surprise queries (e.g. on a slow
                   connection or while heavily editing). *@
                <MudSwitch T="bool" Value="_livePreview" ValueChanged="OnLivePreviewToggled"
                           Color="Color.Primary" Label="Live preview" />
                @if (_queryData is not null)
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        @_queryData.Rows.Count.ToString("N0") rows
                        @if (_queryData.ExecutionMs > 0)
                        {
                            @($" · {_queryData.ExecutionMs}ms")
                        }
                    </MudText>
                    @if (_isPreview)
                    {
                        <MudTooltip Text="@($"Showing the first {PreviewPageSize} rows. Click Run for the full result set.")">
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="Color.Info"
                                     Icon="@Icons.Material.Outlined.Visibility">
                                Preview
                            </MudChip>
                        </MudTooltip>
                    }
                }
            </MudStack>

            <QueryProgress Active="@_isRunning" />

            @if (_lastError is not null)
            {
                <MudAlert Severity="Severity.Error" Dense>
                    @_lastError
                </MudAlert>
            }

            @if (_queryData is not null && _queryData.Rows.Any())
            {
                <ReportGrid Data="_queryData"
                            IsTruncated="@(_queryData.IsTruncated)"
                            DisableUserSort="false" />
            }
            else if (_queryData is not null)
            {
                <EmptyState Icon="@Icons.Material.Outlined.SearchOff"
                            Heading="No results"
                            Body="No rows matched. Try a wider date range or remove the filter." />
            }
        }
    </MudStack>
</MudMainContent>

@* Save dialog — inline so the name prompt doesn't require a separate
   component file for a single text field. @bind-IsVisible flips when
   the user clicks Save and resets after Cancel / Confirm. *@
<MudDialog @bind-Visible="_saveDialogOpen" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
    <TitleContent>Save this report</TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_saveName" Label="Report name" Variant="Variant.Outlined"
                      Margin="Margin.Dense" AutoFocus="true"
                      HelperText="You can rename or share it later from the Report Library." />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _saveDialogOpen = false)">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Outlined.Save"
                   Disabled="@_isSaving"
                   OnClick="ConfirmSaveAsync">
            @(_isSaving ? "Saving..." : "Save")
        </MudButton>
    </DialogActions>
</MudDialog>

<style>
    .quick-field-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 4px 16px;
        max-height: 360px;
        overflow-y: auto;
        padding: 4px;
        border: 1px solid #F1F3F4;
        border-radius: 4px;
        background: #FAFAFA;
    }
    .quick-field-row {
        display: grid;
        grid-template-columns: auto 1fr;
        grid-template-rows: auto auto;
        column-gap: 6px;
        align-items: center;
        padding: 4px 6px;
        border-radius: 3px;
        cursor: pointer;
    }
    .quick-field-row:hover { background: #F1F3F4; }
    .quick-field-label {
        font-size: 0.85rem;
        color: #202124;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    .quick-field-desc {
        grid-column: 2;
        font-size: 0.7rem;
        color: #5F6368;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
</style>

@code {
    private bool _initLoading = true;
    private bool _isRunning;
    private bool _isSaving;
    private string _userId = "anonymous";
    private string _userEmail = string.Empty;

    private List<CompanySummary> _companies = new();
    private Guid? _selectedCompanyId;
    private List<CompanyConnectionRecord> _connections = new();
    private Guid? _selectedConnectionId;
    // Resolved per-connection: the FROM table the query pipeline
    // hangs everything else off of. Preference order matches the
    // Builder: catalog row marked IsDefaultPrimary → schema-level
    // Settings.PrimaryTable. Null when neither is configured — Run
    // surfaces a friendly error pointing the admin at Schema Builder.
    private string? _primaryTable;
    private List<DomainGroup> _domains = new();
    private string? _selectedDomain;
    private HashSet<string> _selectedFieldIds = new(StringComparer.OrdinalIgnoreCase);
    private string _fieldSearch = string.Empty;

    private string _dateFieldId = string.Empty;
    private string _datePreset = RelativeDatePresets.ThisMonth;

    private QueryResponse? _queryData;
    private string? _lastError;

    // ── Live preview state ──
    // _livePreview = on → field / filter / preset changes kick off a
    // debounced auto-run that pulls the first PreviewPageSize rows.
    // _isPreview marks the active _queryData as a preview (vs a full
    // Run) so the UI can label it and so the user knows hitting Save
    // captures the build, not the truncated preview output.
    // _previewCts holds the live debounce token — every change cancels
    // the prior pending run and starts a fresh 350ms timer.
    private bool _livePreview = true;
    private bool _isPreview;
    private CancellationTokenSource? _previewCts;
    private const int PreviewPageSize = 50;
    private const int PreviewDebounceMs = 350;

    private static readonly (string Key, string Label)[] DatePresets =
    {
        (RelativeDatePresets.Today,       "Today"),
        (RelativeDatePresets.Yesterday,   "Yesterday"),
        (RelativeDatePresets.ThisWeek,    "This week"),
        (RelativeDatePresets.LastWeek,    "Last week"),
        (RelativeDatePresets.ThisMonth,   "This month"),
        (RelativeDatePresets.LastMonth,   "Last month"),
        (RelativeDatePresets.ThisQuarter, "This quarter"),
        (RelativeDatePresets.LastQuarter, "Last quarter"),
        (RelativeDatePresets.Ytd,         "Year-to-date"),
        (RelativeDatePresets.LastYear,    "Last year"),
        (RelativeDatePresets.Last30Days,  "Last 30 days"),
        (RelativeDatePresets.Last90Days,  "Last 90 days"),
    };

    // Domain → field list for the currently selected subject. Empty
    // when no domain is picked yet.
    private List<FieldDefinition> _activeDomainFields = new();
    // Date-typed fields within the active domain — drives the date
    // column picker so the user only sees columns that can sensibly
    // be range-filtered. Computed alongside _activeDomainFields.
    private List<FieldDefinition> _activeDateFields = new();

    private IEnumerable<FieldDefinition> FilteredDomainFields
    {
        get
        {
            if (string.IsNullOrWhiteSpace(_fieldSearch)) return _activeDomainFields;
            var q = _fieldSearch.Trim();
            return _activeDomainFields.Where(f => MatchesFieldSearch(f, q));
        }
    }

    // Matches the FieldPicker's MatchesSearch logic — keep in sync so
    // a search that finds a field on the Builder also finds it here.
    private static bool MatchesFieldSearch(FieldDefinition f, string query)
    {
        if (f.Label.Contains(query, StringComparison.OrdinalIgnoreCase)) return true;
        if (f.Id.Contains(query, StringComparison.OrdinalIgnoreCase)) return true;
        if (!string.IsNullOrEmpty(f.Description)
            && f.Description.Contains(query, StringComparison.OrdinalIgnoreCase)) return true;
        if (!string.IsNullOrWhiteSpace(f.SearchAliases))
        {
            foreach (var alias in f.SearchAliases.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
            {
                if (alias.Contains(query, StringComparison.OrdinalIgnoreCase)) return true;
            }
        }
        return false;
    }

    private bool CanRun =>
        _selectedConnectionId is not null
        && !string.IsNullOrEmpty(_selectedDomain)
        && _selectedFieldIds.Any();

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = auth.User;
        _userId = user.FindFirst("oid")?.Value ?? user.Identity?.Name ?? "anonymous";
        _userEmail = user.FindFirst("preferred_username")?.Value ?? string.Empty;

        try
        {
            _companies = await CompanyRegistry.GetActiveAsync();

            // Same auth gate as the Builder — non-admins only see
            // companies they have access to, and viewer-only users
            // get bounced back to the Library.
            var isAdmin = AdminService.IsAdmin(_userEmail);
            var hasAdminAccess = !string.IsNullOrEmpty(_userEmail)
                && await AdminAccess.HasAnyAdminAccessAsync(_userEmail);
            if (!isAdmin && !hasAdminAccess && !string.IsNullOrEmpty(_userEmail))
            {
                var access = await UserManagement.GetCompanyAccessAsync(_userEmail);
                var allowed = access.Select(a => a.CompanyId).ToHashSet();
                _companies = _companies.Where(c => allowed.Contains(c.Id)).ToList();

                // Zero-access bounce only — Viewers are allowed in to
                // save their own reports. Editor-only affordances
                // (Show on Master Dashboard) live on later surfaces,
                // not at the page boundary.
                if (access.Count == 0)
                {
                    Navigation.NavigateTo("/reports", replace: true);
                    return;
                }
            }

            if (_companies.Count > 0)
            {
                _selectedCompanyId = _companies[0].Id;
                await LoadConnectionsForCompanyAsync();
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "QuickReport init failed.");
            Snackbar.Add("Couldn't load companies.", Severity.Warning);
        }
        finally
        {
            _initLoading = false;
        }
    }

    private async Task LoadConnectionsForCompanyAsync()
    {
        if (_selectedCompanyId is null)
        {
            _connections = new();
            _selectedConnectionId = null;
            _domains = new();
            return;
        }
        try
        {
            _connections = (await ConnectionAdminSvc.GetByCompanyAsync(_selectedCompanyId.Value))
                .Where(c => c.IsActive)
                .OrderBy(c => c.Name, StringComparer.OrdinalIgnoreCase)
                .ToList();
            _selectedConnectionId = _connections.FirstOrDefault()?.Id;
            await LoadDomainsForConnectionAsync();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to load connections for company {CompanyId}.", _selectedCompanyId);
            _connections = new();
            _selectedConnectionId = null;
            _domains = new();
        }
    }

    private async Task LoadDomainsForConnectionAsync()
    {
        _primaryTable = null;
        if (_selectedConnectionId is null)
        {
            _domains = new();
            _selectedDomain = null;
            _activeDomainFields = new();
            _activeDateFields = new();
            return;
        }
        try
        {
            // Resolve the FROM table the query pipeline needs. Mirrors
            // ReportBuilder's auto-fill order so a report saved from
            // here lands on the same root as the same connection would
            // get in the Advanced Builder:
            //   1. Catalog row marked IsDefaultPrimary
            //      (RPT_custom_primary_tables) — admin-curated default
            //      that carries a table + alias pair.
            //   2. Schema-level fallback (SchemaConfig.Settings.PrimaryTable)
            //      for connections without a curated catalog row.
            // Null result is non-fatal — the Run handler surfaces a
            // friendly message pointing the admin at Schema Builder
            // instead of failing inside the pipeline.
            await ResolveDefaultPrimaryTableAsync();

            _domains = await SchemaService.GetDomainGroupsAsync(connectionId: _selectedConnectionId);
            _selectedDomain = _domains.FirstOrDefault()?.Name;
            RecomputeActiveDomain();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to load domains for connection {ConnectionId}.", _selectedConnectionId);
            _domains = new();
            _selectedDomain = null;
            _activeDomainFields = new();
            _activeDateFields = new();
        }
    }

    // Pulls the catalog defaults for the current connection, then the
    // schema's fallback. Both reads are wrapped in try/catch — neither
    // is fatal; if both miss, _primaryTable stays null and Run surfaces
    // a clear error instead of letting QueryBuilder throw deep in the
    // pipeline ("Primary Table is required").
    private async Task ResolveDefaultPrimaryTableAsync()
    {
        if (_selectedConnectionId is null) { _primaryTable = null; return; }
        try
        {
            var catalog = await CustomPrimaryTableSvc.GetByConnectionAsync(_selectedConnectionId.Value);
            var def = catalog.FirstOrDefault(e => e.IsDefaultPrimary);
            if (def is not null)
            {
                _primaryTable = PrimaryTableRef.Format(
                    def.TableName,
                    string.IsNullOrEmpty(def.Alias) ? null : def.Alias);
                return;
            }
        }
        catch (Exception ex)
        {
            Logger.LogDebug(ex, "Custom primary table lookup failed for connection {Cid}; falling back to schema default.",
                _selectedConnectionId);
        }
        try
        {
            var schemaCfg = SchemaStore.GetForConnection(_selectedConnectionId.Value);
            _primaryTable = string.IsNullOrWhiteSpace(schemaCfg?.Settings?.PrimaryTable)
                ? null
                : schemaCfg.Settings.PrimaryTable;
        }
        catch (Exception ex)
        {
            Logger.LogDebug(ex, "Schema config lookup failed for connection {Cid}; primary table left null.",
                _selectedConnectionId);
            _primaryTable = null;
        }
    }

    private void RecomputeActiveDomain()
    {
        if (string.IsNullOrEmpty(_selectedDomain))
        {
            _activeDomainFields = new();
            _activeDateFields = new();
            return;
        }
        var grp = _domains.FirstOrDefault(d => string.Equals(d.Name, _selectedDomain, StringComparison.OrdinalIgnoreCase));
        _activeDomainFields = grp?.Fields
            .OrderBy(f => f.Label, StringComparer.OrdinalIgnoreCase)
            .ToList() ?? new();
        _activeDateFields = _activeDomainFields
            .Where(f => f.DataType is "date" or "datetime")
            .ToList();
        // Reset field + date selections so the user can't carry stale
        // ids from a different subject into the run.
        _selectedFieldIds.Clear();
        _dateFieldId = string.Empty;
        _datePreset = RelativeDatePresets.ThisMonth;
        _queryData = null;
        _lastError = null;
    }

    private async Task OnCompanyChanged(Guid? id)
    {
        _selectedCompanyId = id;
        _queryData = null;
        await LoadConnectionsForCompanyAsync();
    }

    private async Task OnConnectionChanged(Guid? id)
    {
        _selectedConnectionId = id;
        _queryData = null;
        await LoadDomainsForConnectionAsync();
    }

    private async Task OnDomainChanged(string name)
    {
        _selectedDomain = name;
        RecomputeActiveDomain();
        await SchedulePreviewAsync();
    }

    private async Task OnFieldToggled(string fieldId, bool isChecked)
    {
        if (isChecked) _selectedFieldIds.Add(fieldId);
        else _selectedFieldIds.Remove(fieldId);
        await SchedulePreviewAsync();
    }

    private void OnFieldSearchChanged(string v) => _fieldSearch = v ?? string.Empty;

    private async Task OnDateFieldChanged(string v)
    {
        _dateFieldId = v ?? string.Empty;
        await SchedulePreviewAsync();
    }

    private async Task OnDatePresetChanged(string v)
    {
        _datePreset = v ?? RelativeDatePresets.ThisMonth;
        await SchedulePreviewAsync();
    }

    private async Task SelectAllFields()
    {
        foreach (var f in FilteredDomainFields) _selectedFieldIds.Add(f.Id);
        await SchedulePreviewAsync();
    }

    private async Task ClearAllFields()
    {
        _selectedFieldIds.Clear();
        await SchedulePreviewAsync();
    }

    private async Task OnLivePreviewToggled(bool v)
    {
        _livePreview = v;
        if (_livePreview) await SchedulePreviewAsync();
    }

    // Explicit Run button — produces the full result set (capped at
    // 50k rows like the Builder uses) and clears the "Preview" badge.
    private Task RunQueryAsync() => ExecuteAsync(isPreview: false, CancellationToken.None);

    // Debounced auto-run for live preview. Every change handler funnels
    // here; each call cancels the pending one and starts a fresh timer
    // so a user typing through three field clicks gets one query, not
    // three. PreviewPageSize caps the row count so the preview round-
    // trip stays cheap on heavy schemas.
    private async Task SchedulePreviewAsync()
    {
        if (!_livePreview) return;
        if (!CanRun)
        {
            _queryData = null;
            _isPreview = false;
            StateHasChanged();
            return;
        }
        _previewCts?.Cancel();
        var cts = new CancellationTokenSource();
        _previewCts = cts;
        try
        {
            await Task.Delay(PreviewDebounceMs, cts.Token);
            if (cts.IsCancellationRequested) return;
            await ExecuteAsync(isPreview: true, cts.Token);
        }
        catch (TaskCanceledException)
        {
            // Expected — newer change superseded this run.
        }
    }

    private async Task ExecuteAsync(bool isPreview, CancellationToken ct)
    {
        if (!CanRun) return;
        if (string.IsNullOrWhiteSpace(_primaryTable))
        {
            // Surface a friendly, actionable message instead of letting
            // QueryBuilder throw "Primary Table is required" deep in the
            // pipeline. This usually means the connection's catalog has
            // no IsDefaultPrimary row AND the schema config has no
            // Settings.PrimaryTable — an admin needs to fix one of those.
            _lastError = "This data source has no default table configured. Ask an admin to set a primary table in Schema Builder.";
            return;
        }
        _isRunning = true;
        _lastError = null;
        _queryData = null;
        StateHasChanged();
        try
        {
            var request = new QueryRequest
            {
                FieldIds = _selectedFieldIds.ToList(),
                ConnectionId = _selectedConnectionId,
                PrimaryTable = _primaryTable,
                AdvancedFilters = BuildDateFilterGroup(),
                Page = 1,
                PageSize = isPreview ? PreviewPageSize : 50_000
            };
            request.Scoping = await ScopeResolver.ResolveAsync(_userEmail, _selectedConnectionId, request.PrimaryTable);
            if (ct.IsCancellationRequested) return;
            var data = await QueryService.ExecuteQueryAsync(request);
            if (ct.IsCancellationRequested) return;
            _queryData = data;
            _isPreview = isPreview;
        }
        catch (OperationCanceledException)
        {
            // Cancelled by a newer preview request — keep prior state.
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "QuickReport run failed.");
            _lastError = FriendlyError.FromException(ex, Logger, "running your report");
        }
        finally
        {
            _isRunning = false;
        }
    }

    // Wraps the picked date-field + preset into a one-clause FilterGroup
    // so the same SQL emitter path the rest of the system uses handles
    // the WHERE. Returns null when no date filter is configured.
    private FilterGroup? BuildDateFilterGroup()
    {
        if (string.IsNullOrEmpty(_dateFieldId)) return null;
        var clause = new FilterClause
        {
            FieldId = _dateFieldId,
            Op = FilterOperators.Relative,
            Values = new List<string> { _datePreset }
        };
        return new FilterGroup
        {
            Op = FilterGroupOps.And,
            Items = new List<FilterItem> { new() { Clause = clause } }
        };
    }

    // Inline save dialog state. _saveDialogOpen drives the MudDialog
    // visibility binding; _saveName holds the user's name input.
    private bool _saveDialogOpen;
    private string _saveName = string.Empty;

    private void OpenSaveDialog()
    {
        if (_queryData is null || _selectedConnectionId is null) return;
        _saveName = string.IsNullOrEmpty(_selectedDomain)
            ? $"Quick report — {DateTime.Now:MMM d}"
            : $"{_selectedDomain} — {DateTime.Now:MMM d}";
        _saveDialogOpen = true;
    }

    private async Task ConfirmSaveAsync()
    {
        var name = (_saveName ?? string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(name))
        {
            Snackbar.Add("Give the report a name first.", Severity.Warning);
            return;
        }
        _saveDialogOpen = false;
        await SaveAsync(name);
    }

    private async Task SaveAsync(string name)
    {
        if (_queryData is null || _selectedConnectionId is null) return;
        _isSaving = true;
        try
        {
            var report = new SavedReport
            {
                Id = Guid.NewGuid(),
                Name = name,
                OwnerId = _userId,
                OwnerEmail = _userEmail,
                FieldIds = System.Text.Json.JsonSerializer.Serialize(_selectedFieldIds.ToList()),
                Filters = null,
                ConnectionId = _selectedConnectionId,
                // Persist the resolved primary table so the Viewer
                // doesn't have to re-resolve it on open — keeps the
                // saved report stable even if the connection's default
                // changes later.
                PrimaryTable = _primaryTable,
                CreatedAt = DateTime.UtcNow,
                UpdatedAt = DateTime.UtcNow
            };
            // Persist the date filter into column_state.AdvancedFilters
            // so opening the saved report in the Viewer re-applies the
            // same WHERE — same shape ReportBuilder uses for its filters.
            var advFilters = BuildDateFilterGroup();
            if (advFilters is not null)
            {
                var columnState = new Dictionary<string, object>
                {
                    ["AdvancedFilters"] = advFilters
                };
                report.ColumnState = System.Text.Json.JsonSerializer.Serialize(columnState);
            }
            var saved = await ReportService.SaveReportAsync(report);
            Snackbar.Add($"Saved \"{saved.Name}\" to your reports.", Severity.Success);
            Navigation.NavigateTo($"/viewer/{saved.Id}");
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "QuickReport save failed.");
            Snackbar.Add($"Couldn't save: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSaving = false;
        }
    }

}
