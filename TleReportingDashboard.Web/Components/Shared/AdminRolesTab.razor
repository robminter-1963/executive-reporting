@inject IRoleService RoleService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@using TleReportingDashboard.Web.Services
@using Microsoft.Data.SqlClient
@using MudBlazor

<MudStack Spacing="3" Class="pa-2">
    <MudText Typo="Typo.body2" Color="Color.Secondary">
        Roles are job-function labels you can assign to users in Admin → Users.
        Marking a user's role as <strong>Administrator</strong> grants them the global admin flag automatically.
        The <strong>Scope</strong> controls row-level visibility — <em>All records</em> means the user sees every row the
        query returns; <em>Only their own</em> auto-filters to rows owned by the user (requires setting each user's LOS / CRM login
        on their company access). Administrator is pinned to All.
    </MudText>

    @* ── Add role form ─────────────────────────────────────────────────── *@
    <MudPaper Elevation="0" Class="pa-4" Style="border: 1px solid #E8EAED; border-radius: 4px;">
        <MudStack Spacing="2">
            <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">Add role</MudText>
            <MudStack Row AlignItems="AlignItems.Start" Spacing="2" Wrap="Wrap.Wrap">
                <MudTextField @bind-Value="_newName" Label="Name" Required
                              Variant="Variant.Outlined" Margin="Margin.Dense" Style="min-width: 220px;" />
                <MudTextField @bind-Value="_newDescription" Label="Description (optional)"
                              Variant="Variant.Outlined" Margin="Margin.Dense" Style="min-width: 320px;" />
                <MudSelect T="string" @bind-Value="_newScope" Label="Scope"
                           Variant="Variant.Outlined" Margin="Margin.Dense" Style="min-width: 180px;">
                    <MudSelectItem T="string" Value="@ScopeRules.All">All records</MudSelectItem>
                    <MudSelectItem T="string" Value="@ScopeRules.Self">Only their own</MudSelectItem>
                    <MudSelectItem T="string" Value="@ScopeRules.Team">Only for their team</MudSelectItem>
                </MudSelect>
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Add"
                           Disabled="@(!CanAdd())" OnClick="AddRole">
                    Add role
                </MudButton>
                <SaveStatusIndicator @ref="_addIndicator" />
            </MudStack>
        </MudStack>
    </MudPaper>

    @* ── Roles table ───────────────────────────────────────────────────── *@
    <MudPaper Elevation="0" Style="border: 1px solid #E8EAED; border-radius: 4px;">
        <MudTable Items="_roles" Dense Hover Class="pa-0" T="RoleRecord">
            <HeaderContent>
                <MudTh>Name</MudTh>
                <MudTh>Description</MudTh>
                <MudTh Style="width: 160px;">Scope</MudTh>
                <MudTh Style="width: 100px;">Active</MudTh>
                <MudTh Style="width: 160px;">Updated</MudTh>
                <MudTh Style="width: 120px;"></MudTh>
            </HeaderContent>
            <RowTemplate>
                @if (_editingId == context.Id)
                {
                    <MudTd>
                        @* Built-in roles (Administrator, System Support)
                           can't be renamed — the name is a protocol-level
                           handle the rest of the app keys off. RoleService
                           re-validates on save so a forged request can't
                           slip a rename through either. *@
                        <MudTextField @bind-Value="_editName" Variant="Variant.Outlined" Margin="Margin.Dense"
                                      Disabled="@IsBuiltInRole(context)"
                                      HelperText="@(IsBuiltInRole(context) ? "Built-in role — name can't be changed" : null)" />
                    </MudTd>
                    <MudTd>
                        <MudStack Spacing="2">
                            <MudTextField @bind-Value="_editDescription" Variant="Variant.Outlined" Margin="Margin.Dense" />

                            @* Per-role admin-section access. Only renders when
                               the parent confirms the current user is a global
                               admin AND the role being edited isn't the
                               Administrator row (admin always has every
                               section; saving the list there would mislead).
                               Each section in AdminSections.All becomes a
                               checkbox; on Save the checked keys serialize
                               to RPT_roles.admin_sections. *@
                            @if (CanEditAdminSections && !IsAdministratorRole(context))
                            {
                                <MudPaper Elevation="0" Class="pa-2"
                                          Style="border: 1px solid #DADCE0; border-radius: 4px; background: #FAFAFA;">
                                    <MudText Typo="Typo.caption" Style="font-weight: 600; color: #5F6368;">
                                        Admin sections this role can access
                                    </MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Style="display: block; margin-bottom: 4px;">
                                        Tick a section to grant access to its tab on the Admin page. Leave all unchecked = no admin access. Administrator role bypasses this list.
                                    </MudText>
                                    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 2px;">
                                        @foreach (var sec in AdminSections.All)
                                        {
                                            var secKey = sec.Key;
                                            var checkedNow = _editAdminSections.Contains(secKey);
                                            <MudCheckBox T="bool" Value="@checkedNow" Dense Color="Color.Primary"
                                                         ValueChanged="@((bool v) => ToggleEditSection(secKey, v))"
                                                         Label="@sec.Label" />
                                        }
                                    </div>
                                </MudPaper>
                            }
                        </MudStack>
                    </MudTd>
                    <MudTd>
                        @if (IsAdministratorRole(context))
                        {
                            @* Admin row is pinned to 'all' on the server no
                               matter what the UI sends, but still disable
                               the dropdown so admins aren't misled. *@
                            <MudSelect T="string" Value="@ScopeRules.All" Disabled
                                       Variant="Variant.Outlined" Margin="Margin.Dense">
                                <MudSelectItem T="string" Value="@ScopeRules.All">All records</MudSelectItem>
                            </MudSelect>
                        }
                        else
                        {
                            <MudSelect T="string" @bind-Value="_editScope"
                                       Variant="Variant.Outlined" Margin="Margin.Dense">
                                <MudSelectItem T="string" Value="@ScopeRules.All">All records</MudSelectItem>
                                <MudSelectItem T="string" Value="@ScopeRules.Self">Only their own</MudSelectItem>
                                <MudSelectItem T="string" Value="@ScopeRules.Team">Only for their team</MudSelectItem>
                            </MudSelect>
                        }
                    </MudTd>
                    <MudTd>
                        <MudSwitch T="bool" @bind-Value="_editIsActive" Color="Color.Success" />
                    </MudTd>
                    <MudTd>@context.UpdatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</MudTd>
                    <MudTd Style="text-align: right;">
                        <MudTooltip Text="Save">
                            <MudIconButton Icon="@Icons.Material.Filled.Check" Size="Size.Small" Color="Color.Success"
                                           OnClick="SaveEdit" />
                        </MudTooltip>
                        <MudTooltip Text="Cancel">
                            <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                           OnClick="CancelEdit" />
                        </MudTooltip>
                    </MudTd>
                }
                else
                {
                    <MudTd>
                        @if (IsBuiltInRole(context))
                        {
                            var shieldTip = IsAdministratorRole(context)
                                ? "Built-in role — can't be renamed or deleted. Renaming would also break the admin-flag auto-sync."
                                : "Built-in role — can't be renamed or deleted.";
                            <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
                                <strong>@context.Name</strong>
                                <MudTooltip Text="@shieldTip">
                                    <MudIcon Icon="@Icons.Material.Filled.Shield" Size="Size.Small" Color="Color.Primary" />
                                </MudTooltip>
                            </MudStack>
                        }
                        else
                        {
                            <strong>@context.Name</strong>
                        }
                    </MudTd>
                    <MudTd>
                        @(string.IsNullOrEmpty(context.Description) ? "—" : context.Description)
                        @* Admin-section-access summary. Administrator implicitly
                           has every section so we show "All admin sections";
                           other roles show the count + a tooltip listing the
                           granted keys, so global admins can spot elevated
                           roles at a glance. Empty list → no marker (the role
                           has no admin access at all). *@
                        @if (IsAdministratorRole(context))
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined"
                                     Icon="@Icons.Material.Filled.AdminPanelSettings"
                                     Style="margin-left: 6px; height: 20px; font-size: 0.7rem;">
                                All admin sections
                            </MudChip>
                        }
                        else if (context.AdminSections is { Count: > 0 } secs)
                        {
                            <MudTooltip Text="@($"Admin sections: {string.Join(", ", secs.Select(LabelForSection))}")">
                                <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined"
                                         Icon="@Icons.Material.Filled.LockPerson"
                                         Style="margin-left: 6px; height: 20px; font-size: 0.7rem;">
                                    @secs.Count admin section@(secs.Count == 1 ? "" : "s")
                                </MudChip>
                            </MudTooltip>
                        }
                    </MudTd>
                    <MudTd>
                        @if (context.ScopeRule == ScopeRules.Self)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Filled"
                                     Icon="@Icons.Material.Filled.FilterAlt">
                                Only their own
                            </MudChip>
                        }
                        else if (context.ScopeRule == ScopeRules.Team)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Filled"
                                     Icon="@Icons.Material.Filled.Groups">
                                Only for their team
                            </MudChip>
                        }
                        else
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">
                                All records
                            </MudChip>
                        }
                    </MudTd>
                    <MudTd>
                        @if (context.IsActive)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Outlined">Active</MudChip>
                        }
                        else
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">Inactive</MudChip>
                        }
                    </MudTd>
                    <MudTd>@context.UpdatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</MudTd>
                    <MudTd Style="text-align: right;">
                        <MudTooltip Text="Edit role">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                           OnClick="@(() => StartEdit(context))" />
                        </MudTooltip>
                        @* Delete is hidden for built-in roles. Service-layer
                           guard refuses too, so a direct API call still
                           can't drop them. *@
                        @if (!IsBuiltInRole(context))
                        {
                            <MudTooltip Text="Delete role">
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                               OnClick="@(() => DeleteRole(context))" />
                            </MudTooltip>
                        }
                    </MudTd>
                }
            </RowTemplate>
            <NoRecordsContent>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="pa-4 d-flex justify-center">
                    No roles defined — add one above.
                </MudText>
            </NoRecordsContent>
        </MudTable>
    </MudPaper>
</MudStack>

@code {
    [Parameter] public string CurrentUserEmail { get; set; } = string.Empty;

    private List<RoleRecord> _roles = new();

    private string _newName = string.Empty;
    private string _newDescription = string.Empty;
    private string _newScope = ScopeRules.All;
    private SaveStatusIndicator? _addIndicator;

    // Only global admins see / edit per-role admin-section access. The
    // Roles tab itself is reachable by any user whose role grants the
    // "roles" section, but the System Support–style roles can't grant
    // themselves elevation through this surface. Parent (Admin.razor)
    // passes _isFullAdmin to gate the editor visibility.
    [Parameter] public bool CanEditAdminSections { get; set; }

    private Guid? _editingId;
    private string _editName = string.Empty;
    private string _editDescription = string.Empty;
    private string _editScope = ScopeRules.All;
    private bool _editIsActive;
    private HashSet<string> _editAdminSections = new(StringComparer.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _roles = await RoleService.GetAllAsync();
    }

    private bool CanAdd() => !string.IsNullOrWhiteSpace(_newName);

    // Matches by name so renames don't accidentally flip this flag; admins
    // are warned in the UI before they rename the Administrator row.
    private static bool IsAdministratorRole(RoleRecord r) =>
        string.Equals(r.Name, RoleRecord.AdministratorName, StringComparison.OrdinalIgnoreCase);

    // Built-in roles can't be renamed or deleted. Currently Administrator
    // (admin-flag auto-sync depends on the name) and System Support
    // (cross-company support role with admin-section access).
    private static bool IsBuiltInRole(RoleRecord r) =>
        RoleRecord.IsBuiltInName(r.Name);

    private async Task AddRole()
    {
        try
        {
            await RoleService.CreateAsync(
                _newName.Trim(),
                string.IsNullOrWhiteSpace(_newDescription) ? null : _newDescription.Trim(),
                _newScope,
                CurrentUserEmail);
            _newName = _newDescription = string.Empty;
            _newScope = ScopeRules.All;
            await ReloadAsync();
            if (_addIndicator is not null) _ = _addIndicator.Flash("Added");
        }
        catch (SqlException ex) when (ex.Number is 2601 or 2627)
        {
            Snackbar.Add("A role with that name already exists.", Severity.Warning);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to add role: {ex.Message}", Severity.Error);
        }
    }

    private void StartEdit(RoleRecord r)
    {
        _editingId = r.Id;
        _editName = r.Name;
        _editDescription = r.Description ?? string.Empty;
        _editScope = IsAdministratorRole(r) ? ScopeRules.All : r.ScopeRule;
        _editIsActive = r.IsActive;
        // Seed the admin-section checkbox state from the role's stored
        // list. Administrator role bypasses the column at access-check
        // time, so we hydrate empty for the editor (the Save path also
        // forces null for that role).
        _editAdminSections = IsAdministratorRole(r) || r.AdminSections is null
            ? new HashSet<string>(StringComparer.OrdinalIgnoreCase)
            : new HashSet<string>(r.AdminSections, StringComparer.OrdinalIgnoreCase);
    }

    private void CancelEdit() => _editingId = null;

    private void ToggleEditSection(string sectionKey, bool isChecked)
    {
        if (isChecked) _editAdminSections.Add(sectionKey);
        else _editAdminSections.Remove(sectionKey);
    }

    // Maps a stored section key (e.g. "db_connections") to its human label
    // for tooltip rendering. Falls back to the raw key if the catalog
    // doesn't recognize it (legacy / future-key resilience).
    private static string LabelForSection(string key) =>
        AdminSections.All.FirstOrDefault(s => s.Key == key).Label ?? key;

    private async Task SaveEdit()
    {
        if (_editingId is not Guid id) return;
        try
        {
            await RoleService.UpdateAsync(id, _editName.Trim(),
                string.IsNullOrWhiteSpace(_editDescription) ? null : _editDescription.Trim(),
                _editScope,
                _editIsActive,
                _editAdminSections.ToList());
            _editingId = null;
            await ReloadAsync();
            Snackbar.Add("Role updated.", Severity.Success);
        }
        catch (SqlException ex) when (ex.Number is 2601 or 2627)
        {
            Snackbar.Add("That name is already taken by another role.", Severity.Warning);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to save: {ex.Message}", Severity.Error);
        }
    }

    private async Task DeleteRole(RoleRecord r)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(new MessageBoxOptions
        {
            Title = "Delete role",
            Message = $"Delete role \"{r.Name}\"? Users currently assigned to it will have their role cleared.",
            YesText = "Delete",
            CancelText = "Cancel"
        });
        if (confirmed != true) return;

        try
        {
            await RoleService.DeleteAsync(r.Id);
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to delete: {ex.Message}", Severity.Error);
        }
    }

    // Manual Move Up / Move Down was removed when CreateAsync + UpdateAsync
    // both started auto-alphabetizing via RenumberSortOrderAlphabeticallyAsync
    // (Administrator pinned to slot 0). Any manual reorder would get
    // clobbered on the next add or rename, which made the arrows worse than
    // useless. RoleService.UpdateSortOrderAsync is left in place for any
    // future reordering needs (data import, scripted re-sort, etc.).
}
