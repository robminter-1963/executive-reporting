@page "/master-dashboard/{CompanyCode}"
@rendermode InteractiveServer
@inject IMasterDashboardService MasterService
@inject IReportService ReportService
@inject ISharingService SharingService
@inject IQueryService QueryService
@inject IGridTemplateService GridTemplateService
@inject IUserPreferenceService PreferenceService
@inject IUserManagementService UserManagement
@inject IQueryScopeResolver ScopeResolver
@inject SchemaBuilderService SchemaBrowser
@inject ISchemaService SchemaService
@inject ICompanyRegistry CompanyRegistry
@inject IAdminService AdminService
@inject IAdminAccessService AdminAccess
@inject CurrentCompanyState CurrentCompany
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@inject IConfiguration Config
@implements IDisposable

<PageTitle>@(_initialized ? $"{_dashboardTitle} - Executive Reporting Suite" : "Executive Reporting Suite")</PageTitle>

@if (!_initialized)
{
    <MudMainContent Style="padding: 16px;">
        <div style="display: flex; flex-direction: column; align-items: center; justify-content: center;
                    min-height: 60vh; gap: 16px;">
            <img src="loading.gif" alt="Loading…"
                 style="max-width: 240px; height: auto;" />
            <MudText Typo="Typo.body2" Color="Color.Secondary">Loading your dashboard…</MudText>
        </div>
    </MudMainContent>
    return;
}

<MudMainContent Style="padding: 16px 16px 32px 16px; overflow-x: hidden; overflow-y: auto; height: calc(100vh - 64px);">
    <MudStack Spacing="3">
        @* ── Header ── *@
        <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
            <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                @* Back arrow goes to the company picker. Hidden for
                   single-company users — the picker auto-redirects them
                   right back here, so the arrow would do nothing useful.
                   ?all=1 bypasses the picker's auto-redirect to the user's
                   last-visited company so they actually see the list. *@
                @if (_accessibleCompanyCount > 1)
                {
                    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                                   OnClick="@(() => Navigation.NavigateTo("/?all=1"))"
                                   title="All companies" />
                }
                @if (_logoDataUri is not null)
                {
                    @* Gray letterbox background so light-on-transparent
                       logos (white text on a transparent PNG, low-alpha
                       exports) stay legible against the page chrome.
                       Small inset padding keeps the image from touching
                       the box edges. *@
                    @* Clickable letterbox when the company has a website_url.
                       target="_blank" + rel="noopener noreferrer" is the
                       standard safe outbound pattern (prevents the opened
                       page from hijacking window.opener). *@
                    @if (!string.IsNullOrEmpty(_companyWebsiteUrl))
                    {
                        <a href="@_companyWebsiteUrl" target="_blank" rel="noopener noreferrer"
                           title="@_companyWebsiteUrl"
                           style="background: #A9A9A9; border-radius: 4px;
                                  padding: 4px 8px; display: inline-flex;
                                  align-items: center; cursor: pointer;">
                            <img src="@_logoDataUri" alt=""
                                 style="height: 36px; max-width: 160px; object-fit: contain;" />
                        </a>
                    }
                    else
                    {
                        <div style="background: #A9A9A9; border-radius: 4px;
                                    padding: 4px 8px; display: inline-flex;
                                    align-items: center;">
                            <img src="@_logoDataUri" alt=""
                                 style="height: 36px; max-width: 160px; object-fit: contain;" />
                        </div>
                    }
                }
                @if (_editMode)
                {
                    <MudFileUpload T="IBrowserFile" Accept=".png,.jpg,.jpeg,.svg,.gif,.webp" FilesChanged="OnLogoUploaded"
                                   Style="margin: 0;">
                        <ActivatorContent>
                            <MudTooltip Text="@(_logoDataUri is not null ? "Change logo" : "Upload logo")" Placement="Placement.Bottom">
                                <MudIconButton Icon="@Icons.Material.Filled.Image" Size="Size.Small"
                                               Color="@(_logoDataUri is not null ? Color.Primary : Color.Default)" />
                            </MudTooltip>
                        </ActivatorContent>
                    </MudFileUpload>
                    @if (_logoDataUri is not null)
                    {
                        <MudTooltip Text="Remove logo" Placement="Placement.Bottom">
                            <MudIconButton Icon="@Icons.Material.Filled.HideImage" Size="Size.Small" Color="Color.Error"
                                           OnClick="RemoveLogo" />
                        </MudTooltip>
                    }
                }
                @* Title removed from the header — the company logo now
                   identifies the dashboard visually, and per-user rename
                   stopped making sense once dashboards became per-company.
                   _dashboardTitle is still set (to the company name) so the
                   browser tab / <PageTitle> stays informative. *@
            </MudStack>
            <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                @* Report Library shortcut. Same audience as the back arrow's
                   prior destination — Editors, Schedulers, and admins all
                   need a way to author / schedule ad-hoc reports without
                   leaving the dashboard manually. Viewers don't get the
                   shortcut because they don't have Report Library access. *@
                @if (_userRoleForCompany != UserRoles.Viewer)
                {
                    <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.LibraryBooks"
                               OnClick="@(() => Navigation.NavigateTo("/reports"))">
                        Report Library
                    </MudButton>
                }
                @* Edit is admin-only — the shared dashboard is the company's
                   canonical layout, and Editors/Viewers don't get to mutate
                   it. Phase 4 adds an approval queue so Editors can propose
                   tiles without direct edit rights. *@
                @if (_userRoleForCompany == UserRoles.Admin)
                {
                    @if (_editMode)
                    {
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Add" OnClick="OpenAddDialog">
                            Add Report
                        </MudButton>
                        <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Tab" OnClick="AddTab">
                            Add Tab
                        </MudButton>
                        <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.ViewModule" OnClick="AddSection"
                                   Disabled="@(ActiveTab is null || _sections.Count >= IMasterDashboardService.MaxSectionsPerTab)"
                                   title="@(_sections.Count >= IMasterDashboardService.MaxSectionsPerTab ? $"Maximum {IMasterDashboardService.MaxSectionsPerTab} sections per tab" : "Add a new section to this tab")">
                            Add Section
                        </MudButton>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Save" OnClick="SaveLayout">
                            Save Layout
                        </MudButton>
                    }
                    <MudButton Variant="@(_editMode ? Variant.Filled : Variant.Outlined)"
                               Color="@(_editMode ? Color.Warning : Color.Default)" Size="Size.Small"
                               StartIcon="@(_editMode ? Icons.Material.Filled.Check : Icons.Material.Filled.Edit)"
                               OnClick="ToggleEditMode">
                        @(_editMode ? "Done Editing" : "Edit Layout")
                    </MudButton>
                }
            </MudStack>
        </MudStack>

        @if (_loading)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
        }

        @* ── Tabs ── *@
        @if (_tabs.Any())
        {
            <MudTabs ActivePanelIndex="_activeTabIndex" ActivePanelIndexChanged="OnTabChanged"
                     Elevation="0" Rounded ApplyEffectsToContainer>
                @foreach (var tab in _tabs)
                {
                    var t = tab;
                    <MudTabPanel>
                        <TabContent>
                            @* Tab header doubles as a drop target while a
                               tile is being dragged in edit mode — drop a
                               tile onto another tab's label to re-home it.
                               Plain div wraps the MudStack because drag
                               directives (:preventDefault / :stopPropagation)
                               don't compose cleanly with MudBlazor component
                               parameters. stopPropagation on drop prevents
                               MudTabs from treating the release as a tab-click. *@
                            <div style="@(_dropTargetTabId == t.Id
                                            ? "outline: 2px dashed #1A73E8; outline-offset: 2px; border-radius: 4px;"
                                            : "")"
                                 @ondragover:preventDefault
                                 @ondragover="@(() => { if (_editMode && (_dragSource >= 0 || _sectionDragSource >= 0) && t.Id != ActiveTab?.Id) _dropTargetTabId = t.Id; })"
                                 @ondragleave="@(() => { if (_dropTargetTabId == t.Id) _dropTargetTabId = 0; })"
                                 @ondrop="@(async () => await OnTabStripDrop(t.Id))"
                                 @ondrop:stopPropagation="true">
                                <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
                                    <span>@t.Label</span>
                                    @if (_editMode)
                                    {
                                        <MudTooltip Text="Rename tab">
                                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                                           Color="Color.Default" Style="padding: 2px;"
                                                           OnClick="@(() => RenameTab(t))" />
                                        </MudTooltip>
                                        @if (_tabs.Count > 1)
                                        {
                                            <MudTooltip Text="Remove tab">
                                                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                                               Color="Color.Error" Style="padding: 2px;"
                                                               OnClick="@(() => RemoveTab(t))" />
                                            </MudTooltip>
                                        }
                                    }
                                </MudStack>
                            </div>
                        </TabContent>
                        <ChildContent>
                            @* ── Tile reorder bar (edit mode) ── *@
                            @if (_editMode && _tiles.Any())
                            {
                                <MudPaper Elevation="0" Class="pa-2 mt-2" Style="border: 1px solid #E8EAED; border-radius: 4px;">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">
                                        Drag to reorder tiles:
                                    </MudText>
                                    <div style="display: flex; flex-wrap: wrap; gap: 4px; align-items: center;">
                                        @for (var i = 0; i < _tiles.Count; i++)
                                        {
                                            var idx = i;
                                            var tile = _tiles[i];
                                            <div @key="tile.Id"
                                                 style="@(_dragSource == idx ? "opacity: 0.3;" : "") position: relative;"
                                                 draggable="true"
                                                 @ondragstart="() => _dragSource = idx"
                                                 @ondragend="() => { _dragSource = -1; _dropTarget = -1; _dropTargetTabId = 0; }"
                                                 @ondragover:preventDefault
                                                 @ondragover="() => { if (_dragSource >= 0 && idx != _dragSource) _dropTarget = idx; }"
                                                 @ondrop="@(async () => await OnTileDrop(idx))">
                                                @if (_dropTarget == idx && _dragSource != idx)
                                                {
                                                    <div style="position: absolute; left: -2px; top: 2px; bottom: 2px; width: 3px; background: #1A73E8; border-radius: 2px; z-index: 10;"></div>
                                                }
                                                <MudChip T="string" Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                                                         Style="cursor: grab;">
                                                    @tile.ReportName
                                                </MudChip>
                                            </div>
                                        }
                                    </div>
                                </MudPaper>
                            }

                            @* ── Tile grid (and section strip when applicable) ──
                               Gate is `_tiles.Any() || _sections.Count > 0` so the section
                               strip renders even on a tab with zero tiles loaded — otherwise
                               re-adding sections to an empty tab would write to the DB but
                               render nothing, since the strip used to live entirely inside
                               the tiles-present branch. The truly-empty pad below stays
                               gated on both being empty. *@
                            @if (_tiles.Any() || _sections.Count > 0)
                            {
                                @* ── Section tab strip ──
                                   Renders only when this tab has at least one section. Each tab is
                                   clickable (switches active), drag-and-drop wired (reorder + cross-
                                   tab move + tile-drop assignment). The "(no section)" pseudo-tab
                                   surfaces only when at least one tile has SectionId = null —
                                   matches the v1 header semantics, just relocated into the strip. *@
                                @if (_sections.Count > 0)
                                {
                                    var sectionTabs = new List<(MasterDashboardSection? Section, string Label, int Key)>();
                                    foreach (var s in _sections) sectionTabs.Add((s, s.Label, s.Id));
                                    if (_tiles.Any(t => t.SectionId is null))
                                        sectionTabs.Add((null, "(no section)", 0));
                                    // Defense-in-depth: if the previously-active section was removed
                                    // out from under us (e.g. a stale cache), repoint to the first
                                    // available tab so rendering doesn't show an empty container.
                                    if (sectionTabs.Count > 0 && sectionTabs.All(st => st.Key != _activeSectionId))
                                    {
                                        _activeSectionId = sectionTabs[0].Key;
                                    }

                                    <div style="display: flex; gap: 4px; margin-top: 12px; border-bottom: 1px solid #DADCE0; flex-wrap: wrap;">
                                        @foreach (var st in sectionTabs)
                                        {
                                            var stLocal = st;
                                            var isActiveSec = _activeSectionId == stLocal.Key;
                                            var sIdx = stLocal.Section is null ? -2 : _sections.IndexOf(stLocal.Section);
                                            var isSecDropTarget = _editMode && _headerDropTargetIdx == sIdx
                                                && (_dragSource >= 0 || (_sectionDragSource >= 0 && _sectionDragSource != sIdx));
                                            var dropBg = _dragSource >= 0 ? "#FFF4E5" : "#E8F0FE";
                                            var dropOutline = _dragSource >= 0 ? "#F9AB00" : "#1A73E8";
                                            var tabBaseStyle = isActiveSec
                                                ? "background: #FFFFFF; border: 1px solid #DADCE0; border-bottom-color: #FFFFFF; position: relative; top: 1px;"
                                                : "background: #F1F3F4; border: 1px solid transparent;";
                                            var tabStyle = $"display: flex; align-items: center; gap: 4px; padding: 3px 12px; cursor: pointer; border-radius: 4px 4px 0 0; {tabBaseStyle} "
                                                         + (isSecDropTarget ? $"outline: 2px dashed {dropOutline}; background: {dropBg};" : string.Empty);

                                            <div style="@tabStyle"
                                                 @ondragover:preventDefault
                                                 @ondragover="@(() => { if (_editMode && (_sectionDragSource >= 0 || _dragSource >= 0)) _headerDropTargetIdx = sIdx; })"
                                                 @ondrop="@(async () => { if (_editMode) await OnHeaderDrop(stLocal.Section); })"
                                                 @onclick="@(() => SetActiveSection(stLocal.Key))">
                                                @if (_editMode && stLocal.Section is not null)
                                                {
                                                    <span draggable="true"
                                                          @ondragstart="@(() => _sectionDragSource = sIdx)"
                                                          @ondragend="@(() => { _sectionDragSource = -1; _headerDropTargetIdx = -1; })"
                                                          style="cursor: grab; display: inline-flex;"
                                                          @onclick:stopPropagation="true"
                                                          title="Drag to reorder sections (or drop on another tab to move)">
                                                        <MudIcon Icon="@Icons.Material.Filled.DragIndicator" Size="Size.Small" Style="color: #5F6368;" />
                                                    </span>
                                                }
                                                @{
                                                    var stAlign = stLocal.Section is null
                                                        ? "left"
                                                        : (string.IsNullOrEmpty(stLocal.Section!.TitleAlign) ? "left" : stLocal.Section.TitleAlign);
                                                }
                                                <span style="@($"font-size: 0.875rem; font-weight: {(isActiveSec ? "600" : "500")}; color: #5F6368; text-align: {stAlign}; min-width: 60px;")">
                                                    @stLocal.Label
                                                </span>
                                            </div>
                                        }
                                    </div>

                                    @* Active section's edit-mode controls (rename / delete / align)
                                       — surfaces under the strip rather than crowding the active tab
                                       itself. Only renders for real sections; the "(no section)"
                                       virtual tab has nothing to rename / delete / align. *@
                                    @if (_editMode)
                                    {
                                        var activeSec = _sections.FirstOrDefault(s => s.Id == _activeSectionId);
                                        if (activeSec is not null)
                                        {
                                            var aSecAlign = string.IsNullOrEmpty(activeSec.TitleAlign) ? "left" : activeSec.TitleAlign;
                                            <div style="display: flex; align-items: center; gap: 6px; padding: 4px 6px; margin-top: 4px;">
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">Section options:</MudText>
                                                <MudTooltip Text="Align section title left">
                                                    <MudIconButton Icon="@Icons.Material.Filled.FormatAlignLeft" Size="Size.Small"
                                                                   Color="@(aSecAlign == "left" ? Color.Primary : Color.Default)"
                                                                   OnClick="@(() => SetSectionAlign(activeSec, "left"))" />
                                                </MudTooltip>
                                                <MudTooltip Text="Align section title center">
                                                    <MudIconButton Icon="@Icons.Material.Filled.FormatAlignCenter" Size="Size.Small"
                                                                   Color="@(aSecAlign == "center" ? Color.Primary : Color.Default)"
                                                                   OnClick="@(() => SetSectionAlign(activeSec, "center"))" />
                                                </MudTooltip>
                                                <MudTooltip Text="Align section title right">
                                                    <MudIconButton Icon="@Icons.Material.Filled.FormatAlignRight" Size="Size.Small"
                                                                   Color="@(aSecAlign == "right" ? Color.Primary : Color.Default)"
                                                                   OnClick="@(() => SetSectionAlign(activeSec, "right"))" />
                                                </MudTooltip>
                                                <MudTooltip Text="Rename section">
                                                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                                                   OnClick="@(() => RenameSection(activeSec))" />
                                                </MudTooltip>
                                                <MudTooltip Text="Delete section (tiles move to '(no section)')">
                                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                                   Color="Color.Error"
                                                                   OnClick="@(() => RemoveSection(activeSec))" />
                                                </MudTooltip>
                                            </div>
                                        }
                                    }
                                }

                                @* All tiles in the tab render, with non-active-section tiles hidden
                                   via display:none. This keeps DashboardView components mounted
                                   across section switches — without this, switching sections
                                   unmounts the active section's tiles + remounts the new section's
                                   tiles, and remounting a DashboardView re-renders the entire grid
                                   (7-10s on a 30k-row tile). The previous filter-on-activeIndices
                                   approach was correct for "tab-like" semantics but leaked the
                                   first-render cost on every section switch.
                                   The "(no section)" pseudo-section uses sectionId == null.
                                   When _sections is empty, every tile is visible (matches pre-
                                   sections layout exactly). *@
                                bool TileVisible(MasterDashboardTile t)
                                {
                                    if (_sections.Count == 0) return true;
                                    if (_activeSectionId == 0) return t.SectionId is null;
                                    return t.SectionId == _activeSectionId;
                                }

                                <div class="mt-2" style="display: flex; flex-wrap: wrap; gap: 16px; padding-bottom: 12px;">
                                    @for (var ti = 0; ti < _tiles.Count; ti++)
                                    {
                                        var idx = ti;
                                        var tl = _tiles[ti];
                                        var visible = TileVisible(tl);
                                        var isDragging = _editMode && _dragSource == idx;
                                        var isDropTarget = _editMode && _dropTarget == idx && _dragSource >= 0 && _dragSource != idx;
                                        var tileClass = "master-tile"
                                            + (_editMode ? " master-tile-edit" : string.Empty)
                                            + (isDragging ? " master-tile-dragging" : string.Empty)
                                            + (isDropTarget ? " master-tile-droptarget" : string.Empty);
                                        @* The inline width is the *preferred* width (ColSpan * 60).
                                           min-width: 0 + flex-shrink: 1 lets the tile shrink with its
                                           flex-row parent when there isn't enough horizontal room —
                                           which then unlocks the table-shrink chain inside. The old
                                           flex-shrink: 0 + min-width: auto combination was pinning
                                           the tile at ColSpan * 60 regardless of viewport / parent
                                           width, which then propagated down to the table. *@
                                        <div @key="tl.Id" id="@($"master-tile-{tl.Id}")"
                                             class="@tileClass"
                                             style="@(visible ? string.Empty : "display: none; ")width: @(tl.ColSpan * 60)px; height: @(tl.Height)px; position: relative; min-width: 0; flex-shrink: 1;"
                                             @ondragover:preventDefault
                                             @ondragover="@(() => { if (_editMode && _dragSource >= 0 && idx != _dragSource) { _dropTarget = idx; } })"
                                             @ondrop="@(async () => await OnTileDrop(idx))"
                                             @oncontextmenu="@(() => ShowTileQuery(tl))"
                                             @oncontextmenu:preventDefault="true">
                                            <MudPaper Elevation="0" Style="border: 1px solid #E8EAED; border-radius: 12px; height: 100%; display: flex; flex-direction: column; overflow: hidden; box-shadow: 7px 7px 9px rgba(0,0,0,0.20), 5px 5px 7px rgba(0,0,0,0.14);">
                                                @* Tile header — drag handle in edit mode; title is bold and per-tile alignable *@
                                                @{
                                                    var tileAlign = string.IsNullOrEmpty(tl.TitleAlign) ? "left" : tl.TitleAlign;
                                                }
                                                <div draggable="@(_editMode ? "true" : "false")"
                                                     @ondragstart="@(() => _dragSource = idx)"
                                                     @ondragend="@(() => { _dragSource = -1; _dropTarget = -1; _dropTargetTabId = 0; })"
                                                     style="@(_editMode ? "cursor: grab;" : "")">
                                                    <div style="display: flex; align-items: center; gap: 4px; padding: 6px 12px; border-bottom: 1px solid #E8EAED; background: #FFFFFF;">
                                                        @if (_editMode)
                                                        {
                                                            <MudIcon Icon="@Icons.Material.Filled.DragIndicator" Size="Size.Small"
                                                                     Style="color: #5F6368; font-size: 18px;" />
                                                        }
                                                        <span style="@($"flex: 1; min-width: 0; font-weight: 700; font-size: 0.95rem; text-align: {tileAlign}; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;")"
                                                              title="@tl.ReportName">@tl.ReportName</span>
                                                        @if (_editMode)
                                                        {
                                                            <MudText Typo="Typo.caption" Color="Color.Secondary" Style="white-space: nowrap;">(@(tl.ColSpan * 60)w x @(tl.Height)h)</MudText>
                                                            <MudTooltip Text="Align left" Placement="Placement.Bottom">
                                                                <MudIconButton Icon="@Icons.Material.Filled.FormatAlignLeft" Size="Size.Small"
                                                                               Color="@(tileAlign == "left" ? Color.Primary : Color.Default)"
                                                                               OnClick="@(() => SetTileAlign(tl, "left"))" />
                                                            </MudTooltip>
                                                            <MudTooltip Text="Align center" Placement="Placement.Bottom">
                                                                <MudIconButton Icon="@Icons.Material.Filled.FormatAlignCenter" Size="Size.Small"
                                                                               Color="@(tileAlign == "center" ? Color.Primary : Color.Default)"
                                                                               OnClick="@(() => SetTileAlign(tl, "center"))" />
                                                            </MudTooltip>
                                                            <MudTooltip Text="Align right" Placement="Placement.Bottom">
                                                                <MudIconButton Icon="@Icons.Material.Filled.FormatAlignRight" Size="Size.Small"
                                                                               Color="@(tileAlign == "right" ? Color.Primary : Color.Default)"
                                                                               OnClick="@(() => SetTileAlign(tl, "right"))" />
                                                            </MudTooltip>
                                                            @* Move-to-section picker — only meaningful when the
                                                               tab actually has sections. The check icon marks
                                                               the tile's current bucket so admins can confirm
                                                               where it lives without opening another tab. *@
                                                            @if (_sections.Count > 0)
                                                            {
                                                                <MudTooltip Text="Move tile to a section" Placement="Placement.Bottom">
                                                                    <MudMenu Icon="@Icons.Material.Filled.ViewModule" Size="Size.Small"
                                                                             Dense AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                                                                        <MudMenuItem OnClick="@(() => MoveTileToSection(tl, null))">
                                                                            @if (tl.SectionId is null)
                                                                            {
                                                                                <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" Style="margin-right: 4px;" />
                                                                            }
                                                                            (no section)
                                                                        </MudMenuItem>
                                                                        @foreach (var s in _sections)
                                                                        {
                                                                            var sLocal = s;
                                                                            <MudMenuItem OnClick="@(() => MoveTileToSection(tl, sLocal.Id))">
                                                                                @if (tl.SectionId == sLocal.Id)
                                                                                {
                                                                                    <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" Style="margin-right: 4px;" />
                                                                                }
                                                                                @sLocal.Label
                                                                            </MudMenuItem>
                                                                        }
                                                                    </MudMenu>
                                                                </MudTooltip>
                                                            }
                                                        }
                                                        @if (_tileData.TryGetValue(tl.ReportId, out var tdHeader) && tdHeader.Config is not null
                                                             && !string.IsNullOrEmpty(tdHeader.Config.ChartType))
                                                        {
                                                            <MudTooltip Text="@(_chartVisibleTiles.Contains(tl.Id) ? "Hide Chart" : "Show Chart")" Placement="Placement.Bottom">
                                                                <MudIconButton Icon="@(_chartVisibleTiles.Contains(tl.Id) ? Icons.Material.Filled.BarChart : Icons.Material.Outlined.BarChart)"
                                                                               Size="Size.Small"
                                                                               Color="@(_chartVisibleTiles.Contains(tl.Id) ? Color.Primary : Color.Default)"
                                                                               OnClick="@(() => ToggleChart(tl.Id))" />
                                                            </MudTooltip>
                                                        }
                                                        @if (_editMode)
                                                        {
                                                            <MudTooltip Text="Remove tile">
                                                                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                                                               Color="Color.Error"
                                                                               OnClick="() => RemoveTile(tl)" />
                                                            </MudTooltip>
                                                        }
                                                    </div>
                                                </div>

                                                @* Tile content. min-width: 0 lets the flex chain inside
                                                   shrink horizontally with the tile (each flex container
                                                   defaults to min-width: auto = content intrinsic min,
                                                   which pegs the table's column widths). *@
                                                <div style="overflow: hidden; flex: 1; display: flex; flex-direction: column; min-width: 0;">
