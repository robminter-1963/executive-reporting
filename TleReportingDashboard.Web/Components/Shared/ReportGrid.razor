@inject IJSRuntime JS
@inject TleReportingDashboard.Web.Services.IColumnWidthDefaultsService ColumnWidthDefaultsSvc
@implements IDisposable

@if (Data is not null && Data.Columns.Any())
{
    <MudStack Spacing="1">

<div @key="@ColumnOrderKey" style="width: 100%;" id="@_gridHostId">
@if (DisableUserSort)
{
    @* Read-only fallback: a plain HTML table rendered to match the look of
       MudDataGrid. Used by the Report Viewer where sort must stay locked
       to what was saved. MudDataGrid still re-sorts on header clicks even
       with SortMode.None + Sortable=false, so we sidestep it entirely here. *@
    <div class="read-only-grid resizable-grid @(SizeColumnsToContent ? "size-to-content" : "")" style="@($"height: {GetGridHeight()}; overflow: auto;")">
        <table>
            <thead>
                <tr>
                    @foreach (var entry in RenderColumns)
                    {
                        if (entry is ColumnMeta col)
                        {
                            var (minWidth, defaultMax) = GetColumnWidths(col, HonorFieldMinWidth);
                            var w = _customWidths.TryGetValue(col.FieldId, out var cw) ? cw : defaultMax;
                            var align = GetCellAlign(col.DataType);
                            <th class="mud-table-cell"
                                style="@($"width: {w}px; max-width: {w}px; min-width: {minWidth}px; {align}")">
                                @col.Label
                            </th>
                        }
                        else if (entry is TableCalcColumnDef cc)
                        {
                            var ccLocal = cc;
                            var (ccMin, ccMax) = GetCalcColumnWidths(cc);
                            var ccAlign = GetCellAlign(cc.DataType ?? "decimal");
                            <th class="mud-table-cell"
                                style="@($"width: {ccMax}px; max-width: {ccMax}px; min-width: {ccMin}px; {ccAlign}")"
                                title="@(string.IsNullOrWhiteSpace(ccLocal.SqlExpression) ? $"Formula: {ccLocal.Formula}" : $"SQL: {ccLocal.SqlExpression}")">
                                @ccLocal.Label
                            </th>
                        }
                    }
                    <th class="grid-filler" style="width: 100%; padding: 0; border: none;"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in PagedSortedRows)
                {
                    <tr>
                        @foreach (var entry in RenderColumns)
                        {
                            if (entry is ColumnMeta col)
                            {
                                var (minWidth, defaultMax) = GetColumnWidths(col, HonorFieldMinWidth);
                                var w = _customWidths.TryGetValue(col.FieldId, out var cw) ? cw : defaultMax;
                                var align = GetCellAlign(col.DataType);
                                <td class="mud-table-cell"
                                    style="@($"width: {w}px; min-width: {minWidth}px; max-width: {w}px; {align}")"
                                    title="@FormatValue(row, col)"
                                    @oncontextmenu="@(e => ShowCellContextMenu(e, col, row))"
                                    @oncontextmenu:preventDefault="EnableContextMenu">
                                    <span style="@($"display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: {w}px;")">@FormatValue(row, col)</span>
                                </td>
                            }
                            else if (entry is TableCalcColumnDef cc)
                            {
                                var (ccMin, ccMax) = GetCalcColumnWidths(cc);
                                var ccAlign = GetCellAlign(cc.DataType ?? "decimal");
                                var ccText = FormatCalcCell(row, cc);
                                <td class="mud-table-cell"
                                    style="@($"width: {ccMax}px; min-width: {ccMin}px; max-width: {ccMax}px; {ccAlign}")"
                                    title="@ccText">
                                    <span style="@($"display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: {ccMax}px;")">@ccText</span>
                                </td>
                            }
                        }
                        <td class="grid-filler" style="padding: 0; border: none;"></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween"
              Class="px-4 py-2" Style="width: 100%;">
        <MudText Typo="Typo.caption" Color="Color.Secondary">
            @GetRowCountText()
        </MudText>
        <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
            <MudText Typo="Typo.caption">Rows per page:</MudText>
            <MudSelect T="int" Value="_pageSize" ValueChanged="OnReadOnlyPageSizeChanged"
                       Dense Variant="Variant.Text" Style="width: 80px;">
                @foreach (var opt in new[] { 25, 50, 100, 250, 500 })
                {
                    <MudSelectItem T="int" Value="@opt">@opt</MudSelectItem>
                }
            </MudSelect>
            <MudText Typo="Typo.caption">
                @(((_readOnlyPage - 1) * _pageSize + 1))–@(Math.Min(_readOnlyPage * _pageSize, (Data?.Rows.Count ?? 0))) of @(Data?.Rows.Count ?? 0)
            </MudText>
            <MudIconButton Icon="@Icons.Material.Outlined.ChevronLeft" Size="Size.Small"
                           Disabled="@(_readOnlyPage <= 1)"
                           OnClick="() => { _readOnlyPage = Math.Max(1, _readOnlyPage - 1); }" />
            <MudIconButton Icon="@Icons.Material.Outlined.ChevronRight" Size="Size.Small"
                           Disabled="@(_readOnlyPage * _pageSize >= (Data?.Rows.Count ?? 0))"
                           OnClick="() => { _readOnlyPage++; }" />
        </MudStack>
    </MudStack>
}
else
{
        <MudDataGrid @ref="_mudGrid" T="Dictionary<string, object?>" Items="@SortedRows"
                     Dense Hover Striped
                     FixedHeader Height="@GetGridHeight()"
                     SortMode="SortMode.Multiple"
                     SortChanged="OnSortChangedInternal"
                     RowsPerPage="_pageSize"
                     RowsPerPageChanged="OnPageSizeChanged"
                     Class="resizable-grid">
            <Columns>
                @* Walk the unified render order so calc columns (TC-SQL) sit
                   wherever the admin dragged them in the chip bar instead of
                   always at the end. Each entry is either a ColumnMeta or a
                   TableCalcColumnDef. *@
                @foreach (var entry in RenderColumns)
                {
                    if (entry is ColumnMeta col)
                    {
                        var (minWidth, defaultMax) = GetColumnWidths(col, HonorFieldMinWidth);
                        var w = _customWidths.TryGetValue(col.FieldId, out var cw) ? cw : defaultMax;
                        var align = GetCellAlign(col.DataType);
                        var c = col;
                        <TemplateColumn T="Dictionary<string, object?>" Title="@ResolveColumnLabel(col.FieldId, col.Label)"
                                        Field="@col.FieldId"
                                        PropertyName="@col.FieldId"
                                        Sortable="true"
                                        SortBy="@(row => GetSortValue(row, c))"
                                        HeaderStyle="@($"width: {w}px; max-width: {w}px; white-space: nowrap; overflow: hidden; {align}")"
                                        CellStyle="@($"width: {w}px; min-width: {minWidth}px; max-width: {w}px; overflow: hidden; text-overflow: ellipsis; {align}")">
                            <CellTemplate>
                                <span style="@($"display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: {w}px;")"
                                      title="@FormatValue(context.Item, col)"
                                      @oncontextmenu="@(e => ShowCellContextMenu(e, c, context.Item))"
                                      @oncontextmenu:preventDefault="EnableContextMenu">@FormatValue(context.Item, col)</span>
                            </CellTemplate>
                        </TemplateColumn>
                    }
                    else if (entry is TableCalcColumnDef cc)
                    {
                        var ccLocal = cc;
                        var (ccMin, ccMax) = GetCalcColumnWidths(cc);
                        var ccAlign = GetCellAlign(cc.DataType ?? "decimal");
                        <TemplateColumn T="Dictionary<string, object?>" Title="@ResolveColumnLabel(cc.Key, cc.Label)"
                                        Sortable="true"
                                        SortBy="@(row => CalcSortValue(row, ccLocal))"
                                        HeaderStyle="@($"width: {ccMax}px; max-width: {ccMax}px; white-space: nowrap; overflow: hidden; {ccAlign}")"
                                        CellStyle="@($"width: {ccMax}px; min-width: {ccMin}px; max-width: {ccMax}px; overflow: hidden; text-overflow: ellipsis; {ccAlign}")">
                            <HeaderTemplate>
                                <MudTooltip Text="@(string.IsNullOrWhiteSpace(ccLocal.SqlExpression) ? $"Formula: {ccLocal.Formula}" : $"SQL: {ccLocal.SqlExpression}")">
                                    <span>@ResolveColumnLabel(ccLocal.Key, ccLocal.Label)</span>
                                </MudTooltip>
                            </HeaderTemplate>
                            <CellTemplate>
                                @{
                                    var ccText = FormatCalcCell(context.Item, ccLocal);
                                }
                                <span style="@($"display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: {ccMax}px;")"
                                      title="@ccText">@ccText</span>
                            </CellTemplate>
                        </TemplateColumn>
                    }
                }
                @* Filler column to absorb remaining width *@
                <TemplateColumn T="Dictionary<string, object?>" title=""
                                Sortable="false"
                                HeaderClass="grid-filler"
                                CellClass="grid-filler"
                                HeaderStyle="width: 100%; padding: 0; border: none;"
                                CellStyle="width: 100%; padding: 0; border: none;">
                    <CellTemplate>&nbsp;</CellTemplate>
                </TemplateColumn>
            </Columns>
            <PagerContent>
                <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween"
                           Class="px-4 py-2" Style="width: 100%;">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        @GetRowCountText()
                    </MudText>
                    <MudDataGridPager T="Dictionary<string, object?>" />
                </MudStack>
            </PagerContent>
        </MudDataGrid>
}
        </div>
    </MudStack>

    @* Cell context menu — single instance shared by every data cell.
       PositionAtCursor anchors the menu at the click coordinates;
       OpenMenuAsync(MouseEventArgs) is called from ShowCellContextMenu
       after the cached state is staged. ActivatorContent is an
       invisible placeholder because we don't want a separate button
       to open this — only the right-click handler. *@
    @if (EnableContextMenu)
    {
        <MudMenu @ref="_cellContextMenu" PositionAtCursor="true" Dense>
            <ActivatorContent>
                <span style="display: none;"></span>
            </ActivatorContent>
            <ChildContent>
                @if (_ctxFieldId is not null)
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="px-3 pt-1" Style="display: block;">
                        @_ctxColumnLabel
                    </MudText>
                }
                <MudMenuItem Icon="@Icons.Material.Outlined.FilterAlt"
                             OnClick="@(() => InvokeCellAction("filter"))">
                    Filter to <strong>@TrimForMenu(_ctxValueDisplay)</strong>
                </MudMenuItem>
                <MudMenuItem Icon="@Icons.Material.Outlined.Block"
                             OnClick="@(() => InvokeCellAction("exclude"))">
                    Exclude <strong>@TrimForMenu(_ctxValueDisplay)</strong>
                </MudMenuItem>
                <MudDivider />
                <MudMenuItem Icon="@Icons.Material.Outlined.ContentCopy"
                             OnClick="@(() => InvokeCellAction("copy"))">
                    Copy value
                </MudMenuItem>
            </ChildContent>
        </MudMenu>
    }

    <style>
        /* Ensure the grid never overflows its parent — the inner table-container
           handles horizontal scroll when columns sum wider than the available width. */
        .resizable-grid {
            max-width: 100%;
        }
        .resizable-grid .mud-table-container {
            overflow-x: auto;
        }
        .resizable-grid table {
            table-layout: fixed;
            width: 100%;
        }
        .resizable-grid th {
            position: relative;
            overflow: visible !important;
            padding: 4px 4px !important;
            /* Header floor: column never narrower than its label + sort icon + handle.
               max-content is the natural width with no wrapping (we have white-space: nowrap),
               so it includes everything inside the th. */
            min-width: max-content !important;
        }
        /* Read-only fallback table (DisableUserSort=true): styled to match
           MudDataGrid's dense-striped look without any MudDataGrid machinery. */
        .read-only-grid table {
            border-collapse: collapse;
            table-layout: fixed;
            width: 100%;
            font-size: 0.875rem;
        }
        .read-only-grid thead th {
            position: sticky;
            top: 0;
            background: #F8F9FA;
            z-index: 2;
            font-weight: 600;
            text-align: left;
            padding: 6px 8px;
            border-bottom: 1px solid #DADCE0;
            white-space: nowrap;
            overflow: hidden;
            user-select: none;
        }
        .read-only-grid tbody td {
            padding: 2px 8px;
            border-bottom: 1px solid #F1F3F4;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }
        .read-only-grid tbody tr:nth-child(odd) {
            background: #FAFBFC;
        }
        /* size-to-content mode: each column floor = max(header, every row).
           Switches the table off fixed layout and strips the inline width
           caps that would otherwise clip content. white-space: nowrap on
           cells (kept from the base rules above) forces columns to expand
           horizontally; overflow-x on the wrapping div produces a scroll
           bar when total width exceeds the viewport. !important is needed
           because the per-cell width/max-width are inlined on every td. */
        .read-only-grid.size-to-content table {
            table-layout: auto !important;
            width: auto !important;
            min-width: 100%;
        }
        .read-only-grid.size-to-content th,
        .read-only-grid.size-to-content td {
            width: auto !important;
            max-width: none !important;
        }
        .read-only-grid.size-to-content tbody td > span {
            max-width: none !important;
            overflow: visible !important;
            text-overflow: clip !important;
        }
        .read-only-grid.size-to-content .grid-filler {
            display: none;
        }
        .read-only-grid tbody tr:hover {
            background: #E8F0FE !important;
        }
        .resizable-grid td {
            overflow: hidden;
            text-overflow: ellipsis;
            padding: 2px 4px !important;
        }
        .col-resize-handle {
            position: absolute;
            right: 0;
            top: 0;
            bottom: 0;
            width: 6px;
            cursor: col-resize;
            z-index: 10;
            background: transparent;
        }
        .col-resize-handle::after {
            content: '';
            position: absolute;
            right: 0;
            top: 20%;
            height: 60%;
            width: 2px;
            background: #DADCE0;
            border-radius: 1px;
        }
        .col-resize-handle:hover::after,
        .col-resize-handle.active::after {
            background: #1A73E8;
            top: 0;
            height: 100%;
        }
        .reorder-zone {
            display: flex;
            flex-wrap: wrap;
            gap: 4px;
            align-items: center;
            min-height: 36px;
        }
        .reorder-chip {
            position: relative;
            transition: opacity 0.15s;
        }
        .reorder-chip.dragging {
            opacity: 0.3;
        }
        .reorder-chip.hidden-col {
            opacity: 0.55;
        }
        .reorder-chip.hidden-col .mud-chip {
            text-decoration: line-through;
        }
        .reorder-end-zone {
            width: 20px;
            min-height: 32px;
            position: relative;
        }
        .drop-indicator {
            position: absolute;
            left: -2px;
            top: 2px;
            bottom: 2px;
            width: 3px;
            background: #1A73E8;
            border-radius: 2px;
            z-index: 10;
        }
    </style>
}
else
{
    <MudText Typo="Typo.body2" Color="Color.Secondary">No data to display.</MudText>
}

@code {
    [Parameter] public QueryResponse? Data { get; set; }
    [Parameter] public bool IsTruncated { get; set; }
    // When true, two related "readable layout" behaviors kick in:
    //   1. ColumnMeta.MinWidth (admin-set on FieldDefinition) is applied
    //      as a floor on the auto-sized column width.
    //   2. Non-text data types (currency, date, datetime, integer, decimal,
    //      phone, boolean, percent) widen to their typical formatted-output
    //      size — "$1,234,567.89", "May 15, 2026 2:30 PM" etc. fit without
    //      truncation instead of squeezing to ~50px.
    // Off by default so the Report Viewer + Master Dashboard tile drill-
    // down keep their compact rendering; opted into by the Report Builder
    // (table view) and the Detail Viewer where wider columns aid editing
    // / drill-down reading. Total report width grows accordingly; the
    // wrapping container's overflow-x: auto kicks in a horizontal
    // scrollbar when columns sum wider than the viewport.
    [Parameter] public bool HonorFieldMinWidth { get; set; }

    // When true, every column's rendered width is at least max(header
    // label width, longest cell content) — columns never clip. Switches
    // the read-only table's layout to auto and removes the inline width
    // clips so the browser sizes each column to its natural content
    // extent. Total grid width grows accordingly; the wrapping div's
    // overflow-x: auto kicks in a horizontal scrollbar when needed.
    // Opted into by the Detail Viewer where data legibility wins over
    // dense layouts.
    [Parameter] public bool SizeColumnsToContent { get; set; }
    [Parameter] public Dictionary<string, int>? InitialColumnWidths { get; set; }
    [Parameter] public EventCallback<Dictionary<string, int>> OnColumnWidthsChanged { get; set; }
    [Parameter] public string? DefaultSortField { get; set; }
    [Parameter] public string? DefaultSortDirection { get; set; }
    [Parameter] public EventCallback<(string? Field, string? Direction)> OnDefaultSortChanged { get; set; }
    [Parameter] public List<string>? InitialColumnOrder { get; set; }
    [Parameter] public EventCallback<List<string>> OnColumnOrderChanged { get; set; }
    [Parameter] public List<string>? InitialHiddenColumns { get; set; }
    [Parameter] public EventCallback<List<string>> OnHiddenColumnsChanged { get; set; }
    // Columns the Table view must always hide — e.g. aggregate fields whose
    // values only make sense in the Dashboard view. Not user-toggleable.
    [Parameter] public List<string>? AlwaysHiddenColumns { get; set; }
    // Calculated columns rendered AFTER the data columns. Each is evaluated
    // per-row at render time against the row dictionary; unlike data
    // columns these don't round-trip through SQL. Null / empty list = no
    // calc columns shown. Independent of any template lock — calc columns
    // are admin derivations on top of the template's field set.
    [Parameter] public List<TableCalcColumnDef>? CalcColumns { get; set; }
    // Per-column header overrides keyed by field id (or calc Key). Used
    // by grid templates to rename column headers without editing the
    // underlying schema. Missing entries fall back to the column's
    // default Label. Empty / null = no overrides.
    [Parameter] public Dictionary<string, string>? ColumnLabelOverrides { get; set; }
    [Parameter] public bool ReadOnly { get; set; }
    // When true, the grid fills the browser viewport (minus a small allowance
    // for the page header above it). Once the user picks a specific rows-per-
    // page value, the grid stops fill-mode and sizes to exactly that many rows.
    [Parameter] public bool FillViewport { get; set; }
    // Lets callers seed the initial rows-per-page (e.g. from user preferences).
    [Parameter] public int? InitialPageSize { get; set; }
    // Raised when the user picks a new rows-per-page via the pager, so callers
    // can persist the choice to user preferences.
    [Parameter] public EventCallback<int> OnPageSizeChangedCallback { get; set; }
    // Ordered list of (fieldId, direction) pairs to seed the grid's multi-sort.
    // Index 0 is the primary sort, index 1 the secondary, etc. Applied once
    // after the grid mounts; user interactions (click + Ctrl-click) take over
    // from there.
    [Parameter] public List<(string Field, string Direction)>? InitialSort { get; set; }
    // Fires whenever the user changes the multi-sort (click or Ctrl-click on
    // a column header). Callers can show the live sort state or persist it.
    [Parameter] public EventCallback<List<(string Field, string Direction)>> OnSortChanged { get; set; }
    // When true, users cannot change the sort: columns are non-sortable and
    // data comes pre-sorted by InitialSort (or the legacy DefaultSortField
    // as a fallback). Used by Report Viewer where sort is locked to what
    // was saved with the report.
    [Parameter] public bool DisableUserSort { get; set; }

    // When true, right-clicking a data cell opens a context menu with
    // "Filter to this value" / "Exclude this value" / "Copy value"
    // entries. Off by default so the menu doesn't surprise users on
    // surfaces (DetailViewer, dashboard tiles) where the parent
    // hasn't wired the OnCellAction callback. Calc columns + the
    // filler column are intentionally excluded — filtering on a
    // computed value doesn't round-trip cleanly to a WHERE clause.
    [Parameter] public bool EnableContextMenu { get; set; }

    // Fired when the user picks a context-menu option on a data cell.
    // Parent decides what to do: ReportViewer translates "filter" /
    // "exclude" into a new FilterClause and re-runs; "copy" writes the
    // raw value to the clipboard.
    [Parameter] public EventCallback<CellAction> OnCellAction { get; set; }

    // Right-click context — opaque to the parent except for the kind
    // string ("filter" | "exclude" | "copy"). FieldId is the schema
    // id (suitable for a FilterClause); Label is the admin-authored
    // header (for snackbar messages); Value is the raw cell value
    // (the parent decides how to stringify it for filter binding).
    public sealed record CellAction(string Kind, string FieldId, string Label, object? Value);

    // Resolves the visible header label for a column. Override (from a
    // grid template's CustomColumnLabels) wins; default is the column's
    // own Label. Empty / whitespace overrides are treated as "no override"
    // so admins can clear a rename by blanking the input.
    private string ResolveColumnLabel(string fieldIdOrKey, string defaultLabel)
    {
        if (ColumnLabelOverrides is { Count: > 0 }
            && !string.IsNullOrEmpty(fieldIdOrKey)
            && ColumnLabelOverrides.TryGetValue(fieldIdOrKey, out var v)
            && !string.IsNullOrWhiteSpace(v))
        {
            return v;
        }
        return defaultLabel;
    }

    private int _pageSize = 100;
    private int _readOnlyPage = 1;
    private bool _initialPageSizeApplied;

    // ── Context-menu state ──
    // Captured when the user right-clicks a data cell; consumed by the
    // shared MudMenu rendered once at the end of the markup so the
    // three menu items can resolve the active cell without re-binding
    // a lambda per row (which would allocate per re-render).
    private MudMenu? _cellContextMenu;
    private string? _ctxFieldId;
    private string _ctxColumnLabel = string.Empty;
    private object? _ctxValue;
    private string _ctxValueDisplay = string.Empty;

    // Right-click handler — caches the cell's id/label/value and pops
    // the context menu at the cursor. The menu picks its action off
    // the cached state; the lambda hands the raw row + col so the
    // formatter can produce a readable preview for the "Filter to ___"
    // menu label without the parent having to compute it.
    private async Task ShowCellContextMenu(MouseEventArgs e, ColumnMeta col, Dictionary<string, object?> row)
    {
        if (!EnableContextMenu) return;
        _ctxFieldId = col.FieldId;
        _ctxColumnLabel = ResolveColumnLabel(col.FieldId, col.Label);
        _ctxValue = row.TryGetValue(col.FieldId, out var v) ? v : null;
        _ctxValueDisplay = FormatValue(row, col);
        StateHasChanged();
        if (_cellContextMenu is not null)
            await _cellContextMenu.OpenMenuAsync(e);
    }

    private async Task InvokeCellAction(string kind)
    {
        if (_ctxFieldId is null) return;
        await OnCellAction.InvokeAsync(
            new CellAction(kind, _ctxFieldId, _ctxColumnLabel, _ctxValue));
    }

    // Clamps the cell-value preview shown in the menu labels. Long
    // values (e.g., a 200-char description) would blow out the menu
    // width; ~32 chars keeps the menu compact while still letting the
    // user verify which value they're about to filter on.
    private static string TrimForMenu(string s)
    {
        if (string.IsNullOrEmpty(s)) return "(blank)";
        const int max = 32;
        return s.Length <= max ? s : s[..max] + "…";
    }
    private MudDataGrid<Dictionary<string, object?>>? _mudGrid;
    private bool _initialSortApplied;
    private bool _widthsLoaded;
    // Unique wrapper id so the fill-viewport JS can measure exactly this grid
    // instance (multiple grids could exist on a page in theory).
    private readonly string _gridHostId = $"rpt-grid-{Guid.NewGuid():N}";
    // Pixel height set by the fill-viewport JS. Null means "not yet measured"
    // or "fill mode is off"; the grid falls back to the CSS calc() value.
    private int? _fillPx;
    private bool _orderLoaded;
    private bool _hiddenLoaded;
    private HashSet<string> _hiddenColumns = new();
    private List<ColumnMeta> _columnOrder = new();
    // Live combined order — mirrors InitialColumnOrder on first load and
    // gets updated whenever ApplyColumnOrder is called. BuildRenderColumns
    // walks this list (not the immutable InitialColumnOrder parameter) so
    // chip-bar reorders take effect immediately without a re-run of the
    // query. Mixed list of field ids and calc keys.
    private List<string>? _combinedColumnOrder;
    private int _renderCount;
    private Dictionary<string, int> _customWidths = new();
    private DotNetObjectReference<ReportGrid>? _dotNetRef;
    // Set in Dispose. OnAfterRenderAsync awaits a 100ms debounce before
    // wiring up JS; if the component disposes during that delay (parent
    // re-render swapping in fresh data, or page navigation), the post-
    // delay code must not use _dotNetRef — it's already been disposed
    // and JSInterop's serializer throws ObjectDisposedException trying
    // to write the reference.
    private bool _disposed;

    // Cached snapshot of admin-configurable column-width defaults. Loaded once
    // per component init; TypeBasedWidths consults this instead of hard-coded
    // values. Null briefly during first render — Seed() is used as fallback
    // so initial column sizing doesn't crash.
    private TleReportingDashboard.Web.Models.ColumnWidthDefaults? _columnWidthDefaults;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _columnWidthDefaults = await ColumnWidthDefaultsSvc.GetAsync();
        }
        catch
        {
            // Service hiccup shouldn't crash the grid — fall back to seed.
            _columnWidthDefaults = TleReportingDashboard.Web.Models.ColumnWidthDefaults.Seed();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Seed multi-sort as soon as the grid, its data, and its ref are all
        // available. Run OUTSIDE the debounce below — the debounce can skip
        // when renders fire <100ms apart, which was masking the sort on load.
        // Skipped when DisableUserSort is on, since SortedRows pre-sorts the
        // data in that mode and the grid headers aren't clickable anyway.
        if (!_initialSortApplied
            && !DisableUserSort
            && Data is not null && Data.Columns.Any()
            && InitialSort is { Count: > 0 }
            && _mudGrid is not null)
        {
            _initialSortApplied = true;

            // Seed multi-sort via simulated header clicks. Programmatic paths
            // (SetSortAsync loop, direct SortDefinitions writes, hybrids) all
            // either drop entries or leave the priority badges unrendered —
            // MudDataGrid's per-header "I'm sorted, my index is N" state
            // only fully wires up via its own click pipeline. Dispatching
            // real click events from JS exercises that pipeline identically
            // to the user, so arrows AND priority numbers paint correctly.
            var specs = new List<object>();
            foreach (var (field, dir) in InitialSort)
            {
                var col = _columnOrder.FirstOrDefault(c =>
                    string.Equals(c.FieldId, field, StringComparison.OrdinalIgnoreCase));
                if (col is not null)
                {
                    specs.Add(new { label = col.Label, direction = dir });
                    continue;
                }
                // Fall back to calc columns — saved sort by a calc Key
                // restores by matching against the calc's Label (the JS
                // applier dispatches a header click on the column whose
                // visible text equals this label).
                var calc = CalcColumns?.FirstOrDefault(c =>
                    string.Equals(c.Key, field, StringComparison.OrdinalIgnoreCase));
                if (calc is not null && !string.IsNullOrEmpty(calc.Label))
                    specs.Add(new { label = calc.Label, direction = dir });
            }
            if (specs.Count > 0)
                await JS.InvokeVoidAsync("mudGridSort.applyInitial", $"#{_gridHostId}", specs);
        }

        // Install the click blocker on the header row whenever user sort is
        // disabled. SortMode.None + Sortable=false aren't enough when SortBy
        // is also set — MudDataGrid still wires a click handler inside each
        // th that flips the sort. A capturing-phase JS blocker on <thead>
        // stops the event before that handler ever sees it.
        if (DisableUserSort && Data is not null && Data.Columns.Any())
        {
            await JS.InvokeVoidAsync("mudGridSort.lockHeaders", $"#{_gridHostId}");
        }

        if (Data is not null && Data.Columns.Any())
        {
            _renderCount++;
            var currentRender = _renderCount;
            await Task.Delay(100);
            // _disposed guard for the disposal-during-delay race: parent
            // re-rendered with fresh data (or the page navigated away)
            // while the 100ms debounce was awaiting, Dispose ran, and
            // _dotNetRef was disposed. Resuming and passing the disposed
            // reference to JSInterop throws ObjectDisposedException
            // inside the serializer. Bail silently — the next render
            // will set everything up again with a fresh ref.
            if (_disposed) return;
            if (currentRender == _renderCount)
            {
                _dotNetRef ??= DotNetObjectReference.Create(this);
                await JS.InvokeVoidAsync("initColumnResize", ".resizable-grid", _dotNetRef);
                if (_disposed) return;

                // Activate the JS-driven dynamic height whenever fill-mode
                // is on. The grid always fills the viewport; pagination and
                // internal scrolling handle larger-than-fits row counts.
                if (FillViewport)
                {
                    await JS.InvokeVoidAsync("fillViewportGrid.init", $"#{_gridHostId}", _dotNetRef);
                }
            }
        }
    }

    // Returns the current multi-sort order from the live grid in priority order
    // (primary first). Used by callers (e.g. ReportBuilder on save) to persist
    // the user's interactively-built sort state along with the report.
    //
    // MudDataGrid keys SortDefinitions by a per-render column GUID, not the
    // field name. We translate by matching each SortDefinition key to the
    // rendered column whose Identifier equals it, then reading that column's
    // Field — which IS stable across reloads.
    public List<(string Field, string Direction)> GetCurrentSort()
    {
        var result = new List<(string Field, string Direction)>();
        if (_mudGrid?.SortDefinitions is null) return result;

        var idToField = BuildIdentifierToFieldMap();
        foreach (var kv in _mudGrid.SortDefinitions.OrderBy(kv => kv.Value.Index))
        {
            if (!idToField.TryGetValue(kv.Key, out var field) || string.IsNullOrWhiteSpace(field))
                continue;
            var dir = kv.Value.Descending ? "desc" : "asc";
            result.Add((field, dir));
        }
        return result;
    }

    // Maps the live column PropertyName (per-render GUID — the key MudDataGrid
    // uses in SortDefinitions) to our stable field id. Identifier is empty on
    // TemplateColumn in MudBlazor 9.3; PropertyName gets auto-generated to a
    // GUID even when we try to override it via the Razor attribute. Title
    // round-trips reliably so we match via Title ↔ ColumnMeta.Label.
    // Also includes calc columns (key = calc Key, label = calc Label) so a
    // sort applied to a calc column survives save/reload — without this,
    // the SortChanged → field-id translation drops calc-column sorts on the
    // floor and the persisted TableSort lacks them.
    private Dictionary<string, string> BuildIdentifierToFieldMap()
    {
        var map = new Dictionary<string, string>(StringComparer.Ordinal);
        if (_mudGrid?.RenderedColumns is null) return map;

        var labelToField = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
        foreach (var c in _columnOrder.Where(c => !_hiddenColumns.Contains(c.FieldId)))
        {
            if (!string.IsNullOrEmpty(c.Label))
                labelToField[c.Label] = c.FieldId;
        }
        if (CalcColumns is { Count: > 0 })
        {
            foreach (var cc in CalcColumns)
            {
                if (!string.IsNullOrEmpty(cc.Label) && !string.IsNullOrEmpty(cc.Key))
                    labelToField[cc.Label] = cc.Key;
            }
        }

        foreach (var rc in _mudGrid.RenderedColumns)
        {
            if (string.IsNullOrEmpty(rc.PropertyName) || string.IsNullOrEmpty(rc.Title)) continue;
            if (labelToField.TryGetValue(rc.Title, out var fieldId))
                map[rc.PropertyName] = fieldId;
        }
        return map;
    }

    // Helper for SetSortAsync above — same logic as the per-column SortBy.
    private object? GetSortValueByFieldId(Dictionary<string, object?> row, string fieldId)
    {
        var col = _columnOrder.FirstOrDefault(c =>
            string.Equals(c.FieldId, fieldId, StringComparison.OrdinalIgnoreCase));
        return col is null ? null : GetSortValue(row, col);
    }

    // MudDataGrid fires this whenever the user clicks a header. The dict keys
    // are per-render column GUIDs — we translate to stable field ids using
    // the RenderedColumns map before relaying to the parent.
    // MudDataGrid's public SortChanged event — fires on every header click
    // (and programmatic sort). The dict keys are per-render column
    // PropertyName GUIDs, which we translate to stable field ids via the
    // RenderedColumns map before relaying to the parent.
    //
    // Note: we intentionally use MudBlazor 9.3's `SortChanged` event (not
    // `SortDefinitionsChanged`). The latter is the two-way-binding pair for
    // the `SortDefinitions` property and does not reliably fire as a
    // standalone event callback.
    private async Task OnSortChangedInternal(Dictionary<string, SortDefinition<Dictionary<string, object?>>> defs)
    {
        if (!OnSortChanged.HasDelegate) return;
        var idToField = BuildIdentifierToFieldMap();
        var tuples = defs
            .OrderBy(kv => kv.Value.Index)
            .Select(kv => (Id: kv.Key, Dir: kv.Value.Descending ? "desc" : "asc"))
            .Where(t => idToField.ContainsKey(t.Id))
            .Select(t => (Field: idToField[t.Id], Direction: t.Dir))
            .ToList();
        await OnSortChanged.InvokeAsync(tuples);
    }

    [JSInvokable]
    public void SetFillHeight(int px)
    {
        if (_fillPx == px) return;
        _fillPx = px;
        InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public async Task OnColumnResized(int colIndex, int newWidth)
    {
        var visible = VisibleColumns.ToList();
        if (colIndex >= 0 && colIndex < visible.Count)
        {
            _customWidths[visible[colIndex].FieldId] = newWidth;
            await OnColumnWidthsChanged.InvokeAsync(new Dictionary<string, int>(_customWidths));
        }
    }

    public Dictionary<string, int> GetCustomWidths() => new(_customWidths);

    public void Dispose()
    {
        // Set first so any in-flight OnAfterRenderAsync past its
        // Task.Delay short-circuits before touching the disposed ref.
        _disposed = true;
        if (FillViewport)
        {
            // Best-effort: tell the fill-viewport observer to detach so we don't
            // leak resize listeners when navigating away from the page.
            try { _ = JS.InvokeVoidAsync("fillViewportGrid.dispose", $"#{_gridHostId}"); }
            catch { /* JS runtime may already be gone — ignore */ }
        }
        _dotNetRef?.Dispose();
        _dotNetRef = null;
    }

    private (int min, int max) GetColumnWidths(ColumnMeta col, bool honorFieldMinWidth)
    {
        // ~6px per character at body2 font size + padding
        const int pxPerChar = 6;
        const int cellPadding = 12;

        // Wide-mode type defaults apply uniformly to every column type
        // (including text) when HonorFieldMinWidth is on — admins fully
        // control text behavior via Admin → Column Widths (text WideMin=0
        // means text columns size to content; a positive value gives all
        // text columns that floor).
        var typeBased = TypeBasedWidths(col.DataType, wide: honorFieldMinWidth);

        // The header-text floor is enforced in CSS via `min-width: max-content` on th
        // (see .resizable-grid th below) — no character-width estimate needed here.
        if (col.MaxLength.HasValue && col.MaxLength.Value > 0)
        {
            var charWidth = col.MaxLength.Value * pxPerChar + cellPadding;
            // Rule: when MaxLength translates to a smaller width than the
            // type's default min, honor it — a 3-char status code should be
            // ~30px, not padded up to the text floor. The CSS rule
            // `min-width: max-content` on th still protects the header
            // text from being clipped, so the declared min can drop below
            // typeBased.min without losing the column label.
            var min = Math.Min(charWidth, typeBased.min);
            var max = Math.Max(min, Math.Min(charWidth, 250));
            return honorFieldMinWidth ? ApplyMinWidthOverride(col.MinWidth, min, max) : (min, max);
        }

        return honorFieldMinWidth
            ? ApplyMinWidthOverride(col.MinWidth, typeBased.min, typeBased.max)
            : (typeBased.min, typeBased.max);
    }


    // Two tiers of type-based default widths driven by ColumnWidthDefaults
    // (admin-configurable via Admin → Column Widths). Falls back to the
    // in-code seed when the service hasn't loaded yet (very brief window
    // during first render).
    //   compact (Report Viewer, dashboard tile drill-down): legacy small
    //     widths — keeps dense reports dense.
    //   wide (Report Builder table view, Detail Viewer): sizes non-text
    //     columns to their typical formatted-output width so dates show
    //     "May 15, 2026 2:30 PM" without truncation, etc.
    private (int min, int max) TypeBasedWidths(string? dataType, bool wide)
    {
        var defaults = _columnWidthDefaults ?? TleReportingDashboard.Web.Models.ColumnWidthDefaults.Seed();
        var entry = defaults.Resolve(dataType);
        return wide ? (entry.WideMin, entry.WideMax) : (entry.CompactMin, entry.CompactMax);
    }

    // Layers the schema-asserted MinWidth on top of the auto-sized pair. A
    // set MinWidth raises both the floor (so the column never sizes below
    // it) and the default max (so the column actually OPENS at the
    // requested width instead of needing a manual resize). Cap both at a
    // sensible upper bound so an absurd value (e.g. 9999) doesn't dominate
    // the grid layout. No-op when MinWidth is unset or non-positive.
    // Authoritative override: when the field has an explicit MinWidth set,
    // it replaces the auto-sized min directly (no Math.Max with the type
    // default). The max is bumped to at least the override only when
    // necessary — a column literally can't render at width < min, so the
    // max has to accommodate. A MinWidth of 0 is treated as an explicit
    // "no minimum" — distinct from null (unset).
    private static (int min, int max) ApplyMinWidthOverride(int? minWidth, int min, int max)
    {
        if (!minWidth.HasValue) return (min, max);
        var clamped = Math.Min(Math.Max(minWidth.Value, 0), 2000);
        return (clamped, Math.Max(max, clamped));
    }

    // Numeric fields right-align; dates, text, bool, and everything else stay left.
    private static string GetCellAlign(string dataType) => IsNumeric(dataType) ? "text-align: right;" : "";

    // ── Calc column rendering (TC-4) ──────────────────────────────────
    // Memoized projection used by the header + row + MudDataGrid render
    // paths. Built once per state mutation that affects the column set
    // (column order changes, hidden-column toggles, parameter changes
    // — all clear the cache via _renderColumns = null). Without this,
    // the read-only branch called BuildRenderColumns() once for the
    // header AND inside the per-row @foreach, which meant N+1 dictionary
    // builds on every render — measurable cost on a 500-row, 20-column
    // detail view.
    private List<object>? _renderColumns;

    private List<object> RenderColumns => _renderColumns ??= BuildRenderColumns();

    // Width pair for a calc column. Mirrors the type-driven branch in
    // GetColumnWidths(ColumnMeta) but without MaxLength (calc results
    // don't have a declared max).
    // Walks the saved ColumnOrder to interleave regular fields and calc
    // columns. Each entry is either a ColumnMeta (field) or a
    // TableCalcColumnDef (calc) — the foreach dispatches by type. Fields
    // and calcs not covered by the saved order get appended at the end so
    // newly added items show up without losing the user's manual order.
    private List<object> BuildRenderColumns()
    {
        var visibleFields = VisibleColumns.ToList();
        var fieldsById = visibleFields.ToDictionary(c => c.FieldId, StringComparer.OrdinalIgnoreCase);
        var calcs = (CalcColumns ?? new()).Where(c => !string.IsNullOrEmpty(c.Key)).ToList();
        var calcsByKey = calcs.ToDictionary(c => c.Key, StringComparer.OrdinalIgnoreCase);

        var result = new List<object>();
        var seen = new HashSet<string>(StringComparer.OrdinalIgnoreCase);

        // Prefer the live _combinedColumnOrder (mutated by ApplyColumnOrder)
        // over the immutable InitialColumnOrder parameter so chip-bar
        // reorders take effect immediately. Falls back to InitialColumnOrder
        // on the first render before the chip bar has emitted any reorder.
        var orderSource = _combinedColumnOrder ?? InitialColumnOrder;

        if (orderSource is { Count: > 0 })
        {
            foreach (var id in orderSource)
            {
                if (seen.Contains(id)) continue;
                if (fieldsById.TryGetValue(id, out var col))
                {
                    result.Add(col);
                    seen.Add(id);
                }
                else if (calcsByKey.TryGetValue(id, out var calc))
                {
                    result.Add(calc);
                    seen.Add(id);
                }
            }
        }

        // Append anything the saved order didn't cover. Maintain VisibleColumns
        // order for fields and CalcColumns order for calcs so the fallback is
        // deterministic.
        foreach (var col in visibleFields)
        {
            if (seen.Add(col.FieldId)) result.Add(col);
        }
        foreach (var calc in calcs)
        {
            if (seen.Add(calc.Key)) result.Add(calc);
        }

        return result;
    }

    private static (int min, int max) GetCalcColumnWidths(TableCalcColumnDef cc) =>
        (cc.DataType ?? string.Empty).ToLowerInvariant() switch
        {
            "currency" or "money"     => (70, 110),
            "percent"  or "percentage"=> (80, 100),
            "integer"  or "int"       => (35, 70),
            "boolean"                 => (50, 80),
            "date"                    => (90, 110),
            "datetime"                => (130, 170),
            "text"                    => (120, 240),
            _                         => (70, 130)
        };

    // Per-row formatted text for a calc column. Two paths:
    //   * SQL mode: value lives in the row dict under cc.Key (server-side
    //     SELECT result). Numeric values still flow through FormatCalcValue
    //     so percent / currency / etc formats apply; non-numeric values
    //     (strings from CASE expressions, etc.) render verbatim.
    //   * Formula mode: client-side evaluator over [bracket-refs]. NaN /
    //     Infinity (e.g. divide-by-zero on a row with a missing operand)
    //     renders blank so a single broken row doesn't crash the grid.
    private string FormatCalcCell(Dictionary<string, object?> row, TableCalcColumnDef cc)
    {
        if (!string.IsNullOrWhiteSpace(cc.SqlExpression))
        {
            if (!row.TryGetValue(cc.Key, out var raw) || raw is null || raw is DBNull)
                return string.Empty;
            return FormatCalcRaw(cc, raw);
        }
        try
        {
            var val = TleReportingDashboard.Web.Services.CalculatedColumnEvaluator
                .Evaluate(cc.Formula, ident => CalcLookup(row, ident));
            if (double.IsNaN(val) || double.IsInfinity(val)) return string.Empty;
            return FormatCalcValue(cc, val);
        }
        catch (FormatException)
        {
            return string.Empty;
        }
    }

    // Sort-key projector. Returns object? so MudDataGrid can compare both
    // numeric (formula / numeric SQL) and string (text-valued SQL) values
    // without an unsafe double cast. NaN / unresolved values still sort to
    // the bottom regardless of direction.
    private object? CalcSortValue(Dictionary<string, object?> row, TableCalcColumnDef cc)
    {
        if (!string.IsNullOrWhiteSpace(cc.SqlExpression))
        {
            if (!row.TryGetValue(cc.Key, out var raw) || raw is null || raw is DBNull)
                return null;
            return CalcToDouble(raw) is double d ? d : raw.ToString();
        }
        try
        {
            var val = TleReportingDashboard.Web.Services.CalculatedColumnEvaluator
                .Evaluate(cc.Formula, ident => CalcLookup(row, ident));
            return double.IsNaN(val) || double.IsInfinity(val) ? double.MinValue : val;
        }
        catch (FormatException)
        {
            return double.MinValue;
        }
    }

    // Resolves a bracketed identifier in a calc formula against this row.
    // Tries the identifier as a field id first (most stable — survives
    // label rename), then falls back to label match (case-insensitive)
    // for ergonomics. Returns null when the identifier doesn't match
    // anything; CalculatedColumnEvaluator turns null into NaN downstream.
    private double? CalcLookup(Dictionary<string, object?> row, string ident)
    {
        if (row.TryGetValue(ident, out var direct))
            return CalcToDouble(direct);

        if (Data?.Columns is { } cols)
        {
            var col = cols.FirstOrDefault(c => string.Equals(c.Label, ident, StringComparison.OrdinalIgnoreCase));
            if (col is not null && row.TryGetValue(col.FieldId, out var byLabel))
                return CalcToDouble(byLabel);
        }
        return null;
    }

    private static double? CalcToDouble(object? v)
    {
        if (v is null || v is DBNull) return null;
        if (v is double d) return d;
        if (v is decimal dec) return (double)dec;
        if (v is int i) return i;
        if (v is long l) return l;
        if (v is short s) return s;
        if (v is float f) return f;
        if (double.TryParse(v.ToString(), System.Globalization.NumberStyles.Any,
                System.Globalization.CultureInfo.CurrentCulture, out var parsed))
            return parsed;
        return null;
    }

    private static string FormatCalcValue(TableCalcColumnDef cc, double val)
    {
        var format = cc.Format;
        if (string.IsNullOrWhiteSpace(format))
        {
            format = (cc.DataType?.ToLowerInvariant()) switch
            {
                "percent"  => "N1",
                "currency" => "C2",
                "integer"  => "N0",
                _          => "N2"
            };
        }
        return val.ToString(format, System.Globalization.CultureInfo.CurrentCulture);
    }

    // Handles non-numeric SQL-mode calc results. Branches by DataType:
    //   text / boolean → ToString (boolean coerces 0/1/true/false to Yes/No)
    //   date / datetime → DateTime parse + .NET format string (cc.Format
    //                     overrides the default).
    //   numeric (anything else parseable as a number) → FormatCalcValue
    //                     so currency/percent/integer/decimal land on the
    //                     same per-type defaults they used in formula mode.
    private static string FormatCalcRaw(TableCalcColumnDef cc, object raw)
    {
        var dt = (cc.DataType ?? string.Empty).ToLowerInvariant();
        var culture = System.Globalization.CultureInfo.CurrentCulture;

        if (dt == "boolean")
        {
            return CoerceBool(raw) is bool b
                ? (b ? "Yes" : "No")
                : (raw.ToString() ?? string.Empty);
        }
        if (dt is "date" or "datetime")
        {
            if (raw is DateTime d
                || (raw is string ds && DateTime.TryParse(ds, culture,
                        System.Globalization.DateTimeStyles.None, out d)))
            {
                var fmt = string.IsNullOrWhiteSpace(cc.Format)
                    ? (dt == "date" ? "yyyy-MM-dd" : "yyyy-MM-dd HH:mm")
                    : cc.Format;
                return d.ToString(fmt, culture);
            }
            return raw.ToString() ?? string.Empty;
        }
        if (dt == "text")
        {
            return raw.ToString() ?? string.Empty;
        }
        // Default / numeric data types — try double, fall back to string.
        var asDouble = CalcToDouble(raw);
        return asDouble is double dd ? FormatCalcValue(cc, dd) : (raw.ToString() ?? string.Empty);
    }

    private static bool? CoerceBool(object? v) => v switch
    {
        bool b => b,
        int i => i != 0,
        long l => l != 0,
        short s => s != 0,
        string str when bool.TryParse(str, out var b) => b,
        string str when str == "1" => true,
        string str when str == "0" => false,
        _ => null
    };

    private static bool IsNumeric(string dataType) => dataType.ToLowerInvariant() switch
    {
        "currency" or "money" or "smallmoney" => true,
        "percent" or "percentage" => true,
        "integer" or "int" or "bigint" or "smallint" or "tinyint" => true,
        "decimal" or "float" or "double" or "numeric" or "real" or "number" => true,
        _ => false
    };


    protected override void OnParametersSet()
    {
        // Seed initial page size from the caller's preference, exactly once.
        if (!_initialPageSizeApplied && InitialPageSize is int size && size > 0)
        {
            _pageSize = size;
            _initialPageSizeApplied = true;
        }

        // Restore saved column widths on first load
        if (!_widthsLoaded && InitialColumnWidths is not null && InitialColumnWidths.Count > 0)
        {
            _customWidths = new Dictionary<string, int>(InitialColumnWidths);
            _widthsLoaded = true;
        }

        // Restore saved hidden columns on first load
        if (!_hiddenLoaded && InitialHiddenColumns is not null && InitialHiddenColumns.Count > 0)
        {
            _hiddenColumns = new HashSet<string>(InitialHiddenColumns, StringComparer.OrdinalIgnoreCase);
            _hiddenLoaded = true;
        }

        if (Data?.Columns is not null && Data.Columns.Count > 0)
        {
            // First-time seed from the saved column order, if provided
            if (!_orderLoaded && InitialColumnOrder is not null && InitialColumnOrder.Count > 0)
            {
                var byId = Data.Columns.ToDictionary(c => c.FieldId, StringComparer.OrdinalIgnoreCase);
                _columnOrder.Clear();
                foreach (var fid in InitialColumnOrder)
                {
                    if (byId.TryGetValue(fid, out var col))
                        _columnOrder.Add(col);
                }
                // Append any columns not in the saved order (e.g. fields added since the report was last saved)
                foreach (var col in Data.Columns)
                {
                    if (!_columnOrder.Any(c => c.FieldId.Equals(col.FieldId, StringComparison.OrdinalIgnoreCase)))
                        _columnOrder.Add(col);
                }
                // Seed the live combined order (mixed field ids + calc keys)
                // so BuildRenderColumns has the saved interleaving from the
                // first render — without this, the first render falls back
                // to InitialColumnOrder anyway, but keeping the two in sync
                // means later resets via ApplyColumnOrder behave consistently.
                _combinedColumnOrder = new List<string>(InitialColumnOrder);
                _orderLoaded = true;
            }
            else
            {
                // Preserve existing order for columns that still exist, append new ones
                var existingIds = new HashSet<string>(_columnOrder.Select(c => c.FieldId));
                var newIds = new HashSet<string>(Data.Columns.Select(c => c.FieldId));

                // Remove columns no longer in data
                _columnOrder.RemoveAll(c => !newIds.Contains(c.FieldId));

                // Add new columns at the end
                foreach (var col in Data.Columns)
                {
                    if (!existingIds.Contains(col.FieldId))
                    {
                        _columnOrder.Add(col);
                    }
                }
                _orderLoaded = true;
            }
        }

        // Parameters could have shifted any of the inputs to BuildRenderColumns
        // (Data, InitialColumnOrder, CalcColumns, AlwaysHiddenColumns, etc.).
        // Drop the memoized cache so the next render rebuilds against the
        // fresh inputs. Cheap — just nulls a reference.
        _renderColumns = null;
    }

    // Used as @key on the data grid wrapper so the grid remounts when the column
    // sequence changes. Without this, MudDataGrid keeps its internally registered
    // column order and the table headers don't reorder even though _columnOrder did.
    // Includes the combined order so calc-column moves (which don't touch
    // _columnOrder) also force a remount.
    private string ColumnOrderKey
    {
        get
        {
            var fields = string.Join("|", _columnOrder.Select(c => c.FieldId));
            var combined = _combinedColumnOrder is null
                ? string.Empty
                : string.Join("|", _combinedColumnOrder);
            return $"{fields}::{combined}";
        }
    }

    private IEnumerable<ColumnMeta> VisibleColumns =>
        _columnOrder.Where(c => !_hiddenColumns.Contains(c.FieldId)
                             && !(AlwaysHiddenColumns?.Contains(c.FieldId, StringComparer.OrdinalIgnoreCase) ?? false)
                             // Double-underscore prefix reserves column ids for
                             // internal use (e.g. "__row_count" from server-side
                             // aggregation). Never show them to the user.
                             && !c.FieldId.StartsWith("__", StringComparison.Ordinal));

    private async Task ToggleColumnVisibility(string fieldId)
    {
        if (!_hiddenColumns.Remove(fieldId))
        {
            _hiddenColumns.Add(fieldId);
        }

        // Hidden-set change affects VisibleColumns → invalidate the
        // RenderColumns memo so the next render rebuilds.
        _renderColumns = null;

        if (OnHiddenColumnsChanged.HasDelegate)
            await OnHiddenColumnsChanged.InvokeAsync(_hiddenColumns.ToList());
    }

    public List<string> GetHiddenColumns() => _hiddenColumns.ToList();

    /// <summary>
    /// Toggle a column's visibility from outside the grid (e.g. from the FieldPicker
    /// when the report is locked to a template). Mirrors the in-grid menu behavior:
    /// updates internal state, emits OnHiddenColumnsChanged, and re-renders.
    /// </summary>
    public async Task ToggleColumnVisibilityExternal(string fieldId)
    {
        await ToggleColumnVisibility(fieldId);
        StateHasChanged();
    }

    /// <summary>
    /// Reorders the grid's columns to match the supplied field-id list.
    /// Called from the field chip bar above the grid (the new reorder surface).
    /// </summary>
    public void ApplyColumnOrder(List<string> fieldIds)
    {
        if (fieldIds is null || fieldIds.Count == 0) return;

        var byId = _columnOrder.ToDictionary(c => c.FieldId, c => c, StringComparer.OrdinalIgnoreCase);
        var reordered = new List<ColumnMeta>(fieldIds.Count);
        foreach (var id in fieldIds)
        {
            if (byId.TryGetValue(id, out var col)) reordered.Add(col);
        }
        // Preserve any columns the caller didn't mention (e.g. a column that
        // exists in the data but not in the chip bar for some reason).
        foreach (var col in _columnOrder)
        {
            if (!fieldIds.Contains(col.FieldId, StringComparer.OrdinalIgnoreCase))
                reordered.Add(col);
        }

        if (reordered.Count == 0) return;
        // ColumnOrderKey is derived from _columnOrder sequence, so assigning a
        // new list here is enough to re-key the MudDataGrid and force a header
        // reorder.
        _columnOrder = reordered;
        // Mirror the unified order (which may include calc keys) so
        // BuildRenderColumns sees the new positions immediately. Without
        // this the grid would only update on the next query re-run because
        // BuildRenderColumns reads from InitialColumnOrder otherwise.
        _combinedColumnOrder = new List<string>(fieldIds);
        // Order mutation → invalidate the RenderColumns memo so the next
        // render reflects the new interleave.
        _renderColumns = null;
        StateHasChanged();
    }

    public List<string> GetCurrentColumnOrder() =>
        _columnOrder.Select(c => c.FieldId).ToList();

    // TEMP DIAGNOSTIC — inspects the rendered columns so the caller can see
    // which column properties actually round-trip from Razor to the live
    // Column instance. Remove once multi-sort persistence is verified.
    public string DumpColumnDiagnostics()
    {
        if (_mudGrid?.RenderedColumns is null) return "(no rendered cols)";
        var cols = _mudGrid.RenderedColumns;
        var samples = cols.Take(3)
            .Select(c => $"[id={c.Identifier?[..8]} title='{c.Title}' prop='{c.PropertyName}']")
            .ToList();
        return $"{cols.Count} cols; " + string.Join(" ", samples);
    }

    private async Task OnPageSizeChanged(int newSize)
    {
        _pageSize = newSize;
        if (OnPageSizeChangedCallback.HasDelegate)
            await OnPageSizeChangedCallback.InvokeAsync(newSize);
    }

    // Page-size change from the read-only table's own pager. Resets to page 1
    // so the user doesn't land on an empty page after shrinking the view.
    private async Task OnReadOnlyPageSizeChanged(int newSize)
    {
        _pageSize = newSize;
        _readOnlyPage = 1;
        if (OnPageSizeChangedCallback.HasDelegate)
            await OnPageSizeChangedCallback.InvokeAsync(newSize);
    }

    // Rows to render in the read-only table for the currently selected page.
    private IEnumerable<Dictionary<string, object?>> PagedSortedRows =>
        SortedRows.Skip((_readOnlyPage - 1) * _pageSize).Take(_pageSize);

    // Height MudDataGrid should use given the current mode:
    //   • not-fill:                 600px (pre-existing behavior)
    //   • fill + JS has measured:   exact pixel value from the measurer
    //   • fill + JS hasn't run yet: CSS calc() fallback so the first paint
    //                               isn't a squashed 0-height grid
    //
    // The grid always fills the viewport when FillViewport is true. If the
    // user picks a page size larger than what fits, the grid scrolls its
    // body internally and the "Showing xx rows" footer stays visible.
    private string? GetGridHeight()
    {
        if (!FillViewport) return "600px";
        return _fillPx.HasValue ? $"{_fillPx.Value}px" : "calc(100vh - 250px)";
    }

    private string GetRowCountText()
    {
        if (Data is null) return string.Empty;

        var totalRows = Data.Rows.Count;
        var totalCount = Data.TotalCount > 0 ? Data.TotalCount : totalRows;

        if (IsTruncated || Data.IsTruncated)
        {
            return $"Showing {totalRows:N0} of {totalCount:N0} rows (results truncated)";
        }

        return $"Showing {totalRows:N0} rows";
    }

    private IEnumerable<Dictionary<string, object?>> SortedRows
    {
        get
        {
            if (Data is null) return [];

            // DisableUserSort path: the grid headers aren't clickable, so we
            // must apply InitialSort ourselves by chaining OrderBy/ThenBy.
            // Falls back to the legacy DefaultSortField pre-sort below if
            // InitialSort is empty.
            if (DisableUserSort && InitialSort is { Count: > 0 })
            {
                IOrderedEnumerable<Dictionary<string, object?>>? ordered = null;
                foreach (var (fieldId, dir) in InitialSort)
                {
                    var col = Data.Columns.FirstOrDefault(c =>
                        string.Equals(c.FieldId, fieldId, StringComparison.OrdinalIgnoreCase));
                    if (col is null) continue;
                    Func<Dictionary<string, object?>, object?> keyFn = r => GetSortValue(r, col);
                    var desc = string.Equals(dir, "desc", StringComparison.OrdinalIgnoreCase);
                    ordered = ordered is null
                        ? (desc ? Data.Rows.OrderByDescending(keyFn) : Data.Rows.OrderBy(keyFn))
                        : (desc ? ordered.ThenByDescending(keyFn) : ordered.ThenBy(keyFn));
                }
                if (ordered is not null) return ordered;
            }

            if (string.IsNullOrEmpty(DefaultSortField)) return Data.Rows;

            var legacyCol = Data.Columns.FirstOrDefault(c => c.FieldId == DefaultSortField);
            if (legacyCol is null) return Data.Rows;

            Func<Dictionary<string, object?>, object?> legacyKey = r => GetSortValue(r, legacyCol);
            return string.Equals(DefaultSortDirection, "desc", StringComparison.OrdinalIgnoreCase)
                ? Data.Rows.OrderByDescending(legacyKey)
                : Data.Rows.OrderBy(legacyKey);
        }
    }

    private object? GetSortValue(Dictionary<string, object?> row, ColumnMeta col)
    {
        if (!row.TryGetValue(col.FieldId, out var val) || val is null) return null;

        // If this column has a custom value sort order map, use it
        if (col.ValueSortOrder is not null)
        {
            var key = val.ToString() ?? "";
            return col.ValueSortOrder.TryGetValue(key, out var rank) ? rank : int.MaxValue;
        }
        return val;
    }

    private string FormatValue(Dictionary<string, object?> row, ColumnMeta col)
    {
        if (!row.TryGetValue(col.FieldId, out var val) || val is null)
            return string.Empty;

        // Per-field Format (mask or .NET format string) wins over the DataType
        // default when set — lets admins override phone/SSN/currency display.
        if (!string.IsNullOrWhiteSpace(col.Format))
            return TleReportingDashboard.Web.Services.FieldFormatter.Format(val, col.Format, col.DataType);

        return col.DataType.ToLowerInvariant() switch
        {
            "currency" or "money" => FormatNumeric(val, "C2"),
            "percent" or "percentage" => FormatNumeric(val, "N3") + "%",
            "date" => FormatDate(val, "MM/dd/yyyy"),
            "datetime" => FormatDate(val, "MM/dd/yyyy HH:mm"),
            "integer" or "int" => FormatNumeric(val, "N0"),
            "decimal" or "float" or "double" or "numeric" => FormatNumeric(val, "N2"),
            _ => val.ToString() ?? string.Empty
        };
    }

    private static string FormatNumeric(object val, string format)
    {
        if (val is double d) return d.ToString(format);
        if (val is decimal dec) return dec.ToString(format);
        if (val is int i) return i.ToString(format);
        if (val is long l) return l.ToString(format);
        if (double.TryParse(val.ToString(), out var parsed)) return parsed.ToString(format);
        return val.ToString() ?? string.Empty;
    }

    private static string FormatDate(object val, string format)
    {
        if (val is DateTime dt) return dt.ToString(format);
        if (val is DateTimeOffset dto) return dto.ToString(format);
        if (DateTime.TryParse(val.ToString(), out var parsed)) return parsed.ToString(format);
        return val.ToString() ?? string.Empty;
    }
}
