@inject IDialogService DialogService

@* Add/edit dialog for the connection's table-alias catalog. The dialog's
   Result.Data is a (TableName, Alias) tuple returned as TableAliasEditDialog.EditResult;
   the caller persists via ICustomPrimaryTableService.

   Dirty-tracked: edits to any of the user-editable fields vs. the initial
   snapshot trigger the unsaved-changes prompt on any non-explicit dismiss.
   Callers must open this dialog with DialogOptions { BackdropClick = false,
   CloseOnEscapeKey = false } so backdrop / Esc routes through TryCancelAsync
   rather than firing MudDialog's default cancel directly. *@
<MudDialog>
    <DialogContent>
        <MudStack Spacing="2" Style="min-width: 420px;">
            @* "Virtual" toggle — flips the table picker between strict
               DB-enumerated mode (default) and free-form text. Use it for
               CTE-backed primaries that don't exist in INFORMATION_SCHEMA
               (e.g. a Lookup CTE alias used as the report's primary). The
               name still passes through PrimaryTableRef.TableRegex on save
               so admins can't smuggle SQL meta-characters in. *@
            <MudCheckBox T="bool" @bind-Value="_isVirtual" Color="Color.Primary" Dense
                         Label="Virtual table (CTE / Lookup, not in DB)" />
            <MudText Typo="Typo.caption" Color="Color.Secondary" Style="margin-left: 32px; margin-top: -8px;">
                Check this if the table doesn't exist in the live database — typical when a Lookup CTE materializes the rows at query time.
            </MudText>

            @if (_isVirtual)
            {
                @* Free-form entry. Same identifier validation runs on save —
                   `^[A-Za-z_][A-Za-z0-9_\.\[\]]*$`, no spaces or SQL meta. *@
                <MudTextField T="string" @bind-Value="_tableName"
                              Label="Virtual table name"
                              Placeholder="ranked_calls"
                              Required RequiredError="Table is required"
                              Variant="Variant.Outlined" Margin="Margin.Dense" Immediate
                              HelperText="Identifier admin chooses; must match the CTE name in the Lookup that defines it." />
            }
            else
            {
                @* Autocomplete over the DB-enumerated table list. SearchFunc
                   substring-matches case-insensitively so admins can type
                   "borr" to narrow to borrower tables. Strict=true prevents
                   freeform entry — only list values are accepted. When editing
                   a row whose table is no longer in the DB (rename/drop), the
                   stale value is injected into the list so it stays editable.
                   MaxItems=null → uncapped list, limited only by the DB result
                   count and MudAutocomplete's own scrollable popover. *@
                <MudAutocomplete T="string" @bind-Value="_tableName"
                                 Label="Schema.Table"
                                 SearchFunc="SearchTables"
                                 Strict="true" CoerceValue="false"
                                 Required RequiredError="Table is required"
                                 Variant="Variant.Outlined" Margin="Margin.Dense"
                                 Dense Immediate
                                 MaxItems="null"
                                 HelperText="@TableHelperText" />
            }
            @* Bound to the Alias property (not the backing field) so every
               keystroke routes through the lowercase normalizer. The user
               sees what gets saved while typing — no confusing "I typed
               uppercase but it saved lowercase" surprise. *@
            <MudTextField @bind-Value="Alias" Label="Alias" Placeholder="l"
                          Variant="Variant.Outlined" Margin="Margin.Dense" Immediate
                          Required RequiredError="Alias is required"
                          Error="@IsAliasTaken()"
                          ErrorText="@("Already used on this connection")"
                          HelperText="Required. Short identifier used in field references (e.g. l.ColName). Always saved lowercase." />

            @* Optional free-text description. Shown in the Admin → Table
               Aliases list so other admins can tell at a glance what each
               alias is for ("loan terms — joined from dl via LNKEY",
               "code lookup for milestone status", etc.). Capped at 500
               chars at the service layer; the input doesn't enforce a
               hard cap so admins see exactly what they typed. *@
            <MudTextField T="string" @bind-Value="_description" Label="Description (optional)"
                          Variant="Variant.Outlined" Margin="Margin.Dense"
                          Lines="2"
                          HelperText="What is this alias for? Up to 500 characters." />

            @* Primary curation flags. Eligible-as-primary surfaces the row
               in the Report Builder's "Suggested primaries" group; default
               pre-selects it for new reports. Default implies eligibility
               so the row stays in the Suggested group; unchecking Eligible
               also clears Default automatically. *@
            <MudCheckBox T="bool" @bind-Value="_isPrimary" Color="Color.Primary" Dense
                         Label="Eligible as primary table" />
            <MudText Typo="Typo.caption" Color="Color.Secondary" Style="margin-left: 32px; margin-top: -8px;">
                When on, appears in the Report Builder's "Suggested primaries" group.
            </MudText>
            <MudCheckBox T="bool" @bind-Value="_isDefaultPrimary" Color="Color.Primary" Dense
                         Disabled="@(!_isPrimary)"
                         Label="Default primary for this connection" />
            <MudText Typo="Typo.caption" Color="Color.Secondary" Style="margin-left: 32px; margin-top: -8px;">
                New reports on this connection start with this primary. Only one row per connection can be the default — saving here will clear any prior default.
            </MudText>

            @* Entity classification + key columns. Optional metadata that
               describes how this table is keyed — feature consumers (drill-
               down lookups, distinct-on emitters, etc.) read it later. The
               type is open-ended at the DB layer so future LOS adapters can
               register their own values without a schema change. *@
            <MudDivider />
            <MudText Typo="Typo.subtitle2" Style="font-weight: 600;">
                Entity classification (optional)
            </MudText>
            <MudSelect T="string?" @bind-Value="_tableType" Label="Table Type"
                       Variant="Variant.Outlined" Margin="Margin.Dense" Dense Clearable
                       HelperText="@TableTypeHelperText">
                <MudSelectItem T="string?" Value="@((string?)null)">(unknown)</MudSelectItem>
                @foreach (var t in TableTypes.All)
                {
                    <MudSelectItem T="string?" Value="@((string?)t)">@TableTypes.Display(t)</MudSelectItem>
                }
            </MudSelect>
            <MudTextField @bind-Value="_primaryColumn" Label="Primary Column"
                          Variant="Variant.Outlined" Margin="Margin.Dense"
                          Placeholder="@PrimaryColumnPlaceholder"
                          HelperText="The column that identifies the entity (first part of the compound key). Letters, digits, and underscores only." />
            <MudTextField @bind-Value="_additionalKeyColumns" Label="Additional Key Columns"
                          Variant="Variant.Outlined" Margin="Margin.Dense"
                          Placeholder="@AdditionalKeysPlaceholder"
                          HelperText="@AdditionalKeysHelperText" />

            @* Role-scoped owner fields — the column that identifies "who
               owns a row" varies by role (Loan Officer → loan_officer_id,
               Processor → processor_id, etc). Each row below maps one
               self-scoped role to the owner field used for its queries.
               A role with no row here → self-scoped users in that role see
               zero rows on this primary. Admins bypass scoping entirely
               regardless of what's configured here. *@
            @if (IsNew)
            {
                <MudAlert Severity="Severity.Info" Dense Variant="Variant.Outlined">
                    Save the primary first, then edit it to configure role-scoped owner fields.
                </MudAlert>
            }
            else
            {
                <MudText Typo="Typo.subtitle2" Style="font-weight: 600; margin-top: 8px;">
                    Role-scoped owner fields
                </MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    Map each self-scoped role to the field whose column identifies the row's owner. Roles without a mapping return zero rows for self-scoped users.
                </MudText>

                @if (_roleOwners.Count > 0)
                {
                    <MudTable Items="_roleOwners" Dense Class="pa-0" T="RoleOwnerRow">
                        <HeaderContent>
                            <MudTh>Role</MudTh>
                            <MudTh>Owner field</MudTh>
                            <MudTh Style="width: 60px;"></MudTh>
                        </HeaderContent>
                        <RowTemplate Context="row">
                            <MudTd>@(AvailableRoles.FirstOrDefault(r => r.Id == row.RoleId)?.Name ?? row.RoleId.ToString())</MudTd>
                            <MudTd>
                                <MudSelect T="string" Value="@row.OwnerFieldId" Dense
                                           Variant="Variant.Outlined" Margin="Margin.Dense"
                                           ValueChanged="@(v => UpdateRoleOwnerField(row, v))">
                                    @foreach (var f in AvailableFields)
                                    {
                                        <MudSelectItem T="string" Value="@f.Id">@f.Label</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudTd>
                            <MudTd Style="text-align: right;">
                                <MudTooltip Text="Remove role mapping">
                                    <MudIconButton Icon="@Icons.Material.Outlined.Delete" Size="Size.Small"
                                                   Color="Color.Error"
                                                   OnClick="@(() => RemoveRoleOwner(row))" />
                                </MudTooltip>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                }

                @* Add-row form. Only offers roles not already mapped +
                   roles with scope_rule = 'self' (an 'all' role would
                   never consult this table, and Administrator is forced
                   to 'all' on the server). *@
                <MudStack Row AlignItems="AlignItems.End" Spacing="2" Wrap="Wrap.Wrap">
                    <MudSelect T="Guid?" @bind-Value="_newRoleId" Label="Role"
                               Variant="Variant.Outlined" Margin="Margin.Dense"
                               Style="min-width: 180px;">
                        @foreach (var r in AvailableRolesForAdd())
                        {
                            <MudSelectItem T="Guid?" Value="@((Guid?)r.Id)">@r.Name</MudSelectItem>
                        }
                    </MudSelect>
                    <MudSelect T="string?" @bind-Value="_newFieldId" Label="Owner field"
                               Variant="Variant.Outlined" Margin="Margin.Dense"
                               Style="min-width: 220px;">
                        @foreach (var f in AvailableFields)
                        {
                            <MudSelectItem T="string?" Value="@f.Id">@f.Label</MudSelectItem>
                        }
                    </MudSelect>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                               StartIcon="@Icons.Material.Outlined.Add"
                               Disabled="@(_newRoleId is null || string.IsNullOrEmpty(_newFieldId))"
                               OnClick="AddRoleOwner">
                        Add
                    </MudButton>
                </MudStack>
            }

            @if (!string.IsNullOrEmpty(_validationError))
            {
                <MudAlert Severity="Severity.Error" Dense>@_validationError</MudAlert>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="TryCancelAsync">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   OnClick="Submit" Disabled="@(!CanSubmit())">
            @(IsNew ? "Add" : "Save")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public string? InitialTableName { get; set; }
    [Parameter] public string? InitialAlias { get; set; }
    [Parameter] public bool InitialIsPrimary { get; set; }
    [Parameter] public bool InitialIsDefaultPrimary { get; set; }
    [Parameter] public bool IsNew { get; set; } = true;

    // Entity-classification metadata. All optional. Null on InitialTableType
    // means "unclassified"; the dropdown shows "(unknown)" and the column
    // fields render empty. Caller passes through from CustomPrimaryTableRecord.
    [Parameter] public string? InitialTableType { get; set; }
    [Parameter] public string? InitialPrimaryColumn { get; set; }
    [Parameter] public string? InitialAdditionalKeyColumns { get; set; }
    // Optional free-text description; persisted to the description column.
    [Parameter] public string? InitialDescription { get; set; }

    // DB-enumerated tables ("schema.table" strings). Caller (AdminTableAliasesTab)
    // fetches via SchemaBuilderService.GetTablesAsync and passes in.
    [Parameter] public List<string> AvailableTables { get; set; } = new();

    // Existing non-empty aliases on this connection (except the one currently
    // being edited). Used to flag duplicates inline so the admin doesn't hit
    // the service-level guard after clicking Save.
    [Parameter] public HashSet<string> TakenAliases { get; set; } = new(StringComparer.OrdinalIgnoreCase);

    // Schema-config fields the admin can pick as the owner field. Caller
    // sources from the current company's schema config so the list reflects
    // what was already declared in the Schema Builder.
    [Parameter] public List<FieldOption> AvailableFields { get; set; } = new();

    // Self-scoped roles the admin can map. Caller filters to roles with
    // scope_rule = 'self' (other roles would never read the mapping).
    [Parameter] public List<RoleOption> AvailableRoles { get; set; } = new();

    // Initial role → owner field map for edit mode. New dialog gets an
    // empty list. Changes are committed directly via OnRoleOwnerSet /
    // OnRoleOwnerCleared callbacks so the admin sees persistence as soon
    // as they add a row (matches the "companies" dialog pattern).
    [Parameter] public List<RoleOwnerRow> InitialRoleOwners { get; set; } = new();
    [Parameter] public EventCallback<(Guid RoleId, string OwnerFieldId)> OnRoleOwnerSet { get; set; }
    [Parameter] public EventCallback<Guid> OnRoleOwnerCleared { get; set; }

    public record EditResult(
        string TableName,
        string? Alias,
        bool IsPrimary,
        bool IsDefaultPrimary,
        string? TableType = null,
        string? PrimaryColumn = null,
        string? AdditionalKeyColumns = null,
        string? Description = null);
    public record FieldOption(string Id, string Label);
    public record RoleOption(Guid Id, string Name);
    public record RoleOwnerRow(Guid RoleId, string OwnerFieldId)
    {
        // Mutable field id so the dropdown can bind — the record wraps an
        // initial value but callers mutate and we emit via callback.
        public string OwnerFieldId { get; set; } = OwnerFieldId;
    }

    private string? _tableName;
    private string? _alias;
    // Lowercase-normalizing facade. MudTextField binds here so the visible
    // value updates as the user types; the underlying _alias storage always
    // holds the lowercased form. Empty/null pass through unchanged.
    private string? Alias
    {
        get => _alias;
        set => _alias = string.IsNullOrEmpty(value) ? value : value.ToLowerInvariant();
    }
    private bool _isPrimary;
    private bool _isDefaultPrimary;
    // True when the admin is registering a CTE/Lookup-backed virtual primary
    // (table won't appear in INFORMATION_SCHEMA, so the autocomplete can't
    // see it). Toggling on swaps the picker for a free-form text field.
    // Not persisted — derived on edit by checking whether InitialTableName
    // is missing from AvailableTables.
    private bool _isVirtual;
    private string? _validationError;
    private List<string> _effectiveTables = new();
    private List<RoleOwnerRow> _roleOwners = new();
    private Guid? _newRoleId;
    private string? _newFieldId;

    // Entity-classification state. _tableType is bound to the Table Type
    // dropdown; the two text fields are free-form column names that get
    // validated server-side on save (alias regex). Helper-text placeholders
    // adapt to the chosen type so admins see the right convention example.
    private string? _tableType;
    private string? _primaryColumn;
    private string? _additionalKeyColumns;
    // Free-text note about what this alias is for. Optional. Bound to the
    // Description input above; trimmed and capped at the service layer.
    private string? _description;

    // Snapshot of the user-editable state captured at OnInitialized so the
    // unsaved-changes prompt can compare current values against it. Role-owner
    // rows are committed live via callbacks (persisted on add / change /
    // remove) so they're intentionally excluded from this snapshot — the
    // pending-state question only covers the in-dialog edits that haven't
    // been saved yet.
    private record FormSnapshot(
        string? TableName,
        string? Alias,
        bool IsPrimary,
        bool IsDefaultPrimary,
        bool IsVirtual,
        string? TableType,
        string? PrimaryColumn,
        string? AdditionalKeyColumns,
        string? Description);
    private FormSnapshot _initialSnapshot = default!;

    private static string Norm(string? s) => (s ?? string.Empty).Trim();

    private string TableTypeHelperText => _tableType switch
    {
        TableTypes.LoanSingle       => "One row per loan (e.g. one main key column).",
        TableTypes.LoanMultiple     => "Many rows per loan, indexed by an additional key.",
        TableTypes.BorrowerSingle   => "One row per borrower per loan (loan key + borrower key).",
        TableTypes.BorrowerMultiple => "Many rows per borrower per loan (loan + borrower + index).",
        _                           => "Optional. Classify how this table is keyed."
    };

    private string PrimaryColumnPlaceholder => _tableType switch
    {
        TableTypes.LoanSingle       or TableTypes.LoanMultiple
            or TableTypes.BorrowerSingle or TableTypes.BorrowerMultiple => "LNKEY",
        _                                                               => "id"
    };

    private string AdditionalKeysPlaceholder => _tableType switch
    {
        TableTypes.LoanSingle       => "(none)",
        TableTypes.LoanMultiple     => "IDX",
        TableTypes.BorrowerSingle   => "WHICHBORR",
        TableTypes.BorrowerMultiple => "WHICHBORR, IDX",
        _                           => ""
    };

    private string AdditionalKeysHelperText => _tableType switch
    {
        TableTypes.LoanSingle       => "Leave blank — Primary Column alone is unique.",
        TableTypes.LoanMultiple     => "Comma-separated. Typically just \"IDX\".",
        TableTypes.BorrowerSingle   => "Comma-separated. Typically just \"WHICHBORR\".",
        TableTypes.BorrowerMultiple => "Comma-separated, e.g. \"WHICHBORR, IDX\".",
        _                           => "Comma-separated extra key columns (optional)."
    };

    private string TableHelperText =>
        _effectiveTables.Count == 0
            ? "No tables could be listed from the database. Check the connection."
            : $"Pick from {_effectiveTables.Count:N0} tables enumerated from the database.";

    protected override void OnInitialized()
    {
        _tableName = InitialTableName;
        // Route through the property setter so a legacy uppercase alias
        // pulled from the DB is normalized the moment the edit dialog opens.
        Alias = InitialAlias;
        // Default implies Eligible; coerce on load so the dialog never shows
        // a contradictory state (default-on + eligible-off).
        _isPrimary = InitialIsPrimary || InitialIsDefaultPrimary;
        _isDefaultPrimary = InitialIsDefaultPrimary;
        _tableType = InitialTableType;
        _primaryColumn = InitialPrimaryColumn;
        _additionalKeyColumns = InitialAdditionalKeyColumns;
        _description = InitialDescription;
        _roleOwners = InitialRoleOwners.Select(r => new RoleOwnerRow(r.RoleId, r.OwnerFieldId)).ToList();

        // Copy the caller's list and ensure the current value is present so a
        // stale saved entry stays editable even if the underlying table is
        // gone from the DB (renamed/dropped since the row was saved).
        _effectiveTables = new List<string>(AvailableTables);
        if (!string.IsNullOrWhiteSpace(InitialTableName)
            && !_effectiveTables.Contains(InitialTableName, StringComparer.OrdinalIgnoreCase))
        {
            _effectiveTables.Insert(0, InitialTableName);
        }

        // Auto-detect virtual-table editing: an existing row whose name isn't
        // in the live DB list is presumed virtual (CTE-backed). Lets the
        // admin re-open and edit the row without re-checking the box.
        if (!IsNew
            && !string.IsNullOrWhiteSpace(InitialTableName)
            && !AvailableTables.Contains(InitialTableName, StringComparer.OrdinalIgnoreCase))
        {
            _isVirtual = true;
        }

        // Snapshot AFTER all initial-state coercions (default→eligible, virtual
        // auto-detect) so the comparison reflects what the user actually sees.
        _initialSnapshot = new FormSnapshot(
            _tableName, _alias, _isPrimary, _isDefaultPrimary, _isVirtual,
            _tableType, _primaryColumn, _additionalKeyColumns, _description);
    }

    private bool IsDirty
    {
        get
        {
            var s = _initialSnapshot;
            return !string.Equals(Norm(_tableName), Norm(s.TableName), StringComparison.Ordinal)
                || !string.Equals(Norm(_alias), Norm(s.Alias), StringComparison.Ordinal)
                || _isPrimary != s.IsPrimary
                || _isDefaultPrimary != s.IsDefaultPrimary
                || _isVirtual != s.IsVirtual
                || !string.Equals(Norm(_tableType), Norm(s.TableType), StringComparison.Ordinal)
                || !string.Equals(Norm(_primaryColumn), Norm(s.PrimaryColumn), StringComparison.Ordinal)
                || !string.Equals(Norm(_additionalKeyColumns), Norm(s.AdditionalKeyColumns), StringComparison.Ordinal)
                || !string.Equals(Norm(_description), Norm(s.Description), StringComparison.Ordinal);
        }
    }

    private Task<IEnumerable<string>> SearchTables(string? value, CancellationToken ct)
    {
        IEnumerable<string> matches = string.IsNullOrWhiteSpace(value)
            ? _effectiveTables
            : _effectiveTables.Where(t => t.Contains(value, StringComparison.OrdinalIgnoreCase));
        return Task.FromResult(matches);
    }

    private bool CanSubmit()
    {
        if (string.IsNullOrWhiteSpace(_tableName)) return false;
        if (!TleReportingDashboard.Web.Services.PrimaryTableRef.TableRegex().IsMatch(_tableName.Trim())) return false;
        var alias = _alias?.Trim() ?? string.Empty;
        // Alias is required — every catalog row needs one so field/join
        // references unambiguously identify their target.
        if (alias.Length == 0) return false;
        if (!TleReportingDashboard.Web.Services.PrimaryTableRef.AliasRegex().IsMatch(alias)) return false;
        if (IsAliasTaken()) return false;
        return true;
    }

    // True when the currently-typed alias is non-empty and already claimed
    // by another row on the same connection. Excludes the current row's
    // alias (caller strips it from TakenAliases before passing in).
    private bool IsAliasTaken()
    {
        var alias = _alias?.Trim() ?? string.Empty;
        if (alias.Length == 0) return false;
        return TakenAliases.Contains(alias);
    }

    private void Submit()
    {
        _validationError = null;
        if (!CanSubmit())
        {
            _validationError = "Table and alias are both required and must be valid identifiers.";
            return;
        }
        // Coerce: Default without Eligible is nonsensical. The Disabled=""
        // on the checkbox should make this impossible but belt-and-suspenders.
        var isPrimary = _isPrimary || _isDefaultPrimary;
        MudDialog.Close(DialogResult.Ok(new EditResult(
            _tableName!.Trim(),
            _alias!.Trim().ToLowerInvariant(),
            isPrimary,
            _isDefaultPrimary,
            string.IsNullOrWhiteSpace(_tableType) ? null : _tableType!.Trim(),
            string.IsNullOrWhiteSpace(_primaryColumn) ? null : _primaryColumn!.Trim(),
            string.IsNullOrWhiteSpace(_additionalKeyColumns) ? null : _additionalKeyColumns!.Trim(),
            string.IsNullOrWhiteSpace(_description) ? null : _description!.Trim())));
    }

    private void Cancel() => MudDialog.Cancel();

    // Routes every dismiss path (Cancel button, Esc key, backdrop) through
    // the unsaved-changes prompt so an accidental close never silently throws
    // away pending edits. Save runs the standard Submit path (with its own
    // validation gate); DontSave dismisses without saving.
    private async Task TryCancelAsync() =>
        await UnsavedChangesPrompt.TryCancelAsync(DialogService, MudDialog, IsDirty,
            saveAsync: () =>
            {
                if (CanSubmit()) Submit();
                return Task.CompletedTask;
            });

    // ── Role-scoped owner field editors ───────────────────────────────────
    // Each add/remove fires a callback so persistence happens without the
    // admin having to hit Save. The main Save button still persists the
    // primary's name/alias/flags.

    private IEnumerable<RoleOption> AvailableRolesForAdd()
    {
        var taken = _roleOwners.Select(r => r.RoleId).ToHashSet();
        return AvailableRoles.Where(r => !taken.Contains(r.Id));
    }

    private async Task AddRoleOwner()
    {
        if (_newRoleId is null || string.IsNullOrEmpty(_newFieldId)) return;
        _roleOwners.Add(new RoleOwnerRow(_newRoleId.Value, _newFieldId!));
        await OnRoleOwnerSet.InvokeAsync((_newRoleId.Value, _newFieldId!));
        _newRoleId = null;
        _newFieldId = null;
    }

    private async Task UpdateRoleOwnerField(RoleOwnerRow row, string newValue)
    {
        if (string.IsNullOrEmpty(newValue)) return;
        row.OwnerFieldId = newValue;
        await OnRoleOwnerSet.InvokeAsync((row.RoleId, newValue));
    }

    private async Task RemoveRoleOwner(RoleOwnerRow row)
    {
        _roleOwners.Remove(row);
        await OnRoleOwnerCleared.InvokeAsync(row.RoleId);
    }
}
