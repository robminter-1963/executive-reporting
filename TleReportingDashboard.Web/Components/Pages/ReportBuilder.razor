    // Mirrors what the grid shows: drops user-hidden columns (HiddenColumns) and
    // always-hidden aggregate columns (AggregateFieldIds, which the Table view
    // hides because they're only meaningful in Dashboard view). Rows are left
    // untouched — the export loop iterates Columns, so dropped fields never get
    // emitted.
    private QueryResponse BuildExportData(QueryResponse source)
    {
        var hidden = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        if (_currentConfig.HiddenColumns is { Count: > 0 })
            foreach (var id in _currentConfig.HiddenColumns) hidden.Add(id);
        foreach (var id in AggregateFieldIds) hidden.Add(id);

        if (hidden.Count == 0) return source;
        var visibleColumns = source.Columns.Where(c => !hidden.Contains(c.FieldId)).ToList();
        if (visibleColumns.Count == source.Columns.Count) return source;
        return new QueryResponse
        {
            Columns = visibleColumns,
            Rows = source.Rows,
            TotalCount = source.TotalCount
        };
    }

