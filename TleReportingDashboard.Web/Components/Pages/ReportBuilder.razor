    private string? BuildColumnStateJson()
    {
        var state = new Dictionary<string, object?>();

        // Dashboard config
        if (!string.IsNullOrEmpty(_currentConfig.DashboardConfigJson))
        {
            try
            {
                var dash = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, object?>>(_currentConfig.DashboardConfigJson);
                if (dash is not null)
                {
                    foreach (var kvp in dash)
                        state[kvp.Key] = kvp.Value;
                }
            }
            catch { }
        }

        // Column widths
        if (_currentConfig.ColumnWidths is not null && _currentConfig.ColumnWidths.Count > 0)
            state["ColumnWidths"] = _currentConfig.ColumnWidths;

        // Column order (table view) — uses distinct key to avoid colliding with
        // DashboardConfig.ColumnOrder which stores dashboard summary column keys.
        if (_currentConfig.ColumnOrder is not null && _currentConfig.ColumnOrder.Count > 0)
            state["TableColumnOrder"] = _currentConfig.ColumnOrder;

        // Hidden columns
        if (_currentConfig.HiddenColumns is not null && _currentConfig.HiddenColumns.Count > 0)
            state["HiddenColumns"] = _currentConfig.HiddenColumns;

        // Table-view calculated columns. Distinct key from any dashboard
        // calc list (which lives inside DashboardConfigJson) — this slot
        // is evaluated per-row in ReportGrid, not per-group.
        if (_currentConfig.TableCalculatedColumns is { Count: > 0 })
            state["TableCalculatedColumns"] = _currentConfig.TableCalculatedColumns;

        // Custom filter IDs
        if (_currentConfig.CustomFilterIds is not null && _currentConfig.CustomFilterIds.Count > 0)
            state["CustomFilterIds"] = _currentConfig.CustomFilterIds;

        // Multi-column sort — ordered list of {Field, Direction}. Primary first.
        // This is the only sort source new saves emit. The legacy TableSortField
        // / TableSortDirection pair is still read on load for backward compat,
        // but isn't written anymore now that the Default Sort dropdown is gone.
        if (_currentConfig.TableSort is { Count: > 0 })
            state["TableSort"] = _currentConfig.TableSort;

        // Per-report DISTINCT. Only written when true so legacy reports
        // don't get a noisy `"Distinct": false` key on every save.
        if (_currentConfig.Distinct)
            state["Distinct"] = true;

        // Detail-view grouping (drill-down). Direction is persisted even when
        // "none" so the user's pick round-trips exactly.
        if (!string.IsNullOrEmpty(_detailGroupByFieldId))
        {
            state["DetailGroupByFieldId"] = _detailGroupByFieldId;
            state["DetailGroupByDirection"] = _detailGroupByDirection;
        }
        // Detail-view default sort (applied as either primary or secondary
        // ORDER BY by DetailViewer depending on whether group-by is set).
        if (!string.IsNullOrEmpty(_detailSortFieldId))
        {
            state["DetailSortFieldId"] = _detailSortFieldId;
            state["DetailSortDirection"] = _detailSortDirection;
        }
        // Then By tiebreaker — only persisted when both primary Sort By
        // and Then By are populated. The empty case means "no tiebreaker".
        if (!string.IsNullOrEmpty(_detailSortFieldId)
            && !string.IsNullOrEmpty(_detailSortThenByFieldId))
        {
            state["DetailSortThenByFieldId"] = _detailSortThenByFieldId;
            state["DetailSortThenByDirection"] = _detailSortThenByDirection;
        }

        // Advanced (ad-hoc) filters. Only emitted when the feature is on
        // AND the user has defined at least one. Keeps existing reports
        // clean of phantom empty arrays.
        if (_advancedFiltersEnabled && HasAdvancedFilterLeaves(_filterRoot))
            state["AdvancedFilters"] = _filterRoot;

        return state.Count > 0
            ? System.Text.Json.JsonSerializer.Serialize(state)
            : null;
    }

    // ── Show Query ──
    private async Task ShowReportJson()
    {
        // Snapshot the current report state in the same shape the save path
        // emits — covers field ids, filters, ColumnState (column order /
        // hidden / widths / dashboard config / calc columns / sorts),
        // primary table, connection. Lets admins inspect drift without
        // round-tripping through the DB.
        // Capture live edits the same way HandleSave does so the JSON
        // reflects what would actually be persisted right now, not just
        // what's in _currentConfig.
        var dashConfig = _dashboardView?.GetCurrentConfig() ?? _dashboardConfig;
        if (dashConfig is not null)
        {
            if (_extraGroupByFieldIds.Count > 0)
                dashConfig = dashConfig with { ExtraGroupByFieldIds = _extraGroupByFieldIds.ToList() };
            _currentConfig.DashboardConfigJson = System.Text.Json.JsonSerializer.Serialize(dashConfig);
        }
        var widths = _reportGrid?.GetCustomWidths();
        if (widths is not null && widths.Count > 0)
            _currentConfig.ColumnWidths = widths;

        var snapshot = new
        {
            ReportId = _loadedReportId,
            Name = _loadedReportName,
            InternalName = _loadedInternalName,
            ConnectionId = _currentConfig.ConnectionId,
            PrimaryTable = _currentConfig.PrimaryTable,
            GridTemplateId = _linkedTemplateId,
            FieldIds = _selectedFieldIds,
            Filters = _currentConfig.Filters,
            CustomFilterIds = _currentConfig.CustomFilterIds,
            ColumnState = TryParseObject(BuildColumnStateJson())
        };
        var json = System.Text.Json.JsonSerializer.Serialize(snapshot,
            new System.Text.Json.JsonSerializerOptions { WriteIndented = true });

        var parameters = new DialogParameters
        {
            { "Title", string.IsNullOrWhiteSpace(_loadedReportName) ? "Report JSON" : $"Report JSON — {_loadedReportName}" },
            { "Subtitle", _loadedReportId is null ? "Unsaved report — showing the snapshot the next save would persist." : null },
            { "Json", json }
        };
        await DialogService.ShowAsync<JsonViewerDialog>("Report JSON", parameters,
            new DialogOptions { MaxWidth = MaxWidth.Large, FullWidth = true });
    }

    // BuildColumnStateJson returns a JSON string. To get a NESTED object
    // in the snapshot (instead of a stringly-quoted blob), parse it back
    // to a JsonElement so System.Text.Json keeps it as structured JSON
    // when serializing the outer envelope.
    private static System.Text.Json.JsonElement? TryParseObject(string? json)
    {
        if (string.IsNullOrWhiteSpace(json)) return null;
        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(json);
            return doc.RootElement.Clone();
        }
        catch { return null; }
    }

    private async Task ShowQuery()
    {
        if (string.IsNullOrWhiteSpace(_currentConfig.PrimaryTable))
        {
            Snackbar.Add("Primary Table is required. Enter the root table (e.g. salesforce.lead) next to the Connection picker.", Severity.Warning);
            return;
        }

        try
        {
            // Schema lookups must match the report's connection — otherwise
            // Postgres field ids get validated against the TLE schema and
            // the builder rejects them as "unknown fields".
            var cid = _currentConfig.ConnectionId;
            var fieldConfigs = await SchemaService.GetFieldConfigsAsync(cid);
            var joinConfigs = await SchemaService.GetJoinConfigsAsync(cid);
            var customFilters = await SchemaService.GetCustomFiltersAsync(cid);
            var lookups = await SchemaService.GetLookupsAsync(cid);
            var queryFieldIds = BuildEffectiveQueryFieldIds();

            var request = new QueryRequest
            {
                FieldIds = queryFieldIds,
                Filters = new Dictionary<string, object?>(_currentConfig.Filters),
                CustomFilterIds = _currentConfig.CustomFilterIds?.Count > 0 ? new List<string>(_currentConfig.CustomFilterIds) : null,
                AdvancedFilters = _advancedFiltersEnabled && HasAdvancedFilterLeaves(_filterRoot)
                    ? CloneFilterGroup(_filterRoot)
                    : null,
                SortField = ResolveEffectiveSortField(),
                SortDirection = ResolveEffectiveSortDirection(),
                SecondarySortField = ResolveEffectiveSecondarySortField(),
                SecondarySortDirection = ResolveEffectiveSecondarySortDirection(),
                DisableDefaultSort = ResolveDisableDefaultSort(),
                Distinct = _currentConfig.Distinct,
                // Mirror HandleRunQuery: ship the primary table's PKs so the
                // Show Query preview matches what'll actually execute when
                // the admin picked "(None)".
                FallbackSortColumns = _primaryTablePkColumns.Count > 0
                    ? new List<string>(_primaryTablePkColumns)
                    : null,
                Page = 1,
                PageSize = 50000,
                ConnectionId = _currentConfig.ConnectionId,
                PrimaryTable = _currentConfig.PrimaryTable,
                GroupByFieldIds = _currentConfig.GroupByFieldIds,
                // Per-report SQL calc columns. Filtered to non-aggregating
                // queries inside QueryBuilder; safe to always include here.
                TableCalcSqlColumns = BuildTableCalcSqlSelectors()
            };
            request.Scoping = await ScopeResolver.ResolveAsync(_userEmail, _currentConfig.ConnectionId, _currentConfig.PrimaryTable);
            // Pick the dialect that matches the report's connection so the
            // preview SQL (TOP vs LIMIT, [brackets] vs "quotes") reflects
            // what will actually run.
            var currentConn = _availableConnections.FirstOrDefault(c => c.Id == _currentConfig.ConnectionId);
            var dialect = DialectFactory.Get(currentConn?.ConnectionType ?? "sqlserver");
            var (sql, parameters) = QueryBuilder.BuildQuery(
                request, fieldConfigs, joinConfigs, customFilters, lookups, dialect,
                _currentConfig.PrimaryTable);

            // Always build the dashboard-wrapped SQL too, regardless of
            // which tab the admin clicked Show Query from. The dialog
            // exposes them as separate tabs so Table / Dashboard / Detail
            // views aren't conflated. Built only when a primary group-by
            // is set; otherwise no meaningful aggregation SQL exists.
            string? dashboardSql = null;
            {
                var liveDashConfig = _dashboardView?.GetCurrentConfig() ?? _dashboardConfig;
                if (liveDashConfig is not null && !string.IsNullOrWhiteSpace(liveDashConfig.GroupByFieldId))
                {
                    var dims = new List<string> { liveDashConfig.GroupByFieldId };
                    if (liveDashConfig.ExtraDimensionFieldIds is { Count: > 0 })
                        dims.AddRange(liveDashConfig.ExtraDimensionFieldIds);

                    var measures = new List<(string FieldId, string Aggregation)>();
                    if (!string.IsNullOrWhiteSpace(liveDashConfig.MeasureFieldId)
                        && !string.Equals(liveDashConfig.Aggregation, "COUNT", StringComparison.OrdinalIgnoreCase))
                    {
                        measures.Add((liveDashConfig.MeasureFieldId, liveDashConfig.Aggregation));
                    }
                    if (liveDashConfig.ExtraColumns is { Count: > 0 })
                        foreach (var ec in liveDashConfig.ExtraColumns)
                            measures.Add((ec.FieldId, ec.Aggregation));

                    dashboardSql = QueryBuilder.BuildDashboardPreviewSql(
                        sql, dims, measures, fieldConfigs, dialect,
                        liveDashConfig.DefaultSortColumn, liveDashConfig.DefaultSortDirection);
                }
            }

            var paramDict = parameters.ToDictionary(p => p.ParameterName, p => (object?)p.Value);

            // Also build the SQL the DetailViewer would execute so the
            // admin can inspect both in one dialog. DetailViewer's request
            // shape: same fields/filters/custom-filters/primary/connection,
            // Page 1 with a much higher PageSize (50k), and sort precedence
            // mirroring DetailViewer's logic — group-by first, detail
            // default second. GroupByFieldIds is intentionally omitted
            // (detail view groups client-side, not via SQL aggregation).
            string? detailPrimary = null, detailPrimaryDir = null;
            string? detailSecondary = null, detailSecondaryDir = null;
            if (!string.IsNullOrEmpty(_detailGroupByFieldId)
                && queryFieldIds.Contains(_detailGroupByFieldId, StringComparer.OrdinalIgnoreCase))
            {
                detailPrimary = _detailGroupByFieldId;
                detailPrimaryDir = _detailGroupByDirection == "desc" ? "desc" : "asc";
                if (!string.IsNullOrEmpty(_detailSortFieldId)
                    && !string.Equals(_detailSortFieldId, _detailGroupByFieldId, StringComparison.OrdinalIgnoreCase)
                    && queryFieldIds.Contains(_detailSortFieldId, StringComparer.OrdinalIgnoreCase))
                {
                    detailSecondary = _detailSortFieldId;
                    detailSecondaryDir = _detailSortDirection == "desc" ? "desc" : "asc";
                }
            }
            else if (!string.IsNullOrEmpty(_detailSortFieldId)
                && queryFieldIds.Contains(_detailSortFieldId, StringComparer.OrdinalIgnoreCase))
            {
                detailPrimary = _detailSortFieldId;
                detailPrimaryDir = _detailSortDirection == "desc" ? "desc" : "asc";
            }

            var detailRequest = new QueryRequest
            {
                FieldIds = queryFieldIds,
                Filters = new Dictionary<string, object?>(_currentConfig.Filters),
                CustomFilterIds = _currentConfig.CustomFilterIds?.Count > 0 ? new List<string>(_currentConfig.CustomFilterIds) : null,
                AdvancedFilters = _advancedFiltersEnabled && HasAdvancedFilterLeaves(_filterRoot)
                    ? CloneFilterGroup(_filterRoot)
                    : null,
                Page = 1,
                PageSize = 50000,
                ConnectionId = _currentConfig.ConnectionId,
                PrimaryTable = _currentConfig.PrimaryTable,
                SortField = detailPrimary,
                SortDirection = detailPrimaryDir,
                SecondarySortField = detailSecondary,
                SecondarySortDirection = detailSecondaryDir,
                Distinct = _currentConfig.Distinct,
                // Same auto-PK fallback as the table-view request: when the
                // detail dropdowns leave SortField unset, QueryBuilder
                // anchors the ORDER BY on PK columns so the preview matches
                // runtime behavior.
                FallbackSortColumns = _primaryTablePkColumns.Count > 0
                    ? new List<string>(_primaryTablePkColumns)
                    : null,
                // Detail view shares the same per-report SQL calc columns as
                // the table view — its preview SQL needs them in the SELECT
                // and FROM chain too, otherwise sorting / displaying by a
                // calc Key references a non-existent alias.
                TableCalcSqlColumns = BuildTableCalcSqlSelectors()
            };
            detailRequest.Scoping = await ScopeResolver.ResolveAsync(_userEmail, _currentConfig.ConnectionId, _currentConfig.PrimaryTable);
            var (detailSql, detailParams) = QueryBuilder.BuildQuery(
                detailRequest, fieldConfigs, joinConfigs, customFilters, lookups, dialect,
                _currentConfig.PrimaryTable);
            var detailParamDict = detailParams.ToDictionary(p => p.ParameterName, p => (object?)p.Value);

            var dlgParams = new DialogParameters
            {
                { "Sql", sql },
                { "Parameters", paramDict },
                { "DashboardSql", dashboardSql },
                { "DashboardParameters", paramDict },
                { "DetailSql", detailSql },
                { "DetailParameters", detailParamDict }
            };
            await DialogService.ShowAsync<ShowQueryDialog>("Generated SQL Query", dlgParams,
                new DialogOptions { MaxWidth = MaxWidth.Large, FullWidth = true });
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "ShowQuery failed to build SQL");
            Snackbar.Add($"Failed to build query: {ex.Message}", Severity.Error);
        }
    }

    // ── Drawer resize ──
    private async Task StartResize(MouseEventArgs e)
    {
        await JS.InvokeVoidAsync("eval", $@"
            (function() {{
                const onMove = function(e) {{
                    const w = Math.min(500, Math.max(180, e.clientX));
                    DotNet.invokeMethodAsync('TleReportingDashboard.Web', 'SetDrawerWidth', w);
                }};
                const onUp = function() {{
                    document.removeEventListener('mousemove', onMove);
                    document.removeEventListener('mouseup', onUp);
                    document.body.style.cursor = '';
                    document.body.style.userSelect = '';
                }};
                document.addEventListener('mousemove', onMove);
                document.addEventListener('mouseup', onUp);
                document.body.style.cursor = 'col-resize';
                document.body.style.userSelect = 'none';
            }})();
        ");
    }

    [JSInvokable]
    public static Task SetDrawerWidth(int width)
    {
        _staticDrawerWidth = width;
        _staticInstance?.InvokeAsync(() =>
        {
            _staticInstance._drawerWidth = width;
            _staticInstance.StateHasChanged();
        });
        return Task.CompletedTask;
    }

    private static ReportBuilder? _staticInstance;
    private static int _staticDrawerWidth = 240;

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            _staticInstance = this;
            _drawerWidth = _staticDrawerWidth;
        }
    }

    public void Dispose()
    {
        _editorScope?.Dispose();
        _editorScope = null;
    }
