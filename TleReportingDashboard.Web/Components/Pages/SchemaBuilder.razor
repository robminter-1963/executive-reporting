    private async Task OpenLookupDialog(LookupEntry? lookup, bool isNew)
    {
        var parameters = new DialogParameters
        {
            { "Lookup", lookup ?? new LookupEntry() },
            { "IsNew", isNew },
            { "ConnectionType", CurrentConnectionType }
        };
        var dialog = await DialogService.ShowAsync<LookupEditDialog>(
            isNew ? "Add Lookup" : "Edit Lookup", parameters,
            DialogPresets.Locked(MaxWidth.Medium));

        var result = await dialog.Result;
        if (result is null || result.Canceled || result.Data is not LookupEntry edited) return;

        if (isNew)
        {
            _lookups.Add(edited);
        }
        else if (lookup is not null)
        {
            // Cascade Id renames into field references so the lookup picker
            // doesn't end up with an unremovable orphan. The "(missing)"
            // marker in FieldEditDialog catches anything we can't update
            // here (e.g. legacy schemas loaded with already-stale ids), but
            // for in-session renames this keeps the references clean.
            var oldId = lookup.Id;
            var newId = edited.Id;
            if (!string.IsNullOrWhiteSpace(oldId)
                && !string.Equals(oldId, newId, StringComparison.Ordinal))
            {
                var touched = 0;
                foreach (var f in _fields)
                {
                    if (f.LookupIds is null) continue;
                    for (var i = 0; i < f.LookupIds.Count; i++)
                    {
                        if (string.Equals(f.LookupIds[i], oldId, StringComparison.OrdinalIgnoreCase))
                        {
                            f.LookupIds[i] = newId;
                            touched++;
                        }
                    }
                }
                if (touched > 0)
                {
                    Snackbar.Add(
                        $"Updated {touched} field reference{(touched == 1 ? "" : "s")} from \"{oldId}\" to \"{newId}\". Save the schema to persist.",
                        Severity.Info);
                }
            }
            lookup.Id = edited.Id;
            lookup.Label = edited.Label;
            lookup.SqlPreamble = edited.SqlPreamble;
            lookup.SqlJoin = edited.SqlJoin;
        }
        StateHasChanged();
    }

    // Lookup Types are the value source for filter chip pickers — the
    // admin authors a SELECT + value/display columns here, then references
    // this lookup type from a Field via "Lookup Type" in the field editor.
    private async Task OpenLookupTypeDialog(LookupTypeEntry? lookupType, bool isNew)
    {
        var parameters = new DialogParameters
        {
            { "LookupType", lookupType ?? new LookupTypeEntry() },
            { "IsNew", isNew }
        };
        var dialog = await DialogService.ShowAsync<LookupTypeEditDialog>(
            isNew ? "Add Lookup Type" : "Edit Lookup Type", parameters,
            DialogPresets.Locked(MaxWidth.Medium));

        var result = await dialog.Result;
        if (result is null || result.Canceled || result.Data is not LookupTypeEntry edited) return;

        if (isNew)
        {
            _lookupTypes.Add(edited);
        }
        else if (lookupType is not null)
        {
            // Cascade Id renames into field references. Same rationale as
            // OpenLookupDialog above — keeps FieldDefinition.LookupTypeId
            // in sync so the filter chip picker keeps resolving.
            var oldId = lookupType.Id;
            var newId = edited.Id;
            if (!string.IsNullOrWhiteSpace(oldId)
                && !string.Equals(oldId, newId, StringComparison.Ordinal))
            {
                var touched = 0;
                foreach (var f in _fields)
                {
                    if (string.Equals(f.LookupTypeId, oldId, StringComparison.OrdinalIgnoreCase))
                    {
                        f.LookupTypeId = newId;
                        touched++;
                    }
                }
                if (touched > 0)
                {
                    Snackbar.Add(
                        $"Updated {touched} field reference{(touched == 1 ? "" : "s")} from \"{oldId}\" to \"{newId}\". Save the schema to persist.",
                        Severity.Info);
                }
            }
            lookupType.Id = edited.Id;
            lookupType.Label = edited.Label;
            lookupType.SelectSql = edited.SelectSql;
            lookupType.ValueColumn = edited.ValueColumn;
            lookupType.DisplayColumn = edited.DisplayColumn;
            lookupType.SourceTableRef = edited.SourceTableRef;
        }
        StateHasChanged();
    }

    private async Task OpenCustomFilterDialog(CustomFilterEntry? filter, bool isNew)
    {
        var parameters = new DialogParameters
        {
            { "Filter", filter ?? new CustomFilterEntry() },
            { "IsNew", isNew },
            { "AvailableJoins", _joins },
            { "AvailableLookups", _lookups.AsEnumerable() },
            { "AvailableDomains", _domainList.AsEnumerable() },
            { "ConnectionType", CurrentConnectionType }
        };
        var dialog = await DialogService.ShowAsync<CustomFilterEditDialog>(
            isNew ? "Add Custom Filter" : "Edit Custom Filter", parameters,
            DialogPresets.Locked(MaxWidth.Medium));

        var result = await dialog.Result;
        if (result is null || result.Canceled || result.Data is not CustomFilterEntry edited) return;

        if (isNew)
        {
            _customFilters.Add(edited);
        }
        else if (filter is not null)
        {
            filter.Id = edited.Id;
            filter.Label = edited.Label;
            filter.Description = edited.Description;
            filter.SqlPreamble = edited.SqlPreamble;
            filter.JoinId = edited.JoinId;
            filter.SqlJoin = edited.SqlJoin;
            filter.SqlCondition = edited.SqlCondition;
            filter.GroupName = edited.GroupName;
        }
        StateHasChanged();
    }

    public class LookupEntry
    {
        public string Id { get; set; } = string.Empty;
        public string Label { get; set; } = string.Empty;
        public string SqlPreamble { get; set; } = string.Empty;
        public string SqlJoin { get; set; } = string.Empty;
    }

    // Editor-side mirror of LookupTypeDefinition. Owns one row per
    // entry in the Lookup Types tab. Drives the FieldEditDialog's
    // "Lookup Type" dropdown and ILookupValueService at runtime.
    public class LookupTypeEntry
    {
        public string Id { get; set; } = string.Empty;
        public string Label { get; set; } = string.Empty;
        // Admin-authored SELECT (e.g. "SELECT CODENUM, CODEDESC FROM
        // EMPOWER.SET_CODESETS WHERE CODEINT=1"). Returns the picker
        // values when ILookupValueService runs it.
        public string SelectSql { get; set; } = string.Empty;
        // Column name in the SELECT result that becomes the filter value.
        public string ValueColumn { get; set; } = string.Empty;
        // Column name shown in the picker.
        public string DisplayColumn { get; set; } = string.Empty;
        // Optional: how the admin references the lookup table in field
        // FilterPredicateSqls. Used by the implicit IN-append path
        // (when the predicate has no {values} placeholder).
        public string SourceTableRef { get; set; } = string.Empty;
    }

    // One row in the Source Table / Alias picker. Value is what gets stored
    // on the field (matches the alias in JoinResolver / the FROM clause);
    // Label shows table + alias together so admins can tell which is which;
    // TableName is the fully-qualified schema.table used to load that table's
    // columns via SchemaBuilderService. Null TableName = the source was
    // extracted from raw SQL and we couldn't resolve a real table, so
    // column enumeration isn't available for it.
    public record SourceOption(string Value, string Label, string? TableName);

    public class CustomFilterEntry
    {
        public string Id { get; set; } = string.Empty;
        public string Label { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public string SqlPreamble { get; set; } = string.Empty;
        public string JoinId { get; set; } = string.Empty;  // Reference to an existing join from the Joins tab
        public string SqlJoin { get; set; } = string.Empty;  // Custom inline JOIN (used when JoinId is empty)
        public List<string>? LookupIds { get; set; }
        public string SqlCondition { get; set; } = string.Empty;
        // Group label used by the Report Builder to bucket presets in the UI.
        // Typically matches a Domain. Blank = "Misc".
        public string GroupName { get; set; } = string.Empty;
    }

    public void Dispose()
    {
        _editorScope?.Dispose();
        _editorScope = null;
    }
}
