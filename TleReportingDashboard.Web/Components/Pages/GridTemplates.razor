@page "/grid-templates"
@rendermode InteractiveServer
@implements IDisposable
@inject EditorModeState EditorMode
@inject IGridTemplateService TemplateService
@inject ISchemaService SchemaService
@inject IAdminService AdminService
@inject ICompanyConnectionAdminService ConnectionAdminSvc
@inject ICompanyRegistry CompanyRegistry
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject ILogger<GridTemplates> Logger

<PageTitle>Grid Templates - Executive Reporting Suite</PageTitle>

@if (_accessDenied)
{
    <MudMainContent Style="padding: 0; margin-left: 15px;">
        <MudAlert Severity="Severity.Warning">
            Grid Templates are an admin-only area. Redirecting to the Report Library…
        </MudAlert>
    </MudMainContent>
    return;
}

<MudMainContent Style="padding: 0; margin-left: 15px;">
    <MudStack Spacing="3">
        <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
            <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                <MudIconButton Icon="@Icons.Material.Outlined.ArrowBack"
                               OnClick="@(() => Navigation.NavigateTo("/reports"))"
                               title="Back to Reports" />
                <MudText Typo="Typo.h5" Style="font-weight: 600;">Grid Templates</MudText>
                <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Outlined"
                         Icon="@Icons.Material.Outlined.Shield"
                         Style="font-size: 0.65rem; height: 22px;">
                    ADMIN
                </MudChip>
            </MudStack>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                       StartIcon="@Icons.Material.Outlined.Add" OnClick="CreateTemplate">
                New Template
            </MudButton>
        </MudStack>

        <MudText Typo="Typo.body2" Color="Color.Secondary">
            Create reusable grid configurations with pre-selected fields, column order, widths, and visibility.
            Apply them to new reports instead of building from scratch.
        </MudText>

        @if (_loading)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
        }
        else if (_templates.Any())
        {
            @* Tabs group templates by their connection's owning company.
               "All" stays first as the default landing tab so admins
               looking for a specific template by name don't have to
               guess which company-tab to open. Per-company tabs label
               with a count for quick eyeballing. *@
            <MudTabs @bind-ActivePanelIndex="_activeTabIndex"
                     Elevation="0" Rounded ApplyEffectsToContainer Class="pa-0">
                <MudTabPanel Text="@($"All ({_templates.Count})")"
                             Icon="@Icons.Material.Outlined.ViewList">
                    @TemplateTable(_templates, showCompanyColumn: true)
                </MudTabPanel>
                @foreach (var co in _companies)
                {
                    var companyId = co.Id;
                    var companyTemplates = TemplatesForCompany(companyId).ToList();
                    @* Hide companies with no templates so the strip
                       stays manageable. Admins can still see the company
                       in "All" if they need to verify it's empty. *@
                    if (companyTemplates.Count == 0) continue;
                    <MudTabPanel Text="@($"{co.Name} ({companyTemplates.Count})")"
                                 Icon="@Icons.Material.Outlined.Business">
                        @TemplateTable(companyTemplates, showCompanyColumn: false)
                    </MudTabPanel>
                }
            </MudTabs>
        }
        else
        {
            <MudPaper Class="pa-8 d-flex flex-column align-center justify-center" Elevation="0"
                      Style="border: 1px dashed #DADCE0; min-height: 200px;">
                <MudIcon Icon="@Icons.Material.Outlined.GridView" Size="Size.Large" Color="Color.Default" />
                <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mt-2">
                    No grid templates yet. Create one to reuse across reports.
                </MudText>
            </MudPaper>
        }
    </MudStack>
</MudMainContent>

@code {
    private string _userId = "anonymous";
    private string _userEmail = string.Empty;
    private bool _loading = true;
    private bool _accessDenied;
    private List<GridTemplate> _templates = new();
    private Dictionary<Guid, string> _connectionNames = new();
    // Connection → owning company id. Built alongside _connectionNames so
    // the per-company tab strip can filter templates by their connection's
    // company without a second round-trip per render.
    private Dictionary<Guid, Guid> _connectionCompanyById = new();
    // Active companies, alphabetized. Drives the per-company tab strip.
    private List<CompanySummary> _companies = new();
    private int _activeTabIndex; // 0 = "All", 1+ = per-company tabs

    private IDisposable? _editorScope;

    protected override async Task OnInitializedAsync()
    {
        _editorScope = EditorMode.Enter();

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        _userId = user.FindFirst("oid")?.Value ?? user.Identity?.Name ?? "anonymous";
        _userEmail = user.FindFirst("preferred_username")?.Value ?? string.Empty;

        if (!AdminService.IsAdmin(_userEmail))
        {
            _accessDenied = true;
            // Bounce non-admins back to the Report Library after a brief pause
            // so they see the warning banner.
            _ = Task.Delay(1500).ContinueWith(_ =>
                InvokeAsync(() => Navigation.NavigateTo("/reports")));
            return;
        }

        // Connection name lookup for the table. Built across every active
        // company so templates belonging to any connection can be labeled
        // correctly — the hardcoded "TLE only" load was leaving templates
        // on other companies' connections rendering as raw IDs.
        // The same loop also captures the connection→company map and the
        // sorted company list so the per-company tab strip below can
        // partition templates without a second round-trip per render.
        try
        {
            _connectionNames = new();
            _connectionCompanyById = new();
            _companies = (await CompanyRegistry.GetActiveAsync())
                .OrderBy(c => c.Name, StringComparer.OrdinalIgnoreCase)
                .ToList();
            // Per-company fetches are independent — parallelize the
            // round-trips so cold load is roughly the slowest single call,
            // not the sum.
            var connsByCompany = await Task.WhenAll(
                _companies.Select(c => ConnectionAdminSvc.GetByCompanyAsync(c.Id)));
            for (var i = 0; i < _companies.Count; i++)
            {
                var compId = _companies[i].Id;
                foreach (var c in connsByCompany[i])
                {
                    _connectionNames[c.Id] = c.Name;
                    _connectionCompanyById[c.Id] = compId;
                }
            }
        }
        catch { /* non-fatal — column shows id/"—" instead */ }

        await LoadTemplates();
    }

    private async Task LoadTemplates()
    {
        _loading = true;
        try
        {
            _templates = await TemplateService.GetTemplatesAsync(_userId);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load templates: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private string GetConnectionName(Guid? connectionId) =>
        connectionId.HasValue && _connectionNames.TryGetValue(connectionId.Value, out var name)
            ? name
            : "—";

    // Filters _templates to those whose connection belongs to the given
    // company. Templates with a missing connection (legacy / orphaned)
    // fall out of every per-company tab and only show in "All".
    private IEnumerable<GridTemplate> TemplatesForCompany(Guid companyId) =>
        _templates.Where(t =>
            t.ConnectionId is Guid cid
            && _connectionCompanyById.TryGetValue(cid, out var cc)
            && cc == companyId);

    // Per-company template counts so the tab labels show "Acme (4)" —
    // gives admins a sense of distribution at a glance and lets them
    // spot empty tabs without clicking through.
    private int TemplateCountForCompany(Guid companyId) =>
        TemplatesForCompany(companyId).Count();

    // Shared table renderer used by both the "All" tab (with a Company
    // column for cross-company context) and per-company tabs (where the
    // column is redundant and just costs horizontal space). Inlined as
    // a RenderFragment so both call sites stay in sync — the only
    // structural difference between the two is one column.
    private RenderFragment TemplateTable(IEnumerable<GridTemplate> items, bool showCompanyColumn) => __builder =>
    {
        <MudTable Items="items" Hover Striped Dense T="GridTemplate">
            <HeaderContent>
                <MudTh>Name</MudTh>
                @if (showCompanyColumn)
                {
                    <MudTh>Company</MudTh>
                }
                <MudTh>Connection</MudTh>
                <MudTh>Description</MudTh>
                <MudTh>Fields</MudTh>
                <MudTh>Shared</MudTh>
                <MudTh>Owner</MudTh>
                <MudTh>Updated</MudTh>
                <MudTh Style="text-align: right;">Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Name">
                    <MudText Typo="Typo.body2" Style="font-weight: 500;">@context.Name</MudText>
                </MudTd>
                @if (showCompanyColumn)
                {
                    <MudTd DataLabel="Company">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@GetCompanyName(context.ConnectionId)</MudText>
                    </MudTd>
                }
                <MudTd DataLabel="Connection">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@GetConnectionName(context.ConnectionId)</MudText>
                </MudTd>
                <MudTd DataLabel="Description">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@(context.Description ?? "—")</MudText>
                </MudTd>
                <MudTd DataLabel="Fields">
                    <MudText Typo="Typo.body2">@GetFieldCount(context) fields</MudText>
                </MudTd>
                <MudTd DataLabel="Shared">
                    @if (context.IsShared)
                    {
                        <MudIcon Icon="@Icons.Material.Outlined.Public" Size="Size.Small" Color="Color.Success" />
                    }
                </MudTd>
                <MudTd DataLabel="Owner">
                    <MudText Typo="Typo.caption">@context.OwnerEmail</MudText>
                </MudTd>
                <MudTd DataLabel="Updated">
                    <MudText Typo="Typo.caption">@context.UpdatedAt.ToString("MMM dd, yyyy")</MudText>
                </MudTd>
                <MudTd DataLabel="Actions" Style="text-align: right;">
                    <MudStack Row Spacing="0" Style="display: inline-flex !important;">
                        <MudIconButton Icon="@Icons.Material.Outlined.Edit" Size="Size.Small"
                                       Color="Color.Primary"
                                       OnClick="() => EditTemplate(context)"
                                       Disabled="@(context.OwnerId != _userId)" title="Edit" />
                        <MudIconButton Icon="@Icons.Material.Outlined.ContentCopy" Size="Size.Small"
                                       Color="Color.Default"
                                       OnClick="() => CloneTemplate(context)" title="Clone" />
                        <MudIconButton Icon="@Icons.Material.Outlined.Delete" Size="Size.Small"
                                       Color="Color.Error"
                                       OnClick="() => DeleteTemplate(context)"
                                       Disabled="@(context.OwnerId != _userId)" title="Delete" />
                    </MudStack>
                </MudTd>
            </RowTemplate>
        </MudTable>
    };

    // Resolve a connection's owning company name. Returns "—" when the
    // connection isn't on the active list (deleted / inactive) so the
    // row keeps rendering with a clear "unknown" marker.
    private string GetCompanyName(Guid? connectionId)
    {
        if (connectionId is not Guid cid) return "—";
        if (!_connectionCompanyById.TryGetValue(cid, out var coId)) return "—";
        return _companies.FirstOrDefault(c => c.Id == coId)?.Name ?? "—";
    }

    private int GetFieldCount(GridTemplate t)
    {
        try
        {
            var ids = System.Text.Json.JsonSerializer.Deserialize<List<string>>(t.FieldIds);
            return ids?.Count ?? 0;
        }
        catch { return 0; }
    }

    private void CreateTemplate()
    {
        Navigation.NavigateTo("/grid-templates/new");
    }

    private void EditTemplate(GridTemplate t)
    {
        Navigation.NavigateTo($"/grid-templates/{t.Id}");
    }

    private async Task CloneTemplate(GridTemplate source)
    {
        // Build the connection list from the same map the table uses
        // for the Connection column — covers every active company so
        // admins can retarget across companies, not just within one.
        var options = _connectionNames
            .Select(kv => new CloneTemplateDialog.ConnectionOption(kv.Key, kv.Value))
            .ToList();

        var dialogParams = new DialogParameters
        {
            { nameof(CloneTemplateDialog.SourceName), source.Name },
            { nameof(CloneTemplateDialog.SourceConnectionId), source.ConnectionId },
            { nameof(CloneTemplateDialog.Connections), options }
        };
        var dialog = await DialogService.ShowAsync<CloneTemplateDialog>("Clone template", dialogParams,
            DialogPresets.Locked(MaxWidth.Small));
        var result = await dialog.Result;
        if (result is null || result.Canceled || result.Data is not CloneTemplateDialog.Result picked)
            return;

        var cloned = new GridTemplate
        {
            Name = picked.NewName,
            Description = source.Description,
            OwnerId = _userId,
            OwnerEmail = _userEmail,
            FieldIds = source.FieldIds,
            ColumnState = source.ColumnState,
            // Connection is now admin-pickable. ColumnState carries
            // field ids that may not exist on the target connection's
            // schema; per product direction, no validation here —
            // missing fields render blank in the grid editor and the
            // admin tunes them up after the clone.
            ConnectionId = picked.TargetConnectionId
        };
        var (ok, _) = await Snackbar.RunAsync(Logger, "cloning grid template",
            () => TemplateService.SaveTemplateAsync(cloned));
        if (ok)
        {
            await LoadTemplates();
        }
    }

    private async Task DeleteTemplate(GridTemplate t)
    {
        if (await Snackbar.RunAsync(Logger, "deleting grid template",
                () => TemplateService.DeleteTemplateAsync(t.Id, _userId)))
        {
            _templates.Remove(t);
        }
    }

    public void Dispose()
    {
        _editorScope?.Dispose();
        _editorScope = null;
    }
}
