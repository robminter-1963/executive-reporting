@inject IDialogService DialogService

@* "Add tile" picker. No initial selection, so dirty = the user has
   picked a report (or chosen a non-default section). Callers must open
   with DialogOptions { BackdropClick = false, CloseOnEscapeKey = false }
   so backdrop / Esc are routed through TryCancelAsync. *@

<MudDialog>
    <TitleContent>
        <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.AddCircle" />
            <MudText Typo="Typo.h6">Add Report to Master Dashboard</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="2" Style="min-width: 480px;">
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Select a report with "Show on Master Dashboard" enabled:
            </MudText>
            <MudList T="SavedReport" Dense>
                @* Sort by the same primary label rendered on each row
                   (InternalName when set, else Name) so the picker order
                   matches what the admin reads off the row. *@
                @foreach (var report in Reports.OrderBy(rp =>
                    string.IsNullOrWhiteSpace(rp.InternalName) ? rp.Name : rp.InternalName!,
                    StringComparer.OrdinalIgnoreCase))
                {
                    var r = report;
                    var summary = FilterSummary(r);
                    var primaryLabel = string.IsNullOrWhiteSpace(r.InternalName) ? r.Name : r.InternalName!;
                    var hasDistinctInternal = !string.IsNullOrWhiteSpace(r.InternalName)
                                              && !string.Equals(r.InternalName, r.Name, StringComparison.Ordinal);
                    <MudListItem T="SavedReport" OnClick="() => Select(r)"
                                  Style="@(_selected?.Id == r.Id ? "background: #E8F0FE;" : "cursor: pointer;")">
                        <MudStack Spacing="0" Style="line-height: 1.2;">
                            <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                                <MudIcon Icon="@Icons.Material.Filled.Dashboard" Size="Size.Small"
                                         Color="@(_selected?.Id == r.Id ? Color.Primary : Color.Default)" />
                                @* Picker primary = InternalName when set,
                                   else falls back to Name. Tile rendering
                                   still uses Name only — this label exists
                                   purely to disambiguate variants here. *@
                                <MudText Typo="Typo.body2" Style="@(_selected?.Id == r.Id ? "font-weight: 600;" : "")">
                                    @primaryLabel
                                </MudText>
                                @if (hasDistinctInternal)
                                {
                                    @* Show the public Name in parens when it
                                       differs from the picker label, so admins
                                       can confirm which tile name they're
                                       pinning. *@
                                    <MudText Typo="Typo.caption" Color="Color.Secondary"
                                             Style="font-size: 0.7rem;">
                                        — tile: @r.Name
                                    </MudText>
                                }
                            </MudStack>
                            @* Subtitle: filter values when present, then the
                               last-updated stamp. Reports that share a name
                               (e.g. one Pipeline per loan type) get
                               distinguished by their saved filter dict. *@
                            @if (!string.IsNullOrEmpty(summary))
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary"
                                         Style="margin-left: 32px; font-size: 0.7rem;">
                                    @summary
                                </MudText>
                            }
                            <MudText Typo="Typo.caption" Color="Color.Secondary"
                                     Style="margin-left: 32px; font-size: 0.65rem;">
                                Updated @r.UpdatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                            </MudText>
                        </MudStack>
                    </MudListItem>
                }
            </MudList>

            @* Optional section picker — only shown when this tab has at
               least one section. Default is "(no section)" so admins who
               don't use sections see no extra UI / friction. The new
               tile gets its section_id set on insert via AddTileAsync. *@
            @if (Sections is { Count: > 0 })
            {
                <MudSelect T="int?" @bind-Value="_selectedSectionId"
                           Label="Section" Variant="Variant.Outlined"
                           Margin="Margin.Dense" Dense
                           HelperText="Optional. Choose '(no section)' to leave the tile in the un-grouped bucket."
                           Style="max-width: 320px;">
                    <MudSelectItem T="int?" Value="@((int?)null)">(no section)</MudSelectItem>
                    @foreach (var s in Sections.OrderBy(x => x.SortOrder))
                    {
                        <MudSelectItem T="int?" Value="@((int?)s.Id)">@s.Label</MudSelectItem>
                    }
                </MudSelect>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="TryCancelAsync">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Ok"
                   Disabled="@(_selected is null)">
            Add
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance? MudDialog { get; set; }
    [Parameter] public List<SavedReport> Reports { get; set; } = new();
    // Optional. When the active tab has sections, the dialog renders a
    // section picker so the admin can drop the new tile straight into a
    // group. Empty list = picker is hidden, exactly the pre-sections UX.
    [Parameter] public List<MasterDashboardSection> Sections { get; set; } = new();

    private SavedReport? _selected;
    // null = "(no section)" — tile lands in the un-grouped bucket.
    private int? _selectedSectionId;

    private void Select(SavedReport report) => _selected = report;
    private void Ok() => MudDialog?.Close(DialogResult.Ok(new AddTileResult(_selected!.Id, _selectedSectionId)));

    // No initial value — dirty when a report has been picked or a
    // non-default section was chosen. Either signal means the user has
    // made progress that an accidental Esc would silently throw away.
    private bool IsDirty => _selected is not null || _selectedSectionId is not null;

    // Routes every dismiss path (Cancel button, Esc, backdrop click)
    // through the unsaved-changes prompt. Save runs the OK handler
    // (only when a report has been picked); DontSave dismisses; Cancel
    // keeps the dialog open.
    private async Task TryCancelAsync()
    {
        if (!IsDirty)
        {
            MudDialog?.Cancel();
            return;
        }

        var choice = await UnsavedChangesPrompt.AskAsync(DialogService);
        switch (choice)
        {
            case UnsavedChangesResult.Save:
                if (_selected is not null) Ok();
                return;
            case UnsavedChangesResult.Cancel:
                return; // stay
            case UnsavedChangesResult.DontSave:
                MudDialog?.Cancel();
                return;
        }
    }

    // Returned to the caller via DialogResult.Data so adding a tile can
    // carry both the picked report and the chosen section in one round-trip.
    public sealed record AddTileResult(Guid ReportId, int? SectionId);

    // Compact one-line summary of a saved report's filter dict so users can
    // distinguish two reports that share a name. JsonDocument streaming
    // (vs. Deserialize<Dictionary<string, object?>>) keeps each value's
    // ValueKind so arrays / numbers / strings format cleanly without
    // wrapping JsonElement boxing in the output. Soft-truncated to ~100
    // chars so a heavy filter set doesn't blow up the row height.
    private static string FilterSummary(SavedReport r)
    {
        if (string.IsNullOrWhiteSpace(r.Filters)) return string.Empty;
        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(r.Filters);
            if (doc.RootElement.ValueKind != System.Text.Json.JsonValueKind.Object)
                return string.Empty;

            var parts = new List<string>();
            foreach (var prop in doc.RootElement.EnumerateObject())
            {
                if (prop.Value.ValueKind == System.Text.Json.JsonValueKind.Null) continue;
                var val = prop.Value.ValueKind switch
                {
                    System.Text.Json.JsonValueKind.String => prop.Value.GetString(),
                    System.Text.Json.JsonValueKind.Array  => string.Join(",",
                        prop.Value.EnumerateArray().Select(e =>
                            e.ValueKind == System.Text.Json.JsonValueKind.String
                                ? e.GetString()
                                : e.ToString())),
                    _ => prop.Value.ToString()
                };
                if (string.IsNullOrEmpty(val)) continue;
                parts.Add($"{prop.Name}: {val}");
            }
            if (parts.Count == 0) return string.Empty;

            var summary = string.Join(" • ", parts);
            return summary.Length > 100 ? summary[..97] + "…" : summary;
        }
        catch
        {
            return string.Empty;
        }
    }
}
