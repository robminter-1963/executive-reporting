                                </MudTooltip>
                            }
                        </MudTd>
                        <MudTd DataLabel="On Dashboard" Style="text-align: center;">
                            @if (_dashboardTabsByReport.TryGetValue(context.Id, out var onTabs))
                            {
                                var onTabsLabel = string.Join(", ", onTabs);
                                <MudTooltip Text="@($"Pinned on Master Dashboard tab: {onTabsLabel}")">
