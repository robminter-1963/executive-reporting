@inject IDialogService DialogService

@* "Save as Template" dialog. Pre-fills with DefaultName; dirty when the
   user has changed it from the default. Callers must open with
   DialogOptions { BackdropClick = false, CloseOnEscapeKey = false } so
   backdrop / Esc are routed through TryCancelAsync. *@

<MudDialog>
    <DialogContent>
        <MudStack Spacing="2">
            <MudTextField @bind-Value="_name" Label="Template Name" Variant="Variant.Outlined"
                          Required RequiredError="Template name is required." Immediate />
            <MudText Typo="Typo.caption" Color="Color.Secondary">
                Templates are visible to all users in the Templates tab and can be cloned.
            </MudText>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="TryCancelAsync">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Save"
                   Disabled="@string.IsNullOrWhiteSpace(_name)">
            Save Template
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance? MudDialog { get; set; }
    [Parameter] public string DefaultName { get; set; } = string.Empty;

    private string _name = string.Empty;

    protected override void OnInitialized()
    {
        _name = DefaultName;
    }

    // Dirty when the current name differs from the pre-filled default.
    private bool IsDirty =>
        !string.Equals(
            (_name ?? string.Empty).Trim(),
            (DefaultName ?? string.Empty).Trim(),
            StringComparison.Ordinal);

    private void Save() => MudDialog?.Close(DialogResult.Ok(_name));

    // Routes every dismiss path (Cancel button, Esc, backdrop click)
    // through the unsaved-changes prompt so an accidental dismiss never
    // silently throws away a typed-in name.
    private async Task TryCancelAsync()
    {
        if (!IsDirty)
        {
            MudDialog?.Cancel();
            return;
        }

        var choice = await UnsavedChangesPrompt.AskAsync(DialogService);
        switch (choice)
        {
            case UnsavedChangesResult.Save:
                if (!string.IsNullOrWhiteSpace(_name)) Save();
                return;
            case UnsavedChangesResult.Cancel:
                return; // stay
            case UnsavedChangesResult.DontSave:
                MudDialog?.Cancel();
                return;
        }
    }
}
