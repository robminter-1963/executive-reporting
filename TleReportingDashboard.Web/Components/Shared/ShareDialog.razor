@inject ISharingService SharingService
@inject IUserManagementService UserManagement
@inject INotificationService Notifications
@inject ISnackbar Snackbar
@inject ILogger<ShareDialog> Logger
@inject IDialogService DialogService

@* Share dialog. Add / Revoke persist to the service immediately, so
   the only unsaved state is a half-typed entry in the "new share email"
   field. IsDirty reflects exactly that, so an accidental Esc / backdrop
   click prompts the user before discarding their typed input. Callers
   must open with DialogOptions { BackdropClick = false,
   CloseOnEscapeKey = false } so backdrop / Esc are routed through
   TryCancelAsync. *@

<MudDialog>
    <TitleContent>
        <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
            <MudIcon Icon="@Icons.Material.Outlined.Share" />
            <MudText Typo="Typo.h6">Share Report</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3" Style="min-width: 420px;">
            @if (!string.IsNullOrWhiteSpace(ReportName))
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Share "@ReportName" with other users or groups.
                </MudText>
            }

            @* Add new share — picker bound to the RPT_users roster so
               sharing is restricted to users who actually have access to
               the website. Free-text was dropped because typos previously
               created shares against non-existent emails that silently
               failed at notification dispatch and confused owners.
               Autocomplete handles large user lists; we filter to active
               users and exclude the current user (self-share is a no-op)
               and users already in the shares list (de-dupe). *@
            <MudStack Row AlignItems="AlignItems.End" Spacing="2">
                <MudAutocomplete T="UserRecord" @bind-Value="_selectedUser"
                                 Label="Share with"
                                 SearchFunc="SearchUsers"
                                 ToStringFunc="@(u => u is null ? string.Empty : FormatUser(u))"
                                 Variant="Variant.Outlined" Margin="Margin.Dense" Dense
                                 Style="flex: 1;"
                                 Placeholder="Start typing a name or email..."
                                 CoerceText="true" ResetValueOnEmptyText="true"
                                 ShowProgressIndicator="@_loadingUsers"
                                 Clearable />
                <MudSelect T="string" @bind-Value="_newSharePermission" Label="Permission"
                           Variant="Variant.Outlined" Margin="Margin.Dense"
                           Style="max-width: 130px;" Dense>
                    <MudSelectItem Value="@("viewer")">Viewer</MudSelectItem>
                    <MudSelectItem Value="@("editor")">Editor</MudSelectItem>
                </MudSelect>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Medium"
                           OnClick="AddShare"
                           Disabled="@(_selectedUser is null || _isSaving)">
                    @if (_isSaving)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    }
                    Share
                </MudButton>
            </MudStack>

            @* "Share with everyone" — single share row keyed by
               SharedWithType='everyone'. Backend (GetSharedWithMeAsync +
               MasterDashboardService UNION arm) treats it as a wildcard,
               so users added LATER inherit access automatically — no
               per-user materialization, no backfill job. Hidden while an
               Everyone share already exists for this report (the existing
               row appears in the list below). Permission picker reuses
               _newSharePermission so the user can choose viewer/editor
               before clicking. *@
            @if (!_hasEveryoneShare)
            {
                <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Outlined.Public" Style="color: #5F6368;" />
                    <MudText Typo="Typo.body2" Style="flex: 1;">
                        Share with <strong>everyone</strong> — current and future users.
                    </MudText>
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                               OnClick="ShareWithEveryone"
                               Disabled="@_isSaving">
                        Share with everyone
                    </MudButton>
                </MudStack>
            }

            <MudDivider />

            @if (_isLoadingShares)
            {
                <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
            }

            @* Current shares list *@
            @if (_shares.Any())
            {
                <MudText Typo="Typo.subtitle2" Style="font-weight: 600;">Shared with</MudText>
                <MudList T="ReportShare" Dense>
                    @foreach (var share in _shares)
                    {
                        var shareLocal = share;
                        var isEveryone = string.Equals(share.SharedWithType, "everyone", StringComparison.OrdinalIgnoreCase);
                        <MudListItem T="ReportShare">
                            <MudStack Row AlignItems="AlignItems.Center"
                                       Justify="Justify.SpaceBetween" Style="width: 100%;">
                                <MudStack Row Spacing="2" AlignItems="AlignItems.Center">
                                    @if (isEveryone)
                                    {
                                        <MudIcon Icon="@Icons.Material.Outlined.Public" Size="Size.Small" Color="Color.Primary" />
                                    }
                                    <MudStack Spacing="0">
                                        <MudText Typo="Typo.body2" Style="@(isEveryone ? "font-weight: 600;" : "")">
                                            @(isEveryone ? "Everyone" : share.SharedWithId)
                                        </MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            @(isEveryone ? "All current and future users" : share.SharedWithType)
                                            &mdash;
                                            @(share.Permission == "editor" ? "Can edit" : "View only")
                                        </MudText>
                                    </MudStack>
                                </MudStack>
                                <MudIconButton Icon="@(isEveryone ? Icons.Material.Outlined.PublicOff : Icons.Material.Outlined.PersonRemove)"
                                               Size="Size.Small" Color="Color.Error"
                                               OnClick="() => RevokeShare(shareLocal)"
                                               title="@(isEveryone ? "Stop sharing with everyone" : "Revoke access")" />
                            </MudStack>
                        </MudListItem>
                    }
                </MudList>
            }
            else if (!_isLoadingShares)
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="pa-2">
                    This report is not shared with anyone yet.
                </MudText>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="TryCancelAsync">Cancel</MudButton>
        <MudButton OnClick="Done" Variant="Variant.Filled" Color="Color.Primary">
            Done
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance? MudDialog { get; set; }
    [Parameter] public Guid ReportId { get; set; }
    [Parameter] public string ReportName { get; set; } = string.Empty;
    [Parameter] public string CurrentUserId { get; set; } = string.Empty;
    [Parameter] public List<ReportShare> ExistingShares { get; set; } = new();

    private List<ReportShare> _shares = new();
    private UserRecord? _selectedUser;
    private string _newSharePermission = "viewer";
    private bool _isLoadingShares;
    private bool _isSaving;

    // Cached user roster for the share picker. Loaded once on dialog open
    // so SearchUsers can filter against it without re-querying per keystroke.
    private List<UserRecord> _users = new();
    private bool _loadingUsers;

    protected override async Task OnInitializedAsync()
    {
        if (ExistingShares.Any())
        {
            _shares = ExistingShares.Select(s => new ReportShare
            {
                Id = s.Id,
                ReportId = s.ReportId,
                SharedWithId = s.SharedWithId,
                SharedWithType = s.SharedWithType,
                Permission = s.Permission,
                SharedById = s.SharedById,
                CreatedAt = s.CreatedAt
            }).ToList();
        }
        else
        {
            _isLoadingShares = true;
            try
            {
                _shares = await SharingService.GetSharesForReportAsync(ReportId);
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Failed to load shares: {ex.Message}", Severity.Error);
            }
            finally
            {
                _isLoadingShares = false;
            }
        }

        // Load the user roster so the picker can offer onboarded users.
        // Lookup failure isn't fatal — the picker just shows empty and the
        // admin can retry. We don't fail-closed to free-text because that
        // would re-introduce the typo-share problem the picker was added
        // to solve.
        _loadingUsers = true;
        try
        {
            _users = await UserManagement.GetAllAsync();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to load user roster for share picker.");
            _users = new();
        }
        finally
        {
            _loadingUsers = false;
        }
    }

    // Display label for a user row in the picker. Prefer display name;
    // fall back to email when name isn't set. Email always shown alongside
    // (as a hint) so two users with the same display name can be told
    // apart at a glance.
    private static string FormatUser(UserRecord u) =>
        string.IsNullOrWhiteSpace(u.DisplayName)
            ? u.Email
            : $"{u.DisplayName} ({u.Email})";

    // Autocomplete search. Filters the cached roster to active users
    // whose email or display name contains the typed substring. Excludes
    // the report owner (no point sharing with yourself) and anyone
    // already in the shares list (prevents duplicate-share clicks).
    private Task<IEnumerable<UserRecord>> SearchUsers(string? value, CancellationToken ct)
    {
        var sharedIds = _shares
            .Select(s => s.SharedWithId)
            .Where(id => !string.IsNullOrWhiteSpace(id))
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        var pool = _users
            .Where(u => u.IsActive
                && !string.IsNullOrWhiteSpace(u.Email)
                && !string.Equals(u.UserId, CurrentUserId, StringComparison.OrdinalIgnoreCase)
                && !sharedIds.Contains(u.Email));

        if (!string.IsNullOrWhiteSpace(value))
        {
            pool = pool.Where(u =>
                (u.Email?.Contains(value, StringComparison.OrdinalIgnoreCase) ?? false)
                || (u.DisplayName?.Contains(value, StringComparison.OrdinalIgnoreCase) ?? false));
        }

        return Task.FromResult(pool
            .OrderBy(u => u.DisplayName ?? u.Email, StringComparer.OrdinalIgnoreCase)
            .Take(50)
            .AsEnumerable());
    }

    // True when this report already has a share of type 'everyone'. Used
    // to hide the "Share with everyone" affordance (only one Everyone
    // share per report makes sense) and to drive de-dup elsewhere.
    private bool _hasEveryoneShare =>
        _shares.Any(s => string.Equals(s.SharedWithType, "everyone", StringComparison.OrdinalIgnoreCase));

    // One-click share with every current and future user. SharedWithId is
    // the sentinel "everyone" because the column is NOT NULL; the actual
    // wildcard semantics live in the SharedWithType discriminator (see
    // GetSharedWithMeAsync). Permission defaults to whatever's selected
    // in the per-user picker's dropdown — admins typically want viewer
    // for broad shares; toggling editor before clicking gives them that.
    private async Task ShareWithEveryone()
    {
        if (_hasEveryoneShare) return; // defensive — UI already hides the button
        _isSaving = true;
        try
        {
            var share = new ReportShare
            {
                Id = Guid.NewGuid(),
                ReportId = ReportId,
                SharedWithId = "everyone",
                SharedWithType = "everyone",
                Permission = _newSharePermission,
                SharedById = CurrentUserId,
                CreatedAt = DateTime.UtcNow
            };
            var saved = await SharingService.ShareReportAsync(share);
            _shares.Add(saved);
            // No per-recipient notification — the audience is "every user",
            // and a broadcast to every active mailbox is too noisy for what
            // is effectively a permission change. Users see the new report
            // the next time they hit the Library / Master Dashboard.
            Snackbar.Add("Shared with everyone.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(FriendlyError.FromException(ex, Logger, "sharing with everyone"), Severity.Error);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task AddShare()
    {
        if (_selectedUser is null || string.IsNullOrWhiteSpace(_selectedUser.Email)) return;

        var targetEmail = _selectedUser.Email.Trim();

        // Prevent duplicate shares for the same user (SearchUsers already
        // hides shared users from the picker; this is the belt-and-suspenders
        // server-side equivalent).
        if (_shares.Any(s => s.SharedWithId.Equals(targetEmail, StringComparison.OrdinalIgnoreCase)))
            return;

        _isSaving = true;
        try
        {
            var share = new ReportShare
            {
                Id = Guid.NewGuid(),
                ReportId = ReportId,
                SharedWithId = targetEmail,
                SharedWithType = "user",
                Permission = _newSharePermission,
                SharedById = CurrentUserId,
                CreatedAt = DateTime.UtcNow
            };

            var saved = await SharingService.ShareReportAsync(share);
            _shares.Add(saved);

            // Notify the recipient. Fire-and-forget — share itself succeeded,
            // a failed notification shouldn't roll back the share. Logged on
            // failure so admins can audit.
            try
            {
                await Notifications.CreateAsync(
                    userEmail:          targetEmail,
                    kind:               NotificationKinds.ReportShared,
                    title:              $"\"{ReportName}\" was shared with you",
                    body:               $"You now have {_newSharePermission} access. Open it from the Report Library or follow the link.",
                    linkUrl:            $"/viewer/{ReportId}",
                    relatedEntityType:  "report",
                    relatedEntityId:    ReportId.ToString());
            }
            catch (Exception nex)
            {
                Logger.LogWarning(nex, "Share saved but notification dispatch failed for {Email}", targetEmail);
            }

            _selectedUser = null;
            _newSharePermission = "viewer";
        }
        catch (Exception ex)
        {
            Snackbar.Add(FriendlyError.FromException(ex, Logger, "sharing report"), Severity.Error);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task RevokeShare(ReportShare share)
    {
        if (await Snackbar.RunAsync(Logger, "revoking share",
                () => SharingService.RevokeShareAsync(share.Id, CurrentUserId)))
        {
            _shares.Remove(share);
            // Severity.Info (not Success) — revoke confirmation is neutral, not celebratory.
            Snackbar.Add("Share revoked.", Severity.Info);
        }
    }

    private void Done()
    {
        MudDialog?.Close(DialogResult.Ok(_shares));
    }

    // Adds and revokes persist immediately to the service, so the only
    // genuinely unsaved state in this dialog is whatever the user has
    // selected in the picker but not yet clicked "Share" on. Treating
    // that as the dirty signal lets the prompt fire when it actually matters.
    private bool IsDirty => _selectedUser is not null;

    // Routes every dismiss path (Cancel button, Esc, backdrop click)
    // through the unsaved-changes prompt. "Save" here means "add the
    // pending entry"; "DontSave" closes without adding it; "Cancel"
    // keeps the dialog open so the user can finish typing.
    private async Task TryCancelAsync() =>
        await UnsavedChangesPrompt.TryCancelAsync(DialogService, MudDialog, IsDirty,
            saveAsync: async () =>
            {
                await AddShare();
                // After Add succeeds the email field is cleared, so
                // IsDirty flips false; close out cleanly. If AddShare
                // failed, _newShareEmail is preserved — stay open so
                // the user can fix the input or explicitly dismiss.
                if (!IsDirty) MudDialog?.Close(DialogResult.Ok(_shares));
            });
}
