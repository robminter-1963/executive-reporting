    private object BuildFieldOutput(FieldEntry f)
    {
        var result = new Dictionary<string, object?>
        {
            ["Id"] = f.Id,
            ["Label"] = f.Label,
            ["Description"] = f.Description,
            ["Domain"] = f.Domain,
            ["DataType"] = f.DataType,
            ["FieldType"] = f.FieldType
        };

        if (f.MaxLength.HasValue) result["MaxLength"] = f.MaxLength.Value;

        if (!string.IsNullOrWhiteSpace(f.AllowedAggregationsStr))
            result["AllowedAggregations"] = f.AllowedAggregationsStr.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

        if (f.CodeSetId.HasValue) result["CodeSetId"] = f.CodeSetId.Value;

        if (f.ValueSortOrder is not null && f.ValueSortOrder.Count > 0)
            result["ValueSortOrder"] = f.ValueSortOrder;

        result["SourceTable"] = f.SourceTable;
        result["SourceColumn"] = f.SourceColumn;

        if (!string.IsNullOrWhiteSpace(f.SqlExpression))
        {
            result["SqlExpression"] = f.SqlExpression;
            if (!string.IsNullOrWhiteSpace(f.SqlPreamble))
                result["SqlPreamble"] = f.SqlPreamble;
        }
        // JoinIds and SqlJoin apply regardless of inline-SQL mode: a plain
        // SourceTable/SourceColumn field can still need a JOIN (e.g. column on a
        // joined table). Both contribute at query time.
        if (f.JoinIds is not null && f.JoinIds.Count > 0)
            result["JoinIds"] = f.JoinIds;
        if (!string.IsNullOrWhiteSpace(f.SqlJoin))
            result["SqlJoin"] = f.SqlJoin;
        // LookupIds can exist on any field (e.g. a plain SourceTable/Column field
        // that uses a lookup CTE for custom sort order) — not just SqlExpression fields.
        if (f.LookupIds is not null && f.LookupIds.Count > 0)
            result["LookupIds"] = f.LookupIds;

        if (!string.IsNullOrWhiteSpace(f.RolesRequired))
        {
            result["RolesRequired"] = f.RolesRequired;
            result["DefaultRedactionValue"] = "'*** REDACTED ***'";
        }

        if (!string.IsNullOrWhiteSpace(f.Format))
            result["Format"] = f.Format;

        if (f.ApplyTimezoneConversion)
            result["ApplyTimezoneConversion"] = true;

        if (f.IsUnique)
            result["IsUnique"] = true;

        return result;
    }

    private async Task DownloadJson()
    {
        if (string.IsNullOrEmpty(_jsonPreview)) return;
        var bytes = System.Text.Encoding.UTF8.GetBytes(_jsonPreview);
        await JS.InvokeVoidAsync("downloadFile", "schema_config.json",
            Convert.ToBase64String(bytes), "application/json");
    }

    private async Task CopyToClipboard()
    {
        if (string.IsNullOrEmpty(_jsonPreview)) return;
        var ok = await JS.InvokeAsync<bool>("copyToClipboard", _jsonPreview);
        Snackbar.Add(
            ok ? "Copied to clipboard" : "Couldn't copy — your browser blocked clipboard access.",
            ok ? Severity.Success : Severity.Warning);
    }

    private async Task Save()
    {
        if (string.IsNullOrEmpty(_jsonPreview)) return;
        _savedMessage = null;

        // Final guard: if any duplicate field ids slipped through (e.g. a
        // schema was loaded with duplicates already in it and the admin
        // didn't fix them), block the persist. The same data would crash
        // ReportBuilder / GridTemplateEditor on the very next render of
        // any consumer that loads it.
        var dupes = FindDuplicateFieldIds();
        if (dupes.Count > 0)
        {
            _savedSeverity = Severity.Error;
            _savedMessage = $"Cannot save: duplicate field id(s) — {string.Join(", ", dupes)}. Each id must be unique across the schema.";
            Snackbar.Add(_savedMessage, Severity.Error);
            return;
        }

        try
        {
            // Deserialize the preview into a SchemaConfig and route through the
            // store. In live mode it persists to RPT_schema_config; in mock
            // mode it updates the in-memory copy only. Either way Current
            // hot-swaps so every circuit sees the new schema immediately.
            var parsed = System.Text.Json.JsonSerializer.Deserialize<TleReportingDashboard.Web.Configuration.SchemaConfig>(
                _jsonPreview,
                new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
            if (parsed is null)
            {
                _savedSeverity = Severity.Error;
                _savedMessage = "Could not parse preview JSON as SchemaConfig.";
                Snackbar.Add("Save failed: invalid JSON preview.", Severity.Error);
                return;
            }

            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var updatedBy = authState.User.FindFirst("preferred_username")?.Value
                ?? authState.User.Identity?.Name ?? "schema-builder";

            if (_selectedConnectionId is not Guid targetConnectionId)
            {
                _savedSeverity = Severity.Error;
                _savedMessage = "Pick a connection before saving.";
                return;
            }
            await SchemaConfigStoreSvc.SaveAsync(parsed, targetConnectionId, updatedBy);

            // Success path — inline indicator flashes near the Save button.
            // _savedMessage is reserved for error display below.
            if (_saveIndicator is not null) _ = _saveIndicator.Flash("Saved");
        }
        catch (Exception ex)
        {
            _savedSeverity = Severity.Error;
            _savedMessage = $"Failed to save: {ex.Message}";
            Snackbar.Add($"Save failed: {ex.Message}", Severity.Error);
        }
    }

    private static string FormatLabel(string columnName)
    {
        // BORR_NAME → Borr Name, LOANAMT → Loanamt
        var parts = columnName.Split('_', StringSplitOptions.RemoveEmptyEntries);
        return string.Join(" ", parts.Select(p =>
            p.Length > 1
                ? char.ToUpper(p[0]) + p[1..].ToLower()
                : p.ToUpper()));
    }

    // Heuristic guesses for the Empower-era TLE schema. Only accepted if the
    // guessed domain is actually in the current connection's domain list —
    // otherwise we return empty so the user picks from their own list rather
    // than seeing a stray "Loan (legacy)" on every Postgres connection.
    private static string GuessDomain(string tableName, IEnumerable<string> availableDomains)
    {
        var guess = tableName.ToUpperInvariant() switch
        {
            _ when tableName.Contains("BORR", StringComparison.OrdinalIgnoreCase) => "Borrower",
            _ when tableName.Contains("PROP", StringComparison.OrdinalIgnoreCase) => "Property",
            _ when tableName.Contains("CONTACT", StringComparison.OrdinalIgnoreCase) => "Organization",
            _ when tableName.Contains("REGULAT", StringComparison.OrdinalIgnoreCase) => "Compliance",
            _ when tableName.Contains("INCOME", StringComparison.OrdinalIgnoreCase) => "Borrower",
            _ when tableName.Contains("CODES", StringComparison.OrdinalIgnoreCase) => "Loan",
            _ => "Loan"
        };
        return availableDomains.Any(d => string.Equals(d, guess, StringComparison.OrdinalIgnoreCase))
            ? guess
            : string.Empty;
    }

    public class FieldEntry
    {
        public string Id { get; set; } = string.Empty;
        public string Label { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public string Domain { get; set; } = string.Empty;
        public string DataType { get; set; } = "text";
        public string FieldType { get; set; } = "Dimension";
        public int? MaxLength { get; set; }
        public int? CodeSetId { get; set; }
        public string AllowedAggregationsStr { get; set; } = string.Empty;
        public string SourceTable { get; set; } = string.Empty;
        public string SourceColumn { get; set; } = string.Empty;
        public string? SqlExpression { get; set; }
        public string? SqlPreamble { get; set; }
        public List<string>? JoinIds { get; set; }  // References to existing joins from the Joins tab
        public string? SqlJoin { get; set; }
        public List<string>? LookupIds { get; set; }
        public string? RolesRequired { get; set; }
        public Dictionary<string, int>? ValueSortOrder { get; set; }
        // Display format — applied at render/export time, not in SQL.
        public string? Format { get; set; }
        // When true and the connection is Postgres with a display timezone
        // configured, the emitter wraps this field's expression with
        // `AT TIME ZONE '<tz>'`. Persisted to schema_config.json alongside
        // the rest of the field shape.
        public bool ApplyTimezoneConversion { get; set; }
        // Admin-asserted single-column uniqueness — bypasses the
        // information_schema constraint check, which can fail on locked-
        // down accounts. Drives the Sort By "(-)" marker and the OFFSET
        // pagination fallback when the live constraint lookup returns
        // nothing.
        public bool IsUnique { get; set; }
    }

    public class JoinEntry
    {
        public string Id { get; set; } = string.Empty;
        public string JoinType { get; set; } = "LEFT JOIN";
        public string TargetTable { get; set; } = string.Empty;
        public string Alias { get; set; } = string.Empty;
        public string OnClause { get; set; } = string.Empty;
        public string ExtraCondition { get; set; } = string.Empty;
        public bool UseRawSql { get; set; }
        public string RawSql { get; set; } = string.Empty;
        // Optional. The parent table this join depends on. When set, the
        // query builder picks this join in preference to others targeting
        // the same table whenever the report's primary table matches.
        public string SourceTable { get; set; } = string.Empty;
        public string SourceAlias { get; set; } = string.Empty;
        // Optional. Restricts this join to reports whose primary table
        // matches. Empty = generic (eligible for any primary), preserving
        // legacy behavior. When set, QueryBuilder filters out this join
        // for non-matching reports (PR-2) so a "lead → account" composite
        // doesn't collide with a generic "anything → account".
        public string PrimaryTable { get; set; } = string.Empty;
        public string PrimaryAlias { get; set; } = string.Empty;

        public string BuildSql()
        {
            if (UseRawSql && !string.IsNullOrWhiteSpace(RawSql))
                return RawSql;

            var target = string.IsNullOrWhiteSpace(Alias)
                ? TargetTable
                : $"{TargetTable} AS {Alias}";
            var sql = $"{JoinType} {target} ON {OnClause}";
            if (!string.IsNullOrWhiteSpace(ExtraCondition))
                sql += $" AND {ExtraCondition}";
            return sql;
        }
    }

    public enum TableType
    {
        LoanSingle,      // No WHICHBORR, no IDX — one row per loan
        LoanMultiple,    // IDX only — multiple rows per loan
        BorrowerSingle,  // WHICHBORR only — one row per borrower
        BorrowerMultiple // WHICHBORR + IDX — multiple rows per borrower
    }

    private string GetTableTypeLabel() => _selectedTableType switch
    {
        TableType.LoanSingle => "Loan Single",
        TableType.LoanMultiple => "Loan Multiple (IDX)",
        TableType.BorrowerSingle => "Borrower Single (WHICHBORR)",
        TableType.BorrowerMultiple => "Borrower Multiple (WHICHBORR+IDX)",
        _ => "Unknown"
    };

    private string GetTableTypeHint() => _selectedTableType switch
    {
        TableType.LoanSingle => "One row per loan. Join directly on LNKEY.",
        TableType.LoanMultiple => "Multiple rows per loan. Join needs IDX filter (e.g. IDX=1 for first record).",
        TableType.BorrowerSingle => "One row per borrower. Join needs WHICHBORR=1 for primary borrower.",
        TableType.BorrowerMultiple => "Multiple rows per borrower. Join needs WHICHBORR=1 AND IDX=1.",
        _ => ""
    };

    private Color GetTableTypeColor() => _selectedTableType switch
    {
        TableType.LoanSingle => Color.Success,
        TableType.LoanMultiple => Color.Warning,
        TableType.BorrowerSingle => Color.Info,
        TableType.BorrowerMultiple => Color.Error,
        _ => Color.Default
    };

    // ── Custom Filters ──

    private async Task OpenLookupDialog(LookupEntry? lookup, bool isNew)
    {
        var parameters = new DialogParameters
        {
            { "Lookup", lookup ?? new LookupEntry() },
            { "IsNew", isNew },
            { "ConnectionType", CurrentConnectionType }
        };
        var dialog = await DialogService.ShowAsync<LookupEditDialog>(
            isNew ? "Add Lookup" : "Edit Lookup", parameters,
            new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true });

        var result = await dialog.Result;
        if (result is null || result.Canceled || result.Data is not LookupEntry edited) return;

        if (isNew)
        {
            _lookups.Add(edited);
        }
        else if (lookup is not null)
        {
            lookup.Id = edited.Id;
            lookup.Label = edited.Label;
            lookup.SqlPreamble = edited.SqlPreamble;
            lookup.SqlJoin = edited.SqlJoin;
        }
        StateHasChanged();
    }

    private async Task OpenCustomFilterDialog(CustomFilterEntry? filter, bool isNew)
    {
        var parameters = new DialogParameters
        {
            { "Filter", filter ?? new CustomFilterEntry() },
            { "IsNew", isNew },
            { "AvailableJoins", _joins },
            { "AvailableLookups", _lookups.AsEnumerable() },
            { "AvailableDomains", _domainList.AsEnumerable() },
            { "ConnectionType", CurrentConnectionType }
        };
        var dialog = await DialogService.ShowAsync<CustomFilterEditDialog>(
            isNew ? "Add Custom Filter" : "Edit Custom Filter", parameters,
            new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true });

        var result = await dialog.Result;
        if (result is null || result.Canceled || result.Data is not CustomFilterEntry edited) return;

        if (isNew)
        {
            _customFilters.Add(edited);
        }
        else if (filter is not null)
        {
            filter.Id = edited.Id;
            filter.Label = edited.Label;
            filter.Description = edited.Description;
            filter.SqlPreamble = edited.SqlPreamble;
            filter.JoinId = edited.JoinId;
            filter.SqlJoin = edited.SqlJoin;
            filter.SqlCondition = edited.SqlCondition;
            filter.GroupName = edited.GroupName;
        }
        StateHasChanged();
    }

    public class LookupEntry
    {
        public string Id { get; set; } = string.Empty;
        public string Label { get; set; } = string.Empty;
        public string SqlPreamble { get; set; } = string.Empty;
        public string SqlJoin { get; set; } = string.Empty;
    }

    // One row in the Source Table / Alias picker. Value is what gets stored
    // on the field (matches the alias in JoinResolver / the FROM clause);
    // Label shows table + alias together so admins can tell which is which;
    // TableName is the fully-qualified schema.table used to load that table's
    // columns via SchemaBuilderService. Null TableName = the source was
    // extracted from raw SQL and we couldn't resolve a real table, so
    // column enumeration isn't available for it.
    public record SourceOption(string Value, string Label, string? TableName);

    public class CustomFilterEntry
    {
        public string Id { get; set; } = string.Empty;
        public string Label { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public string SqlPreamble { get; set; } = string.Empty;
        public string JoinId { get; set; } = string.Empty;  // Reference to an existing join from the Joins tab
        public string SqlJoin { get; set; } = string.Empty;  // Custom inline JOIN (used when JoinId is empty)
        public List<string>? LookupIds { get; set; }
        public string SqlCondition { get; set; } = string.Empty;
        // Group label used by the Report Builder to bucket presets in the UI.
        // Typically matches a Domain. Blank = "Misc".
        public string GroupName { get; set; } = string.Empty;
    }

    public void Dispose()
    {
        _editorScope?.Dispose();
        _editorScope = null;
    }
}
