@using TleReportingDashboard.Web.Services
@using TleReportingDashboard.Web.Models
@using MudBlazor
@inject IColumnWidthDefaultsService DefaultsSvc
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject ILogger<AdminColumnWidthsTab> Logger

<MudStack Spacing="3" Class="pa-2">
    <MudText Typo="Typo.body2" Color="Color.Secondary" Style="max-width: 820px;">
        Default min and max column widths per data type, in pixels. Two tiers:
        <strong>Compact</strong> (Report Viewer, Master Dashboard tile drill-down) keeps dense
        reports dense; <strong>Wide</strong> (Report Builder table view, Detail Viewer) sizes
        columns to their typical formatted-output width so dates / currency / etc. render
        without truncation. Per-field <code>MinWidth</code> overrides set in Schema Builder
        still win on top of these.
    </MudText>

    <MudPaper Elevation="0" Class="pa-3" Style="border: 1px solid #E8EAED; border-radius: 4px; max-width: 820px;">
        @if (_loading)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
        }
        else if (_defaults is not null)
        {
            <table style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr style="border-bottom: 1px solid #E2E8F0;">
                        <th style="text-align: left;  padding: 6px 8px; width: 140px;">Data Type</th>
                        <th style="text-align: right; padding: 6px 8px;">Compact Min</th>
                        <th style="text-align: right; padding: 6px 8px;">Compact Max</th>
                        <th style="text-align: right; padding: 6px 8px;">Wide Min</th>
                        <th style="text-align: right; padding: 6px 8px;">Wide Max</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var key in ColumnWidthDefaults.EditableTypes)
                    {
                        var k = key;
                        var entry = GetOrCreate(k);
                        <tr style="border-bottom: 1px solid #F1F5F9;">
                            <td style="padding: 6px 8px; font-weight: 500;">@k</td>
                            <td style="padding: 4px 8px;">
                                <MudNumericField T="int" @bind-Value="entry.CompactMin" Min="0" Max="2000"
                                                 Variant="Variant.Outlined" Margin="Margin.Dense" />
                            </td>
                            <td style="padding: 4px 8px;">
                                <MudNumericField T="int" @bind-Value="entry.CompactMax" Min="0" Max="2000"
                                                 Variant="Variant.Outlined" Margin="Margin.Dense" />
                            </td>
                            <td style="padding: 4px 8px;">
                                <MudNumericField T="int" @bind-Value="entry.WideMin" Min="0" Max="2000"
                                                 Variant="Variant.Outlined" Margin="Margin.Dense" />
                            </td>
                            <td style="padding: 4px 8px;">
                                <MudNumericField T="int" @bind-Value="entry.WideMax" Min="0" Max="2000"
                                                 Variant="Variant.Outlined" Margin="Margin.Dense" />
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <MudStack Row Justify="Justify.SpaceBetween" Class="mt-3">
                <MudButton Variant="Variant.Text" Color="Color.Default"
                           StartIcon="@Icons.Material.Outlined.RestartAlt"
                           Disabled="@_saving"
                           OnClick="ResetAsync">
                    Reset to defaults
                </MudButton>
                <MudStack Row Spacing="2">
                    <MudButton Variant="Variant.Outlined" Color="Color.Default"
                               StartIcon="@Icons.Material.Outlined.Refresh"
                               Disabled="@_saving"
                               OnClick="ReloadAsync">
                        Discard changes
                    </MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Outlined.Save"
                               Disabled="@_saving"
                               OnClick="SaveAsync">
                        Save
                    </MudButton>
                </MudStack>
            </MudStack>
        }
    </MudPaper>

    <MudText Typo="Typo.caption" Color="Color.Secondary" Style="max-width: 820px;">
        Changes take effect on the next page load (or after the user hits Refresh on a
        report). Aliases <code>money</code> ↔ <code>currency</code> and <code>int</code> ↔
        <code>integer</code> are kept in sync automatically.
    </MudText>
</MudStack>

@code {
    [Parameter] public string CurrentUserEmail { get; set; } = string.Empty;

    private ColumnWidthDefaults? _defaults;
    private bool _loading = true;
    private bool _saving;

    protected override async Task OnInitializedAsync() => await ReloadAsync();

    private async Task ReloadAsync()
    {
        _loading = true;
        try
        {
            // Service returns the cached instance — clone it so user edits
            // before Save don't mutate other consumers' in-memory copy.
            var live = await DefaultsSvc.GetAsync();
            _defaults = new ColumnWidthDefaults
            {
                Types = new Dictionary<string, ColumnWidthEntry>(
                    live.Types.ToDictionary(
                        kv => kv.Key,
                        kv => new ColumnWidthEntry
                        {
                            CompactMin = kv.Value.CompactMin,
                            CompactMax = kv.Value.CompactMax,
                            WideMin    = kv.Value.WideMin,
                            WideMax    = kv.Value.WideMax
                        }),
                    StringComparer.OrdinalIgnoreCase)
            };
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Loading column-width defaults failed");
            Snackbar.Add("Couldn't load column-width defaults.", Severity.Error);
            _defaults = ColumnWidthDefaults.Seed();
        }
        finally
        {
            _loading = false;
        }
    }

    private ColumnWidthEntry GetOrCreate(string key)
    {
        if (_defaults is null) _defaults = new ColumnWidthDefaults();
        if (!_defaults.Types.TryGetValue(key, out var entry))
        {
            entry = new ColumnWidthEntry();
            _defaults.Types[key] = entry;
        }
        return entry;
    }

    private async Task SaveAsync()
    {
        if (_defaults is null) return;
        // Quick sanity: Max should be >= Min in each tier. Don't reject —
        // some admins might intentionally collapse them — just warn.
        var weirdRows = new List<string>();
        foreach (var (key, e) in _defaults.Types)
        {
            if (e.CompactMax < e.CompactMin || e.WideMax < e.WideMin)
                weirdRows.Add(key);
        }
        if (weirdRows.Count > 0)
        {
            Snackbar.Add($"Max < Min on: {string.Join(", ", weirdRows)} — saved anyway.", Severity.Warning);
        }

        _saving = true;
        try
        {
            await Snackbar.RunAsync(Logger, "saving column-width defaults",
                () => DefaultsSvc.SaveAsync(_defaults, CurrentUserEmail),
                successMessage: "Column-width defaults saved.");
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task ResetAsync()
    {
        var ok = await DialogService.ShowMessageBoxAsync(new MessageBoxOptions
        {
            Title = "Reset to defaults?",
            Message = "This restores the built-in widths and discards any customizations. Continue?",
            YesText = "Reset",
            CancelText = "Cancel"
        });
        if (ok != true) return;

        _saving = true;
        try
        {
            await Snackbar.RunAsync(Logger, "resetting column-width defaults",
                () => DefaultsSvc.ResetToSeedAsync(CurrentUserEmail),
                successMessage: "Reset to built-in defaults.");
            await ReloadAsync();
        }
        finally
        {
            _saving = false;
        }
    }
}
