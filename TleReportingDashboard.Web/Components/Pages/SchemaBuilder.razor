    private void GenerateJson()
    {
        var config = new
        {
            Settings = new
            {
                MaxRowLimit = _maxRowLimit,
                CommandTimeoutSeconds = _commandTimeout,
                DefaultPageSize = _defaultPageSize,
                RelativeDateOperators = new object[]
                {
                    new { Id = "today", Label = "Today", SqlTemplate = "CAST(GETDATE() AS DATE)" },
                    new { Id = "yesterday", Label = "Yesterday", SqlTemplate = "DATEADD(day, -1, CAST(GETDATE() AS DATE))" },
                    new { Id = "last_7_days", Label = "Last 7 Days", SqlTemplate = "DATEADD(day, -7, CAST(GETDATE() AS DATE))" },
                    new { Id = "last_30_days", Label = "Last 30 Days", SqlTemplate = "DATEADD(day, -30, CAST(GETDATE() AS DATE))" },
                    new { Id = "current_month", Label = "Current Month", SqlTemplate = "DATEADD(month, DATEDIFF(month, 0, GETDATE()), 0)" },
                    new { Id = "last_month", Label = "Last Month", SqlTemplate = "DATEADD(month, DATEDIFF(month, 0, GETDATE()) - 1, 0)" },
                    new { Id = "ytd", Label = "Year to Date", SqlTemplate = "DATEFROMPARTS(YEAR(GETDATE()), 1, 1)" },
                    new { Id = "custom_range", Label = "Custom Range", SqlTemplate = (string?)null }
                }
            },
            // Carry the explicit Source/Target metadata through the export
            // JSON so JoinResolver can apply primary-table precedence on the
            // server. Nulled out for legacy joins that haven't been touched
            // since these fields were introduced — keeps the JSON tidy.
            Joins = _joins.Select(j => new
            {
                j.Id,
                Sql = j.BuildSql(),
                SourceTable = string.IsNullOrWhiteSpace(j.SourceTable) ? null : j.SourceTable,
                SourceAlias = string.IsNullOrWhiteSpace(j.SourceAlias) ? null : j.SourceAlias,
                TargetTable = string.IsNullOrWhiteSpace(j.TargetTable) ? null : j.TargetTable,
                TargetAlias = string.IsNullOrWhiteSpace(j.Alias) ? null : j.Alias,
                // PR-4. Primary scope. Nulled when blank so generic joins
                // stay tidy in the JSON; QueryBuilder treats null/empty as
                // "any primary" (legacy behavior).
                PrimaryTable = string.IsNullOrWhiteSpace(j.PrimaryTable) ? null : j.PrimaryTable,
                PrimaryAlias = string.IsNullOrWhiteSpace(j.PrimaryAlias) ? null : j.PrimaryAlias
            }),
            Fields = _fields.Select(f => BuildFieldOutput(f)),
            Lookups = _lookups.Select(lu =>
            {
                var obj = new Dictionary<string, object?> { ["Id"] = lu.Id, ["Label"] = lu.Label, ["SqlPreamble"] = lu.SqlPreamble };
                if (!string.IsNullOrWhiteSpace(lu.SqlJoin)) obj["SqlJoin"] = lu.SqlJoin;
                return obj;
            }),
            CustomFilters = _customFilters.Select(cf =>
            {
                var obj = new Dictionary<string, object?> { ["Id"] = cf.Id, ["Label"] = cf.Label };
                if (!string.IsNullOrWhiteSpace(cf.Description)) obj["Description"] = cf.Description;
                if (!string.IsNullOrWhiteSpace(cf.SqlPreamble)) obj["SqlPreamble"] = cf.SqlPreamble;
                if (!string.IsNullOrWhiteSpace(cf.JoinId)) obj["JoinId"] = cf.JoinId;
                if (!string.IsNullOrWhiteSpace(cf.SqlJoin)) obj["SqlJoin"] = cf.SqlJoin;
                if (cf.LookupIds is not null && cf.LookupIds.Count > 0) obj["LookupIds"] = cf.LookupIds;
                obj["SqlCondition"] = cf.SqlCondition;
                if (!string.IsNullOrWhiteSpace(cf.GroupName)) obj["GroupName"] = cf.GroupName;
                return obj;
            }),
            Domains = _domainList.OrderBy(d => d, StringComparer.OrdinalIgnoreCase).ToList()
        };

        _jsonPreview = System.Text.Json.JsonSerializer.Serialize(config, new System.Text.Json.JsonSerializerOptions
        {
            WriteIndented = true,
            DefaultIgnoreCondition = System.Text.Json.Serialization.JsonIgnoreCondition.WhenWritingNull
        });
    }

