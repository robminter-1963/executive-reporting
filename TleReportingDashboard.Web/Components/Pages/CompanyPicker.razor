@page "/"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.WebUtilities
@using TleReportingDashboard.Web.Services
@inject ICompanyRegistry CompanyRegistry
@inject IUserManagementService UserManagement
@inject IAdminService AdminService
@inject IAdminAccessService AdminAccess
@inject IUserPreferenceService PreferenceService
@inject IReportService ReportService
@inject INotificationService Notifications
@inject LandingGreetingState GreetingState
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject ILogger<CompanyPicker> Logger

<PageTitle>Companies - Executive Reporting Suite</PageTitle>

@* Scope body overflow so the picker owns vertical scrolling when there are
   many companies, rather than doubling up with the outer layout. *@
<HeadContent>
    <style>
        html, body { overflow-y: auto !important; overflow-x: hidden !important; }
    </style>
</HeadContent>

<MudContainer MaxWidth="MaxWidth.False" Style="margin-left: 15px; padding: 0 0 32px 0;">
    @if (_loading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
    }
    else if (_visible.Count == 0)
    {
        @* Two flavors of the empty state:
            1. "Not registered"  — the email isn't in RPT_users at all. Firm
               message: the site doesn't know them and access has to be
               created from scratch by an admin.
            2. "No access yet"   — they're registered but have no company
               grants. Lighter message: access is a grant away.
           Both surface the signed-in email so the user can quote it when
           asking the admin for access. *@
        <MudPaper Elevation="0" Class="pa-8" Style="border: 1px solid #E8EAED; border-radius: 8px; max-width: 640px; margin: 80px auto;">
            <MudStack AlignItems="AlignItems.Center" Spacing="3">
                @if (!_isRegistered)
                {
                    <MudIcon Icon="@Icons.Material.Outlined.Block" Color="Color.Error" Style="font-size: 64px;" />
                    <MudText Typo="Typo.h5" Style="font-weight: 600;">You do not have access to this site</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Style="text-align: center;">
                        Your account isn't registered here. Contact your administrator to request access.
                    </MudText>
                }
                else
                {
                    <MudIcon Icon="@Icons.Material.Outlined.Lock" Color="Color.Default" Style="font-size: 64px;" />
                    <MudText Typo="Typo.h5" Style="font-weight: 600;">No access yet</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Style="text-align: center;">
                        Your account isn't mapped to any company yet. Ask your administrator to grant access and try signing in again.
                    </MudText>
                }
                @if (!string.IsNullOrEmpty(_userEmail))
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        Signed in as <strong>@_userEmail</strong>
                    </MudText>
                }
            </MudStack>
        </MudPaper>
    }
    else
    {
        @* Personalized landing strip — same component as the per-company
           Master Dashboard. The All Companies picker IS the user's "home"
           when they have access to multiple companies, so the greeting
           lands here too. Once-per-circuit slot is CLAIMED on mount via
           GreetingState.HasShown (see OnInitializedAsync) so navigating
           from here to a Master Dashboard mid-display doesn't re-show. *@
        @if (_showGreeting)
        {
            <LandingGreeting DisplayName="@_userName"
                             LastSeenUtc="@_lastSeenUtc"
                             UpdatedSinceCount="@_updatedSinceLastVisit"
                             UnreadNotificationCount="@_unreadNotificationCount"
                             OnDismissed="HandleGreetingDismissed" />
        }
        <MudStack Spacing="4">
            <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Wrap="Wrap.Wrap">
                <MudStack Spacing="1">
                    <MudText Typo="Typo.h4" Style="font-weight: 600; color: #202124;">Select a company</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        Choose a company to open its dashboard.
                    </MudText>
                </MudStack>
                @* Batches dropdown — same control rendered in every
                   header surface. Self-hides when the user has nothing
                   to run, so non-batch users see no clutter. *@
                <BatchQuickAccess UserEmail="@_userEmail"
                                  UserId="@(_userId ?? string.Empty)"
                                  HasAnyAdminAccess="@_hasAnyAdminAccess"
                                  CanCreateBatches="@_canCreateBatches" />
            </MudStack>

            @* Uniform logo card grid. Admin-defined display_order drives the
               layout; ties resolve by name. Each card is keyed to the
               company id so Blazor diffs correctly when the order changes. *@
            <div class="company-grid">
                @foreach (var c in _visible)
                {
                    <MudPaper Elevation="1"
                              Class="company-card"
                              @key="c.Id"
                              @onclick="@(() => PickCompany(c))">
                        @* Tooltip wraps only the image/initials so the card
                           itself stays a flex container that vertically +
                           horizontally centers its single child. The tooltip
                           root renders inline-block, which flexbox treats
                           like any other child for alignment purposes. *@
                        <MudTooltip Text="@c.Name" Placement="Placement.Top">
                            @if (c.Logo is not null && c.Logo.Length > 0)
                            {
                                <img src="@BuildLogoDataUri(c)" alt="@c.Name" class="company-logo" />
                            }
                            else
                            {
                                @* Fallback when no logo has been uploaded:
                                   initials in a circle + a generic icon,
                                   with the full name as the tooltip. *@
                                <div class="company-initials">@GetInitials(c.Name)</div>
                            }
                        </MudTooltip>
                    </MudPaper>
                }
            </div>
        </MudStack>
    }
</MudContainer>

<style>
    @* Flex + wrap (instead of grid with fr columns) so the row of tiles
       centers on the page even when the count doesn't fill the viewport.
       Fixed card width keeps each tile the same size as the row wraps. *@
    .company-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 20px;
        justify-content: center;
    }
    .company-card {
        width: 240px;
        aspect-ratio: 3 / 2;
        cursor: pointer;
        /* Match Master Dashboard tiles: 12px corners + the same layered
           drop shadow so the picker reads as part of the same visual
           system. Hover keeps the existing lift; the resting shadow
           replaces MudPaper's Elevation default. */
        border-radius: 12px;
        box-shadow: 7px 7px 9px rgba(0, 0, 0, 0.20),
                    5px 5px 7px rgba(0, 0, 0, 0.14);
        /* Overshoot cubic-bezier gives the hover lift a little "hop" feel
           without a full keyframe animation — transform springs past the
           target position and settles. */
        transition: transform 0.25s cubic-bezier(0.175, 0.885, 0.32, 1.475),
                    box-shadow 0.25s ease;
        background: #A9A9A9;
        /* Centers the logo (or initials circle) vertically and horizontally
           inside the tile. Padding keeps the logo off the tile's edges. */
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px;
    }
    .company-card:hover {
        transform: translateY(-12px);
        box-shadow: 10px 14px 18px rgba(0, 0, 0, 0.24),
                    7px 9px 12px rgba(0, 0, 0, 0.18);
    }
    .company-logo {
        max-width: 100%;
        max-height: 100%;
        object-fit: contain;
    }
    .company-initials {
        width: 88px;
        height: 88px;
        border-radius: 50%;
        background: #E8EAED;
        color: #3C4043;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 28px;
        font-weight: 600;
        letter-spacing: 1px;
    }
</style>

@code {
    private bool _loading = true;
    private string _userEmail = string.Empty;
    private string? _userId;
    private string _userName = string.Empty;
    // Fed to LandingGreeting. _lastSeenUtc is read BEFORE the timestamp
    // bump; _updatedSinceLastVisit is computed against the user's
    // accessible companies (admins see across-the-org, non-admins only
    // their granted companies — same authorization model as _visible).
    private DateTime? _lastSeenUtc;
    private int _updatedSinceLastVisit;
    // Bell-icon unread count, fetched once at greeting time so the toast
    // chip can mirror the count the user would see on the bell.
    private int _unreadNotificationCount;
    // Local "the greeting is currently mounted on this page" flag.
    // True only when this page claimed the once-per-circuit slot.
    // Flipped off by the dismiss callback so the slide-up animation
    // can complete before the component is removed from the DOM.
    private bool _showGreeting;
    private List<CompanySummary> _visible = new();
    // Does the signed-in user have a row in RPT_users? Admins are always
    // treated as registered (they can get in even without a RPT_users row
    // via the legacy RPT_admins seed). Drives the "you do not have access
    // to this site" vs "no access yet" wording on the empty state.
    private bool _isRegistered = true;
    // Any admin authority (Global admin OR Administrator role OR admin-
    // section role). Fed to BatchQuickAccess so admins see every batch
    // in the header dropdown; non-admins see only their grants.
    private bool _hasAnyAdminAccess;
    // Per-user batch-authoring permission. Surfaces "+ New batch" in the
    // header dropdown so authors who can't reach the Report Library
    // (Viewers without shares) still have a way to create a batch.
    private bool _canCreateBatches;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            _userEmail = user.FindFirst("preferred_username")?.Value ?? string.Empty;
            _userId = user.FindFirst("oid")?.Value
                      ?? user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            // Display name for LandingGreeting — same claim resolution as
            // MasterDashboard so "Good morning, Rob" matches across pages.
            _userName = user.FindFirst("name")?.Value
                        ?? user.Identity?.Name
                        ?? _userEmail;

            // Drop hidden companies BEFORE the role-based filtering below.
            // is_hidden is intentionally global (admins included) — the
            // intent is "don't render this tile on the picker grid."
            // Admins who need to reach a hidden company can navigate
            // directly via /master-dashboard/{code} or the Admin →
            // Companies tab, both of which still surface hidden rows.
            var all = (await CompanyRegistry.GetActiveAsync())
                .Where(c => !c.IsHidden)
                .ToList();
            var isAdmin = AdminService.IsAdmin(_userEmail);
            // Roles with any admin-section access (Administrator, System
            // Support, etc.) bypass the per-company grant list — they need
            // to navigate to every company to do administrative work. Same
            // mental model as `is_admin` historically had; just generalized
            // to anyone whose role grants admin access.
            var hasAdminAccess = await AdminAccess.HasAnyAdminAccessAsync(_userEmail);
            _hasAnyAdminAccess = isAdmin || hasAdminAccess;

            if (isAdmin || hasAdminAccess)
            {
                _visible = all;
                _isRegistered = true;
            }
            else if (!string.IsNullOrEmpty(_userEmail))
            {
                // Non-admin / non-admin-section users only see companies
                // they've been granted access to. Access is email-keyed in
                // UserManagementService so it works even for pre-
                // provisioned users who haven't signed in yet.
                var userRow = await UserManagement.GetByEmailAsync(_userEmail);
                _isRegistered = userRow is not null;
                _canCreateBatches = userRow?.CanCreateBatches == true;

                var access = await UserManagement.GetCompanyAccessAsync(_userEmail);
                var allowedIds = access.Select(a => a.CompanyId).ToHashSet();
                _visible = all.Where(c => allowedIds.Contains(c.Id)).ToList();
            }
            else
            {
                _visible = new();
                _isRegistered = false;
            }

            // Single-company users can't reach the picker. Even with
            // ?all=1 forcing it, there's nothing to pick — auto-redirect
            // straight to their only company. This rule does NOT apply to
            // global admins or admin-section users: they see every active
            // company by design, so _visible.Count > 1 in the typical case
            // and the regular flow takes over.
            if (!isAdmin && !hasAdminAccess && _visible.Count == 1)
            {
                Navigation.NavigateTo($"/master-dashboard/{_visible[0].Code}", replace: true);
                return;
            }

            // Auto-redirect to last-visited company, but only when the URL
            // doesn't carry ?all=1 (the "show me the picker anyway" escape
            // hatch used by the Ralis logo and the breadcrumb).
            var query = QueryHelpers.ParseQuery(new Uri(Navigation.Uri).Query);
            var forcePicker = query.TryGetValue("all", out var v) && v.ToString() == "1";

            if (forcePicker && !string.IsNullOrEmpty(_userEmail))
            {
                // The user explicitly chose the "All Companies" view —
                // persist that as their preference so the next sign-in
                // lands here instead of auto-redirecting back into the
                // last-visited company. The flag is a separate column from
                // last_visited_company_id because the latter gets re-set
                // on every Master Dashboard load (including bookmarks /
                // session restore), which would clobber this choice.
                // PickCompany resets it back to false. Fire-and-forget; a
                // transient SQL hiccup shouldn't block the picker render.
                try { await UserManagement.SetPrefersCompanyPickerAsync(_userEmail, true); }
                catch (Exception ex) { Logger.LogWarning(ex, "Could not set PrefersCompanyPicker for {Email}", _userEmail); }
            }
            else if (!string.IsNullOrEmpty(_userEmail))
            {
                // forceRefresh=true bypasses the per-email cache for this
                // critical-redirect read. Cache writes have a tiny race
                // window — between SetPrefers's Invalidate and a
                // concurrent reader's in-flight factory completion, an
                // older snapshot can land back in the cache. The picker's
                // entire reason to read this field is to honor changes
                // made earlier in the session, so eat the extra DB query.
                var last = await UserManagement.GetByEmailAsync(_userEmail, forceRefresh: true);

                // Sticky picker preference wins over last-visited auto-redirect.
                if (last?.PrefersCompanyPicker == true)
                {
                    // Show the picker — user explicitly chose "All Companies"
                    // as their default. Stays on the picker even though
                    // last_visited_company_id may still hold a value from
                    // their most recent company navigation.
                }
                else if (last?.LastVisitedCompanyId is Guid lastId)
                {
                    var target = _visible.FirstOrDefault(c => c.Id == lastId);
                    if (target is not null)
                    {
                        // Stay on the loading spinner until the navigation
                        // actually transitions — otherwise Blazor's render
                        // pass after _loading=false would briefly paint the
                        // picker grid before the URL change takes effect,
                        // which is the "all-companies blink" the user sees.
                        Navigation.NavigateTo($"/master-dashboard/{target.Code}", replace: true);
                        return;
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "CompanyPicker load failed");
        }

        // Greeting plumbing. Only relevant when the picker actually
        // renders (we didn't redirect above), and only when no other
        // hosting page already claimed the once-per-circuit slot.
        // Claim it now so subsequent navigation to a Master Dashboard
        // (e.g., user clicks a tile a second after landing here) doesn't
        // re-show the strip. Mirrors MasterDashboard: capture OLD
        // timestamp, count reports updated since, fire-and-forget the
        // touch.
        if (!GreetingState.HasShown && !string.IsNullOrEmpty(_userId))
        {
            GreetingState.HasShown = true;
            _showGreeting = true;
            try
            {
                var prefs = await PreferenceService.GetPreferencesAsync(_userId);
                _lastSeenUtc = prefs.LastMasterDashboardSeen;
                if (_lastSeenUtc is not null)
                {
                    var allowedCompanyIds = _visible.Select(c => c.Id).ToHashSet();
                    if (allowedCompanyIds.Count > 0)
                    {
                        var allReports = await ReportService.GetAllReportsAsync();
                        _updatedSinceLastVisit = allReports.Count(r =>
                            allowedCompanyIds.Contains(r.CompanyId)
                            && r.UpdatedAt > _lastSeenUtc.Value);
                    }
                }
                _ = PreferenceService.TouchLastMasterDashboardSeenAsync(_userId);
                // Unread bell count — separate try inside so a notifications
                // table miss (pre-migration) or DB blip doesn't suppress
                // the rest of the greeting payload above.
                try
                {
                    if (!string.IsNullOrEmpty(_userEmail))
                        _unreadNotificationCount = await Notifications.GetUnreadCountAsync(_userEmail);
                }
                catch (Exception nex)
                {
                    Logger.LogDebug(nex, "Unread notification count fetch failed on CompanyPicker");
                }
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Greeting load failed on CompanyPicker");
            }
        }

        // Only reached when we're NOT redirecting — flip the spinner off so
        // the picker / empty state can paint. The redirect path returns
        // early above, leaving _loading = true so the spinner persists
        // until the new page swaps in.
        _loading = false;
    }

    private void HandleGreetingDismissed()
    {
        // GreetingState.HasShown was already set on mount — no further
        // action there. Just unmount locally so the slide-up animation
        // can complete and the component can clean up its timer.
        _showGreeting = false;
        StateHasChanged();
    }

    private async Task PickCompany(CompanySummary c)
    {
        // Picking a specific company from the picker is the user's signal
        // that they're back to per-company defaults — clear the sticky
        // "always show the picker" flag so the next sign-in auto-redirects
        // again. Last-visited is saved on the dashboard page's load rather
        // than here, keeping the write next to the thing it tracks.
        if (!string.IsNullOrEmpty(_userEmail))
        {
            try { await UserManagement.SetPrefersCompanyPickerAsync(_userEmail, false); }
            catch (Exception ex) { Logger.LogWarning(ex, "Could not reset PrefersCompanyPicker for {Email}", _userEmail); }
        }
        Navigation.NavigateTo($"/master-dashboard/{c.Code}");
    }

    private static string BuildLogoDataUri(CompanySummary c)
    {
        var mime = string.IsNullOrEmpty(c.LogoContentType) ? "image/png" : c.LogoContentType;
        return $"data:{mime};base64,{Convert.ToBase64String(c.Logo!)}";
    }

    private static string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        if (parts.Length == 1) return parts[0][..Math.Min(2, parts[0].Length)].ToUpperInvariant();
        return $"{parts[0][0]}{parts[^1][0]}".ToUpperInvariant();
    }
}
