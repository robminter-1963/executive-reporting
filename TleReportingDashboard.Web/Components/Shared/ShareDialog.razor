@inject ISharingService SharingService
@inject INotificationService Notifications
@inject ISnackbar Snackbar
@inject ILogger<ShareDialog> Logger
@inject IDialogService DialogService

@* Share dialog. Add / Revoke persist to the service immediately, so
   the only unsaved state is a half-typed entry in the "new share email"
   field. IsDirty reflects exactly that, so an accidental Esc / backdrop
   click prompts the user before discarding their typed input. Callers
   must open with DialogOptions { BackdropClick = false,
   CloseOnEscapeKey = false } so backdrop / Esc are routed through
   TryCancelAsync. *@

<MudDialog>
    <TitleContent>
        <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
            <MudIcon Icon="@Icons.Material.Outlined.Share" />
            <MudText Typo="Typo.h6">Share Report</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3" Style="min-width: 420px;">
            @if (!string.IsNullOrWhiteSpace(ReportName))
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Share "@ReportName" with other users or groups.
                </MudText>
            }

            @* Add new share *@
            <MudStack Row AlignItems="AlignItems.End" Spacing="2">
                <MudTextField @bind-Value="_newShareEmail" Label="User email or name"
                              Variant="Variant.Outlined" Margin="Margin.Dense"
                              Style="flex: 1;"
                              Placeholder="Enter email address..." />
                <MudSelect T="string" @bind-Value="_newSharePermission" Label="Permission"
                           Variant="Variant.Outlined" Margin="Margin.Dense"
                           Style="max-width: 130px;" Dense>
                    <MudSelectItem Value="@("viewer")">Viewer</MudSelectItem>
                    <MudSelectItem Value="@("editor")">Editor</MudSelectItem>
                </MudSelect>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Medium"
                           OnClick="AddShare"
                           Disabled="@(string.IsNullOrWhiteSpace(_newShareEmail) || _isSaving)">
                    @if (_isSaving)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    }
                    Share
                </MudButton>
            </MudStack>

            <MudDivider />

            @if (_isLoadingShares)
            {
                <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
            }

            @* Current shares list *@
            @if (_shares.Any())
            {
                <MudText Typo="Typo.subtitle2" Style="font-weight: 600;">Shared with</MudText>
                <MudList T="ReportShare" Dense>
                    @foreach (var share in _shares)
                    {
                        <MudListItem T="ReportShare">
                            <MudStack Row AlignItems="AlignItems.Center"
                                       Justify="Justify.SpaceBetween" Style="width: 100%;">
                                <MudStack Spacing="0">
                                    <MudText Typo="Typo.body2">@share.SharedWithId</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        @share.SharedWithType
                                        &mdash;
                                        @(share.Permission == "editor" ? "Can edit" : "View only")
                                    </MudText>
                                </MudStack>
                                <MudIconButton Icon="@Icons.Material.Outlined.PersonRemove"
                                               Size="Size.Small" Color="Color.Error"
                                               OnClick="() => RevokeShare(share)"
                                               title="Revoke access" />
                            </MudStack>
                        </MudListItem>
                    }
                </MudList>
            }
            else if (!_isLoadingShares)
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="pa-2">
                    This report is not shared with anyone yet.
                </MudText>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="TryCancelAsync">Cancel</MudButton>
        <MudButton OnClick="Done" Variant="Variant.Filled" Color="Color.Primary">
            Done
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance? MudDialog { get; set; }
    [Parameter] public Guid ReportId { get; set; }
    [Parameter] public string ReportName { get; set; } = string.Empty;
    [Parameter] public string CurrentUserId { get; set; } = string.Empty;
    [Parameter] public List<ReportShare> ExistingShares { get; set; } = new();

    private List<ReportShare> _shares = new();
    private string _newShareEmail = string.Empty;
    private string _newSharePermission = "viewer";
    private bool _isLoadingShares;
    private bool _isSaving;

    protected override async Task OnInitializedAsync()
    {
        if (ExistingShares.Any())
        {
            _shares = ExistingShares.Select(s => new ReportShare
            {
                Id = s.Id,
                ReportId = s.ReportId,
                SharedWithId = s.SharedWithId,
                SharedWithType = s.SharedWithType,
                Permission = s.Permission,
                SharedById = s.SharedById,
                CreatedAt = s.CreatedAt
            }).ToList();
        }
        else
        {
            _isLoadingShares = true;
            try
            {
                _shares = await SharingService.GetSharesForReportAsync(ReportId);
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Failed to load shares: {ex.Message}", Severity.Error);
            }
            finally
            {
                _isLoadingShares = false;
            }
        }
    }

    private async Task AddShare()
    {
        if (string.IsNullOrWhiteSpace(_newShareEmail)) return;

        // Prevent duplicate shares for the same user
        if (_shares.Any(s => s.SharedWithId.Equals(_newShareEmail, StringComparison.OrdinalIgnoreCase)))
            return;

        _isSaving = true;
        try
        {
            var share = new ReportShare
            {
                Id = Guid.NewGuid(),
                ReportId = ReportId,
                SharedWithId = _newShareEmail.Trim(),
                SharedWithType = "user",
                Permission = _newSharePermission,
                SharedById = CurrentUserId,
                CreatedAt = DateTime.UtcNow
            };

            var saved = await SharingService.ShareReportAsync(share);
            _shares.Add(saved);

            // Notify the recipient. Fire-and-forget — share itself succeeded,
            // a failed notification shouldn't roll back the share. Logged on
            // failure so admins can audit.
            try
            {
                await Notifications.CreateAsync(
                    userEmail:          _newShareEmail.Trim(),
                    kind:               NotificationKinds.ReportShared,
                    title:              $"\"{ReportName}\" was shared with you",
                    body:               $"You now have {_newSharePermission} access. Open it from the Report Library or follow the link.",
                    linkUrl:            $"/viewer/{ReportId}",
                    relatedEntityType:  "report",
                    relatedEntityId:    ReportId.ToString());
            }
            catch (Exception nex)
            {
                Logger.LogWarning(nex, "Share saved but notification dispatch failed for {Email}", _newShareEmail);
            }

            _newShareEmail = string.Empty;
            _newSharePermission = "viewer";
        }
        catch (Exception ex)
        {
            Snackbar.Add(FriendlyError.FromException(ex, Logger, "sharing report"), Severity.Error);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task RevokeShare(ReportShare share)
    {
        if (await Snackbar.RunAsync(Logger, "revoking share",
                () => SharingService.RevokeShareAsync(share.Id, CurrentUserId)))
        {
            _shares.Remove(share);
            // Severity.Info (not Success) — revoke confirmation is neutral, not celebratory.
            Snackbar.Add("Share revoked.", Severity.Info);
        }
    }

    private void Done()
    {
        MudDialog?.Close(DialogResult.Ok(_shares));
    }

    // Adds and revokes persist immediately to the service, so the only
    // genuinely unsaved state in this dialog is whatever the user has
    // typed into the new-share email field but not yet clicked "Share"
    // on. Treating that as the dirty signal lets the prompt fire when
    // it actually matters.
    private bool IsDirty => !string.IsNullOrWhiteSpace(_newShareEmail);

    // Routes every dismiss path (Cancel button, Esc, backdrop click)
    // through the unsaved-changes prompt. "Save" here means "add the
    // pending entry"; "DontSave" closes without adding it; "Cancel"
    // keeps the dialog open so the user can finish typing.
    private async Task TryCancelAsync() =>
        await UnsavedChangesPrompt.TryCancelAsync(DialogService, MudDialog, IsDirty,
            saveAsync: async () =>
            {
                await AddShare();
                // After Add succeeds the email field is cleared, so
                // IsDirty flips false; close out cleanly. If AddShare
                // failed, _newShareEmail is preserved — stay open so
                // the user can fix the input or explicitly dismiss.
                if (!IsDirty) MudDialog?.Close(DialogResult.Ok(_shares));
            });
}
