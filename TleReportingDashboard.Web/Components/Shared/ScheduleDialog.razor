@using TleReportingDashboard.Web.Services
@using TleReportingDashboard.Web.Models
@inject IReportService ReportService
@inject ITeamSourceService TeamSource
@inject IDialogService DialogService

@* Multi-field schedule dialog. Initial state is captured once on init
   into _initialSnapshot (JSON of all editable fields); IsDirty compares
   the current snapshot byte-wise. Callers must open with DialogOptions
   { BackdropClick = false, CloseOnEscapeKey = false } so backdrop / Esc
   are routed through TryCancelAsync. *@

<MudDialog>
    <TitleContent>
        <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
            <MudIcon Icon="@Icons.Material.Outlined.Schedule" />
            <MudText Typo="Typo.h6">
                @(ExistingSchedule is not null ? "Edit Schedule" : "New Schedule")
            </MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3" Style="min-width: 560px; max-width: 620px;">

            @* ── General ── *@
            <MudText Typo="Typo.subtitle2" Style="font-weight: 600;">General</MudText>

            <MudTextField @bind-Value="_subject" Label="Subject" Variant="Variant.Outlined"
                          Margin="Margin.Dense" Required
                          RequiredError="Subject is required."
                          Placeholder="e.g. Weekly Loan Pipeline Report" />

            @* ── Recipients ── *@
            <MudDivider />
            <MudText Typo="Typo.subtitle2" Style="font-weight: 600;">Recipients</MudText>

            <MudRadioGroup T="ScheduleKind" @bind-Value="_kind">
                <MudRadio T="ScheduleKind" Value="ScheduleKind.Individual" Color="Color.Primary">
                    <strong>Individual</strong> — one personalized, scope-filtered copy per team member
                </MudRadio>
                <MudRadio T="ScheduleKind" Value="ScheduleKind.Distribution" Color="Color.Primary">
                    <strong>Distribution</strong> — one email to a shared mailbox / dist-list address
                </MudRadio>
            </MudRadioGroup>

            @if (_kind == ScheduleKind.Individual)
            {
                @* Individual: pick a Team Builder team on the report's
                   connection. The Worker fan-out resolves each member's
                   email + role at fire time and applies their per-role
                   scope rule, so admins on the team get the unfiltered
                   view and self-scoped agents get their own loans. *@
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    Each team member receives a personalized export filtered by their role's scope rule.
                    Members not registered as app users on the report's connection are skipped with a logged warning.
                </MudText>

                @if (_reportConnectionId is null)
                {
                    <MudAlert Severity="Severity.Warning" Dense>
                        This report has no connection set, so a team can't be picked. Save the report with a connection first.
                    </MudAlert>
                }
                else if (_loadingTeams)
                {
                    <MudStack Row Spacing="2" AlignItems="AlignItems.Center">
                        <MudProgressCircular Indeterminate Size="Size.Small" />
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Loading teams…</MudText>
                    </MudStack>
                }
                else if (_availableTeams.Count == 0)
                {
                    <MudAlert Severity="Severity.Info" Dense>
                        No teams returned by this connection's Team Builder configuration.
                        Configure <strong>Teams SQL</strong> in Admin → Team Builder.
                    </MudAlert>
                }
                else
                {
                    <MudSelect T="int?" @bind-Value="_teamId" Label="Team"
                               Variant="Variant.Outlined" Margin="Margin.Dense" Dense>
                        @* Sort in-foreach so a freshly-added team in
                           Team Builder shows up alphabetically without
                           re-fetching the list. *@
                        @foreach (var t in _availableTeams.OrderBy(t => t.TeamName ?? $"team {t.TeamId}", StringComparer.OrdinalIgnoreCase))
                        {
                            <MudSelectItem T="int?" Value="@((int?)t.TeamId)">
                                @(t.TeamName ?? $"team {t.TeamId}")
                                @(string.IsNullOrEmpty(t.TeamType) ? "" : $" · {t.TeamType}")
                            </MudSelectItem>
                        }
                    </MudSelect>

                    @* Fan-out sub-mode. Members preserves the legacy "one
                       email per team member" behavior; Manager sends a
                       single email to the team's manager (scoped to the
                       team's roll-up); Both delivers to manager AND every
                       member. The "all-access" exception applies to the
                       Manager / Both branches: a manager whose role grants
                       full access receives the unfiltered report. *@
                    @if (_teamId is not null)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Send to</MudText>
                        <MudRadioGroup T="TeamFanout" @bind-Value="_teamFanout" Class="mb-1">
                            <MudRadio T="TeamFanout" Value="TeamFanout.Members" Color="Color.Primary">
                                <strong>Members</strong> — one personalized email per team member
                            </MudRadio>
                            <MudRadio T="TeamFanout" Value="TeamFanout.Manager" Color="Color.Primary">
                                <strong>Manager only</strong> — single email to the team manager (full team data)
                            </MudRadio>
                            <MudRadio T="TeamFanout" Value="TeamFanout.Both" Color="Color.Primary">
                                <strong>Both</strong> — manager <em>and</em> each member
                            </MudRadio>
                        </MudRadioGroup>
                    }

                    @if (_teamId is not null)
                    {
                        <MudButton Variant="Variant.Text" Size="Size.Small"
                                   StartIcon="@Icons.Material.Outlined.People"
                                   OnClick="ToggleMembersPreview">
                            @(_showMembers ? "Hide members" : "Preview members")
                        </MudButton>
                        @if (_showMembers)
                        {
                            @if (_loadingMembers)
                            {
                                <MudStack Row Spacing="2" AlignItems="AlignItems.Center">
                                    <MudProgressCircular Indeterminate Size="Size.Small" />
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">Loading members…</MudText>
                                </MudStack>
                            }
                            else if (!string.IsNullOrEmpty(_membersError))
                            {
                                <MudAlert Severity="Severity.Error" Dense>@_membersError</MudAlert>
                            }
                            else if (MembersForSelected().Count == 0)
                            {
                                <MudAlert Severity="Severity.Info" Dense>
                                    No members returned for this team — the schedule will fail at fire time.
                                </MudAlert>
                            }
                            else
                            {
                                <MudPaper Elevation="0" Style="border: 1px solid #E8EAED; border-radius: 4px; max-height: 200px; overflow-y: auto;">
                                    <MudTable Items="MembersForSelected()" Dense T="TeamMemberRecord" Class="pa-0">
                                        <HeaderContent>
                                            <MudTh Style="width: 200px;">Login</MudTh>
                                            <MudTh>Name</MudTh>
                                        </HeaderContent>
                                        <RowTemplate>
                                            <MudTd><code>@context.MemberExtId</code></MudTd>
                                            <MudTd>@(string.IsNullOrEmpty(context.MemberName) ? "—" : context.MemberName)</MudTd>
                                        </RowTemplate>
                                    </MudTable>
                                </MudPaper>
                            }
                        }
                    }
                }
            }
            else
            {
                @* Distribution: one shared address. The mail server fans
                   out to its members; we never see the member list. No
                   per-recipient scoping applies — the saved report's own
                   filters are the only filtering. *@
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    The saved report's filters are the only filtering applied. Scope rules cannot be applied to a shared mailbox.
                </MudText>

                <MudTextField @bind-Value="_distEmail" Label="Distribution email"
                              Variant="Variant.Outlined" Margin="Margin.Dense"
                              Required RequiredError="Distribution email is required."
                              Placeholder="loanteam@ralisservices.com" />
            }

            @* ── Trigger ── *@
            <MudDivider />
            <MudText Typo="Typo.subtitle2" Style="font-weight: 600;">Trigger</MudText>

            <MudStack Row Spacing="2">
                <MudSelect T="string" @bind-Value="_type" Label="Type"
                           Variant="Variant.Outlined" Margin="Margin.Dense" Dense
                           Style="flex: 1;">
                    <MudSelectItem Value="@("OneTime")">One time</MudSelectItem>
                    <MudSelectItem Value="@("Daily")">Daily</MudSelectItem>
                    <MudSelectItem Value="@("Weekly")">Weekly</MudSelectItem>
                    <MudSelectItem Value="@("Monthly")">Monthly</MudSelectItem>
                </MudSelect>

                <MudTimePicker @bind-Time="_time" Label="Time" Variant="Variant.Outlined"
                               Margin="Margin.Dense" AmPm Style="flex: 1;" />
            </MudStack>

            @* Daily: recur every N days *@
            @if (_type == "Daily")
            {
                <MudNumericField T="int" @bind-Value="_interval" Label="Recur every (days)"
                                 Variant="Variant.Outlined" Margin="Margin.Dense"
                                 Min="1" Max="365" />
            }

            @* Weekly: recur every N weeks + days of week *@
            @if (_type == "Weekly")
            {
                <MudNumericField T="int" @bind-Value="_interval" Label="Recur every (weeks)"
                                 Variant="Variant.Outlined" Margin="Margin.Dense"
                                 Min="1" Max="52" />

                <MudText Typo="Typo.caption" Color="Color.Secondary">Run on:</MudText>
                <div style="display: flex; flex-wrap: wrap; gap: 4px;">
                    @foreach (var day in Enum.GetValues<DayOfWeek>())
                    {
                        var d = day;
                        var selected = _daysOfWeek.Contains(d);
                        <MudChip T="string"
                                 Variant="@(selected ? Variant.Filled : Variant.Outlined)"
                                 Color="@(selected ? Color.Primary : Color.Default)"
                                 Size="Size.Small"
                                 OnClick="() => ToggleDayOfWeek(d)">
                            @d.ToString()[..3]
                        </MudChip>
                    }
                </div>
            }

            @* Monthly: day-of-month OR ordinal-weekday *@
            @if (_type == "Monthly")
            {
                <MudRadioGroup T="string" @bind-Value="_monthlyMode">
                    <MudRadio T="string" Value="@("DaysOfMonth")" Color="Color.Primary">Days of month</MudRadio>
                    <MudRadio T="string" Value="@("Ordinal")" Color="Color.Primary">Nth weekday</MudRadio>
                </MudRadioGroup>

                @if (_monthlyMode == "DaysOfMonth")
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Select day(s) of month:</MudText>
                    <div style="display: flex; flex-wrap: wrap; gap: 4px;">
                        @for (int d = 1; d <= 31; d++)
                        {
                            var day = d;
                            var selected = _daysOfMonth.Contains(day);
                            <MudChip T="string"
                                     Variant="@(selected ? Variant.Filled : Variant.Outlined)"
                                     Color="@(selected ? Color.Primary : Color.Default)"
                                     Size="Size.Small"
                                     OnClick="() => ToggleDayOfMonth(day)">
                                @day
                            </MudChip>
                        }
                    </div>
                }
                else
                {
                    <MudStack Row Spacing="2">
                        <MudSelect T="string" @bind-Value="_monthlyOrdinal" Label="Occurrence"
                                   Variant="Variant.Outlined" Margin="Margin.Dense" Dense
                                   Style="flex: 1;">
                            <MudSelectItem Value="@("First")">First</MudSelectItem>
                            <MudSelectItem Value="@("Second")">Second</MudSelectItem>
                            <MudSelectItem Value="@("Third")">Third</MudSelectItem>
                            <MudSelectItem Value="@("Fourth")">Fourth</MudSelectItem>
                            <MudSelectItem Value="@("Last")">Last</MudSelectItem>
                        </MudSelect>
                        <MudSelect T="DayOfWeek" @bind-Value="_monthlyDayOfWeek" Label="Day of week"
                                   Variant="Variant.Outlined" Margin="Margin.Dense" Dense
                                   Style="flex: 1;">
                            @foreach (var day in Enum.GetValues<DayOfWeek>())
                            {
                                <MudSelectItem Value="@day">@day</MudSelectItem>
                            }
                        </MudSelect>
                    </MudStack>
                }
            }

            @* ── Date range ── *@
            <MudDivider />
            <MudText Typo="Typo.subtitle2" Style="font-weight: 600;">Date range</MudText>

            <MudStack Row Spacing="2">
                <MudDatePicker @bind-Date="_startDate" Label="Start" Variant="Variant.Outlined"
                               Margin="Margin.Dense" Style="flex: 1;" />
                <MudDatePicker @bind-Date="_endDate" Label="Expire (optional)" Variant="Variant.Outlined"
                               Margin="Margin.Dense" Style="flex: 1;" Clearable />
            </MudStack>

            @* ── Delivery ── *@
            <MudDivider />
            <MudText Typo="Typo.subtitle2" Style="font-weight: 600;">Delivery</MudText>

            <MudSelect T="string" @bind-Value="_attachmentFormat" Label="Attachment format"
                       Variant="Variant.Outlined" Margin="Margin.Dense" Dense>
                <MudSelectItem Value="@("xlsx")">Excel (.xlsx)</MudSelectItem>
                <MudSelectItem Value="@("csv")">CSV</MudSelectItem>
                <MudSelectItem Value="@("pdf")">PDF</MudSelectItem>
            </MudSelect>

            <MudSwitch T="bool" @bind-Value="_includePreview" Label="Include inline preview in email"
                       Color="Color.Primary" />

            @* ── Summary ── *@
            <MudAlert Severity="Severity.Info" Dense Variant="Variant.Outlined">
                <strong>@ScheduleCron.Describe(BuildPattern())</strong>
                @if (_startDate.HasValue) { @($" — starts {_startDate:MMM d, yyyy}") }
                @if (_endDate.HasValue) { @($", ends {_endDate:MMM d, yyyy}") }
            </MudAlert>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="TryCancelAsync">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Save"
                   Disabled="@(!IsValid)">
            Save
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance? MudDialog { get; set; }
    [Parameter] public Guid ReportId { get; set; }
    [Parameter] public string ReportName { get; set; } = string.Empty;
    [Parameter] public string UserId { get; set; } = string.Empty;
    [Parameter] public string UserEmail { get; set; } = string.Empty;
    [Parameter] public ReportSchedule? ExistingSchedule { get; set; }

    private string _subject = string.Empty;
    // Deprecated string fields preserved so an existing schedule round-
    // trips its old values back into the DB without loss while the
    // codebase finishes migrating to Kind+Team / Kind+DistEmail. Not
    // surfaced in the UI any more.
    private string _recipients = string.Empty;
    private string _ccRecipients = string.Empty;
    private string _bccRecipients = string.Empty;

    // Kind + per-kind state. Defaults: Individual, since the most common
    // request driving this feature is "send each agent their own loans."
    private ScheduleKind _kind = ScheduleKind.Individual;
    private int? _teamId;
    private string _distEmail = string.Empty;
    // Default to Members so the dialog matches the historical behavior
    // every existing schedule has — saving a new dialog without touching
    // the radio doesn't quietly switch fan-out.
    private TeamFanout _teamFanout = TeamFanout.Members;

    // Loaded once on init from the saved report so the team picker can
    // query Team Builder for that connection without making the caller
    // pass it in.
    private Guid? _reportConnectionId;
    private List<TeamRecord> _availableTeams = new();
    private bool _loadingTeams;

    // Lazy members preview state — same pattern as the Team Builder tab.
    private bool _showMembers;
    private bool _loadingMembers;
    private List<TeamMemberRecord>? _allMembers;
    private string? _membersError;

    private string _type = "Daily";
    private int _interval = 1;
    private TimeSpan? _time = new TimeSpan(8, 0, 0);
    private HashSet<DayOfWeek> _daysOfWeek = new();
    private HashSet<int> _daysOfMonth = new();
    private string _monthlyMode = "DaysOfMonth";
    private string _monthlyOrdinal = "First";
    private DayOfWeek _monthlyDayOfWeek = DayOfWeek.Monday;

    private DateTime? _startDate = DateTime.Today;
    private DateTime? _endDate;

    private string _attachmentFormat = "xlsx";
    private bool _includePreview = true;

    // Serialized snapshot of all editable fields at the moment we
    // finished hydrating from ExistingSchedule (or defaults for a new
    // schedule). Compared byte-wise against the current state to drive
    // the unsaved-changes prompt.
    private string _initialSnapshot = string.Empty;

    private bool IsDirty =>
        !string.Equals(_initialSnapshot, BuildSnapshot(), StringComparison.Ordinal);

    private string BuildSnapshot() => System.Text.Json.JsonSerializer.Serialize(new
    {
        Subject = _subject ?? string.Empty,
        Recipients = _recipients ?? string.Empty,
        CcRecipients = _ccRecipients ?? string.Empty,
        BccRecipients = _bccRecipients ?? string.Empty,
        Kind = _kind,
        TeamId = _teamId,
        TeamFanout = _teamFanout,
        DistEmail = _distEmail ?? string.Empty,
        Type = _type,
        Interval = _interval,
        Time = _time?.ToString(),
        DaysOfWeek = _daysOfWeek.OrderBy(d => d).ToList(),
        DaysOfMonth = _daysOfMonth.OrderBy(d => d).ToList(),
        MonthlyMode = _monthlyMode,
        MonthlyOrdinal = _monthlyOrdinal,
        MonthlyDayOfWeek = _monthlyDayOfWeek,
        StartDate = _startDate,
        EndDate = _endDate,
        AttachmentFormat = _attachmentFormat,
        IncludePreview = _includePreview
    });

    private bool IsValid =>
        !string.IsNullOrWhiteSpace(_subject)
        && _time.HasValue
        && (_type != "Weekly" || _daysOfWeek.Count > 0)
        && (_type != "Monthly" || _monthlyMode == "Ordinal" || _daysOfMonth.Count > 0)
        && (_kind != ScheduleKind.Individual || (_reportConnectionId is not null && _teamId is not null))
        && (_kind != ScheduleKind.Distribution || !string.IsNullOrWhiteSpace(_distEmail));

    protected override async Task OnInitializedAsync()
    {
        if (ExistingSchedule is not null)
        {
            _subject = ExistingSchedule.Subject;
            _recipients = ExistingSchedule.Recipients ?? string.Empty;
            _ccRecipients = ExistingSchedule.CcRecipients ?? string.Empty;
            _bccRecipients = ExistingSchedule.BccRecipients ?? string.Empty;
            _attachmentFormat = ExistingSchedule.AttachmentFormat;
            _includePreview = ExistingSchedule.IncludePreview;
            _startDate = ExistingSchedule.StartDate;
            _endDate = ExistingSchedule.EndDate;
            _kind = ExistingSchedule.Kind;
            _teamId = ExistingSchedule.TeamId;
            _teamFanout = ExistingSchedule.TeamFanout;
            _distEmail = ExistingSchedule.DistEmail ?? string.Empty;

            var pattern = SchedulePattern.FromJson(ExistingSchedule.SchedulePatternJson);
            _type = pattern.Type;
            _interval = pattern.Interval;
            _time = new TimeSpan(pattern.Hour, pattern.Minute, 0);
            _daysOfWeek = new HashSet<DayOfWeek>(pattern.DaysOfWeek);
            _daysOfMonth = new HashSet<int>(pattern.DaysOfMonth);
            if (!string.IsNullOrEmpty(pattern.MonthlyOrdinal))
            {
                _monthlyMode = "Ordinal";
                _monthlyOrdinal = pattern.MonthlyOrdinal;
                _monthlyDayOfWeek = pattern.MonthlyDayOfWeek ?? DayOfWeek.Monday;
            }
        }

        // Pull the report's connection so the team picker has a target
        // for QueryTeamsAsync. Falls back to the existing schedule's
        // saved team_connection_id when the report has been re-pointed
        // since the schedule was last saved (rare but possible).
        var report = await ReportService.GetReportByIdAsync(ReportId);
        _reportConnectionId = report?.ConnectionId
                              ?? ExistingSchedule?.TeamConnectionId;

        if (_reportConnectionId is Guid cid)
        {
            await LoadTeamsAsync(cid);
        }

        // Capture the post-hydration state so IsDirty reflects only
        // user-driven edits. Capturing before LoadTeamsAsync would be
        // fine too — the team list itself isn't part of the snapshot —
        // but doing it last is the obvious "everything is settled" point.
        _initialSnapshot = BuildSnapshot();
    }

    private async Task LoadTeamsAsync(Guid connectionId)
    {
        _loadingTeams = true;
        try
        {
            _availableTeams = await TeamSource.QueryTeamsAsync(connectionId);
        }
        catch
        {
            // Couldn't load teams (bad SQL, source unreachable, etc.).
            // Leave the list empty — the conditional UI surfaces the
            // empty state. Surfacing the raw error here would confuse
            // schedule-authoring; admins debug Team Builder on its own
            // tab.
            _availableTeams = new();
        }
        finally
        {
            _loadingTeams = false;
        }
    }

    private async Task ToggleMembersPreview()
    {
        _showMembers = !_showMembers;
        if (!_showMembers || _allMembers is not null) return;
        if (_reportConnectionId is not Guid cid) return;

        _loadingMembers = true;
        _membersError = null;
        try
        {
            _allMembers = await TeamSource.QueryMembersAsync(cid);
        }
        catch (Exception ex)
        {
            _membersError = ex.Message;
        }
        finally
        {
            _loadingMembers = false;
        }
    }

    private List<TeamMemberRecord> MembersForSelected()
    {
        if (_teamId is not int tid || _allMembers is null) return new();
        return _allMembers
            .Where(m => m.TeamId == tid)
            .OrderBy(m => m.MemberName ?? m.MemberExtId, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private void ToggleDayOfWeek(DayOfWeek d)
    {
        if (!_daysOfWeek.Add(d)) _daysOfWeek.Remove(d);
    }

    private void ToggleDayOfMonth(int d)
    {
        if (!_daysOfMonth.Add(d)) _daysOfMonth.Remove(d);
    }

    private SchedulePattern BuildPattern() => new()
    {
        Type = _type,
        Interval = _interval,
        Hour = _time?.Hours ?? 8,
        Minute = _time?.Minutes ?? 0,
        DaysOfWeek = _daysOfWeek.ToList(),
        DaysOfMonth = _monthlyMode == "DaysOfMonth" ? _daysOfMonth.ToList() : new List<int>(),
        MonthlyOrdinal = _type == "Monthly" && _monthlyMode == "Ordinal" ? _monthlyOrdinal : null,
        MonthlyDayOfWeek = _type == "Monthly" && _monthlyMode == "Ordinal" ? _monthlyDayOfWeek : null
    };

    // Routes every dismiss path (Cancel button, Esc, backdrop click)
    // through the unsaved-changes prompt so an accidental dismiss never
    // silently throws away the user's edits. Save runs the full
    // Save() handler; DontSave dismisses; Cancel keeps the dialog open.
    private async Task TryCancelAsync() =>
        await UnsavedChangesPrompt.TryCancelAsync(DialogService, MudDialog, IsDirty,
            saveAsync: () =>
            {
                if (IsValid) Save();
                return Task.CompletedTask;
            });

    private void Save()
    {
        var pattern = BuildPattern();

        var schedule = ExistingSchedule is not null
            ? ExistingSchedule
            : new ReportSchedule
            {
                Id = Guid.NewGuid(),
                ReportId = ReportId,
                OwnerId = UserId,
                OwnerEmail = UserEmail,
                CreatedAt = DateTime.UtcNow,
                IsActive = true
            };

        schedule.Subject = _subject;
        // Carry the deprecated string fields through so a round-trip
        // through this dialog doesn't drop them. New schedules leave
        // them null; edits of older schedules preserve whatever was
        // there. The Worker no longer reads them.
        schedule.Recipients = string.IsNullOrWhiteSpace(_recipients) ? null : _recipients.Trim();
        schedule.CcRecipients = string.IsNullOrWhiteSpace(_ccRecipients) ? null : _ccRecipients.Trim();
        schedule.BccRecipients = string.IsNullOrWhiteSpace(_bccRecipients) ? null : _bccRecipients.Trim();
        schedule.SchedulePatternJson = pattern.ToJson();
        schedule.CronExpression = ScheduleCron.Build(pattern);
        schedule.StartDate = _startDate;
        schedule.EndDate = _endDate;
        schedule.AttachmentFormat = _attachmentFormat;
        schedule.IncludePreview = _includePreview;

        // Kind-specific fields. Clear the unused side so a kind switch
        // doesn't leave stale values behind on either path.
        schedule.Kind = _kind;
        if (_kind == ScheduleKind.Individual)
        {
            schedule.TeamId = _teamId;
            schedule.TeamConnectionId = _reportConnectionId;
            schedule.TeamFanout = _teamFanout;
            schedule.DistEmail = null;
        }
        else
        {
            schedule.TeamId = null;
            schedule.TeamConnectionId = null;
            // Reset to the default so a kind-switch back doesn't surface a
            // stale Manager / Both selection from a previous Individual edit.
            schedule.TeamFanout = TeamFanout.Members;
            schedule.DistEmail = string.IsNullOrWhiteSpace(_distEmail) ? null : _distEmail.Trim();
        }

        MudDialog?.Close(DialogResult.Ok(schedule));
    }
}
