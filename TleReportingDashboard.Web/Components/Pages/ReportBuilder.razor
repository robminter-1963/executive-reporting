@page "/builder"
@page "/builder/{ReportId:guid?}"
@rendermode InteractiveServer
@implements IDisposable
@inject EditorModeState EditorMode
@inject ISchemaService SchemaService
@inject IQueryService QueryService
@inject IReportService ReportService
@inject IExportService ExportService
@inject ISharingService SharingService
@inject IScheduleService ScheduleService
@inject IJSRuntime JS
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IGridTemplateService GridTemplateService
@inject IAdminService AdminService
@inject IAdminAccessService AdminAccess
@inject IUserManagementService UserManagement
@inject IQueryScopeResolver ScopeResolver
@inject ICompanyConnectionAdminService ConnectionAdminSvc
@inject ICompanyRegistry CompanyRegistry
@inject IUserPreferenceService PreferenceService
@inject ISchemaConfigStore SchemaStore
@inject SchemaBuilderService SchemaBrowser
@inject ICustomPrimaryTableService CustomPrimaryTableSvc
@inject TleReportingDashboard.Web.Services.QueryPipeline.ISqlDialectFactory DialectFactory
@inject ILogger<ReportBuilder> Logger
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject IConfiguration Config

<PageTitle>Report Builder - Executive Reporting Suite</PageTitle>

@* ── Left drawer: Field Picker (resizable) ── *@
@if (_drawerOpen)
{
    @* Offset by the 64px MudAppBar in MainLayout so the top of the picker (banner / search) isn't clipped. *@
    <div style="display: flex; height: calc(100vh - 64px); position: fixed; top: 64px; left: 0; z-index: 100;">
        <div style="width: @(_drawerWidth)px; min-width: 180px; max-width: 500px;
                    background: #FFFFFF; border-right: 1px solid #DADCE0;
                    overflow: hidden; display: flex; flex-direction: column;">
            <FieldPicker Domains="_domains" SelectedFieldIds="_selectedFieldIds"
                         OnFieldAdded="HandleFieldAdded" OnFieldRemoved="HandleFieldRemoved"
                         TemplateLocked="_linkedTemplateId.HasValue"
                         TemplateName="@_linkedTemplateName"
                         HiddenFieldIds="@(_currentConfig.HiddenColumns ?? new List<string>())"
                         OnFieldVisibilityToggled="HandleFieldVisibilityToggled" />
        </div>
        <div style="width: 5px; cursor: col-resize; background: transparent; flex-shrink: 0;"
             @onmousedown="StartResize" @onmousedown:stopPropagation="true">
            <div style="width: 1px; height: 100%; margin: 0 auto; background: #DADCE0;"></div>
        </div>
    </div>
}

<MudMainContent Style="@($"padding: 0 16px 16px 16px; margin-left: {(_drawerOpen ? _drawerWidth + 5 : 0)}px; transition: margin-left 0.15s; height: calc(100vh - 64px); overflow-y: auto;")">
    @* ── Loading indicator ── *@
    @if (_isLoading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
    }

    <MudStack Spacing="3">
        @* ── Top action bar (sticky) ── Pinned to the top of the scroll
           container (no gap above — the app bar ends at the viewport top
           48px and the action bar picks up from there). *@
        <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween"
                   Style="position: sticky; top: 0; z-index: 100; background: var(--mud-palette-background); padding: 8px 0; margin: 0; border-bottom: 1px solid var(--mud-palette-lines-default);">
            <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                <MudTooltip Text="@(_drawerOpen ? "Hide column list" : "Show column list")">
                    <MudIconButton Icon="@(_drawerOpen ? Icons.Material.Filled.MenuOpen : Icons.Material.Filled.Menu)"
                                   OnClick="() => _drawerOpen = !_drawerOpen" />
                </MudTooltip>
                <MudTooltip Text="Back to Report Library">
                    <MudIconButton Icon="@Icons.Material.Filled.Home" OnClick="NavigateBackToLibrary" />
                </MudTooltip>
                @if (_editingName)
                {
                    <MudTextField @bind-Value="_loadedReportName" Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Style="max-width: 300px; font-size: 1.1rem;"
                                  Placeholder="Report Name" Immediate
                                  OnKeyDown="OnNameKeyDown"
                                  Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Check"
                                  OnAdornmentClick="() => _editingName = false" />
                }
                else
                {
                    <MudText Typo="Typo.h6" Style="cursor: pointer;" @ondblclick="() => _editingName = true"
                             title="Double-click to rename">
                        @(_loadedReportName ?? "New Report")
                    </MudText>
                    <MudTooltip Text="Rename report">
                        <MudIconButton Icon="@Icons.Material.Filled.EditNote" Size="Size.Small" Color="Color.Default"
                                       OnClick="() => _editingName = true" />
                    </MudTooltip>
                }
                @* Internal Name — admin-facing label shown only in the Master
                   Dashboard's Add Report picker. The Name (left) is what
                   tile users see; this field is what dashboard admins read
                   when picking which variant of a same-named report to pin.
                   Blank = falls back to Name in every consumer. *@
                <MudTooltip Text="Shown in the master dashboard's Add Report picker. Use this to tell apart reports that share the same Name (e.g. one Pipeline per loan type). Leave blank to default to the Name.">
                    <MudTextField @bind-Value="_loadedInternalName"
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Style="max-width: 220px; font-size: 0.85rem;"
                                  Placeholder="Internal name (admin-only)"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Tag" />
                </MudTooltip>
            </MudStack>
            <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                @* ── Connection picker ── Editable for new reports only.
                   Once the report is saved, the connection is immutable
                   (swapping connections silently invalidates field refs). *@
                <MudTooltip Text="@(_loadedReportId is not null ? "Connection is locked after first save" : "Which data-source this report queries against")">
                    <MudSelect T="Guid?" Value="_currentConfig.ConnectionId" ValueChanged="OnConnectionChanged"
                               Label="Connection" Variant="Variant.Outlined" Margin="Margin.Dense"
                               ToStringFunc="@ConnectionToLabel"
                               Disabled="@(_loadedReportId is not null)" Style="min-width: 260px;">
                        @* Flat list. Each row shows its company as a leading
                           label so users can tell connections apart across
                           companies without a subheader tree. Sorted by
                           company then connection name so rows for the same
                           company still sit together visually. *@
                        @foreach (var c in _availableConnections
                            .Where(c => c.IsActive)
                            .OrderBy(c => CompanyNameFor(c.CompanyId), StringComparer.OrdinalIgnoreCase)
                            .ThenBy(c => c.Name, StringComparer.OrdinalIgnoreCase))
                        {
                            <MudSelectItem T="Guid?" Value="@((Guid?)c.Id)">
                                <span style="color: #5F6368; font-weight: 500;">@CompanyNameFor(c.CompanyId)</span>
                                <span style="margin: 0 6px; color: #BDC1C6;">·</span>
                                <span>@c.Name@(c.IsDefault ? " (default)" : "")</span>
                            </MudSelectItem>
                        }
                    </MudSelect>
                </MudTooltip>

                @* ── Primary Table ──
                   One dropdown, always. Options come from Schema Builder's
                   Table Aliases catalog plus the schema default. There's no
                   custom / free-text mode anymore; if a legacy report was
                   saved against a table that isn't in the catalog, that
                   value is injected as a "(off catalog)" option so the
                   report still opens — the user then picks a catalog entry
                   from the same dropdown. *@
                <MudTooltip Text="Root table this report queries against. Options come from the connection's Table Aliases catalog.">
                    <MudSelect T="string" Value="_currentConfig.PrimaryTable"
                               ValueChanged="OnPrimaryTableChanged"
                               Label="Primary Table" Variant="Variant.Outlined" Margin="Margin.Dense"
                               ToStringFunc="@PrimaryTableLabelFor"
                               Required RequiredError="Primary Table is required"
                               Style="min-width: 320px;">
                        @{
                            var primaryOpts = BuildPrimaryTableOptions().ToList();
                            var suggested = primaryOpts.Where(o => o.IsSuggested).ToList();
                            var legacy = primaryOpts.Where(o => o.IsLegacy).ToList();
                        }
                        @* Only curated "Suggested primaries" show, plus any
                           existing legacy value so old reports keep working
                           and the user can re-pick a curated row. Non-
                           eligible catalog tables are hidden on purpose. *@
                        @foreach (var opt in suggested)
                        {
                            <MudSelectItem T="string" Value="@opt.Value">
                                <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
                                    <MudIcon Icon="@(opt.IsDefault ? Icons.Material.Filled.Star : Icons.Material.Filled.StarBorder)"
                                             Size="Size.Small"
                                             Color="@(opt.IsDefault ? Color.Primary : Color.Default)" />
                                    <span>@opt.Label@(opt.IsDefault ? " (default)" : "")</span>
                                </MudStack>
                            </MudSelectItem>
                        }
                        @if (legacy.Count > 0)
                        {
                            @if (suggested.Count > 0)
                            {
                                <MudDivider />
                            }
                            <div style="padding: 6px 16px; font-size: 0.7rem; font-weight: 600;
                                        text-transform: uppercase; letter-spacing: 0.5px; color: #5F6368;">
                                Off catalog
                            </div>
                            @foreach (var opt in legacy)
                            {
                                <MudSelectItem T="string" Value="@opt.Value">
                                    @opt.Label (off catalog)
                                </MudSelectItem>
                            }
                        }
                    </MudSelect>
                </MudTooltip>

                @* ── Primary actions ── *@
                <MudTooltip Text="@(!_selectedFieldIds.Any() ? "Pick at least one column to enable" : "Fetch fresh data using the current columns and filters")">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.PlayArrow"
                               OnClick="HandleRunQuery" Disabled="@(!_selectedFieldIds.Any() || _isLoading)">
                        Run Report
                    </MudButton>
                </MudTooltip>
                <MudTooltip Text="@GetSaveTooltip()">
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Save"
                               OnClick="HandleSave" Disabled="@(!CanSave())">
                        Save
                    </MudButton>
                </MudTooltip>

                <MudDivider Vertical FlexItem Style="margin: 4px 4px;" />

                @* ── Download (kept visible — frequent post-run action) ── *@
                <MudMenu Variant="Variant.Outlined" Color="Color.Default" Dense
                         Icon="@Icons.Material.Filled.Download"
                         Disabled="@(_queryData is null || !_queryData.Rows.Any())"
                         title="Download the current results">
                    <MudMenuItem OnClick="ExportExcel">Excel (.xlsx)</MudMenuItem>
                    <MudMenuItem OnClick="ExportCsv">CSV</MudMenuItem>
                </MudMenu>

                @* ── "More" overflow menu ── Template, Schedule, Share, and
                   admin-only tools. Keeps the main bar readable on narrow
                   screens where ~13 controls used to wrap and clip. *@
                <MudTooltip Text="More actions">
                    <MudMenu Icon="@Icons.Material.Filled.MoreVert" Dense
                             AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                        @if (_linkedTemplateId.HasValue)
                        {
                            <MudMenuItem Disabled>
                                <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
                                    <MudIcon Icon="@Icons.Material.Filled.GridView" Size="Size.Small" Color="Color.Info" />
                                    <MudText Typo="Typo.body2">Linked: @_linkedTemplateName</MudText>
                                </MudStack>
                            </MudMenuItem>
                            <MudMenuItem OnClick="UnlinkTemplate"
                                         Icon="@Icons.Material.Filled.LinkOff" IconColor="Color.Warning">
                                Unlink template
                            </MudMenuItem>
                        }
                        else
                        {
                            <MudMenuItem OnClick="ApplyTemplate"
                                         Icon="@Icons.Material.Filled.GridView">
                                Apply template…
                            </MudMenuItem>
                        }
                        <MudMenuItem OnClick="HandleSchedule"
                                     Disabled="@(_loadedReportId is null)"
                                     Icon="@Icons.Material.Filled.Schedule">
                            @(_loadedReportId is null ? "Schedule (save report first)" : "Schedule…")
                        </MudMenuItem>
                        <MudMenuItem OnClick="HandleShare"
                                     Disabled="@(_loadedReportId is null)"
                                     Icon="@Icons.Material.Filled.Share">
                            @(_loadedReportId is null ? "Share (save report first)" : "Share…")
                        </MudMenuItem>
                        <MudDivider />
                        @if (_isAdmin)
                        {
                            <MudMenuItem OnClick="HandleSaveAsTemplate"
                                         Disabled="@(!_selectedFieldIds.Any())"
                                         Icon="@Icons.Material.Filled.ContentCopy">
                                Save as template
                            </MudMenuItem>
                        }
                        @* Show generated SQL is intentionally available to
                           every user — it's the same right-click affordance
                           the dashboard tile menu offers, used to debug
                           "why am I seeing zero rows?" without admin help. *@
                        <MudMenuItem OnClick="ShowQuery"
                                     Disabled="@(!_selectedFieldIds.Any())"
                                     Icon="@Icons.Material.Filled.Code">
                            Show generated SQL
                        </MudMenuItem>
                        @* Show the report's saved-state JSON in a dialog —
                           same purpose as Schema Builder's Export tab, but
                           inline so admins can copy/inspect without leaving
                           the report. Useful for diagnosing column-order /
                           hidden-list / dashboard-config drift. *@
                        <MudMenuItem OnClick="ShowReportJson"
                                     Icon="@Icons.Material.Filled.DataObject">
                            View report JSON
                        </MudMenuItem>
                    </MudMenu>
                </MudTooltip>
                @if (_isAdmin)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Outlined"
                             Icon="@Icons.Material.Filled.Shield"
                             Style="font-size: 0.65rem; height: 22px;">
                        ADMIN
                    </MudChip>
                }
            </MudStack>
        </MudStack>

        @* Saved-roots chip bar removed — the Primary Table dropdown above
           now surfaces catalog entries inline with their aliases, so a
           second list of the same data was redundant. Managing the
           catalog (add/edit/delete) lives in Schema Builder → Table Aliases. *@

        @* ── Primary Table warning ── Fires only while the current root is
           off-catalog (legacy value from an older report). Picking any
           catalog-backed entry from the dropdown clears it. *@
        @if (IsSelectedPrimaryOffCatalog())
        {
            <MudAlert Severity="Severity.Warning" Dense Variant="Variant.Outlined"
                      Icon="@Icons.Material.Filled.ReportProblem">
                <strong>@_currentConfig.PrimaryTable</strong> isn't in this connection's Table Aliases catalog.
                Reports rooted here may or may not work — any field from a different table will fail unless
                a join is defined. Pick a catalog entry from the dropdown, or register this one in
                Schema Builder → Table Aliases.
            </MudAlert>
        }

        @* ── Filters ── One visual band: preset chips grouped by GroupName,
           ad-hoc filter builder below. Filters without a GroupName fall into
           a "Misc" bucket that sorts last. *@
        <MudStack Spacing="1">
            <MudText Typo="Typo.overline" Color="Color.Secondary" Style="letter-spacing: 0.5px;">Filters</MudText>
            @if (_customFilters.Any())
            {
                // Group by normalized GroupName (case-insensitive). Misc
                // (blank) is rendered last regardless of alphabetical
                // position. Inside each group, preserve schema order.
                const string MiscGroup = "Misc";
                var filterGroups = _customFilters
                    .GroupBy(cf => string.IsNullOrWhiteSpace(cf.GroupName) ? MiscGroup : cf.GroupName!.Trim(),
                             StringComparer.OrdinalIgnoreCase)
                    .OrderBy(g => g.Key.Equals(MiscGroup, StringComparison.OrdinalIgnoreCase) ? 1 : 0)
                    .ThenBy(g => g.Key, StringComparer.OrdinalIgnoreCase)
                    .ToList();
                @foreach (var group in filterGroups)
                {
                    <MudStack Row AlignItems="AlignItems.Center" Spacing="1" Wrap="Wrap.Wrap">
                        <MudText Typo="Typo.caption" Color="Color.Secondary"
                                 Style="min-width: 80px; font-weight: 600;">
                            @group.Key
                        </MudText>
                        @foreach (var cf in group)
                        {
                            var id = cf.Id;
                            var isActive = _currentConfig.CustomFilterIds?.Contains(id) == true;
                            var tip = !string.IsNullOrWhiteSpace(cf.Description)
                                ? (isActive ? $"Active — click to turn off. {cf.Description}" : $"Click to apply. {cf.Description}")
                                : (isActive ? "Active — click to turn off" : "Click to apply");
                            <MudTooltip Text="@tip">
                                <MudChip T="string" Variant="@(isActive ? Variant.Filled : Variant.Outlined)"
                                         Color="@(isActive ? Color.Primary : Color.Default)" Size="Size.Small"
                                         OnClick="() => ToggleCustomFilter(id)"
                                         Style="cursor: pointer;">
                                    @cf.Label
                                </MudChip>
                            </MudTooltip>
                        }
                    </MudStack>
                }
            }
            <HeaderFilters Filters="_currentConfig.Filters" Domains="_domains"
                           OnFiltersChanged="HandleFiltersChanged" />
        </MudStack>

        @* ── Advanced (ad-hoc) Filters ──
           Experimental — gated on Features:AdvancedFilters (appsettings).
           Each row is { field, operator, value(s) } and is ANDed with every
           other filter source at query time. Persisted under
           ColumnState.AdvancedFilters so existing reports without advanced
           filters stay untouched. *@
        @if (_advancedFiltersEnabled)
        {
            <MudExpansionPanels Elevation="0" Class="mt-1"
                                Style="border: 1px solid #E8EAED; border-radius: 4px;">
                <MudExpansionPanel>
                    <TitleContent>
                        <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
                            <MudIcon Icon="@Icons.Material.Filled.Tune" Size="Size.Small" Color="Color.Primary" />
                            <MudText Typo="Typo.body2" Style="font-weight: 500;">
                                Advanced Filters
                            </MudText>
                            @{
                                var leafCount = CountAdvancedFilterLeaves(_filterRoot);
                            }
                            @if (leafCount > 0)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined"
                                         Style="height: 20px;">@leafCount</MudChip>
                            }
                        </MudStack>
                    </TitleContent>
                    <ChildContent>
                        @if (_advancedFilterFields.Count == 0)
                        {
                            <MudAlert Severity="Severity.Info" Dense Variant="Variant.Outlined">
                                Pick a connection first to load the field catalog.
                            </MudAlert>
                        }
                        else
                        {
                            <AdvancedFilterGroup Group="_filterRoot"
                                                 AvailableFields="_advancedFilterFields"
                                                 IsRoot="true"
                                                 OnChanged="MarkDirty" />
                        }
                    </ChildContent>
                </MudExpansionPanel>
            </MudExpansionPanels>
        }

        @* ── Selected field chips — also the column reorder bar ── *@
        @if (_selectedFieldIds.Any())
        {
            <FieldChipBar SelectedFields="_selectedFieldDefinitions"
                          OrphanFieldIds="_orphanFieldIds"
                          OnFieldRemoved="HandleFieldRemoved"
                          OnClearAll="HandleClearAllFields"
                          OnFieldOrderChanged="HandleFieldOrderChanged"
                          CalcColumns="_currentConfig.TableCalculatedColumns"
                          CombinedOrder="_currentConfig.ColumnOrder"
                          TemplateLocked="_linkedTemplateId.HasValue" />

            @* Calc-column add button. The actual calc chips render INSIDE
               FieldChipBar above as green chips so they reorder inline with
               regular fields. Clicking a chip in the bar opens its edit
               dialog (re-routed below); the X on a chip removes it. *@
            <MudStack Row AlignItems="AlignItems.Center" Spacing="1" Wrap="Wrap.Wrap">
                <MudButton StartIcon="@Icons.Material.Filled.Calculate" Variant="Variant.Text"
                           Color="Color.Tertiary" Dense Size="Size.Small"
                           OnClick="@(() => OpenTableCalcDialog(null))">
                    + Calc Column
                </MudButton>
                @if (_currentConfig.TableCalculatedColumns is { Count: > 0 })
                {
                    @* Edit links — small text buttons listed compactly so the
                       admin still has a click-to-edit path without crowding
                       the chip bar above with click handlers. *@
                    @foreach (var cc in _currentConfig.TableCalculatedColumns)
                    {
                        var ccLocal = cc;
                        <MudTooltip Text="@($"Edit \"{ccLocal.Label}\" — {(string.IsNullOrWhiteSpace(ccLocal.SqlExpression) ? $"Formula: {ccLocal.Formula}" : $"SQL: {ccLocal.SqlExpression}")}")">
                            <MudChip T="string" Variant="Variant.Outlined" Color="Color.Success" Size="Size.Small"
                                     Icon="@Icons.Material.Filled.Edit"
                                     OnClick="@(() => OpenTableCalcDialog(ccLocal.Key))"
                                     OnClose="@(() => RemoveTableCalcColumn(ccLocal.Key))">
                                @ccLocal.Label
                            </MudChip>
                        </MudTooltip>
                    }
                }
            </MudStack>
        }

        @* ── Group By chips ── Shown only when at least one selected field has
           an aggregate SQL expression. Defaults to all selected non-aggregate
           fields in pick order; user can toggle individual fields off via the
           close chip X. *@
        @if (HasAggregateField())
        {
            <MudStack Spacing="1">
                <MudText Typo="Typo.overline" Color="Color.Secondary" Style="letter-spacing: 0.5px;">
                    Group By
                </MudText>
                <MudStack Row AlignItems="AlignItems.Center" Spacing="1" Wrap="Wrap.Wrap">
                    @foreach (var fid in EffectiveGroupByFieldIds)
                    {
                        var fidRef = fid;
                        <MudChip T="string" Variant="Variant.Outlined" Color="Color.Info" Size="Size.Small"
                                 OnClose="() => ToggleGroupByField(fidRef)">
                            @GetSelectedFieldLabel(fidRef)
                        </MudChip>
                    }
                    @{
                        var excluded = SelectedNonAggregateFieldIds
                            .Where(id => !EffectiveGroupByFieldIds.Contains(id, StringComparer.OrdinalIgnoreCase))
                            .ToList();
                    }
                    @if (excluded.Any())
                    {
                        <MudMenu Icon="@Icons.Material.Filled.AddCircleOutline" Variant="Variant.Text"
                                 Color="Color.Info" Dense Size="Size.Small" Label="+ Field"
                                 AnchorOrigin="Origin.BottomLeft" TransformOrigin="Origin.TopLeft">
                            @foreach (var fid in excluded)
                            {
                                var fidRef = fid;
                                <MudMenuItem OnClick="() => ToggleGroupByField(fidRef)">@GetSelectedFieldLabel(fidRef)</MudMenuItem>
                            }
                        </MudMenu>
                    }
                </MudStack>
            </MudStack>
        }

        @* ── Truncation notice ── *@
        @if (_queryData is not null && _queryData.IsTruncated)
        {
            <MudAlert Severity="Severity.Info" Dense Variant="Variant.Outlined"
                      Icon="@Icons.Material.Filled.FilterAlt">
                Showing the first @_queryData.Rows.Count.ToString("N0") of @_queryData.TotalCount.ToString("N0") results.
                Add filters above to narrow to the rows you need.
            </MudAlert>
        }

        @* ── Persistent query-error banner ── *@
        @* Stays visible until the next successful Run. Backed by the
           last-good _queryData restoration in HandleRunQuery so the
           table / dashboard tabs below are still interactive — admins
           edit the offending filter/field/sort right where they are and
           hit Run again. The snackbar is transient; this banner sticks
           around as long as the report is in a broken state. *@
        @if (!string.IsNullOrEmpty(_lastQueryError))
        {
            <MudAlert Severity="Severity.Error" Dense Variant="Variant.Outlined"
                      Icon="@Icons.Material.Filled.ErrorOutline" Class="mb-2"
                      ShowCloseIcon CloseIconClicked="() => _lastQueryError = null">
                <MudText Typo="Typo.body2" Style="font-weight: 600;">Last run failed</MudText>
                <MudText Typo="Typo.caption" Style="white-space: pre-wrap; word-break: break-word;">
                    @_lastQueryError
                </MudText>
                @if (_queryData is not null)
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Style="display: block; margin-top: 4px;">
                        Showing the previous successful results below — edit the filter / field / sort that caused the error and re-run.
                    </MudText>
                }
            </MudAlert>
        }

        @* ── Results area ── *@
        @if (_queryData is not null)
        {
            <KpiBar Data="_queryData" ActiveKpiIds="_activeKpiIds"
                    OnKpiAdded="HandleKpiAdded" OnKpiRemoved="HandleKpiRemoved" />

            <MudTabs @bind-ActivePanelIndex="_activeTabIndex" Elevation="0" Rounded ApplyEffectsToContainer>
                <MudTabPanel Text="Table" Icon="@Icons.Material.Filled.TableChart">
                    @* Aggregate-hidden hint — the Table view hides any field
                       whose SqlExpression is an aggregate (they only make
                       sense when grouped). Without this banner users think
                       their field disappeared. *@
                    @if (AggregateFieldIds.Count > 0)
                    {
                        <MudAlert Severity="Severity.Info" Dense Variant="Variant.Outlined" Class="mb-2"
                                  Icon="@Icons.Material.Filled.Functions">
                            @AggregateFieldIds.Count aggregated @(AggregateFieldIds.Count == 1 ? "column is" : "columns are") hidden in the Table view.
                            <MudButton Variant="Variant.Text" Color="Color.Info" Size="Size.Small"
                                       Class="ml-2" OnClick="() => _activeTabIndex = 2">
                                Switch to Dashboard
                            </MudButton>
                        </MudAlert>
                    }
                    @* Live sort indicator — reflects whatever's currently
                       applied via column-header clicks. Updates in real time. *@
                    @if (_liveSort is { Count: > 0 } || IsSortDeviated())
                    {
                        <MudStack Row AlignItems="AlignItems.Center" Spacing="1" Wrap="Wrap.Wrap" Class="mb-1">
                            <MudText Typo="Typo.overline" Color="Color.Secondary" Style="letter-spacing: 0.5px;">
                                Sort:
                            </MudText>
                            @for (var si = 0; si < _liveSort.Count; si++)
                            {
                                // Capture per-iteration locals so the MudChip
                                // RenderFragment doesn't close over the final
                                // value of `si` and show the same number on
                                // every chip.
                                var priority = si + 1;
                                var step = _liveSort[si];
                                var label = GetFieldLabel(step.Field);
                                var isDesc = string.Equals(step.Direction, "desc", StringComparison.OrdinalIgnoreCase);
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary"
                                         Icon="@(isDesc ? Icons.Material.Filled.ArrowDownward : Icons.Material.Filled.ArrowUpward)">
                                    @priority. @label
                                </MudChip>
                            }
                            @if (IsSortDeviated())
                            {
                                <MudTooltip Text="Restore the sort saved with this report">
                                    <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Warning"
                                               StartIcon="@Icons.Material.Filled.Undo"
                                               OnClick="RevertSort">
                                        Revert
                                    </MudButton>
                                </MudTooltip>
                            }
                        </MudStack>
                    }
                    @* Detail-view grouping + default sort. Only affects the
                       drill-down (DetailViewer) render — the Table tab's grid
                       and the Dashboard view both ignore these. When group-by
                       is set, the default sort becomes the secondary ORDER BY
                       so rows cluster by group first. *@
                    <MudStack Row AlignItems="AlignItems.Center" Spacing="2" Class="mb-1">
                        <MudText Typo="Typo.overline" Color="Color.Secondary" Style="letter-spacing: 0.5px;">
                            Group By
                        </MudText>
                        <MudSelect T="string" Value="_detailGroupByFieldId ?? string.Empty"
                                   ValueChanged="OnDetailGroupByChanged"
                                   ToStringFunc="@DetailGroupLabelFor"
                                   Variant="Variant.Outlined" Margin="Margin.Dense" Dense
                                   Style="min-width: 240px;">
                            <MudSelectItem T="string" Value="@string.Empty">(None)</MudSelectItem>
                            @{
                                var detailHidden = _currentConfig.HiddenColumns is { Count: > 0 }
                                    ? new HashSet<string>(_currentConfig.HiddenColumns, StringComparer.OrdinalIgnoreCase)
                                    : null;
                            }
                            @foreach (var f in _selectedFieldDefinitions
                                .Where(f => string.IsNullOrWhiteSpace(f.SqlExpression)
                                         && (detailHidden is null || !detailHidden.Contains(f.Id))))
                            {
                                <MudSelectItem T="string" Value="@f.Id">@f.Label</MudSelectItem>
                            }
                            @* SQL-mode table calcs are real columns in the
                               SELECT; sortable / groupable via their Key alias. *@
                            @foreach (var cc in (_currentConfig.TableCalculatedColumns ?? new())
                                .Where(c => !string.IsNullOrWhiteSpace(c.SqlExpression)
                                         && (detailHidden is null || !detailHidden.Contains(c.Key))))
                            {
                                <MudSelectItem T="string" Value="@cc.Key">@cc.Label (*)</MudSelectItem>
                            }
                        </MudSelect>
                        <MudSelect T="string" @bind-Value="_detailGroupByDirection"
                                   Label="Direction"
                                   Disabled="@string.IsNullOrEmpty(_detailGroupByFieldId)"
                                   Variant="Variant.Outlined" Margin="Margin.Dense" Dense
                                   Style="width: 150px;">
                            <MudSelectItem T="string" Value="@("none")">None</MudSelectItem>
                            <MudSelectItem T="string" Value="@("asc")">Ascending</MudSelectItem>
                            <MudSelectItem T="string" Value="@("desc")">Descending</MudSelectItem>
                        </MudSelect>
                        <MudText Typo="Typo.overline" Color="Color.Secondary" Style="letter-spacing: 0.5px; margin-left: 16px;">
                            Sort By
                        </MudText>
                        <MudSelect T="string" Value="_detailSortFieldId ?? string.Empty"
                                   ValueChanged="OnDetailSortChanged"
                                   ToStringFunc="@DetailSortLabelFor"
                                   Variant="Variant.Outlined" Margin="Margin.Dense" Dense
                                   Style="min-width: 240px;">
                            <MudSelectItem T="string" Value="@string.Empty">(None)</MudSelectItem>
                            @{
                                var detailSortHidden = _currentConfig.HiddenColumns is { Count: > 0 }
                                    ? new HashSet<string>(_currentConfig.HiddenColumns, StringComparer.OrdinalIgnoreCase)
                                    : null;
                                var sortSelectedSet = new HashSet<string>(_selectedFieldIds, StringComparer.OrdinalIgnoreCase);
                                // Combine selected fields with the rest of the schema.
                                // Selected fields filter out hidden columns (admin chose
                                // to hide; honor that for sort too). Non-selected fields
                                // are eligible regardless of hidden state — they're
                                // already invisible in the grid by virtue of not being
                                // in _selectedFieldIds.
                                var sortFieldOptions = _domains
                                    .SelectMany(d => d.Fields)
                                    .GroupBy(f => f.Id, StringComparer.OrdinalIgnoreCase)
                                    .Select(g => g.First())
                                    .Where(f => !sortSelectedSet.Contains(f.Id)
                                             || detailSortHidden is null
                                             || !detailSortHidden.Contains(f.Id))
                                    .OrderByDescending(f => sortSelectedSet.Contains(f.Id))
                                    .ThenBy(f => f.Label, StringComparer.OrdinalIgnoreCase);
                            }
                            @foreach (var f in sortFieldOptions)
                            {
                                @* Suffix legend:
                                   (-) = unique column, eligible OFFSET tiebreaker
                                   (+) = not in this report; QueryBuilder adds it to
                                         the SELECT silently so it's reachable from
                                         ORDER BY, but it doesn't render as a grid
                                         column. Useful for picking a unique sort
                                         key without polluting the visible columns. *@
                                var inReport = sortSelectedSet.Contains(f.Id);
                                var sortLabel = f.Label;
                                if (_uniqueFieldIds.Contains(f.Id)) sortLabel += " (-)";
                                if (!inReport) sortLabel += " (+)";
                                <MudSelectItem T="string" Value="@f.Id">@sortLabel</MudSelectItem>
                            }
                            @foreach (var cc in (_currentConfig.TableCalculatedColumns ?? new())
                                .Where(c => !string.IsNullOrWhiteSpace(c.SqlExpression)
                                         && (detailSortHidden is null || !detailSortHidden.Contains(c.Key))))
                            {
                                <MudSelectItem T="string" Value="@cc.Key">@cc.Label (*)</MudSelectItem>
                            }
                        </MudSelect>
                        <MudSelect T="string" @bind-Value="_detailSortDirection"
                                   Label="Direction"
                                   Disabled="@string.IsNullOrEmpty(_detailSortFieldId)"
                                   Variant="Variant.Outlined" Margin="Margin.Dense" Dense
                                   Style="width: 150px;">
                            <MudSelectItem T="string" Value="@("asc")">Ascending</MudSelectItem>
                            <MudSelectItem T="string" Value="@("desc")">Descending</MudSelectItem>
                        </MudSelect>
                        @* Tiebreaker / unique-key sort. Required for stable
                           OFFSET pagination when the primary Sort By field
                           isn't unique (e.g. Status). Without it, OFFSET +
                           a low-cardinality sort can shuffle rows between
                           pages on Postgres. *@
                        <MudText Typo="Typo.overline" Color="Color.Secondary" Style="letter-spacing: 0.5px; margin-left: 16px;">
                            Then By
                        </MudText>
                        <MudSelect T="string" Value="_detailSortThenByFieldId ?? string.Empty"
                                   ValueChanged="OnDetailSortThenByChanged"
                                   ToStringFunc="@DetailSortThenByLabelFor"
                                   Disabled="@string.IsNullOrEmpty(_detailSortFieldId)"
                                   Variant="Variant.Outlined" Margin="Margin.Dense" Dense
                                   Style="min-width: 220px;">
                            <MudSelectItem T="string" Value="@string.Empty">(None)</MudSelectItem>
                            @{
                                // Re-derive locally — Razor's @{} blocks don't share variable
                                // scope across sibling MudSelect children, so we can't reuse
                                // the detailSortHidden from the primary Sort By picker above.
                                var thenByHidden = _currentConfig.HiddenColumns is { Count: > 0 }
                                    ? new HashSet<string>(_currentConfig.HiddenColumns, StringComparer.OrdinalIgnoreCase)
                                    : null;
                                var thenBySelectedSet = new HashSet<string>(_selectedFieldIds, StringComparer.OrdinalIgnoreCase);
                                var thenByFieldOptions = _domains
                                    .SelectMany(d => d.Fields)
                                    .GroupBy(f => f.Id, StringComparer.OrdinalIgnoreCase)
                                    .Select(g => g.First())
                                    .Where(f => (!thenBySelectedSet.Contains(f.Id)
                                                 || thenByHidden is null
                                                 || !thenByHidden.Contains(f.Id))
                                             && !string.Equals(f.Id, _detailSortFieldId, StringComparison.OrdinalIgnoreCase))
                                    .OrderByDescending(f => thenBySelectedSet.Contains(f.Id))
                                    .ThenBy(f => f.Label, StringComparer.OrdinalIgnoreCase);
                            }
                            @foreach (var f in thenByFieldOptions)
                            {
                                @* (-) unique tiebreaker, (+) not in this report (added
                                   to SELECT silently for ORDER BY but no grid column). *@
                                var inReport = thenBySelectedSet.Contains(f.Id);
                                var thenByLabel = f.Label;
                                if (_uniqueFieldIds.Contains(f.Id)) thenByLabel += " (-)";
                                if (!inReport) thenByLabel += " (+)";
                                <MudSelectItem T="string" Value="@f.Id">@thenByLabel</MudSelectItem>
                            }
                            @foreach (var cc in (_currentConfig.TableCalculatedColumns ?? new())
                                .Where(c => !string.IsNullOrWhiteSpace(c.SqlExpression)
                                         && (thenByHidden is null || !thenByHidden.Contains(c.Key))
                                         && !string.Equals(c.Key, _detailSortFieldId, StringComparison.OrdinalIgnoreCase)))
                            {
                                <MudSelectItem T="string" Value="@cc.Key">@cc.Label (*)</MudSelectItem>
                            }
                        </MudSelect>
                        <MudSelect T="string" @bind-Value="_detailSortThenByDirection"
                                   Label="Direction"
                                   Disabled="@(string.IsNullOrEmpty(_detailSortFieldId) || string.IsNullOrEmpty(_detailSortThenByFieldId))"
                                   Variant="Variant.Outlined" Margin="Margin.Dense" Dense
                                   Style="width: 150px;">
                            <MudSelectItem T="string" Value="@("asc")">Ascending</MudSelectItem>
                            <MudSelectItem T="string" Value="@("desc")">Descending</MudSelectItem>
                        </MudSelect>
                        @* Per-report DISTINCT. Useful when a one-to-many
                           LEFT JOIN multiplies rows and the admin only
                           wants the parent's distinct values. Skipped
                           server-side when the query already has GROUP BY
                           (aggregation deduplicates by definition), so
                           toggling this on a dashboard-aggregated report
                           is a no-op. *@
                        <MudTooltip Text="Emit SELECT DISTINCT — collapses duplicate rows produced by LEFT JOINs"
                                    Placement="Placement.Top">
                            <MudSwitch T="bool" @bind-Value="_currentConfig.Distinct"
                                       Color="Color.Primary" Size="Size.Small"
                                       Style="margin-left: 16px;">
                                Distinct
                            </MudSwitch>
                        </MudTooltip>
                    </MudStack>
                    @* Execution summary — intentionally rendered above the
                       grid, not below. When the grid has FillViewport on,
                       anything placed after it is pushed past the
                       MudMainContent's bottom boundary and triggers a second
                       outer scrollbar alongside the grid's own internal
                       one. Sitting above costs one row of height and
                       eliminates the double-scrollbar symptom entirely. *@
                    <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween"
                              Class="mb-1"
                              Style="padding: 2px 0;">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @_queryData.Rows.Count of @_queryData.TotalCount rows
                        </MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            Executed in @_queryData.ExecutionMs ms
                        </MudText>
                    </MudStack>
                    <ReportGrid @ref="_reportGrid" @key="_gridRenderKey" Data="_queryData" IsTruncated="@(_queryData?.IsTruncated ?? false)"
                                InitialColumnWidths="_currentConfig.ColumnWidths"
                                OnColumnWidthsChanged="w => _currentConfig.ColumnWidths = w"
                                InitialColumnOrder="_currentConfig.ColumnOrder"
                                OnColumnOrderChanged="o => _currentConfig.ColumnOrder = o"
                                InitialHiddenColumns="_currentConfig.HiddenColumns"
                                OnHiddenColumnsChanged="h => _currentConfig.HiddenColumns = h"
                                AlwaysHiddenColumns="@AggregateFieldIds"
                                DefaultSortField="@_currentConfig.DefaultSortField"
                                DefaultSortDirection="@_currentConfig.DefaultSortDirection"
                                InitialSort="@_initialSortTuples"
                                OnSortChanged="HandleSortChanged"
                                CalcColumns="_currentConfig.TableCalculatedColumns"
                                FillViewport="true" />
                </MudTabPanel>
                <MudTabPanel Text="Chart" Icon="@Icons.Material.Filled.BarChart">
                    <ChartBuilder Data="_queryData" AvailableColumns="_queryData.Columns" />
                </MudTabPanel>
                <MudTabPanel Text="Dashboard" Icon="@Icons.Material.Filled.Dashboard">
                    <DashboardView @ref="_dashboardView" Data="_queryData"
                                   InitialConfig="_dashboardConfig"
                                   TableSortField="@_currentConfig.DefaultSortField"
                                   TableSortDirection="@_currentConfig.DefaultSortDirection"
                                   ColumnWidths="_currentConfig.ColumnWidths"
                                   ColumnOrder="_currentConfig.ColumnOrder"
                                   AllDimensionFields="_allDimensionFields"
                                   TableCalcColumns="_currentConfig.TableCalculatedColumns"
                                   InitialHiddenColumns="_currentConfig.HiddenColumns"
                                   OnExtraFieldRequired="HandleExtraFieldRequired" />
                </MudTabPanel>
            </MudTabs>
        }
        else if (!_isLoading && _selectedFieldIds.Any())
        {
            @* Columns chosen, but query hasn't run yet *@
            <MudPaper Class="pa-8 d-flex flex-column align-center justify-center" Elevation="0"
                      Style="border: 1px dashed #DADCE0; min-height: 300px;">
                <MudIcon Icon="@Icons.Material.Filled.TableChart" Size="Size.Large" Color="Color.Primary" Style="font-size: 64px;" />
                <MudText Typo="Typo.h6" Class="mt-3">Ready to go</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-1" Style="max-width: 420px; text-align: center;">
                    Your columns and filters are set. Click <strong>Run Report</strong> to pull the data.
                </MudText>
                <MudButton Class="mt-4" Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.PlayArrow"
                           OnClick="HandleRunQuery" Disabled="@_isLoading">
                    Run Report
                </MudButton>
            </MudPaper>
        }
        else if (!_isLoading)
        {
            @* First-time onboarding card *@
            <MudPaper Class="pa-8 d-flex flex-column align-center justify-center" Elevation="0"
                      Style="border: 1px dashed #DADCE0; min-height: 340px;">
                <MudIcon Icon="@Icons.Material.Filled.Assessment" Size="Size.Large" Color="Color.Primary" Style="font-size: 64px;" />
                <MudText Typo="Typo.h6" Class="mt-3">Build your report in three steps</MudText>
                <MudStack Spacing="1" Class="mt-3" Style="max-width: 520px;">
                    <MudStack Row AlignItems="AlignItems.Start" Spacing="2">
                        <MudAvatar Color="Color.Primary" Size="Size.Small" Style="font-size: 0.85rem;">1</MudAvatar>
                        <MudText Typo="Typo.body2">
                            <strong>Pick columns</strong> from the panel on the left — loan number, borrower name, dates, dollars, anything you need.
                        </MudText>
                    </MudStack>
                    <MudStack Row AlignItems="AlignItems.Start" Spacing="2">
                        <MudAvatar Color="Color.Primary" Size="Size.Small" Style="font-size: 0.85rem;">2</MudAvatar>
                        <MudText Typo="Typo.body2">
                            <strong>Add filters</strong> to narrow the data to the rows that matter — a date range, a status, a branch.
                        </MudText>
                    </MudStack>
                    <MudStack Row AlignItems="AlignItems.Start" Spacing="2">
                        <MudAvatar Color="Color.Primary" Size="Size.Small" Style="font-size: 0.85rem;">3</MudAvatar>
                        <MudText Typo="Typo.body2">
                            Click <strong>Run Report</strong> to see results. You can also chart, create a dashboard, schedule emails, and share.
                        </MudText>
                    </MudStack>
                </MudStack>
                @if (!_drawerOpen)
                {
                    <MudButton Class="mt-4" Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.ViewColumn"
                               OnClick="() => _drawerOpen = true">
                        Show column list
                    </MudButton>
                }
                else
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-4">
                        Tip: drag the right edge of the column panel to make it wider.
                    </MudText>
                }
            </MudPaper>
        }
    </MudStack>
</MudMainContent>

@code {
    [Parameter] public Guid? ReportId { get; set; }
    [SupplyParameterFromQuery(Name = "tab")] public int? ReturnTab { get; set; }

    // ── UI state ──
    private bool _drawerOpen = true;
    private bool _isLoading;
    private bool _hasRunOnce;
    private int _activeTabIndex;
    private bool _editingName;
    private int _drawerWidth = 240;
    // Set when the last Run failed; cleared on the next successful run.
    // Surfaces as a persistent banner above the tabs so the editor stays
    // usable on bad SQL — admins can fix the offending field/filter and
    // re-run without losing the dashboard config or the previously-good
    // data already rendered in the table/dashboard tabs.
    private string? _lastQueryError;

    // ── Custom filters ──
    private List<TleReportingDashboard.Web.Configuration.CustomFilterDefinition> _customFilters = new();

    // ── Advanced (ad-hoc) filters — experimental, feature-flagged ──
    // _advancedFiltersEnabled gates the entire section (UI hidden when
    // Features:AdvancedFilters=false in appsettings). _filterRoot is the
    // root of the filter tree — a FilterGroup with AND/OR operator and
    // nested clauses + sub-groups. Always non-null (empty group = no
    // filters). _advancedFilterFields is the field catalog that populates
    // each row's Field picker; reloaded whenever the schema changes
    // (connection swap, fresh report load).
    private bool _advancedFiltersEnabled;
    private TleReportingDashboard.Web.Models.FilterGroup _filterRoot = new()
    {
        Op = TleReportingDashboard.Web.Models.FilterGroupOps.And,
        Items = new List<TleReportingDashboard.Web.Models.FilterItem>()
    };
    private List<TleReportingDashboard.Web.Models.FieldConfig> _advancedFilterFields = new();

    // ── All dimension fields for dashboard group-by ──
    private List<ColumnMeta> _allDimensionFields = new();
    private HashSet<string> _extraGroupByFieldIds = new();

    // ── Primary Table picker state ──
    // _customEntries holds the connection's Table Aliases catalog — the only
    // source of dropdown options. _defaultPrimaryTable comes from
    // SchemaSettings.PrimaryTable and seeds new reports. _primaryTable +
    // _primaryAlias stay as separate state fields so the emitter + JoinResolver
    // still get the two parts they need; the UI just consolidates them into
    // one dropdown Value.
    private string? _defaultPrimaryTable;
    private string? _primaryTable;
    private string? _primaryAlias;
    private List<CustomPrimaryTableRecord> _customEntries = new();

    // ── User identity ──
    private string _userId = "anonymous";
    private string _userEmail = string.Empty;
    private bool _isAdmin;

    // ── Schema & data ──
    private List<DomainGroup> _domains = new();
    private List<string> _selectedFieldIds = new();
    private ReportConfig _currentConfig = new();
    private QueryResponse? _queryData;
    private List<string> _activeKpiIds = new() { "total_volume", "funded_count", "avg_loan_amount" };
    private DashboardView? _dashboardView;
    private ReportGrid? _reportGrid;
    // Materialized list passed to ReportGrid.InitialSort. Built from
    // _currentConfig.TableSort on report load, and also when a template's
    // default sort resolves to a multi-sort. Rebuilt rather than bound live so
    // the grid only seeds once on first mount.
    private List<(string Field, string Direction)>? _initialSortTuples;
    // Live sort, refreshed from ReportGrid every time the user clicks a
    // header. Drives the "Sort: …" indicator above the grid and mirrors into
    // _currentConfig.TableSort so save captures whatever is currently applied
    // without having to also query the grid at save time.
    private List<(string Field, string Direction)> _liveSort = new();
    // Rotated on Revert so the ReportGrid remounts and its first-render
    // InitialSort-seeding path runs again from scratch — cheaper and more
    // reliable than trying to surgically reset MudDataGrid's sort state.
    private string _gridRenderKey = Guid.NewGuid().ToString();
    private DashboardView.DashboardConfig? _dashboardConfig;

    // Drill-down detail view grouping. When set, the DetailViewer renders
    // rows as a flat table with inline group-header / group-footer rows
    // keyed on this field id. Null = ungrouped (default). Direction sorts
    // the groups themselves (not rows within a group). Persisted to
    // ColumnState JSON under "DetailGroupByFieldId" + "DetailGroupByDirection".
    private string? _detailGroupByFieldId;
    private string _detailGroupByDirection = "asc";
    // Detail-view default sort. Picked by the user in the editor and
    // persisted alongside the group-by pair. Applied by DetailViewer as
    // either the primary ORDER BY (when there's no group-by) or as a
    // secondary ORDER BY (when group-by is set) so rows inside each group
    // fall into the intended order.
    private string? _detailSortFieldId;
    private string _detailSortDirection = "asc";
    // Tiebreaker / "Then By" sort. Required for stable OFFSET pagination
    // when the primary Sort By field isn't unique. Persisted as
    // DetailSortThenByFieldId / DetailSortThenByDirection in ColumnState.
    private string? _detailSortThenByFieldId;
    private string _detailSortThenByDirection = "asc";
    // Field ids whose source column is uniquely keyed in the target DB
    // (PK or single-column UNIQUE). Drives the "(-)" marker in the Sort
    // By / Then By dropdowns so admins can spot stable-pagination picks
    // at a glance. Cached per session — refreshed on connection change
    // and when fields are added.
    private HashSet<string> _uniqueFieldIds = new(StringComparer.OrdinalIgnoreCase);
    private readonly Dictionary<string, HashSet<string>> _uniqueColumnsByTable
        = new(StringComparer.OrdinalIgnoreCase);
    // Primary-key columns of the report's primary table, in PK ordinal
    // order. Pre-computed once per (connection, primary-table) and shipped
    // on the QueryRequest as FallbackSortColumns — QueryBuilder uses them
    // when no user sort is configured so OFFSET pagination stays stable
    // even when the admin picked "(None)".
    private List<string> _primaryTablePkColumns = new();
    private string? _pkLookupCacheKey;

    // ── Linked template ──
    private Guid? _linkedTemplateId;
    private string? _linkedTemplateName;

    // ── Loaded report state ──
    private Guid? _loadedReportId;
    private string? _loadedReportName;
    // Admin-facing label shown in the master dashboard's Add Report picker.
    // Falls back to _loadedReportName when blank — only useful for variants
    // that share a public Name (e.g. one Pipeline per loan type).
    private string? _loadedInternalName;

    // Active companies — used to group the Connection dropdown and resolve
    // each connection's owning company for the label.
    private List<CompanySummary> _companies = new();
    // connectionId → companyId lookup. Lets us label a connection with its
    // company without re-querying the DB on every render.
    private Dictionary<Guid, Guid> _connectionCompanyIdByConnectionId = new();
    // Connections available across every active company. Loaded in OnInitializedAsync.
    // The picker is enabled only for new (unsaved) reports; once the report
    // has an id, the connection is locked to prevent silent schema mismatches.
    private List<CompanyConnectionRecord> _availableConnections = new();

    // The chip bar IS the column reorder surface, so it must render chips in
    // the same sequence as the grid columns. ColumnOrder is the source of truth
    // when present; fall back to _selectedFieldIds insertion order otherwise.
    private List<FieldDefinition> _selectedFieldDefinitions
    {
        get
        {
            // Dedupe by id — a field is allowed to surface under multiple
            // domains (e.g. credit_score under both Borrower and Credit) and
            // ToDictionary would throw on the duplicate key. First-wins
            // matches the order _domains expose them; we only need one
            // FieldDefinition per id for the render path below.
            var fieldById = _domains
                .SelectMany(d => d.Fields)
                .GroupBy(f => f.Id, StringComparer.OrdinalIgnoreCase)
                .ToDictionary(g => g.Key, g => g.First(), StringComparer.OrdinalIgnoreCase);

            var order = _currentConfig.ColumnOrder is { Count: > 0 }
                ? _currentConfig.ColumnOrder
                : _selectedFieldIds;

            var selected = new HashSet<string>(_selectedFieldIds, StringComparer.OrdinalIgnoreCase);
            var seen = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
            var result = new List<FieldDefinition>(_selectedFieldIds.Count);

            foreach (var id in order)
            {
                if (!selected.Contains(id)) continue;
                if (!seen.Add(id)) continue;
                if (fieldById.TryGetValue(id, out var f)) result.Add(f);
            }
            // Catch any selected field that's missing from ColumnOrder (e.g.
            // just added) — render it at the end.
            foreach (var id in _selectedFieldIds)
            {
                if (seen.Add(id) && fieldById.TryGetValue(id, out var f)) result.Add(f);
            }
            return result;
        }
    }

    // Field ids that drive the SQL request but don't have a regular chip
    // in the bar. Two cases produce phantom columns the admin had no way
    // to remove:
    //   (a) IDs in _selectedFieldIds that don't resolve in _domains
    //       (deleted/renamed/role-restricted). Always orphan.
    //   (b) IDs in _extraGroupByFieldIds (dashboard-tab extra dimensions)
    //       that aren't already a regular chip — they get injected into
    //       queryFieldIds in HandleRunQuery without any visible UI.
    // Both are surfaced as warning chips so the admin can click ✕ to
    // remove them from the report.
    private List<string> _orphanFieldIds
    {
        get
        {
            if (_domains.Count == 0) return new();
            var fieldById = _domains
                .SelectMany(d => d.Fields)
                .Select(f => f.Id)
                .ToHashSet(StringComparer.OrdinalIgnoreCase);
            var visibleSelected = _selectedFieldIds
                .Where(fieldById.Contains)
                .ToHashSet(StringComparer.OrdinalIgnoreCase);
            return _selectedFieldIds
                .Concat(_extraGroupByFieldIds)
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .Where(id => !visibleSelected.Contains(id))
                .ToList();
        }
    }

    private void NavigateBackToLibrary()
    {
        var url = ReturnTab.HasValue ? $"/reports?tab={ReturnTab.Value}" : "/reports";
        Navigation.NavigateTo(url);
    }

    // ── Lifecycle ──

    // Held for the lifetime of the page so ConfigDbCache bypasses for this
    // circuit while the admin is editing. Disposed on navigation so cached
    // reads resume in the next visited page.
    private IDisposable? _editorScope;

    protected override async Task OnInitializedAsync()
    {
        _editorScope = EditorMode.Enter();
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            _userId = user.FindFirst("oid")?.Value ?? user.Identity?.Name ?? "anonymous";
            _userEmail = user.FindFirst("preferred_username")?.Value ?? string.Empty;
            _isAdmin = AdminService.IsAdmin(_userEmail);
            // Feature flag read once on init. Flip it off in appsettings to
            // hide the Advanced Filters panel entirely and ignore any
            // persisted filters from previous experimental saves.
            _advancedFiltersEnabled = Config.GetValue<bool>("Features:AdvancedFilters", false);

            // Load connections across every active company — not just TLE.
            // Reports belonging to other companies (e.g. when the user filters
            // Report Library by company and opens one of those reports) need
            // their connection present in the picker so MudSelect can map the
            // saved ConnectionId back to a label instead of showing a raw GUID.
            _companies = await CompanyRegistry.GetActiveAsync();

            // Non-admins only see companies they've been granted access to.
            // Matches the filter on Report Library / picker so a user can't
            // create a report scoped to a company they couldn't view.
            // Admin-section roles (System Support et al.) bypass this filter
            // — they have cross-company visibility everywhere else, this
            // surface needs to match.
            var hasAdminAccess = await AdminAccess.HasAnyAdminAccessAsync(_userEmail);
            if (!_isAdmin && !hasAdminAccess && !string.IsNullOrEmpty(_userEmail))
            {
                var access = await UserManagement.GetCompanyAccessAsync(_userEmail);
                var allowed = access.Select(a => a.CompanyId).ToHashSet();
                _companies = _companies.Where(c => allowed.Contains(c.Id)).ToList();
            }

            _availableConnections = new();
            _connectionCompanyIdByConnectionId = new();
            foreach (var comp in _companies)
            {
                var conns = await ConnectionAdminSvc.GetByCompanyAsync(comp.Id);
                foreach (var conn in conns)
                {
                    _availableConnections.Add(conn);
                    _connectionCompanyIdByConnectionId[conn.Id] = comp.Id;
                }
            }

            // New report: pick a sensible default connection. Preference order:
            //   1. The default (or first active) connection of the user's Report
            //      Library company pick (RPT_user_preferences.report_library_company_id).
            //      Keeps "filter library by a company → New Report" anchored to
            //      that company's world.
            //   2. Any connection flagged is_default across the whole registry.
            //   3. Any active connection at all. If there are none, ConnectionId
            //      stays null — the picker renders required-red until the user
            //      either configures a connection or opens an existing report.
            if (!ReportId.HasValue)
            {
                Guid? targetCompanyId = null;
                try
                {
                    var prefs = await PreferenceService.GetPreferencesAsync(_userId);
                    targetCompanyId = prefs.ReportLibraryCompanyId;
                }
                catch { /* preferences unavailable — fall through to registry-wide default */ }

                CompanyConnectionRecord? defaultConn = null;
                if (targetCompanyId is Guid cid)
                {
                    defaultConn = _availableConnections.FirstOrDefault(c => c.CompanyId == cid && c.IsDefault && c.IsActive)
                               ?? _availableConnections.FirstOrDefault(c => c.CompanyId == cid && c.IsActive);
                }
                defaultConn ??= _availableConnections.FirstOrDefault(c => c.IsDefault && c.IsActive)
                              ?? _availableConnections.FirstOrDefault(c => c.IsActive);
                _currentConfig.ConnectionId = defaultConn?.Id;
            }

            // Schema (domains/fields/custom filters/dimension fields) is per-connection.
            // For a saved report, _currentConfig.ConnectionId gets set later in
            // LoadSavedReport, which calls ReloadSchemaForConnectionAsync again.
            await ReloadSchemaForConnectionAsync();

            // If opened with a report ID, load the saved report
            if (ReportId.HasValue)
            {
                await LoadSavedReport(ReportId.Value);
            }
            else
            {
                // New report — prompt the user to name it inline immediately,
                // so Save can be a single click later (no modal on first save).
                _editingName = true;
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to initialize: {ex.Message}", Severity.Error);
        }
    }

    private async Task LoadSavedReport(Guid reportId)
    {
        try
        {
            // Phase 3 authorization: fetch directly and gate by company
            // access. Matches DetailViewer / ReportViewer. Owner/share
            // scoping doesn't work anymore (admins editing cross-company
            // via the library, Editors using shared dashboards, etc).
            var report = await ReportService.GetReportByIdAsync(reportId);
            if (report is null)
            {
                Snackbar.Add("Report not found.", Severity.Warning);
                return;
            }
            // Admin-section roles (System Support et al.) bypass the per-
            // company gate too — same model used by the company filter
            // above and elsewhere in the app.
            if (!_isAdmin && !await AdminAccess.HasAnyAdminAccessAsync(_userEmail))
            {
                var access = await UserManagement.GetCompanyAccessAsync(_userEmail);
                if (!access.Any(a => a.CompanyId == report.CompanyId))
                {
                    Snackbar.Add("You don't have access to this report.", Severity.Warning);
                    return;
                }
            }

            _loadedReportId = report.Id;
            _loadedReportName = report.Name;
            _loadedInternalName = report.InternalName;
            _currentConfig.ConnectionId = report.ConnectionId;
            _currentConfig.PrimaryTable = report.PrimaryTable;
            // Reload the field catalog to match this report's connection.
            await ReloadSchemaForConnectionAsync();

            // Resolve linked template if present (kept for the post-snapshot reconciliation below)
            ResolvedTemplate? resolvedTemplate = null;
            if (report.GridTemplateId.HasValue)
            {
                _linkedTemplateId = report.GridTemplateId;
                var tmpl = await GridTemplateService.GetTemplateAsync(report.GridTemplateId.Value);
                _linkedTemplateName = tmpl?.Name;
                resolvedTemplate = await GridTemplateService.ResolveTemplateAsync(report.GridTemplateId);
                if (resolvedTemplate is not null)
                {
                    _selectedFieldIds = new List<string>(resolvedTemplate.FieldIds);
                    _currentConfig.SelectedFieldIds = new List<string>(resolvedTemplate.FieldIds);
                    _currentConfig.ColumnOrder = resolvedTemplate.ColumnOrder;
                    _currentConfig.HiddenColumns = resolvedTemplate.HiddenColumns;
                    _currentConfig.DefaultSortField = resolvedTemplate.DefaultSortField;
                    _currentConfig.DefaultSortDirection = resolvedTemplate.DefaultSortDirection;
                }
            }
            else
            {
                // Parse field IDs from report JSON (no linked template)
                if (!string.IsNullOrWhiteSpace(report.FieldIds))
                {
                    var fieldIds = System.Text.Json.JsonSerializer.Deserialize<List<string>>(report.FieldIds);
                    if (fieldIds is not null)
                    {
                        _selectedFieldIds = fieldIds;
                        _currentConfig.SelectedFieldIds = new List<string>(fieldIds);
                    }
                }
            }

            // Parse filters
            if (!string.IsNullOrWhiteSpace(report.Filters))
            {
                var filters = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, object?>>(report.Filters);
                if (filters is not null)
                {
                    _currentConfig.Filters = filters;
                }
            }

            // Parse dashboard config if saved
            if (!string.IsNullOrWhiteSpace(report.ColumnState))
            {
                try
                {
                    // Parse ColumnState as a combined object containing dashboard config + column widths
                    var stateDoc = System.Text.Json.JsonDocument.Parse(report.ColumnState);
                    var root = stateDoc.RootElement;

                    // Extract column widths if present
                    if (root.TryGetProperty("ColumnWidths", out var cwElement))
                    {
                        _currentConfig.ColumnWidths = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, int>>(cwElement.GetRawText());
                    }

                    // Extract table column order if present (uses distinct key from DashboardConfig.ColumnOrder)
                    if (root.TryGetProperty("TableColumnOrder", out var coElement))
                    {
                        _currentConfig.ColumnOrder = System.Text.Json.JsonSerializer.Deserialize<List<string>>(coElement.GetRawText());
                    }

                    // Extract detail-view grouping pair if present.
                    if (root.TryGetProperty("DetailGroupByFieldId", out var dgfEl))
                        _detailGroupByFieldId = dgfEl.GetString();
                    if (root.TryGetProperty("DetailGroupByDirection", out var dgdEl))
                        _detailGroupByDirection = dgdEl.GetString() ?? "asc";
                    // Extract detail-view default sort pair if present.
                    if (root.TryGetProperty("DetailSortFieldId", out var dsfEl))
                        _detailSortFieldId = dsfEl.GetString();
                    if (root.TryGetProperty("DetailSortDirection", out var dsdEl))
                        _detailSortDirection = dsdEl.GetString() ?? "asc";
                    if (root.TryGetProperty("DetailSortThenByFieldId", out var dstfEl))
                        _detailSortThenByFieldId = dstfEl.GetString();
                    if (root.TryGetProperty("DetailSortThenByDirection", out var dstdEl))
                        _detailSortThenByDirection = dstdEl.GetString() ?? "asc";

                    // Extract hidden columns. Union with the template's list
                    // (set earlier at line ~953) instead of overwriting — a
                    // stale per-report list was blocking fields newly hidden
                    // at the template level. Matches the fix in ReportViewer
                    // / DetailViewer / MasterDashboard.
                    if (root.TryGetProperty("HiddenColumns", out var hcElement))
                    {
                        var reportHidden = System.Text.Json.JsonSerializer
                            .Deserialize<List<string>>(hcElement.GetRawText()) ?? new();
                        _currentConfig.HiddenColumns = _currentConfig.HiddenColumns is null
                            ? reportHidden
                            : _currentConfig.HiddenColumns.Union(reportHidden, StringComparer.OrdinalIgnoreCase).ToList();
                    }

                    // Extract custom filter IDs
                    if (root.TryGetProperty("CustomFilterIds", out var cfElement))
                    {
                        _currentConfig.CustomFilterIds = System.Text.Json.JsonSerializer.Deserialize<List<string>>(cfElement.GetRawText());
                    }

                    // Table-view calculated columns. Independent of the
                    // dashboard's calc columns (those live inside
                    // DashboardConfigJson). Missing key on legacy saves
                    // is treated as "no calc columns".
                    if (root.TryGetProperty("TableCalculatedColumns", out var tcElement))
                    {
                        _currentConfig.TableCalculatedColumns = System.Text.Json.JsonSerializer
                            .Deserialize<List<TableCalcColumnDef>>(tcElement.GetRawText());
                    }

                    // Extract Advanced (ad-hoc) filters. Only honored when
                    // the feature flag is on; when flipped off, persisted
                    // filters are silently ignored (rollback-friendly —
                    // re-enabling the flag restores them).
                    //
                    // Back-compat: older experimental saves stored a flat
                    // array of FilterClause. Detect the array shape and
                    // wrap into a root AND-group so the tree-based UI
                    // renders them unchanged. New saves always emit the
                    // object shape {op,items:[…]}.
                    if (_advancedFiltersEnabled
                        && root.TryGetProperty("AdvancedFilters", out var afElement))
                    {
                        try
                        {
                            if (afElement.ValueKind == System.Text.Json.JsonValueKind.Array)
                            {
                                var flat = System.Text.Json.JsonSerializer
                                    .Deserialize<List<TleReportingDashboard.Web.Models.FilterClause>>(afElement.GetRawText())
                                    ?? new();
                                _filterRoot = new TleReportingDashboard.Web.Models.FilterGroup
                                {
                                    Op = TleReportingDashboard.Web.Models.FilterGroupOps.And,
                                    Items = flat
                                        .Select(c => new TleReportingDashboard.Web.Models.FilterItem { Clause = c })
                                        .ToList()
                                };
                            }
                            else if (afElement.ValueKind == System.Text.Json.JsonValueKind.Object)
                            {
                                _filterRoot = System.Text.Json.JsonSerializer
                                    .Deserialize<TleReportingDashboard.Web.Models.FilterGroup>(afElement.GetRawText(),
                                        new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true })
                                    ?? NewEmptyFilterRoot();
                            }
                        }
                        catch { _filterRoot = NewEmptyFilterRoot(); }
                    }

                    // Extract table view default sort
                    if (root.TryGetProperty("TableSortField", out var tsfElement))
                        _currentConfig.DefaultSortField = tsfElement.GetString();
                    if (root.TryGetProperty("TableSortDirection", out var tsdElement))
                        _currentConfig.DefaultSortDirection = tsdElement.GetString();

                    // Per-report DISTINCT toggle. Read explicitly from JSON
                    // (true / false / missing → defaults to false) so a
                    // saved report keeps its stored state. The model's
                    // `Distinct = true` initializer only matters for
                    // brand-new reports that never hit this load path.
                    _currentConfig.Distinct = root.TryGetProperty("Distinct", out var distElement)
                        && distElement.ValueKind == System.Text.Json.JsonValueKind.True;

                    // Extract multi-column sort (primary first). When present,
                    // takes precedence over DefaultSortField/Direction for the
                    // grid's initial sort seeding.
                    if (root.TryGetProperty("TableSort", out var tsElement)
                        && tsElement.ValueKind == System.Text.Json.JsonValueKind.Array)
                    {
                        try
                        {
                            _currentConfig.TableSort = System.Text.Json.JsonSerializer
                                .Deserialize<List<TableSortSpec>>(tsElement.GetRawText()) ?? new();
                        }
                        catch { _currentConfig.TableSort = new(); }
                    }

                    // The rest is dashboard config — deserialize the whole thing
                    // (DashboardConfig ignores unknown properties like ColumnWidths)
                    _dashboardConfig = System.Text.Json.JsonSerializer.Deserialize<DashboardView.DashboardConfig>(report.ColumnState,
                        new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                    _currentConfig.DashboardConfigJson = report.ColumnState;

                    // Restore extra group-by field IDs. Both the legacy
                    // ExtraGroupByFieldIds (picker-required fields) and the
                    // new ExtraDimensionFieldIds (composite group-by) need to
                    // be included in the next query's SELECT.
                    if (_dashboardConfig?.ExtraGroupByFieldIds is not null)
                        _extraGroupByFieldIds = new HashSet<string>(_dashboardConfig.ExtraGroupByFieldIds, StringComparer.OrdinalIgnoreCase);
                    if (_dashboardConfig?.ExtraDimensionFieldIds is not null)
                        foreach (var fid in _dashboardConfig.ExtraDimensionFieldIds)
                            _extraGroupByFieldIds.Add(fid);
                }
                catch { /* not valid JSON, ignore */ }
            }

            // When a template is linked, the template owns the column order and default sort
            // so the report stays consistent with the template (matching the "fields locked
            // to template" lock on the FieldPicker). Per-report show/hide is preserved but
            // filtered to fields that still exist in the template.
            // Calc columns are NOT owned by the template — they're per-report
            // derivations on top — so calc keys from the saved combined
            // order are woven back into the template's field order at the
            // user-customized positions. Without this merge, every reload
            // of a templated report would drop the user's calc positioning.
            if (report.GridTemplateId.HasValue && resolvedTemplate is not null)
            {
                var templateOrder = resolvedTemplate.ColumnOrder is { Count: > 0 }
                    ? new List<string>(resolvedTemplate.ColumnOrder)
                    : new List<string>(_selectedFieldIds);
                _currentConfig.ColumnOrder = WeaveCalcsIntoTemplateOrder(
                    templateOrder,
                    _currentConfig.ColumnOrder ?? new List<string>(),
                    _currentConfig.TableCalculatedColumns);
                // Default sort: keep the per-report sort if the user saved one;
                // only fall back to the template's sort when the report has none.
                if (string.IsNullOrEmpty(_currentConfig.DefaultSortField)
                    && !string.IsNullOrEmpty(resolvedTemplate.DefaultSortField))
                {
                    _currentConfig.DefaultSortField = resolvedTemplate.DefaultSortField;
                    _currentConfig.DefaultSortDirection = resolvedTemplate.DefaultSortDirection;
                }
                _currentConfig.HiddenColumns = TleReportingDashboard.Web.Services.GridTemplateService
                    .FilterHiddenToTemplate(_selectedFieldIds, _currentConfig.HiddenColumns);
            }

            // Seed ReportGrid's multi-sort from persisted state (TableSort wins
            // if populated; otherwise fall back to the legacy single Default
            // Sort pair so pre-multi-sort reports still open with their sort).
            if (_currentConfig.TableSort is { Count: > 0 })
            {
                _initialSortTuples = _currentConfig.TableSort
                    .Select(s => (s.Field, s.Direction))
                    .ToList();
            }
            else if (!string.IsNullOrEmpty(_currentConfig.DefaultSortField))
            {
                _initialSortTuples = new List<(string, string)>
                {
                    (_currentConfig.DefaultSortField!, _currentConfig.DefaultSortDirection ?? "asc")
                };
            }

            // If we have an initial sort, mirror it into _liveSort so the
            // indicator strip shows the correct state before the user
            // interacts — otherwise it'd only populate after the first click.
            if (_initialSortTuples is { Count: > 0 })
                _liveSort = new List<(string, string)>(_initialSortTuples);

            // Auto-run the query after loading
            if (_selectedFieldIds.Any())
            {
                await HandleRunQuery();
            }
            // Seed the unique-column lookup so the Sort By / Then By
            // dropdowns show "(-)" markers from the very first render.
            await RefreshUniqueFieldIdsAsync();
            // Pre-fetch primary-table PKs so the first run already has a
            // FallbackSortColumns payload — without this the very first
            // (None)-sorted query falls through to "ORDER BY first selected
            // field" (legacy behavior), which is the same instability we're
            // trying to avoid.
            await RefreshPrimaryKeyColumnsAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load report: {ex.Message}", Severity.Error);
        }
    }

    // ── Field management ──

    private async Task HandleFieldAdded(string fieldId)
    {
        if (!_selectedFieldIds.Contains(fieldId))
        {
            _selectedFieldIds.Add(fieldId);
            _currentConfig.SelectedFieldIds = new List<string>(_selectedFieldIds);
            // Keep ColumnOrder in sync so the chip bar sequence matches the
            // grid. New fields append to the end of the existing order.
            if (_currentConfig.ColumnOrder is { Count: > 0 } && !_currentConfig.ColumnOrder.Contains(fieldId))
                _currentConfig.ColumnOrder.Add(fieldId);
            // Refresh the unique-column lookup so the new field's source
            // table gets queried (skipped if cached) — drives the "(-)"
            // marker in the Sort By / Then By dropdowns.
            await RefreshUniqueFieldIdsAsync();
            if (_hasRunOnce) await HandleRunQuery();
        }
    }

    private async Task HandleFieldRemoved(string fieldId)
    {
        // The chip bar emits IDs for both fields AND calc keys (calc chips
        // are reorderable inline). Dispatch to the calc-removal helper when
        // the id matches a calc Key — otherwise fall through to the regular
        // field-removal path.
        if (_currentConfig.TableCalculatedColumns is { Count: > 0 } &&
            _currentConfig.TableCalculatedColumns.Any(c =>
                string.Equals(c.Key, fieldId, StringComparison.OrdinalIgnoreCase)))
        {
            RemoveTableCalcColumn(fieldId);
            _currentConfig.ColumnOrder?.Remove(fieldId);
            return;
        }

        _selectedFieldIds.Remove(fieldId);
        _currentConfig.SelectedFieldIds = new List<string>(_selectedFieldIds);
        _currentConfig.ColumnOrder?.Remove(fieldId);

        // Also strip from the dashboard's extra group-by / dimension lists.
        // Without this, an id that lives ONLY in _extraGroupByFieldIds (a
        // dashboard-configured extra) keeps getting injected into the SQL
        // even after the admin clicks ✕ on its orphan chip — the chip
        // disappears for one frame and reappears on the next render.
        _extraGroupByFieldIds.RemoveWhere(id => string.Equals(id, fieldId, StringComparison.OrdinalIgnoreCase));
        if (_dashboardConfig is not null)
        {
            var newExtraGroupBy = _dashboardConfig.ExtraGroupByFieldIds?
                .Where(id => !string.Equals(id, fieldId, StringComparison.OrdinalIgnoreCase))
                .ToList();
            var newExtraDim = _dashboardConfig.ExtraDimensionFieldIds?
                .Where(id => !string.Equals(id, fieldId, StringComparison.OrdinalIgnoreCase))
                .ToList();
            _dashboardConfig = _dashboardConfig with
            {
                ExtraGroupByFieldIds = newExtraGroupBy,
                ExtraDimensionFieldIds = newExtraDim
            };
            _currentConfig.DashboardConfigJson = System.Text.Json.JsonSerializer.Serialize(_dashboardConfig);
        }

        if (_hasRunOnce && _selectedFieldIds.Any()) await HandleRunQuery();
        else if (!_selectedFieldIds.Any()) _queryData = null;
    }

    // Used only when the report is linked to a template — flips a column's hide state.
    // If the grid is mounted, route through it so the table updates immediately and the
    // grid emits OnHiddenColumnsChanged, which keeps _currentConfig.HiddenColumns in sync.
    // If no grid yet (query hasn't run), just mutate the config so the picker re-renders.
    private async Task HandleFieldVisibilityToggled(string fieldId)
    {
        if (_reportGrid is not null)
        {
            await _reportGrid.ToggleColumnVisibilityExternal(fieldId);
            return;
        }

        var hidden = _currentConfig.HiddenColumns ?? new List<string>();
        if (!hidden.Remove(fieldId))
            hidden.Add(fieldId);
        _currentConfig.HiddenColumns = hidden;
        StateHasChanged();
    }

    private Task HandleClearAllFields()
    {
        _selectedFieldIds.Clear();
        _currentConfig.SelectedFieldIds.Clear();
        _queryData = null;
        return Task.CompletedTask;
    }

    // ── Table-view calculated columns ─────────────────────────────────
    // Add / edit / remove a TableCalcColumnDef. Storage lives on
    // ReportConfig.TableCalculatedColumns; ReportGrid reads the list to
    // render extra columns inline alongside the data columns. Per-row
    // evaluation runs against the row dict via CalculatedColumnEvaluator.
    private async Task OpenTableCalcDialog(string? existingKey)
    {
        var list = _currentConfig.TableCalculatedColumns ??= new List<TableCalcColumnDef>();
        var existing = existingKey is null ? null : list.FirstOrDefault(c => c.Key == existingKey);

        // Picks come from the report's currently-selected non-aggregate
        // fields — those are the values present on each row. Aggregate
        // fields are excluded because their values aren't on the raw row;
        // they're only meaningful in dashboard / group-by contexts.
        var picks = _selectedFieldDefinitions
            .Where(f => string.IsNullOrWhiteSpace(f.SqlExpression))
            .Select(f => new CalculatedColumnDialog.ColumnPick(f.Id, f.Label))
            .ToList();

        // Load this connection's joins so the SQL-mode JOINs picker has
        // something to offer. Best-effort: a load failure leaves the list
        // empty and the dialog falls back to the "no joins available"
        // hint, which is still actionable.
        var joinPicks = await LoadJoinPicksAsync();

        var parameters = new DialogParameters
        {
            { "IsNew", existing is null },
            { "InitialKey", existing?.Key },
            { "InitialLabel", existing?.Label ?? string.Empty },
            { "InitialFormula", existing?.Formula ?? string.Empty },
            { "InitialFormat", existing?.Format },
            { "InitialDataType", existing?.DataType },
            { "InitialSqlExpression", existing?.SqlExpression },
            { "InitialJoinIds", existing?.JoinIds },
            { "AvailableColumns", picks },
            // Per-report SQL mode is enabled for the table view's calc
            // dialog. The dashboard's calc dialog leaves AllowSqlMode at
            // its default of false so its existing formula-only flow is
            // unchanged.
            { "AllowSqlMode", true },
            { "AvailableJoins", joinPicks }
        };
        var dialog = await DialogService.ShowAsync<CalculatedColumnDialog>(
            existing is null ? "Add Calculated Column" : "Edit Calculated Column",
            parameters,
            new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true });

        var result = await dialog.Result;
        if (result is null || result.Canceled) return;
        if (result.Data is not CalculatedColumnDialog.CalcDialogResult res) return;

        if (existing is null)
        {
            list.Add(new TableCalcColumnDef
            {
                Key = res.Key,
                Label = res.Label,
                Formula = res.Formula,
                SqlExpression = res.SqlExpression,
                JoinIds = res.JoinIds,
                Format = res.Format,
                DataType = res.DataType
            });
        }
        else
        {
            existing.Label = res.Label;
            existing.Formula = res.Formula;
            existing.SqlExpression = res.SqlExpression;
            existing.JoinIds = res.JoinIds;
            existing.Format = res.Format;
            existing.DataType = res.DataType;
        }
        MarkDirty();
        StateHasChanged();
    }

    // Loads the report's connection joins and projects them into the
    // (Id, Label) shape the calc dialog's JOINs picker expects. JoinId is
    // the string slug QueryBuilder uses to match references; label is a
    // friendly "<id> — <ToTable>" description. Joins without a JoinId
    // (raw SQL with no slug) are skipped because they can't be referenced.
    private async Task<List<CalculatedColumnDialog.JoinPick>> LoadJoinPicksAsync()
    {
        try
        {
            var joinConfigs = await SchemaService.GetJoinConfigsAsync(_currentConfig.ConnectionId);
            return joinConfigs
                .Where(j => !string.IsNullOrWhiteSpace(j.JoinId))
                .Select(j => new CalculatedColumnDialog.JoinPick(
                    j.JoinId!,
                    string.IsNullOrWhiteSpace(j.ToTable)
                        ? j.JoinId!
                        : $"{j.JoinId} — {j.ToTable}"))
                .OrderBy(p => p.Label, StringComparer.OrdinalIgnoreCase)
                .ToList();
        }
        catch
        {
            return new List<CalculatedColumnDialog.JoinPick>();
        }
    }

    private void RemoveTableCalcColumn(string key)
    {
        _currentConfig.TableCalculatedColumns?.RemoveAll(c => c.Key == key);
        StateHasChanged();
    }

    // Resolves the effective sort field for the table-view query. Priority:
    //   1. _currentConfig.TableSort (live multi-sort from column-header
    //      clicks — most-recent explicit user intent). Element 0 = primary.
    //   2. _detailSortFieldId (the "Sort By" dropdown). The dropdown drives
    //      both the table-view query sort AND the detail-view sort so
    //      what the admin sees in the dropdown matches what the SQL does.
    //   3. _detailGroupByFieldId (the "Group By" dropdown) as the primary
    //      sort, with the Sort By dropdown sliding into secondary — same
    //      cluster-by-group then sort-within-group shape the detail view
    //      uses, so the table view stays consistent.
    //   4. Legacy DefaultSortField (older saves before multi-sort existed).
    // Without this, the SQL falls back to ORDER BY first selected field.
    private string? ResolveEffectiveSortField()
    {
        if (_currentConfig.TableSort is { Count: > 0 } ts) return ts[0].Field;
        if (!string.IsNullOrWhiteSpace(_detailGroupByFieldId)
            && _detailGroupByDirection != "none") return _detailGroupByFieldId;
        if (!string.IsNullOrWhiteSpace(_detailSortFieldId)) return _detailSortFieldId;
        // Empty (not null) _detailSortFieldId = user explicitly picked
        // (None) — fall through with no sort. The legacy SortField
        // fallback only applies when the dropdown was never touched (null).
        if (_detailSortFieldId == string.Empty) return null;
        return _currentConfig.SortField ?? _currentConfig.DefaultSortField;
    }

    // True when the user has explicitly chosen "(None)" in the Sort By
    // dropdown AND no other sort source (live header click, Group By,
    // legacy default) is in play. Drives QueryRequest.DisableDefaultSort
    // so QueryBuilder skips its own fallback ORDER BY.
    private bool ResolveDisableDefaultSort()
    {
        if (_currentConfig.TableSort is { Count: > 0 }) return false;
        if (!string.IsNullOrWhiteSpace(_detailGroupByFieldId)
            && _detailGroupByDirection != "none") return false;
        if (!string.IsNullOrWhiteSpace(_detailSortFieldId)) return false;
        // Sort By dropdown picked (None) wins over the legacy slots —
        // honoring the explicit choice over an older saved default.
        if (_detailSortFieldId == string.Empty) return true;
        return false;
    }

    private string? ResolveEffectiveSortDirection()
    {
        if (_currentConfig.TableSort is { Count: > 0 } ts) return ts[0].Direction;
        if (!string.IsNullOrWhiteSpace(_detailGroupByFieldId)
            && _detailGroupByDirection != "none")
            return _detailGroupByDirection == "desc" ? "desc" : "asc";
        if (!string.IsNullOrWhiteSpace(_detailSortFieldId))
            return _detailSortDirection == "desc" ? "desc" : "asc";
        return _currentConfig.SortDirection ?? _currentConfig.DefaultSortDirection;
    }

    private string? ResolveEffectiveSecondarySortField()
    {
        if (_currentConfig.TableSort is { Count: > 1 } ts) return ts[1].Field;
        // When Group By drives primary, the Sort By dropdown slides into
        // secondary — sort rows within each group by the picked field.
        if (!string.IsNullOrWhiteSpace(_detailGroupByFieldId)
            && _detailGroupByDirection != "none"
            && !string.IsNullOrWhiteSpace(_detailSortFieldId)
            && !string.Equals(_detailSortFieldId, _detailGroupByFieldId, StringComparison.OrdinalIgnoreCase))
            return _detailSortFieldId;
        // Then By tiebreaker — stable OFFSET pagination when Sort By
        // isn't unique. Only relevant when there's a primary Sort By
        // and the tiebreaker picks a different field.
        if (!string.IsNullOrWhiteSpace(_detailSortFieldId)
            && !string.IsNullOrWhiteSpace(_detailSortThenByFieldId)
            && !string.Equals(_detailSortFieldId, _detailSortThenByFieldId, StringComparison.OrdinalIgnoreCase))
            return _detailSortThenByFieldId;
        return null;
    }

    private string? ResolveEffectiveSecondarySortDirection()
    {
        if (_currentConfig.TableSort is { Count: > 1 } ts) return ts[1].Direction;
        if (!string.IsNullOrWhiteSpace(_detailGroupByFieldId)
            && _detailGroupByDirection != "none"
            && !string.IsNullOrWhiteSpace(_detailSortFieldId)
            && !string.Equals(_detailSortFieldId, _detailGroupByFieldId, StringComparison.OrdinalIgnoreCase))
            return _detailSortDirection == "desc" ? "desc" : "asc";
        if (!string.IsNullOrWhiteSpace(_detailSortFieldId)
            && !string.IsNullOrWhiteSpace(_detailSortThenByFieldId)
            && !string.Equals(_detailSortFieldId, _detailSortThenByFieldId, StringComparison.OrdinalIgnoreCase))
            return _detailSortThenByDirection == "desc" ? "desc" : "asc";
        return null;
    }

    // Projects the report's SQL-mode calc columns into the request shape
    // QueryBuilder reads. Formula-mode calcs aren't included — they
    // evaluate client-side in ReportGrid and don't touch the query.
    private List<TleReportingDashboard.Web.Models.TableCalcSqlSelector>? BuildTableCalcSqlSelectors()
    {
        var calcs = _currentConfig.TableCalculatedColumns;
        if (calcs is null || calcs.Count == 0) return null;
        var sqlCalcs = calcs
            .Where(c => !string.IsNullOrWhiteSpace(c.SqlExpression))
            .Select(c => new TleReportingDashboard.Web.Models.TableCalcSqlSelector
            {
                Key = c.Key,
                SqlExpression = c.SqlExpression!,
                JoinIds = c.JoinIds
            })
            .ToList();
        return sqlCalcs.Count > 0 ? sqlCalcs : null;
    }

    // Called from FieldChipBar drag-drop. The chip bar owns the column order
    // now — user drags chips to reorder the report table. Persist the new
    // order and rebuild _selectedFieldIds so subsequent picker changes and
    // query runs respect it.
    private Task HandleSortChanged(List<(string Field, string Direction)> sort)
    {
        _liveSort = sort;
        _currentConfig.TableSort = sort
            .Select(t => new TableSortSpec { Field = t.Field, Direction = t.Direction })
            .ToList();
        return Task.CompletedTask;
    }

    // True when the user's interactive sort differs from the one saved on the
    // report. Used to toggle visibility of the Revert button.
    private bool IsSortDeviated()
    {
        var initial = _initialSortTuples ?? new List<(string, string)>();
        if (initial.Count != _liveSort.Count) return true;
        for (var i = 0; i < initial.Count; i++)
        {
            if (!string.Equals(initial[i].Field, _liveSort[i].Field, StringComparison.OrdinalIgnoreCase)) return true;
            if (!string.Equals(initial[i].Direction, _liveSort[i].Direction, StringComparison.OrdinalIgnoreCase)) return true;
        }
        return false;
    }

    // Restore the saved sort by forcing ReportGrid to remount. Its first-
    // render path re-applies InitialSort from scratch, which also refreshes
    // _liveSort via the OnSortChanged callback once the grid settles.
    private void RevertSort()
    {
        _gridRenderKey = Guid.NewGuid().ToString();
        _liveSort = _initialSortTuples is { Count: > 0 }
            ? new List<(string, string)>(_initialSortTuples)
            : new List<(string, string)>();
    }

    // Resolves a field id to its human-readable label for the sort indicator,
    // falling back to the raw id if the field isn't in the currently-loaded
    // domain list.
    private string GetFieldLabel(string fieldId)
    {
        foreach (var dom in _domains)
        {
            var match = dom.Fields.FirstOrDefault(f =>
                string.Equals(f.Id, fieldId, StringComparison.OrdinalIgnoreCase));
            if (match is not null) return match.Label;
        }
        return fieldId;
    }

    private Task HandleFieldOrderChanged(List<string> newOrder)
    {
        // newOrder is the unified chip list — a mix of field ids and calc
        // keys. Split into the field-only and calc-only subsets so the
        // separate state stores stay accurate. ColumnOrder holds the FULL
        // mixed sequence so the grid can interleave on render.
        var calcKeys = (_currentConfig.TableCalculatedColumns ?? new())
            .Select(c => c.Key)
            .Where(k => !string.IsNullOrEmpty(k))
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        var fieldOrder = newOrder.Where(id => !calcKeys.Contains(id)).ToList();
        var calcOrder = newOrder.Where(id => calcKeys.Contains(id)).ToList();

        _selectedFieldIds = new List<string>(fieldOrder);
        _currentConfig.SelectedFieldIds = new List<string>(fieldOrder);
        _currentConfig.ColumnOrder = new List<string>(newOrder);

        // Reorder TableCalculatedColumns to match the new calc-key order.
        // Any calc not in calcOrder (shouldn't happen but defensive) gets
        // appended at the end so we don't drop user data.
        if (_currentConfig.TableCalculatedColumns is { Count: > 0 } && calcOrder.Count > 0)
        {
            var byKey = _currentConfig.TableCalculatedColumns
                .ToDictionary(c => c.Key, StringComparer.OrdinalIgnoreCase);
            var reordered = new List<TleReportingDashboard.Web.Models.TableCalcColumnDef>();
            foreach (var key in calcOrder)
            {
                if (byKey.TryGetValue(key, out var c))
                {
                    reordered.Add(c);
                    byKey.Remove(key);
                }
            }
            // Anything left in byKey wasn't represented in calcOrder —
            // append in original list order.
            foreach (var c in _currentConfig.TableCalculatedColumns)
            {
                if (byKey.ContainsKey(c.Key)) reordered.Add(c);
            }
            _currentConfig.TableCalculatedColumns = reordered;
        }

        // If the grid is mounted, push the new order through so it re-lays-out.
        _reportGrid?.ApplyColumnOrder(newOrder);
        return Task.CompletedTask;
    }

    private Task HandleFiltersChanged(Dictionary<string, object?> filters)
    {
        _currentConfig.Filters = filters;
        return Task.CompletedTask;
    }

    // ── Group By helpers (shown only when an aggregate field is selected) ──

    private bool HasAggregateField() =>
        _selectedFieldDefinitions.Any(f => !string.IsNullOrWhiteSpace(f.SqlExpression)
            && TleReportingDashboard.Web.Services.QueryBuilder.IsAggregateField(ToFieldConfig(f)));

    private IEnumerable<string> SelectedNonAggregateFieldIds =>
        _selectedFieldDefinitions
            .Where(f => !(!string.IsNullOrWhiteSpace(f.SqlExpression)
                && TleReportingDashboard.Web.Services.QueryBuilder.IsAggregateField(ToFieldConfig(f))))
            .Select(f => f.Id);

    // Resolves the effective GROUP BY set: user's custom list if set,
    // otherwise all non-aggregate selected fields in pick order.
    private List<string> EffectiveGroupByFieldIds =>
        _currentConfig.GroupByFieldIds is { Count: > 0 }
            ? _currentConfig.GroupByFieldIds
                .Where(id => SelectedNonAggregateFieldIds.Contains(id, StringComparer.OrdinalIgnoreCase))
                .ToList()
            : SelectedNonAggregateFieldIds.ToList();

    // Returns the field id list to ship on a QueryRequest. Removes
    // HiddenColumns from the SELECT unless something else in the report
    // config still needs them — Sort By / Then By / Detail Group By /
    // aggregation Group By all "protect" their referenced field so the
    // SQL emits correct ORDER BY / GROUP BY clauses (and any associated
    // lookup CTE + JOIN). Without this filter, a hidden column wastes a
    // SELECT column AND emits its lookup CTE + JOIN even when nothing
    // references it. The QueryBuilder's sort-only auto-include path
    // re-adds out-of-report sort fields to resolvedFields anyway, so
    // hiding a sort field here is safe — its lookup still gets emitted
    // because it's reachable from the sort.
    private List<string> BuildEffectiveQueryFieldIds()
    {
        var hidden = _currentConfig.HiddenColumns is { Count: > 0 }
            ? new HashSet<string>(_currentConfig.HiddenColumns, StringComparer.OrdinalIgnoreCase)
            : null;

        var protectedIds = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        var primary = ResolveEffectiveSortField();
        if (!string.IsNullOrWhiteSpace(primary)) protectedIds.Add(primary);
        var secondary = ResolveEffectiveSecondarySortField();
        if (!string.IsNullOrWhiteSpace(secondary)) protectedIds.Add(secondary);
        if (!string.IsNullOrWhiteSpace(_detailSortFieldId)) protectedIds.Add(_detailSortFieldId);
        if (!string.IsNullOrWhiteSpace(_detailSortThenByFieldId)) protectedIds.Add(_detailSortThenByFieldId);
        if (!string.IsNullOrWhiteSpace(_detailGroupByFieldId)) protectedIds.Add(_detailGroupByFieldId);
        if (_currentConfig.GroupByFieldIds is { Count: > 0 })
        {
            foreach (var id in _currentConfig.GroupByFieldIds) protectedIds.Add(id);
        }

        var result = new List<string>(_selectedFieldIds.Count);
        foreach (var id in _selectedFieldIds)
        {
            if (hidden is null || !hidden.Contains(id) || protectedIds.Contains(id))
                result.Add(id);
        }

        // Extra group-by fields (dashboard-tab "extra dimensions") aren't
        // necessarily in _selectedFieldIds and aren't subject to the hide
        // filter — they're explicit dashboard-only adds.
        foreach (var extra in _extraGroupByFieldIds)
        {
            if (!result.Contains(extra, StringComparer.OrdinalIgnoreCase))
                result.Add(extra);
        }

        return result;
    }

    private void ToggleGroupByField(string fieldId)
    {
        var list = _currentConfig.GroupByFieldIds is { Count: > 0 }
            ? new List<string>(_currentConfig.GroupByFieldIds)
            : SelectedNonAggregateFieldIds.ToList();
        if (list.Contains(fieldId, StringComparer.OrdinalIgnoreCase))
            list.RemoveAll(id => string.Equals(id, fieldId, StringComparison.OrdinalIgnoreCase));
        else
            list.Add(fieldId);
        _currentConfig.GroupByFieldIds = list;
    }

    private string GetSelectedFieldLabel(string fieldId) =>
        _selectedFieldDefinitions.FirstOrDefault(f => f.Id == fieldId)?.Label ?? fieldId;

    // Drill-down group-by picker. Empty string in the dropdown means "(None)";
    // we normalize to null for persistence so the ColumnState JSON doesn't
    // carry an empty key.
    private void OnDetailGroupByChanged(string? value)
    {
        _detailGroupByFieldId = string.IsNullOrEmpty(value) ? null : value;
        // Picking from this dropdown is an explicit sort intent — clear
        // any live header-click sort so it doesn't shadow the dropdown's
        // choice. Without this, a stale TableSort entry (e.g. from a
        // column header you clicked earlier) keeps winning even after
        // you change the dropdown.
        ClearLiveTableSort();
    }

    // Resolves a field id back to its label for the picker's display — keeps
    // MudSelect's closed label correct when the items list rebuilds (same
    // pattern used by the Primary Table and Connection pickers elsewhere).
    private string DetailGroupLabelFor(string? value)
    {
        if (string.IsNullOrEmpty(value)) return "(None)";
        var f = _selectedFieldDefinitions.FirstOrDefault(f => f.Id == value);
        if (f is not null) return f.Label;
        // SQL-mode calc Key — return its caption with the (*) marker so the
        // closed display matches the dropdown items.
        var cc = _currentConfig.TableCalculatedColumns?.FirstOrDefault(c =>
            string.Equals(c.Key, value, StringComparison.OrdinalIgnoreCase));
        if (cc is not null) return $"{cc.Label} (*)";
        return value;
    }

    // Detail default sort — same pattern as the group-by picker.
    private void OnDetailSortChanged(string? value)
    {
        // Distinguish "user explicitly picked (None)" (empty string) from
        // "dropdown never touched" (null). Used by ResolveEffectiveSortField
        // to skip the fallback ORDER BY when None was the explicit choice
        // — without this, the table query always sorts by the first column.
        _detailSortFieldId = value ?? string.Empty;
        // Same reason as OnDetailGroupByChanged: dropdown pick is an
        // explicit override of any prior live header-click sort.
        ClearLiveTableSort();
    }

    // Resets the live multi-sort state when the admin makes an explicit
    // choice via the Sort By / Group By dropdowns. Without this, a stale
    // TableSort entry from a previous column-header click outranks the
    // dropdown in ResolveEffectiveSortField and the dropdown's choice
    // never reaches the SQL.
    private void ClearLiveTableSort()
    {
        if (_currentConfig.TableSort is { Count: > 0 })
            _currentConfig.TableSort = new();
        if (_liveSort.Count > 0)
            _liveSort = new List<(string, string)>();
        // Force the grid to re-mount so MudDataGrid's internal sort
        // indicators clear too — otherwise the up/down arrow stays on
        // the previously-clicked column even though the saved sort is gone.
        _gridRenderKey = Guid.NewGuid().ToString();
    }

    private string DetailSortLabelFor(string? value)
    {
        if (string.IsNullOrEmpty(value)) return "(None)";
        var f = _selectedFieldDefinitions.FirstOrDefault(f => f.Id == value);
        if (f is not null)
        {
            return _uniqueFieldIds.Contains(f.Id) ? $"{f.Label} (-)" : f.Label;
        }
        var cc = _currentConfig.TableCalculatedColumns?.FirstOrDefault(c =>
            string.Equals(c.Key, value, StringComparison.OrdinalIgnoreCase));
        if (cc is not null) return $"{cc.Label} (*)";
        return value;
    }

    private void OnDetailSortThenByChanged(string? value)
    {
        _detailSortThenByFieldId = string.IsNullOrEmpty(value) ? null : value;
        // Same intent as the primary Sort By dropdown — clear any live
        // header-click sort so the dropdown chain takes over.
        ClearLiveTableSort();
    }

    private string DetailSortThenByLabelFor(string? value) => DetailSortLabelFor(value);

    // Refreshes the unique-column lookup for every distinct source table
    // referenced by selected fields. Runs after field changes so the
    // dropdown's "(-)" marker accurately tags eligible tiebreakers.
    // Best-effort: per-table query failures (locked-down accounts) just
    // skip the marker for that table.
    private async Task RefreshUniqueFieldIdsAsync()
    {
        var tables = _selectedFieldDefinitions
            .Where(f => string.IsNullOrWhiteSpace(f.SqlExpression)
                     && !string.IsNullOrWhiteSpace(f.SourceTable)
                     && !string.IsNullOrWhiteSpace(f.SourceColumn))
            .Select(f => f.SourceTable)
            .Distinct(StringComparer.OrdinalIgnoreCase);

        foreach (var tableRef in tables)
        {
            if (_uniqueColumnsByTable.ContainsKey(tableRef)) continue;
            // Strip alias / schema-qualify. "schema.table" or "table" both
            // accepted; aliased "schema.table AS x" reduces to schema.table.
            var bare = tableRef;
            var asIdx = bare.IndexOf(" AS ", StringComparison.OrdinalIgnoreCase);
            if (asIdx > 0) bare = bare[..asIdx].Trim();
            var dot = bare.IndexOf('.');
            string? schema = dot > 0 ? bare[..dot] : null;
            var table = dot > 0 ? bare[(dot + 1)..] : bare;
            try
            {
                var cols = await SchemaBrowser.GetUniqueColumnNamesAsync(_currentConfig.ConnectionId, schema, table);
                _uniqueColumnsByTable[tableRef] = cols;
            }
            catch
            {
                _uniqueColumnsByTable[tableRef] = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
            }
        }

        var ids = new HashSet<string>(StringComparer.OrdinalIgnoreCase);

        // Pass 1: admin-asserted IsUnique fields from the ENTIRE schema —
        // not just the report's selected set. The Sort By / Then By
        // dropdowns surface every schema field with markers, and an admin
        // routinely picks a unique column (e.g. an "ID") as the tiebreaker
        // *without* adding it as a visible grid column. If we only scanned
        // selected fields, that out-of-report unique pick would lose its
        // (-) marker AND fail the save-time stability check.
        foreach (var f in _domains.SelectMany(d => d.Fields))
        {
            if (f.IsUnique) ids.Add(f.Id);
        }

        // Pass 2: DB-attested uniques for the selected fields' source
        // tables. Constraint coverage stays scoped to selected fields —
        // those are the only tables the report is reading from.
        foreach (var f in _selectedFieldDefinitions)
        {
            if (string.IsNullOrWhiteSpace(f.SourceTable) || string.IsNullOrWhiteSpace(f.SourceColumn)) continue;
            if (_uniqueColumnsByTable.TryGetValue(f.SourceTable, out var cols)
                && cols.Contains(f.SourceColumn))
            {
                ids.Add(f.Id);
            }
        }
        _uniqueFieldIds = ids;
    }

    // Pulls the PK column names of the report's primary table (in PK ordinal
    // order) and stashes them on _primaryTablePkColumns. Shipped on the
    // QueryRequest as FallbackSortColumns — QueryBuilder appends them as the
    // ORDER BY when no user sort is configured, so OFFSET pagination stays
    // stable on Postgres even when the admin picked "(None)" in the Sort By
    // dropdown. Cached per (connection, primary-table) to avoid repeating the
    // information_schema lookup on every keystroke / re-run.
    private async Task RefreshPrimaryKeyColumnsAsync()
    {
        var primary = _currentConfig.PrimaryTable;
        var cid = _currentConfig.ConnectionId;
        if (string.IsNullOrWhiteSpace(primary) || cid is null)
        {
            _primaryTablePkColumns = new();
            _pkLookupCacheKey = null;
            return;
        }

        // Strip alias if present — we only need the bare schema.table.
        var bare = primary;
        var asIdx = bare.IndexOf(" AS ", StringComparison.OrdinalIgnoreCase);
        if (asIdx > 0) bare = bare[..asIdx].Trim();

        var cacheKey = $"{cid}|{bare}";
        if (string.Equals(_pkLookupCacheKey, cacheKey, StringComparison.OrdinalIgnoreCase))
            return;

        var dot = bare.IndexOf('.');
        string? schema = dot > 0 ? bare[..dot] : null;
        var table = dot > 0 ? bare[(dot + 1)..] : bare;
        try
        {
            // GetEffectivePrimaryKeyColumnsAsync layers admin-flagged
            // IsUnique fields on top of the information_schema lookup, so
            // accounts that can't query constraints still get a fallback
            // tiebreaker (and accounts that can get the union).
            var schemaFields = await SchemaService.GetFieldConfigsAsync(cid);
            var pks = await SchemaBrowser.GetEffectivePrimaryKeyColumnsAsync(cid, schema, table, schemaFields);
            _primaryTablePkColumns = pks ?? new List<string>();
        }
        catch
        {
            _primaryTablePkColumns = new List<string>();
        }
        _pkLookupCacheKey = cacheKey;
    }

    // ── Advanced Filters helpers ──
    // Factory for a fresh empty root group — used on load failures and
    // when resetting state. Always an AND root with zero items.
    private static TleReportingDashboard.Web.Models.FilterGroup NewEmptyFilterRoot() => new()
    {
        Op = TleReportingDashboard.Web.Models.FilterGroupOps.And,
        Items = new List<TleReportingDashboard.Web.Models.FilterItem>()
    };

    // Counts every leaf clause in the tree, across all nesting levels.
    // Drives the chip count shown next to the panel title.
    private static int CountAdvancedFilterLeaves(TleReportingDashboard.Web.Models.FilterGroup? g)
    {
        if (g?.Items is null) return 0;
        var count = 0;
        foreach (var item in g.Items)
        {
            if (item?.Clause is not null) count++;
            else if (item?.Group is not null) count += CountAdvancedFilterLeaves(item.Group);
        }
        return count;
    }

    // Tree-walk helper: returns true when at least one leaf clause exists.
    // Empty root or group-of-only-empty-groups both count as "no filters".
    private static bool HasAdvancedFilterLeaves(TleReportingDashboard.Web.Models.FilterGroup? g)
    {
        if (g?.Items is null) return false;
        foreach (var item in g.Items)
        {
            if (item?.Clause is not null) return true;
            if (item?.Group is not null && HasAdvancedFilterLeaves(item.Group)) return true;
        }
        return false;
    }

    // Deep-clones a FilterGroup tree so the QueryRequest we send off
    // doesn't share mutable state with the UI. Same pattern the legacy
    // flat-list path used.
    private static TleReportingDashboard.Web.Models.FilterGroup CloneFilterGroup(TleReportingDashboard.Web.Models.FilterGroup source)
    {
        var copy = new TleReportingDashboard.Web.Models.FilterGroup
        {
            Op = source.Op,
            Items = new List<TleReportingDashboard.Web.Models.FilterItem>()
        };
        if (source.Items is null) return copy;
        foreach (var item in source.Items)
        {
            if (item is null) continue;
            var c = new TleReportingDashboard.Web.Models.FilterItem();
            if (item.Clause is not null)
            {
                c.Clause = new TleReportingDashboard.Web.Models.FilterClause
                {
                    FieldId = item.Clause.FieldId,
                    Op = item.Clause.Op,
                    Values = new List<string>(item.Clause.Values ?? new())
                };
            }
            else if (item.Group is not null)
            {
                c.Group = CloneFilterGroup(item.Group);
            }
            copy.Items.Add(c);
        }
        return copy;
    }

    // Shared marker for "something changed, re-render". The
    // AdvancedFilterGroup component + row component call back into this
    // so any place that reads the filter tree during render sees fresh
    // state (e.g. chip count in the panel header).
    private void MarkDirty() => StateHasChanged();

    // Ids of selected fields whose SqlExpression contains an aggregate —
    // Table view hides these; Dashboard view shows them as measures.
    private List<string> AggregateFieldIds =>
        _selectedFieldDefinitions
            .Where(f => !string.IsNullOrWhiteSpace(f.SqlExpression)
                && TleReportingDashboard.Web.Services.QueryBuilder.IsAggregateField(ToFieldConfig(f)))
            .Select(f => f.Id)
            .ToList();

    // Adapter so QueryBuilder.IsAggregateField (which takes FieldConfig) works
    // against the FieldDefinition instances the UI holds.
    private static FieldConfig ToFieldConfig(FieldDefinition f) =>
        new() { Id = f.Id, SqlExpression = f.SqlExpression };

    private void OnNameKeyDown(KeyboardEventArgs e)
    {
        if (e.Key is "Enter" or "Escape")
            _editingName = false;
    }

    // Save is gated on: at least one column picked, and (for new reports) a
    // non-empty name in the inline rename field. Existing reports already have
    // a name so the name check only applies when _loadedReportId is null.
    private bool CanSave()
    {
        if (!_selectedFieldIds.Any()) return false;
        if (_loadedReportId is null && string.IsNullOrWhiteSpace(_loadedReportName)) return false;
        return true;
    }

    private string GetSaveTooltip()
    {
        if (!_selectedFieldIds.Any()) return "Pick at least one column to enable";
        if (_loadedReportId is null && string.IsNullOrWhiteSpace(_loadedReportName))
            return "Name your report first (click the title to type a name)";
        return "Save your changes";
    }

    private async Task HandleExtraFieldRequired(string fieldId)
    {
        _extraGroupByFieldIds.Add(fieldId);
        await HandleRunQuery();
    }

    private void ToggleCustomFilter(string filterId)
    {
        _currentConfig.CustomFilterIds ??= new();
        if (!_currentConfig.CustomFilterIds.Remove(filterId))
            _currentConfig.CustomFilterIds.Add(filterId);
    }

    // ── Run Query ──

    private async Task OnConnectionChanged(Guid? newId)
    {
        // Saved reports ignore the picker (it's disabled anyway). New reports
        // update the pending config AND reload the schema so the field picker
        // reflects the newly-selected connection.
        if (_loadedReportId is not null) return;
        _currentConfig.ConnectionId = newId;
        await ReloadSchemaForConnectionAsync();
    }

    private async Task ReloadSchemaForConnectionAsync()
    {
        _domains = await SchemaService.GetDomainGroupsAsync(connectionId: _currentConfig.ConnectionId);
        _customFilters = await SchemaService.GetCustomFiltersAsync(_currentConfig.ConnectionId);

        // Dashboard group-by dropdown pulls from this list. Must rebuild on every
        // connection change or a saved-report load — otherwise it stays pinned to
        // whichever connection was active at page init (typically TLE).
        var allFields = await SchemaService.GetFieldConfigsAsync(_currentConfig.ConnectionId);
        _allDimensionFields = allFields
            .Where(f => f.DataType.Equals("text", StringComparison.OrdinalIgnoreCase) ||
                         f.DataType.Equals("integer", StringComparison.OrdinalIgnoreCase) ||
                         f.DataType.Equals("int", StringComparison.OrdinalIgnoreCase))
            .Select(f => new ColumnMeta { FieldId = f.Id, Label = f.Label, DataType = f.DataType, MaxLength = f.MaxLength, ValueSortOrder = f.ValueSortOrder, Format = f.Format })
            .OrderBy(f => f.Label, StringComparer.OrdinalIgnoreCase)
            .ToList();

        // Advanced Filters picker — shares the same field catalog. Copy
        // so the expansion panel's <AdvancedFilterRow> binds against a
        // stable list. Filter out aggregate-expression fields: filtering
        // by an outer aggregate makes no sense at the row level.
        _advancedFilterFields = allFields
            .Where(f => !QueryBuilder.IsAggregateField(f))
            .OrderBy(f => f.Label, StringComparer.OrdinalIgnoreCase)
            .ToList();

        // Primary Table dropdown now draws from the Schema Builder's Table
        // Aliases catalog only — the raw DB table listing is out. Admins
        // decide what's a valid root by registering it in Schema Builder →
        // Table Aliases; the Report Builder surfaces that curated set here.
        _defaultPrimaryTable = null;
        if (_currentConfig.ConnectionId.HasValue)
        {
            try
            {
                var schemaCfg = SchemaStore.GetForConnection(_currentConfig.ConnectionId.Value);
                _defaultPrimaryTable = string.IsNullOrWhiteSpace(schemaCfg?.Settings?.PrimaryTable)
                    ? null
                    : schemaCfg.Settings.PrimaryTable;
            }
            catch { /* no schema row yet — fall through */ }
        }

        _customEntries = new();
        if (_currentConfig.ConnectionId.HasValue)
        {
            try
            {
                _customEntries = await CustomPrimaryTableSvc.GetByConnectionAsync(_currentConfig.ConnectionId.Value);
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Failed to load custom primary tables for connection {Cid}",
                    _currentConfig.ConnectionId);
            }
        }

        // Always split the stored value into (table, alias). The two parts
        // stay as independent state; the UI just consolidates them into one
        // dropdown Value for display.
        var (parsedTable, parsedAlias) = PrimaryTableRef.Parse(_currentConfig.PrimaryTable);
        _primaryTable = string.IsNullOrWhiteSpace(parsedTable) ? null : parsedTable;
        _primaryAlias = string.IsNullOrWhiteSpace(parsedAlias) ? null : parsedAlias;

        // New report: auto-fill the Primary Table. Preference order:
        //   1. The catalog row marked IsDefaultPrimary (admin-curated default
        //      for this connection — carries the connection's table+alias pair).
        //   2. The schema-level default (Settings.PrimaryTable), kept as a
        //      fallback so connections without a curated catalog still work.
        if (_loadedReportId is null && string.IsNullOrWhiteSpace(_currentConfig.PrimaryTable))
        {
            var catalogDefault = _customEntries.FirstOrDefault(e => e.IsDefaultPrimary);
            if (catalogDefault is not null)
            {
                var combined = PrimaryTableRef.Format(
                    catalogDefault.TableName,
                    string.IsNullOrEmpty(catalogDefault.Alias) ? null : catalogDefault.Alias);
                _currentConfig.PrimaryTable = combined;
                _primaryTable = catalogDefault.TableName;
                _primaryAlias = string.IsNullOrEmpty(catalogDefault.Alias) ? null : catalogDefault.Alias;
            }
            else if (!string.IsNullOrWhiteSpace(_defaultPrimaryTable))
            {
                _currentConfig.PrimaryTable = _defaultPrimaryTable;
                _primaryTable = _defaultPrimaryTable;
                _primaryAlias = null;
            }
        }

    }

    // Dropdown pick handler. Value is the combined "table AS alias" form
    // for catalog entries, or a bare "table" for the schema default /
    // legacy off-catalog rows. We parse the selection back into
    // (_primaryTable, _primaryAlias) so the rest of the app has the two
    // parts it needs for FROM emission and JoinResolver.
    private async Task OnPrimaryTableChanged(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            _primaryTable = null;
            _primaryAlias = null;
            RecombinePrimaryTable();
            // Primary table cleared → drop the PK fallback so we don't ship
            // stale identifiers from the previous root.
            await RefreshPrimaryKeyColumnsAsync();
            return;
        }
        var (table, alias) = PrimaryTableRef.Parse(value);
        _primaryTable = string.IsNullOrWhiteSpace(table) ? null : table;
        _primaryAlias = string.IsNullOrWhiteSpace(alias) ? null : alias;
        RecombinePrimaryTable();
        // Refresh PKs against the new primary so subsequent (None)-sorted
        // runs ship the right identifiers as FallbackSortColumns.
        await RefreshPrimaryKeyColumnsAsync();
    }

    // Single source of truth for _currentConfig.PrimaryTable. Called whenever
    // either part changes so the persisted/queried string stays in sync.
    // _primaryTable and _primaryAlias remain the authoritative two-part
    // state; the combined string is just what the emitter + DB store need.
    private void RecombinePrimaryTable()
    {
        _currentConfig.PrimaryTable = string.IsNullOrWhiteSpace(_primaryTable)
            ? null
            : PrimaryTableRef.Format(_primaryTable!, _primaryAlias);
    }

    // One option in the Primary Table dropdown. Value is the combined
    // "table AS alias" string that round-trips into _currentConfig.PrimaryTable.
    // Group flags place it in "Suggested primaries" (IsSuggested=true) vs
    // "Other tables". IsDefault tags the connection's designated default
    // so it renders with "(default)"; IsLegacy tags a saved value that
    // isn't in the catalog so users know to re-pick it.
    private record PrimaryTableOption(
        string Value, string Label,
        bool IsDefault, bool IsSuggested,
        bool IsLegacy = false);

    // Maps a ConnectionId back to its display label — wired to the
    // Connection MudSelect's ToStringFunc. Without it, MudBlazor falls back
    // to value.ToString() (a raw GUID) for a beat after the items list
    // rebuilds, and permanently when the saved ConnectionId belongs to a
    // connection that isn't in the current list (which previously happened
    // whenever the report's company didn't match the hardcoded load).
    // Format mirrors the open dropdown: "Company · Connection (default)".
    private string ConnectionToLabel(Guid? id)
    {
        if (id is null) return string.Empty;
        var c = _availableConnections.FirstOrDefault(x => x.Id == id);
        if (c is null) return string.Empty;
        var company = CompanyNameFor(c.CompanyId);
        var connLabel = $"{c.Name}{(c.IsDefault ? " (default)" : "")}";
        return string.IsNullOrEmpty(company) ? connLabel : $"{company} · {connLabel}";
    }

    // Resolves a connection's owning company name. Returns empty string
    // when the company isn't in the active list (shouldn't happen, but
    // keeps the label rendering safe).
    private string CompanyNameFor(Guid companyId)
    {
        var comp = _companies.FirstOrDefault(x => x.Id == companyId);
        return comp?.Name ?? string.Empty;
    }

    // Maps the selected Value back to its display label — wired to
    // MudSelect.ToStringFunc. Without this, MudBlazor re-renders the
    // options list on every tick and can associate the selected value
    // with the wrong MudSelectItem's rendered ChildContent, so the closed
    // control shows one row while the backing state holds another.
    private string PrimaryTableLabelFor(string? value)
    {
        if (string.IsNullOrEmpty(value)) return string.Empty;
        var match = BuildPrimaryTableOptions()
            .FirstOrDefault(o => string.Equals(o.Value, value, StringComparison.OrdinalIgnoreCase));
        if (match is null) return value;
        var suffix = match.IsDefault ? " (default)" : match.IsLegacy ? " (off catalog)" : string.Empty;
        return match.Label + suffix;
    }

    // Dropdown options = the *curated* subset of Schema Builder's Table
    // Aliases catalog for this connection — only rows flagged "Eligible as
    // primary" are surfaced. Non-eligible catalog rows are intentionally
    // hidden so end users don't see every join/reference table as a root
    // candidate. Two exceptions are still included so the dropdown is
    // always valid:
    //   * The schema's Settings.PrimaryTable when nothing in the catalog
    //     carries a flag yet (fresh connection, pre-curation).
    //   * Any saved report's existing Primary Table, even if it's no
    //     longer eligible — tagged IsLegacy so the existing report keeps
    //     working and the user gets nudged to re-pick from the curated
    //     list.
    private IEnumerable<PrimaryTableOption> BuildPrimaryTableOptions()
    {
        var byValue = new Dictionary<string, PrimaryTableOption>(StringComparer.OrdinalIgnoreCase);

        foreach (var e in _customEntries)
        {
            // Skip non-eligible rows entirely. Admins curate the list via
            // the "Eligible as primary" checkbox in Table Aliases; anything
            // unchecked is a supporting table (lookup, join target, etc.)
            // and shouldn't clutter the Primary Table picker.
            if (!e.IsPrimary && !e.IsDefaultPrimary) continue;

            var alias = string.IsNullOrEmpty(e.Alias) ? null : e.Alias;
            var combined = PrimaryTableRef.Format(e.TableName, alias);
            var label = string.IsNullOrEmpty(alias) ? e.TableName : $"{e.TableName} AS {alias}";
            // Primary source of truth for "default": the catalog's
            // IsDefaultPrimary flag. Legacy schema-level default still
            // honored as a fallback when no row carries the flag.
            var isDefault = e.IsDefaultPrimary
                            || (string.Equals(e.TableName, _defaultPrimaryTable, StringComparison.OrdinalIgnoreCase)
                                && string.IsNullOrEmpty(alias));
            byValue[combined] = new PrimaryTableOption(combined, label, isDefault, IsSuggested: true);
        }

        // Surface the schema's default (Settings.PrimaryTable) even if no
        // Table Aliases entry has been created for it yet — keeps new
        // connections usable before an admin opens the catalog.
        if (!string.IsNullOrWhiteSpace(_defaultPrimaryTable)
            && !byValue.ContainsKey(_defaultPrimaryTable))
        {
            byValue[_defaultPrimaryTable] = new PrimaryTableOption(
                _defaultPrimaryTable, _defaultPrimaryTable,
                IsDefault: true, IsSuggested: true);
        }

        // Legacy / off-catalog value: when a saved report's Primary Table
        // isn't in the curated list (legacy report, or someone unchecked
        // Eligible after the report was built), surface it anyway so the
        // dropdown stays valid and the report keeps running. Tagged
        // IsLegacy so the UI hints "(off catalog)" and nudges the user
        // toward a curated pick.
        var savedValue = _currentConfig.PrimaryTable;
        if (!string.IsNullOrWhiteSpace(savedValue) && !byValue.ContainsKey(savedValue))
        {
            byValue[savedValue] = new PrimaryTableOption(
                savedValue, savedValue,
                IsDefault: false, IsSuggested: false, IsLegacy: true);
        }

        // Order: Suggested first (default at top within Suggested), then
        // any legacy off-catalog values. No "Other tables" group — those
        // rows are hidden by design.
        return byValue.Values
            .OrderByDescending(o => o.IsSuggested)
            .ThenByDescending(o => o.IsDefault)
            .ThenBy(o => o.Label, StringComparer.OrdinalIgnoreCase);
    }

    // True when the currently-selected Primary Table isn't backed by a
    // catalog entry — i.e., the option we surfaced as IsLegacy because the
    // saved value didn't match anything in the Table Aliases catalog or
    // the schema default. Blank selection returns false so the warning
    // doesn't shout at users who haven't picked anything yet (the
    // "Required" error on the dropdown already does that).
    private bool IsSelectedPrimaryOffCatalog()
    {
        if (string.IsNullOrWhiteSpace(_currentConfig.PrimaryTable)) return false;
        var match = BuildPrimaryTableOptions()
            .FirstOrDefault(o => string.Equals(o.Value, _currentConfig.PrimaryTable, StringComparison.OrdinalIgnoreCase));
        return match?.IsLegacy == true;
    }

    private async Task HandleRunQuery()
    {
        if (!_selectedFieldIds.Any()) return;

        // Primary Table is required — surface the error inline rather than
        // letting the query pipeline throw a cryptic SQL error mid-execution.
        if (string.IsNullOrWhiteSpace(_currentConfig.PrimaryTable))
        {
            Snackbar.Add("Primary Table is required. Enter the root table (e.g. salesforce.lead) next to the Connection picker.", Severity.Warning);
            return;
        }

        _isLoading = true;
        // Snapshot the DashboardView's current config BEFORE nulling _queryData, because
        // null _queryData unmounts the entire MudTabs block (including DashboardView).
        // Without this, the user's dashboard edits (group-by, measure, chart, etc.) are
        // lost on every Run Query.
        var liveConfig = _dashboardView?.GetCurrentConfig();
        if (liveConfig is not null)
            _dashboardConfig = liveConfig;

        // Snapshot the last-good QueryResponse so we can restore it if the
        // upcoming Run throws. Without restoration the table/dashboard tabs
        // would vanish on a SQL error, locking the admin out of the very
        // config they need to edit to fix the problem.
        var previousData = _queryData;

        // Force grid to unmount so stale DOM is cleared before new columns render
        _queryData = null;
        StateHasChanged();
        await Task.Yield();

        try
        {
            var queryFieldIds = BuildEffectiveQueryFieldIds();

            var request = new QueryRequest
            {
                FieldIds = queryFieldIds,
                Filters = new Dictionary<string, object?>(_currentConfig.Filters),
                CustomFilterIds = _currentConfig.CustomFilterIds?.Count > 0 ? new List<string>(_currentConfig.CustomFilterIds) : null,
                AdvancedFilters = _advancedFiltersEnabled && HasAdvancedFilterLeaves(_filterRoot)
                    ? CloneFilterGroup(_filterRoot)
                    : null,
                SortField = ResolveEffectiveSortField(),
                SortDirection = ResolveEffectiveSortDirection(),
                SecondarySortField = ResolveEffectiveSecondarySortField(),
                SecondarySortDirection = ResolveEffectiveSecondarySortDirection(),
                DisableDefaultSort = ResolveDisableDefaultSort(),
                Distinct = _currentConfig.Distinct,
                // Auto-PK fallback: when the admin picked "(None)" in the
                // Sort By dropdown (DisableDefaultSort = true) AND no live
                // header click is active, QueryBuilder consults this list
                // to keep OFFSET pagination stable. Pre-loaded by
                // RefreshPrimaryKeyColumnsAsync on report load + primary
                // table change. Empty = no PK detected, fall back to
                // legacy "first selected field" behavior.
                FallbackSortColumns = _primaryTablePkColumns.Count > 0
                    ? new List<string>(_primaryTablePkColumns)
                    : null,
                Page = 1,
                PageSize = 50000,
                ConnectionId = _currentConfig.ConnectionId,
                PrimaryTable = _currentConfig.PrimaryTable,
                GroupByFieldIds = _currentConfig.GroupByFieldIds,
                // Per-report SQL calc columns. Filtered to non-aggregating
                // queries inside QueryBuilder; safe to always include here.
                TableCalcSqlColumns = BuildTableCalcSqlSelectors()
            };
            request.Scoping = await ScopeResolver.ResolveAsync(_userEmail, _currentConfig.ConnectionId, _currentConfig.PrimaryTable);
            _queryData = await QueryService.ExecuteQueryAsync(request);
            _hasRunOnce = true;
            _activeTabIndex = 0;
            _lastQueryError = null;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Query failed: {ex.Message}", Severity.Error);
            // Surface the error as a persistent inline banner AND restore
            // the last-good data so the table/dashboard tabs stay rendered.
            // Editing the broken filter/field/sort and re-running is the
            // admin's path forward — that's only possible if those tabs
            // remain reachable.
            _lastQueryError = ex.Message;
            _queryData = previousData;
        }
        finally
        {
            _isLoading = false;
        }
    }

    // ── Save ──

    private async Task ApplyTemplate()
    {
        if (!_currentConfig.ConnectionId.HasValue)
        {
            Snackbar.Add("Pick a connection first — templates are scoped to a connection.", Severity.Warning);
            return;
        }

        List<GridTemplate> templates;
        try
        {
            // Scope the list to templates built against this report's connection
            // so applying one never drops field ids from a different schema.
            templates = await GridTemplateService.GetTemplatesAsync(_userId, _currentConfig.ConnectionId);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load templates: {ex.Message}", Severity.Error);
            return;
        }

        if (!templates.Any())
        {
            Snackbar.Add("No grid templates for this connection. Create one from the Grid Templates page.", Severity.Info);
            return;
        }

        var parameters = new DialogParameters { { "Templates", templates } };
        var dialog = await DialogService.ShowAsync<ApplyTemplateDialog>("Apply Grid Template", parameters,
            new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true });

        var result = await dialog.Result;
        if (result is null || result.Canceled || result.Data is not GridTemplate selected) return;

        // Link the template
        _linkedTemplateId = selected.Id;
        _linkedTemplateName = selected.Name;
        await ApplyResolvedTemplate(await GridTemplateService.ResolveTemplateAsync(selected.Id));
        StateHasChanged();
    }

    private async Task UnlinkTemplate()
    {
        if (!_linkedTemplateId.HasValue) return;

        // Three-way message box: Clone (Yes) / Don't clone (No) / Cancel.
        // Returns true, false, or null respectively.
        var cloneFields = await DialogService.ShowMessageBoxAsync(
            title: "Unlink grid template",
            message: $"Unlinking \"{_linkedTemplateName}\". Clone its fields to this report so you can modify them?\n\n"
                     + "Clone — keep the current fields and edit freely.\n"
                     + "Don't clone — start with no fields; pick your own.",
            yesText: "Clone",
            noText: "Don't clone",
            cancelText: "Cancel");

        if (cloneFields is null) return;  // user hit Cancel

        if (cloneFields == false)
        {
            _selectedFieldIds.Clear();
            _currentConfig.SelectedFieldIds.Clear();
            _currentConfig.ColumnOrder = null;
            _currentConfig.HiddenColumns = null;
            _currentConfig.DefaultSortField = null;
            _currentConfig.DefaultSortDirection = null;
            _queryData = null;
        }
        // When cloning, the existing _selectedFieldIds / ColumnOrder / etc. remain
        // as-is — they become the report's own fields once the template id is cleared.

        _linkedTemplateId = null;
        _linkedTemplateName = null;
        Snackbar.Add(cloneFields == true
            ? "Template unlinked. Fields cloned — edit freely."
            : "Template unlinked. Fields cleared.", Severity.Info);
    }

    private Task ApplyResolvedTemplate(ResolvedTemplate? resolved)
    {
        if (resolved is null) return Task.CompletedTask;
        _selectedFieldIds = new List<string>(resolved.FieldIds);
        _currentConfig.SelectedFieldIds = new List<string>(resolved.FieldIds);
        _currentConfig.ColumnOrder = WeaveCalcsIntoTemplateOrder(
            resolved.ColumnOrder ?? new List<string>(_selectedFieldIds),
            _currentConfig.ColumnOrder ?? new List<string>(),
            _currentConfig.TableCalculatedColumns);
        _currentConfig.HiddenColumns = resolved.HiddenColumns;
        _currentConfig.DefaultSortField = resolved.DefaultSortField;
        _currentConfig.DefaultSortDirection = resolved.DefaultSortDirection;
        return Task.CompletedTask;
    }

    // Returns a user-facing error string when the configured sort would
    // produce unstable OFFSET pagination AND no auto-anchor is available.
    // Stability is provided by ANY of:
    //   * DISTINCT off — QueryBuilder appends PK tiebreakers silently AND
    //     the legacy "ORDER BY first selected field" fallback applies, so
    //     even a non-unique sort produces deterministic enough results;
    //     not worth blocking save over,
    //   * a unique sort field (primary or secondary, marked "(-)") — admin
    //     opted in explicitly,
    //   * the primary table having PKs that QueryBuilder can append as
    //     silent tiebreakers (FallbackSortColumns) — covers the common
    //     case where the user picked "Status" or any non-unique field,
    //   * no sort configured at all — QueryBuilder uses the PK list as
    //     the entire ORDER BY.
    // Only DISTINCT-on reports without one of the other escape hatches
    // get the error: under DISTINCT, ORDER BY columns must be in SELECT
    // and PK auto-anchors are suppressed (would leak unselected columns
    // into the projection), so a non-unique sort really can shuffle.
    private string? ValidateSortHasUniqueField()
    {
        // DISTINCT off bypasses the check entirely. The PK auto-anchor +
        // legacy fallback handle stability without admin intervention.
        if (!_currentConfig.Distinct) return null;

        var primary = ResolveEffectiveSortField();
        var secondary = ResolveEffectiveSecondarySortField();

        // No sort + no PKs is fine on Postgres (DisableDefaultSort emits
        // no ORDER BY) and falls back to the first selected field on
        // SQL Server. Either way nothing to validate at save time.
        if (string.IsNullOrEmpty(primary) && string.IsNullOrEmpty(secondary))
            return null;

        bool primaryIsUnique = !string.IsNullOrEmpty(primary)
            && _uniqueFieldIds.Contains(primary);
        bool secondaryIsUnique = !string.IsNullOrEmpty(secondary)
            && _uniqueFieldIds.Contains(secondary);
        if (primaryIsUnique || secondaryIsUnique) return null;

        // PK auto-anchor available — QueryBuilder will silently append
        // the primary table's PK columns to the ORDER BY at run time, so
        // pagination is stable without requiring the admin to pick a
        // unique tiebreaker manually. (Note: under DISTINCT, the
        // QueryBuilder *suppresses* the PK auto-anchor to avoid leaking
        // un-selected columns into the projection — but this validation
        // path only runs with DISTINCT on already, so the check here is
        // stricter and PK presence is not enough on its own. Keep the
        // path for explicitness; admins will see the "(-)" requirement.)
        if (_primaryTablePkColumns.Count > 0) return null;

        var primaryLabel = !string.IsNullOrEmpty(primary)
            ? (_selectedFieldDefinitions.FirstOrDefault(f => f.Id == primary)?.Label ?? primary)
            : "(none)";
        return $"Sort by \"{primaryLabel}\" isn't unique and the primary table has no detectable PK — "
             + "page results can shuffle between runs. Add a unique field (marked \"(-)\" in the dropdown) "
             + "as Then By to make pagination stable.";
    }

    // Wrapper around the shared GridTemplateService helper — projects the
    // calc-def list down to keys before delegating.
    private static List<string> WeaveCalcsIntoTemplateOrder(
        IList<string> templateOrder,
        IList<string> savedOrder,
        List<TleReportingDashboard.Web.Models.TableCalcColumnDef>? calcDefs) =>
        TleReportingDashboard.Web.Services.GridTemplateService.WeaveCalcsIntoTemplateOrder(
            templateOrder, savedOrder, calcDefs?.Select(c => c.Key));

    private async Task HandleSave()
    {
        // Primary Table is required — don't let a report be saved in a
        // non-runnable state. We validate here (not just at run-time) so users
        // get feedback as soon as they try to persist.
        if (string.IsNullOrWhiteSpace(_currentConfig.PrimaryTable))
        {
            Snackbar.Add("Primary Table is required. Enter the root table (e.g. salesforce.lead) next to the Connection picker.", Severity.Warning);
            return;
        }

        // Sort stability check: when any sort is configured (Sort By
        // dropdown, Then By, or live header click), at least one of the
        // sort fields must be a uniquely-keyed column (marked "(-)" in
        // the dropdowns). Without it, OFFSET pagination shuffles rows
        // between pages on Postgres and the saved report runs differently
        // every time. Calc columns aren't considered unique here — the
        // check only counts DB-attested unique fields.
        var sortValidationError = ValidateSortHasUniqueField();
        if (sortValidationError is not null)
        {
            Snackbar.Add(sortValidationError, Severity.Warning);
            return;
        }

        // Always capture the latest dashboard + column width state before saving.
        // Also write the config back to _dashboardConfig so that if DashboardView
        // remounts later (e.g. after a re-run) it gets the user's latest edits,
        // not the original loaded config.
        var dashConfig = _dashboardView?.GetCurrentConfig() ?? _dashboardConfig;
        if (dashConfig is not null)
        {
            // Inject extra group-by field IDs into the config
            if (_extraGroupByFieldIds.Count > 0)
                dashConfig = dashConfig with { ExtraGroupByFieldIds = _extraGroupByFieldIds.ToList() };
            _dashboardConfig = dashConfig;
            _currentConfig.DashboardConfigJson = System.Text.Json.JsonSerializer.Serialize(dashConfig);
        }

        // Capture column widths from the grid
        var widths = _reportGrid?.GetCustomWidths();
        if (widths is not null && widths.Count > 0)
            _currentConfig.ColumnWidths = widths;

        // Capture the live multi-sort (primary + any Ctrl-click secondaries)
        // from the grid so it persists with the report's ColumnState.
        var liveSort = _reportGrid?.GetCurrentSort();
        if (liveSort is not null)
        {
            _currentConfig.TableSort = liveSort
                .Select(t => new TableSortSpec { Field = t.Field, Direction = t.Direction })
                .ToList();
        }


        try
        {
            if (_loadedReportId.HasValue)
            {
                // Direct by-id fetch (Phase 3). UpdateReportAsync still
                // enforces owner_id match at the SQL layer — admins editing
                // someone else's report hit the "not owned" guard and see a
                // clear error instead of a silent no-op.
                var existing = await ReportService.GetReportByIdAsync(_loadedReportId.Value);
                if (existing is not null)
                {
                    existing.Name = _loadedReportName ?? existing.Name;
                    existing.InternalName = string.IsNullOrWhiteSpace(_loadedInternalName)
                        ? null
                        : _loadedInternalName.Trim();
                    existing.FieldIds = System.Text.Json.JsonSerializer.Serialize(_selectedFieldIds);
                    existing.Filters = _currentConfig.Filters.Any()
                        ? System.Text.Json.JsonSerializer.Serialize(_currentConfig.Filters)
                        : null;
                    existing.ColumnState = BuildColumnStateJson();
                    existing.GridTemplateId = _linkedTemplateId;
                    // ConnectionId is locked after first save — don't touch it here.
                    existing.PrimaryTable = _currentConfig.PrimaryTable;
                    existing.UpdatedAt = DateTime.UtcNow;
                    existing.LastRunAt = DateTime.UtcNow;
                    await ReportService.UpdateReportAsync(existing);
                    Snackbar.Add($"Report \"{existing.Name}\" saved.", Severity.Success);
                    return;
                }
            }

            // New report — use the inline-rename name from the action bar.
            // CanSave() already gates the button on a non-empty name, but belt-
            // and-suspenders: if they got here with a blank name, drop into
            // inline rename mode and prompt.
            if (string.IsNullOrWhiteSpace(_loadedReportName))
            {
                _editingName = true;
                Snackbar.Add("Name your report before saving.", Severity.Warning);
                return;
            }

            var report = new SavedReport
            {
                Id = Guid.NewGuid(),
                Name = _loadedReportName.Trim(),
                InternalName = string.IsNullOrWhiteSpace(_loadedInternalName)
                    ? null
                    : _loadedInternalName.Trim(),
                OwnerId = _userId,
                OwnerEmail = _userEmail,
                FieldIds = System.Text.Json.JsonSerializer.Serialize(_selectedFieldIds),
                Filters = _currentConfig.Filters.Any()
                    ? System.Text.Json.JsonSerializer.Serialize(_currentConfig.Filters)
                    : null,
                ColumnState = BuildColumnStateJson(),
                GridTemplateId = _linkedTemplateId,
                ConnectionId = _currentConfig.ConnectionId,
                PrimaryTable = _currentConfig.PrimaryTable,
                LastRunAt = DateTime.UtcNow,
                CreatedAt = DateTime.UtcNow,
                UpdatedAt = DateTime.UtcNow
            };

            var saved = await ReportService.SaveReportAsync(report);
            _loadedReportId = saved.Id;
            _loadedReportName = saved.Name;
            Snackbar.Add($"Report \"{saved.Name}\" saved.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Save failed: {ex.Message}", Severity.Error);
        }
    }

    // Admin-only: save current report config as a new template.
    // Saves a NEW GridTemplate from the current report's column layout. Column
    // scaffolding only — field ids, order, widths, hidden, and default sort.
    // Filters, primary table, and dashboard config are intentionally excluded.
    private async Task HandleSaveAsTemplate()
    {
        if (!_isAdmin || !_selectedFieldIds.Any()) return;

        if (!_currentConfig.ConnectionId.HasValue)
        {
            Snackbar.Add("Pick a connection first — templates are scoped to a connection.", Severity.Warning);
            return;
        }

        // Pull latest column widths from the grid before serializing.
        var widths = _reportGrid?.GetCustomWidths();
        if (widths is not null && widths.Count > 0)
            _currentConfig.ColumnWidths = widths;

        var defaultName = string.IsNullOrWhiteSpace(_loadedReportName)
            ? "New Template"
            : $"{_loadedReportName} (Template)";

        var parameters = new DialogParameters<SaveAsTemplateDialog>
        {
            { x => x.DefaultName, defaultName }
        };
        var dialog = await DialogService.ShowAsync<SaveAsTemplateDialog>("Save as Template", parameters);
        var dialogResult = await dialog.Result;
        if (dialogResult is null || dialogResult.Canceled || dialogResult.Data is not string templateName) return;

        try
        {
            // Build the GridTemplate-shaped ColumnState: only the grid layout
            // keys the grid-template editor/ResolveTemplateAsync know about.
            var columnState = new Dictionary<string, object?>();
            if (_currentConfig.ColumnOrder is { Count: > 0 })
                columnState["TableColumnOrder"] = _currentConfig.ColumnOrder;
            if (_currentConfig.HiddenColumns is { Count: > 0 })
                columnState["HiddenColumns"] = _currentConfig.HiddenColumns;
            if (_currentConfig.ColumnWidths is { Count: > 0 })
                columnState["ColumnWidths"] = _currentConfig.ColumnWidths;
            if (!string.IsNullOrWhiteSpace(_currentConfig.DefaultSortField))
            {
                columnState["TableSortField"] = _currentConfig.DefaultSortField;
                columnState["TableSortDirection"] = _currentConfig.DefaultSortDirection ?? "asc";
            }

            var template = new GridTemplate
            {
                Id = Guid.NewGuid(),
                Name = templateName,
                OwnerId = _userId,
                OwnerEmail = _userEmail,
                IsShared = true,
                FieldIds = System.Text.Json.JsonSerializer.Serialize(_selectedFieldIds),
                ColumnState = columnState.Count > 0
                    ? System.Text.Json.JsonSerializer.Serialize(columnState)
                    : null,
                ConnectionId = _currentConfig.ConnectionId,
                CreatedAt = DateTime.UtcNow,
                UpdatedAt = DateTime.UtcNow
            };
            await GridTemplateService.SaveTemplateAsync(template);
            Snackbar.Add($"Grid template \"{template.Name}\" saved.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Save as Template failed: {ex.Message}", Severity.Error);
        }
    }

