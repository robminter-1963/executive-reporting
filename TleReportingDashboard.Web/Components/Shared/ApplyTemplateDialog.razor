@inject IDialogService DialogService

@* Dirty-tracked: selecting a template makes the dialog dirty and a
   non-explicit dismiss (Cancel / Esc / backdrop) fires the unsaved-
   changes prompt. Callers must open this dialog with DialogOptions
   { BackdropClick = false, CloseOnEscapeKey = false }. *@

<MudDialog>
    <TitleContent>
        <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.GridView" />
            <MudText Typo="Typo.h6">Apply Grid Template</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="2" Style="min-width: 400px;">
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Select a template to apply its fields, column order, and visibility settings to this report.
            </MudText>
            <MudList T="GridTemplate" Dense>
                @foreach (var t in Templates)
                {
                    var tmpl = t;
                    <MudListItem T="GridTemplate" OnClick="() => _selected = tmpl"
                                  Style="@(_selected?.Id == tmpl.Id ? "background: #E8F0FE;" : "cursor: pointer;")">
                        <MudStack Spacing="0">
                            <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
                                <MudText Typo="Typo.body2" Style="@(_selected?.Id == tmpl.Id ? "font-weight: 600;" : "")">
                                    @tmpl.Name
                                </MudText>
                                @if (tmpl.IsShared)
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.Public" Size="Size.Small" Color="Color.Success" />
                                }
                            </MudStack>
                            @if (!string.IsNullOrEmpty(tmpl.Description))
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@tmpl.Description</MudText>
                            }
                        </MudStack>
                    </MudListItem>
                }
            </MudList>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="TryCancelAsync">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Apply"
                   Disabled="@(_selected is null)">
            Apply
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance? MudDialog { get; set; }
    [Parameter] public List<GridTemplate> Templates { get; set; } = new();

    private GridTemplate? _selected;

    // Initial state has no selection; any selection is a pending change.
    private bool IsDirty => _selected is not null;

    private void Apply() => MudDialog?.Close(DialogResult.Ok(_selected!));

    // Routes every dismiss path through the unsaved-changes prompt so
    // an accidental Esc / backdrop click never silently throws away
    // the admin's selection. Save runs Apply; DontSave dismisses.
    private async Task TryCancelAsync() =>
        await UnsavedChangesPrompt.TryCancelAsync(DialogService, MudDialog, IsDirty,
            saveAsync: () =>
            {
                if (_selected is not null) Apply();
                return Task.CompletedTask;
            });
}
