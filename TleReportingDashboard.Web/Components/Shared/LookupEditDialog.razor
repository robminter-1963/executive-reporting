@using TleReportingDashboard.Web.Components.Pages
@inject IDialogService DialogService

<MudDialog>
    <TitleContent>
        <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.TableView" />
            <MudText Typo="Typo.h6">@(IsNew ? "Add Lookup" : "Edit Lookup")</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudGrid Spacing="2" Style="min-width: 600px;">
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_edited.Id" Label="ID" Variant="Variant.Outlined" Margin="Margin.Dense"
                              HelperText="Unique identifier (e.g. status_events)" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_edited.Label" Label="Label" Variant="Variant.Outlined" Margin="Margin.Dense"
                              HelperText="Display name (e.g. Status Event Number Mapping)" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="_edited.SqlPreamble" Label="CTE Definition"
                              Variant="Variant.Outlined" Margin="Margin.Dense"
                              Lines="6" Style="font-family: monospace; font-size: 0.85rem;"
                              Placeholder="LOOKUP(STATUS, EVENTNUM, ORDERBY) AS (SELECT 1, 346, 1 UNION ALL SELECT 2, 347, 2 ...)"
                              HelperText="CTE body without the WITH keyword. Added to the WITH clause when referenced." />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="_edited.SqlJoin" Label="JOIN clause (optional)"
                              Variant="Variant.Outlined" Margin="Margin.Dense"
                              Lines="2" Style="font-family: monospace; font-size: 0.85rem;"
                              Placeholder="@SqlJoinPlaceholder"
                              HelperText="JOIN appended after schema joins when this lookup is referenced." />
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="TryCancelAsync">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Ok"
                   Disabled="@(string.IsNullOrWhiteSpace(_edited.Id) || string.IsNullOrWhiteSpace(_edited.Label) || string.IsNullOrWhiteSpace(_edited.SqlPreamble))">
            OK
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance? MudDialog { get; set; }
    [Parameter] public SchemaBuilder.LookupEntry? Lookup { get; set; }
    [Parameter] public bool IsNew { get; set; }
    [Parameter] public string? ConnectionType { get; set; }

    // Placeholder only appears once the admin has named this lookup (i.e.
    // the CTE exists in some form). Until then the field stays blank so
    // we don't invent a LOOKUP reference that doesn't match anything real.
    private string SqlJoinPlaceholder =>
        string.IsNullOrWhiteSpace(_edited.Id)
            ? string.Empty
            : $"LEFT JOIN {_edited.Id} lu ON lu.key = joined_alias.fk_column";

    private SchemaBuilder.LookupEntry _edited = new();

    // JSON snapshot at OnInitialized — IsDirty compares a fresh snapshot
    // against this to drive the unsaved-changes prompt on dismiss.
    private string _initialSnapshot = string.Empty;

    protected override void OnInitialized()
    {
        if (Lookup is not null)
        {
            _edited = new SchemaBuilder.LookupEntry
            {
                Id = Lookup.Id,
                Label = Lookup.Label,
                SqlPreamble = Lookup.SqlPreamble,
                SqlJoin = Lookup.SqlJoin
            };
        }

        _initialSnapshot = BuildSnapshot();
    }

    private string BuildSnapshot() =>
        System.Text.Json.JsonSerializer.Serialize(new
        {
            _edited.Id,
            _edited.Label,
            _edited.SqlPreamble,
            _edited.SqlJoin
        });

    private bool IsDirty =>
        !string.Equals(_initialSnapshot, BuildSnapshot(), StringComparison.Ordinal);

    // Routes Cancel through the unsaved-changes prompt. Save only re-enters
    // Ok() when the OK button's enable conditions are met.
    private async Task TryCancelAsync()
    {
        if (IsDirty)
        {
            var choice = await UnsavedChangesPrompt.AskAsync(DialogService);
            switch (choice)
            {
                case UnsavedChangesResult.Save:
                    if (!string.IsNullOrWhiteSpace(_edited.Id)
                        && !string.IsNullOrWhiteSpace(_edited.Label)
                        && !string.IsNullOrWhiteSpace(_edited.SqlPreamble)) Ok();
                    return;
                case UnsavedChangesResult.Cancel:
                    return;
                case UnsavedChangesResult.DontSave:
                    break;
            }
        }
        MudDialog?.Cancel();
    }

    private void Ok() => MudDialog?.Close(DialogResult.Ok(_edited));
}
