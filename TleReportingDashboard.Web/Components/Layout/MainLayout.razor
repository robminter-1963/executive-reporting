@inherits LayoutComponentBase
@using TleReportingDashboard.Web.Services
@inject TleReportingDashboard.Web.Services.UserPreferenceState PreferenceState
@inject TleReportingDashboard.Web.Services.CurrentCompanyState CurrentCompany
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthStateProvider
@inject TleReportingDashboard.Web.Services.IUserManagementService UserManagement
@inject TleReportingDashboard.Web.Services.ICompanyRegistry CompanyRegistry
@inject TleReportingDashboard.Web.Services.IAdminService AdminService
@inject TleReportingDashboard.Web.Services.IAdminAccessService AdminAccess
@inject TleReportingDashboard.Web.Services.INotificationService Notifications
@inject TleReportingDashboard.Web.Services.IThemeService ThemeSvc
@inject IWebHostEnvironment HostEnv
@inject IConfiguration Configuration
@inject ILogger<MainLayout> Logger
@implements IDisposable

@* MudButton's `.mud-button-label` ships with `overflow: hidden; text-overflow:
   ellipsis; max-width: 100%` so its content never escapes the button's bounds.
   That's the right default for a dense action bar but it clips long emails on
   the user-menu activator after a company switch. Override the clipper rules
   for this one button so the per-company email always renders in full,
   regardless of which email was rendered before. *@
<style>
    .user-badge-button .mud-button-label {
        overflow: visible !important;
        text-overflow: clip !important;
        max-width: none !important;
        white-space: nowrap !important;
        display: inline-flex !important;
        width: max-content !important;
    }
</style>

@* Theme tokens — loaded once during OnInitializedAsync from the
   IThemeService and injected as a :root CSS-variable block here.
   Chrome CSS across the app references these via var(--surface-page),
   var(--text-primary), etc. Empty until the theme finishes loading;
   any chrome reference falls back to whatever default is set on the
   var(...) call (declared at the chrome's CSS, not here). *@
@if (!string.IsNullOrEmpty(_themeCss))
{
    <style>@((MarkupString)_themeCss)</style>
}

<MudThemeProvider Theme="_theme" IsDarkMode="false" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    @* Removed `Dense` so the bar uses the standard ~64px toolbar height.
       The user badge stacks three lines (name / email / role) and the
       Dense (48px) variant clipped them against the bar's borders. With
       full height the breadcrumb row still fits — Dense was a holdover
       from when the badge was a single line. *@
    <MudAppBar Elevation="1" Fixed Style="z-index: 1300; background-color: var(--surface-toolbar, #3C4043); color: var(--text-on-toolbar, #E8EAED);">
        <MudStack Row AlignItems="AlignItems.Center" Spacing="2" Style="width: 100%;">
            @* Kiosk mode (detail view opened from a Master Dashboard tile): render
               the logo as a static element and hide the Help button so the only
               way off the page is closing the tab. *@
            @if (_kioskMode)
            {
                <div style="display: flex; align-items: center; gap: 8px;">
                    <img src="ralis.webp" alt="Ralis" style="height: 32px;" />
                    <span style="font-weight: 600; font-size: 1rem; color: var(--text-on-toolbar, #E8EAED);">Executive Reporting Suite</span>
                </div>
            }
            else
            {
                @* Ralis logo + suite name navigate to the all-companies
                   picker for users with access to more than one company.
                   Single-company users have nowhere else to pick, so the
                   header is a static decoration for them — clicking does
                   nothing rather than redirecting to the same dashboard
                   they're already on. Global admins AND admin-section
                   roles (System Support et al.) get the click affordance
                   because their _accessibleCompanyCount is set to the
                   active company total (vs. counting only the user's own
                   RPT_user_companies grants, which would leave System
                   Support at 0 and silently suppress the click). *@
                @if (_accessibleCompanyCount > 1)
                {
                    <div style="cursor: pointer; display: flex; align-items: center; gap: 8px;" @onclick="@(() => Navigation.NavigateTo("/?all=1"))">
                        <img src="ralis.webp" alt="Ralis" style="height: 32px;" />
                        <span style="font-weight: 600; font-size: 1rem; color: var(--text-on-toolbar, #E8EAED);">Executive Reporting Suite</span>
                    </div>
                }
                else
                {
                    <div style="display: flex; align-items: center; gap: 8px;">
                        <img src="ralis.webp" alt="Ralis" style="height: 32px;" />
                        <span style="font-weight: 600; font-size: 1rem; color: var(--text-on-toolbar, #E8EAED);">Executive Reporting Suite</span>
                    </div>
                }
            }
            @* Environment badge — visible when Environment:Label is
               configured (Staging / Production / custom). Read once on
               render from IConfiguration; the host process's environment
               is fixed at startup, so no need to refresh. The color comes
               from Environment:BannerColor; falls back to a neutral gray
               so a misconfigured env doesn't render as transparent. *@
            @if (!string.IsNullOrEmpty(_envLabel))
            {
                <span title="Current environment"
                      style="@($"display: inline-flex; align-items: center; padding: 2px 8px; border-radius: 3px; font-size: 0.65rem; font-weight: 700; letter-spacing: 0.5px; background: {_envBannerColor}; color: #1A1A1A;")">
                    @_envLabel
                </span>
            }
            @foreach (var crumb in _crumbs)
            {
                <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" Style="color: #BDC1C6;" />
                @if (!string.IsNullOrEmpty(crumb.Url))
                {
                    <MudLink Href="@crumb.Url" Typo="Typo.body2"
                             Style="color: #BDC1C6; cursor: pointer;">@crumb.Label</MudLink>
                }
                else
                {
                    <MudText Typo="Typo.body2" Style="color: #E8EAED;">@crumb.Label</MudText>
                }
            }
            <div style="flex: 1;"></div>
            @if (!_kioskMode && !string.IsNullOrEmpty(_userName))
            {
                @* Signed-in user name + email, right-aligned, to the
                   left of the Help button. Appears on every page via
                   the layout so individual pages don't need to render
                   it themselves. Clicking opens a menu with user-level
                   actions (preferences, etc.). Hidden in kiosk mode
                   where nothing else in the app bar is interactive. *@
                @* MudMenu 9.3's ActivatorContent wrapper wires its own click,
                   but a MudButton inside swallows the click before it bubbles
                   to the wrapper — you'd see the ripple flash but the menu
                   would never open. Drive open-state manually via @ref so
                   the button's OnClick directly opens the menu. *@
                <MudMenu @ref="_userMenu" AnchorOrigin="Origin.BottomRight"
                         TransformOrigin="Origin.TopRight" Dense>
                    <ActivatorContent>
                        @{
                            // Compute the email up-front so we can key the
                            // button on it. Switching companies changes the
                            // displayed email; re-keying forces Blazor to
                            // recreate the MudButton's DOM, which kicks the
                            // browser into a fresh layout pass — without
                            // that, the button caches its previous (shorter)
                            // content width and clips the longer string.
                            var displayedEmail = !string.IsNullOrWhiteSpace(CurrentCompany.ActiveEmail)
                                ? CurrentCompany.ActiveEmail
                                : _userEmail;
                        }
                        <MudButton @key="@($"user-badge-{displayedEmail}")"
                                   Variant="Variant.Text" DisableElevation
                                   Class="user-badge-button"
                                   Style="text-transform: none; color: #E8EAED; padding: 6px 8px; min-width: 0; max-width: none; width: max-content; flex-shrink: 0;"
                                   EndIcon="@Icons.Material.Filled.ArrowDropDown"
                                   OnClick="ToggleUserMenu">
                            <MudStack Spacing="0" Style="text-align: right; line-height: 1.25; min-width: max-content; width: max-content; padding: 2px 0;">
                                <MudText Typo="Typo.body2" Style="font-weight: 500; color: #E8EAED;">
                                    @_userName
                                </MudText>
                                @if (!string.IsNullOrEmpty(displayedEmail))
                                {
                                    @* Prefer the per-company email override
                                       (set on the active company's
                                       RPT_user_companies row) so the badge
                                       reflects how the user appears INSIDE
                                       that tenant. Falls back to the auth /
                                       login email when no override is set
                                       or no company is currently active. *@
                                    <MudText Typo="Typo.caption"
                                             Style="color: #BDC1C6; white-space: nowrap; overflow: visible; text-overflow: clip; max-width: none; width: max-content; align-self: end;">
                                        @displayedEmail
                                    </MudText>
                                }
                                @* TEMP: role + per-company access. Amber tint
                                   marks this as transient debug surface — see
                                   _currentRoleLabel comment for the cleanup
                                   trigger. *@
                                @if (!string.IsNullOrEmpty(_currentRoleLabel))
                                {
                                    <MudText Typo="Typo.caption"
                                             Style="color: #FFD54F; font-size: 0.65rem; font-weight: 500;">
                                        @_currentRoleLabel
                                    </MudText>
                                }
                            </MudStack>
                        </MudButton>
                    </ActivatorContent>
                    <ChildContent>
                        <MudMenuItem Icon="@Icons.Material.Filled.Settings"
                                     OnClick="@(() => Navigation.NavigateTo("/preferences"))">
                            User Preferences
                        </MudMenuItem>
                        @if (_hasAdminAccess)
                        {
                            @* Admin-only Report Library shortcut. Lives next
                               to Admin in the user menu so admins can jump
                               to it from any page (Master Dashboard, Schema
                               Builder, etc.) without bouncing through nav. *@
                            <MudMenuItem Icon="@Icons.Material.Filled.LibraryBooks"
                                         OnClick="@(() => Navigation.NavigateTo("/reports"))">
                                Report Library
                            </MudMenuItem>
                            @* Admin entry moved off the Report Library's top
                               bar (where it was oddly scoped to that page)
                               into the user menu — reachable from every page.
                               Visible whenever the user has access to ANY
                               admin section (global admins always do; the
                               System Support role gets it via
                               RPT_roles.admin_sections). *@
                            <MudMenuItem Icon="@Icons.Material.Filled.AdminPanelSettings"
                                         OnClick="@(() => Navigation.NavigateTo("/admin"))">
                                Admin
                            </MudMenuItem>
                        }
                        @if (_isDevMode && _simUsers.Count > 0)
                        {
                            @* Dev-only user switcher. forceLoad:true so the
                               browser does a real HTTP GET to /dev/switch-user,
                               which sets the cookie and redirects — the new
                               circuit then sees the impersonated identity. *@
                            <MudDivider />
                            <MudText Typo="Typo.overline" Class="px-4 pt-2" Style="color: #9AA0A6;">
                                Simulate user (dev)
                            </MudText>
                            @foreach (var u in _simUsers)
                            {
                                <MudMenuItem Icon="@(u.IsAdmin ? Icons.Material.Filled.AdminPanelSettings : Icons.Material.Filled.Person)"
                                             OnClick="@(() => Navigation.NavigateTo($"/dev/switch-user?email={Uri.EscapeDataString(u.Email)}", forceLoad: true))">
                                    @(u.DisplayName ?? u.Email)
                                    @if (string.Equals(u.Email, _userEmail, StringComparison.OrdinalIgnoreCase))
                                    {
                                        <span style="color: #9AA0A6; margin-left: 8px;">(current)</span>
                                    }
                                </MudMenuItem>
                            }
                            @* Ghost user — not in RPT_users. Useful for
                               testing the "authenticated but no access"
                               flow: the picker's empty-state card,
                               /master-dashboard/{code} bouncing back, etc.
                               StubAuthenticationHandler synthesizes claims
                               from the email alone when RPT_users has no
                               matching row. *@
                            <MudMenuItem Icon="@Icons.Material.Filled.PersonOff"
                                         OnClick="@(() => Navigation.NavigateTo($"/dev/switch-user?email={Uri.EscapeDataString(GhostEmail)}", forceLoad: true))">
                                @GhostLabel
                                @if (string.Equals(GhostEmail, _userEmail, StringComparison.OrdinalIgnoreCase))
                                {
                                    <span style="color: #9AA0A6; margin-left: 8px;">(current)</span>
                                }
                            </MudMenuItem>
                            <MudMenuItem Icon="@Icons.Material.Filled.RestartAlt"
                                         OnClick="@(() => Navigation.NavigateTo("/dev/clear-user", forceLoad: true))">
                                Reset to default
                            </MudMenuItem>
                        }
                        @* Sign out — visible whenever Entra ID is wired
                           (i.e., not in stub-auth dev mode). forceLoad:true
                           because /MicrosoftIdentity/Account/SignOut is an
                           MVC controller endpoint outside the Blazor router,
                           not a Blazor route. The endpoint clears the auth
                           cookie and redirects through Entra's logout flow,
                           landing back on /signout-callback-oidc. *@
                        @if (!_isDevMode)
                        {
                            <MudDivider />
                            <MudMenuItem Icon="@Icons.Material.Filled.Logout"
                                         OnClick="@(() => Navigation.NavigateTo("/MicrosoftIdentity/Account/SignOut", forceLoad: true))">
                                Sign out
                            </MudMenuItem>
                        }
                    </ChildContent>
                </MudMenu>
            }
            @if (!_kioskMode)
            {
                @* Notifications bell. Click opens a dropdown with the most
                   recent items; click on any item navigates to its link
                   (if any) and marks it read. Unread count is read on
                   every menu open and after the user marks all read.
                   Polling cadence is intentionally simple — no SignalR
                   push needed for an MVP. *@
                <MudMenu @ref="_notificationMenu" AnchorOrigin="Origin.BottomRight"
                         TransformOrigin="Origin.TopRight"
                         Dense MaxHeight="480">
                    <ActivatorContent>
                        <MudTooltip Text="@($"Notifications{(_unreadCount > 0 ? $" ({_unreadCount} new)" : "")}")"
                                    Placement="Placement.Bottom">
                            <MudBadge Content="@_unreadCount" Color="Color.Error"
                                      Overlap="true" Visible="@(_unreadCount > 0)"
                                      Bordered="true">
                                <MudIconButton Icon="@(_unreadCount > 0 ? Icons.Material.Filled.NotificationsActive : Icons.Material.Filled.Notifications)"
                                               Size="Size.Small"
                                               Style="color: #E8EAED;"
                                               OnClick="ToggleNotificationMenu" />
                            </MudBadge>
                        </MudTooltip>
                    </ActivatorContent>
                    <ChildContent>
                        @if (_notifications.Count == 0)
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary"
                                     Style="padding: 16px; min-width: 320px; text-align: center;">
                                You're all caught up.
                            </MudText>
                        }
                        else
                        {
                            <div style="min-width: 360px; max-width: 440px;">
                                <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween"
                                          Style="padding: 8px 12px; border-bottom: 1px solid #E8EAED;">
                                    <MudText Typo="Typo.subtitle2">Notifications</MudText>
                                    @if (_unreadCount > 0)
                                    {
                                        <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Primary"
                                                   OnClick="MarkAllNotificationsRead">
                                            Mark all read
                                        </MudButton>
                                    }
                                </MudStack>
                                @foreach (var n in _notifications)
                                {
                                    <MudMenuItem OnClick="@(() => OnNotificationClicked(n))">
                                        <MudStack Row AlignItems="AlignItems.Start" Spacing="2"
                                                  Style="@($"padding: 4px 0; opacity: {(n.IsRead ? 0.6 : 1)};")">
                                            <MudIcon Icon="@NotificationIcon(n.Kind)" Size="Size.Small"
                                                     Style="@($"color: {(n.IsRead ? "#9AA0A6" : "#1976D2")}; margin-top: 4px;")" />
                                            <MudStack Spacing="0">
                                                <MudText Typo="Typo.body2"
                                                         Style="@($"font-weight: {(n.IsRead ? "400" : "600")}; line-height: 1.3;")">
                                                    @n.Title
                                                </MudText>
                                                @if (!string.IsNullOrWhiteSpace(n.Body))
                                                {
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary"
                                                             Style="white-space: normal; line-height: 1.3;">
                                                        @n.Body
                                                    </MudText>
                                                }
                                                <MudText Typo="Typo.caption" Color="Color.Secondary"
                                                         Style="font-size: 0.65rem;">
                                                    @FormatRelativeTime(n.CreatedAt)
                                                </MudText>
                                            </MudStack>
                                        </MudStack>
                                    </MudMenuItem>
                                }
                            </div>
                        }
                    </ChildContent>
                </MudMenu>
                <MudTooltip Text="Help" Placement="Placement.Bottom">
                    <MudIconButton Icon="@Icons.Material.Filled.HelpOutline" Size="Size.Small"
                                   Style="color: var(--text-on-toolbar, #E8EAED);" OnClick="OpenHelp" />
                </MudTooltip>
            }
        </MudStack>
    </MudAppBar>

    @* App bar offset = 64px (MudBlazor's canonical non-Dense AppBar
       height). All page-internal `calc(100vh - 64px)` expressions use
       the same value so available heights line up exactly with the
       content area below the bar. The earlier 53px was a half-fix; it
       worked everywhere except pages that stacked their own AppBar
       (ReportLibrary), which is now fixed by replacing those with plain
       toolbars instead of trying to compensate at the layout level. *@
    <MudMainContent Style="padding-top: 64px;">
        @if (_envAccessDenied)
        {
            @* Environment-level access gate. Staging (and any other env
               that sets Environment:AllowedRoles) restricts use to a
               named subset of roles. Global admins always pass. The
               gate is layout-level rather than per-page so a user can't
               sidestep it by navigating directly to a route — every
               page renders through MainLayout. *@
            <div style="max-width: 640px; margin: 64px auto; padding: 24px;">
                <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">
                    <MudText Typo="Typo.h6" Style="font-weight: 600; margin-bottom: 8px;">
                        Not authorized for this environment
                    </MudText>
                    <MudText Typo="Typo.body2">
                        Your role doesn't have access to the <strong>@_envLabel</strong> environment.
                        Contact a global administrator if you need access here.
                    </MudText>
                </MudAlert>
            </div>
        }
        else
        {
            @Body
        }
    </MudMainContent>
</MudLayout>

@code {
    private record Crumb(string Label, string? Url);

    private List<Crumb> _crumbs = new();
    private bool _kioskMode;
    private string _userName = string.Empty;
    private string _userEmail = string.Empty;

    // Notifications bell state. _notifications holds the most recent N items
    // for the dropdown; _unreadCount is shown as the badge. Both are
    // refreshed every time the menu is opened so the user sees the freshest
    // state without a SignalR push channel.
    private MudMenu? _notificationMenu;
    private List<NotificationRecord> _notifications = new();
    private int _unreadCount;

    // App-wide theme tokens, loaded once during init. Rendered as a
    // :root CSS-variable block via the @if guard above. Empty during
    // the brief window between mount and first ThemeSvc.GetAsync — any
    // chrome CSS that references var(--…) before this lands falls back
    // to whatever default was declared in the var(...) call.
    private string? _themeCss;
    // How many companies the signed-in user can see. Drives whether the
    // master-dashboard breadcrumb shows an "All Companies" link — the breadcrumb
    // is only useful when there's actually another company to switch to.
    private int _accessibleCompanyCount;
    private bool _isAdmin;
    // True when the user has access to ANY admin section (global admin or
    // a role with a non-empty RPT_roles.admin_sections list). Drives the
    // Admin entry in the user menu — limited-access users like System
    // Support need it visible without being elevated to global admin.
    private bool _hasAdminAccess;
    // TEMP: surface the user's job-function role + per-company access type
    // under their name in the app bar so admins can sanity-check what role
    // they're running as while the role/scope features bake. Refreshed when
    // the current company changes. Remove this + RefreshRoleLabelAsync once
    // the auth model stabilizes.
    private string? _currentRoleLabel;
    private MudMenu? _userMenu;
    // Dev-only user switcher. Populated in OnInitializedAsync when the app
    // is running with the stub auth scheme. Outside Development the list
    // stays empty and the menu section doesn't render.
    private bool _isDevMode;
    private List<UserRecord> _simUsers = new();

    // Environment badge — driven by Environment:Label / Environment:BannerColor
    // in appsettings.{env}.json. The label is rendered inline next to the
    // logo so admins can tell at a glance whether they're on Staging or
    // Production (and any custom envs in the future). Production's
    // appsettings.Production.json leaves BannerColor empty by default
    // → falls back to a neutral gray so the badge still renders without
    // shouting at users on the canonical environment.
    private string? _envLabel;
    private string _envBannerColor = "#BDC1C6";
    // Set true when the active environment configures Environment:AllowedRoles
    // and the signed-in user's role is not in the list (and they're not a
    // global admin). Renders the lockout pane in place of @Body. Resolved
    // once during OnInitializedAsync so navigation-time changes don't
    // ricochet between allowed/denied; admins changing the user's role
    // mid-session need them to refresh the browser to take effect.
    private bool _envAccessDenied;

    // Ghost user — not in RPT_users. Used by the dev switcher to exercise
    // the no-access code path (picker empty state, dashboard redirect, etc).
    // StubAuthenticationHandler synthesizes claims from any unknown email,
    // so switching to this one leaves the user authenticated but with no
    // company grants and is_admin=false.
    private const string GhostEmail = "no-access@example.com";
    private const string GhostLabel = "No-access user (dev)";

    private async Task ToggleUserMenu()
    {
        // Refresh the dev user switcher list every time the menu opens so
        // admins who just added/edited/deleted a user in Admin → Users see
        // the change without a page reload. Cheap — RPT_users is tiny.
        // Runs before OpenMenuAsync so the menu renders with the fresh list.
        if (_isDevMode)
        {
            try { _simUsers = await UserManagement.GetAllAsync(); }
            catch { /* non-fatal — last known list stays visible */ }
        }

        // Always call OpenMenuAsync — if the menu is already open the outside-
        // click on the button will close it first, and MudMenu's internal
        // state guards against a double-open. Avoids reading the Open state
        // directly (MudBlazor's analyzer disallows external reads).
        if (_userMenu is not null)
            await _userMenu.OpenMenuAsync(new MouseEventArgs());
    }

    protected override async Task OnInitializedAsync()
    {
        PreferenceState.OnChange += StateHasChanged;
        CurrentCompany.OnChange += OnCurrentCompanyChanged;
        Navigation.LocationChanged += OnLocationChanged;
        UpdateCurrentPage();

        // Theme tokens load once per layout mount — the theme is global
        // and changes are admin-driven, so refreshing at this cadence is
        // fine. A future hook could subscribe to a ThemeSvc.OnChanged
        // event to re-render every active circuit when an admin saves;
        // for v1, the next page load picks up the new palette.
        try
        {
            var theme = await ThemeSvc.GetAsync();
            _themeCss = theme.ToCssBlock();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Theme load failed — chrome will use built-in defaults.");
        }

        // Resolve env label once — appsettings.{env}.json is loaded at host
        // startup and won't change during the process lifetime. Fall back to
        // HostEnv.EnvironmentName when Environment:Label isn't configured so
        // the badge always shows something useful for non-prod envs.
        var configuredLabel = Configuration["Environment:Label"];
        var configuredColor = Configuration["Environment:BannerColor"];
        if (string.IsNullOrWhiteSpace(configuredLabel) && !HostEnv.IsProduction())
        {
            configuredLabel = HostEnv.EnvironmentName?.ToUpperInvariant();
        }
        _envLabel = configuredLabel;
        if (!string.IsNullOrWhiteSpace(configuredColor))
            _envBannerColor = configuredColor!;

        // Pull the signed-in user from the current auth state so the app bar
        // can show "Name / email" on every page without each page having to
        // resolve it. Safe under stub auth too — the claims are populated
        // identically there.
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            _userEmail = user.FindFirst("preferred_username")?.Value ?? string.Empty;
            _userName = user.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value
                        ?? (string.IsNullOrEmpty(_userEmail) ? "User" : _userEmail);

            // Multi-AD identity stitching: when the user signs in with one
            // company's AD address (e.g. paul.bae@cashcall.com) and that
            // address is registered as a per-company contact email on
            // someone's RPT_user_companies row, route them to the canonical
            // RPT_users row so their full set of company grants applies.
            // No-op for single-AD users — the resolver returns the same
            // string back. Caller-side, _userEmail becomes the canonical
            // form everywhere downstream; the login address is preserved
            // separately in case any UI wants to show "signed in as X."
            if (!string.IsNullOrEmpty(_userEmail))
            {
                try
                {
                    var canonical = await UserManagement.ResolveCanonicalUserEmailAsync(_userEmail);
                    if (!string.IsNullOrEmpty(canonical) &&
                        !string.Equals(canonical, _userEmail, StringComparison.OrdinalIgnoreCase))
                    {
                        Logger.LogInformation(
                            "Identity stitched: login {LoginEmail} → canonical {CanonicalEmail}",
                            _userEmail, canonical);
                        _userEmail = canonical;
                    }
                }
                catch (Exception ex)
                {
                    Logger.LogWarning(ex, "ResolveCanonicalUserEmailAsync failed for {Email} — falling back to login email",
                        _userEmail);
                }
            }

            // First-sign-in binding: upsert RPT_users with the Entra OID and
            // rebind any email-keyed pre-provisioned access rows. Idempotent,
            // cheap, and tolerant of the table not existing yet (swallowed
            // below). Runs once per circuit — MainLayout is instantiated once
            // per connected session.
            var userId = user.FindFirst("oid")?.Value
                         ?? user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            if (!string.IsNullOrEmpty(_userEmail) && !string.IsNullOrEmpty(userId))
            {
                try
                {
                    await UserManagement.BindSignedInUserAsync(_userEmail, userId, _userName);
                }
                catch (Exception ex)
                {
                    Logger.LogWarning(ex, "BindSignedInUserAsync failed for {Email} — non-fatal", _userEmail);
                }
            }

            // Count of companies this user can navigate to. Cached for the
            // circuit — rebuilt only on demand (no OnChange subscription on
            // the admin or registry caches). Rare that a user's access list
            // changes mid-session; they'll see the new count on next reload.
            try
            {
                _isAdmin = AdminService.IsAdmin(_userEmail);
                // Section-scoped admin access (e.g. System Support role).
                // True for global admins too — they always see Admin.
                _hasAdminAccess = await AdminAccess.HasAnyAdminAccessAsync(_userEmail);

                // Environment-level role gate. Staging restricts the app to
                // a configured subset of roles (Admin + QA by default); other
                // envs leave Environment:AllowedRoles empty and skip this
                // check entirely. Global admins always pass — Staging needs
                // a way for the admin to recover from a bad config without
                // SSH'ing into the box.
                var allowedRolesCsv = Configuration["Environment:AllowedRoles"];
                if (!_isAdmin && !string.IsNullOrWhiteSpace(allowedRolesCsv))
                {
                    var allowed = allowedRolesCsv
                        .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                        .Where(s => s.Length > 0)
                        .ToHashSet(StringComparer.OrdinalIgnoreCase);
                    var userRow = await UserManagement.GetByEmailAsync(_userEmail);
                    var roleName = userRow?.RoleName;
                    if (string.IsNullOrEmpty(roleName) || !allowed.Contains(roleName))
                    {
                        _envAccessDenied = true;
                    }
                }
                if (_isAdmin || _hasAdminAccess)
                {
                    // Global admins and admin-section roles (System
                    // Support et al.) need cross-company visibility to
                    // do their job — same model the picker, master
                    // dashboard, and report library use. Counting only
                    // RPT_user_companies grants would leave them at 0
                    // (those rows are non-admin-only), which then
                    // suppressed the title-bar click-to-picker
                    // affordance for everyone except global admins.
                    _accessibleCompanyCount = (await CompanyRegistry.GetActiveAsync()).Count;
                }
                else if (!string.IsNullOrEmpty(_userEmail))
                {
                    _accessibleCompanyCount = (await UserManagement.GetCompanyAccessAsync(_userEmail)).Count;
                }

                await RefreshRoleLabelAsync();

                // Dev mode = IsDevelopment AND Entra ID isn't configured
                // (same check ReportLibrary uses to toggle its DEV MODE
                // banner). Only admins see the switcher — there's no case
                // where impersonation makes sense for a non-admin dev user.
                _isDevMode = HostEnv.IsDevelopment()
                             && string.IsNullOrEmpty(Configuration["AzureAd:ClientId"]);
                // Switcher stays available to *every* impersonated identity
                // in dev mode, not just admins — otherwise switching to a
                // non-admin user strands the dev with no way back. The stub
                // auth scheme is Dev-only anyway, so there's no privilege
                // path to protect against here.
                if (_isDevMode)
                {
                    _simUsers = await UserManagement.GetAllAsync();
                }
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Access-count load failed — breadcrumb will hide the picker link");
            }

            // Now that _accessibleCompanyCount is settled, re-run the crumb
            // builder — the master-dashboard path depends on it.
            UpdateCurrentPage();

            // Initial unread-count fetch so the bell badge renders correctly
            // on first paint. Subsequent updates happen on menu-open.
            try { _unreadCount = await Notifications.GetUnreadCountAsync(_userEmail); }
            catch (Exception ex) { Logger.LogWarning(ex, "Initial unread-count fetch failed"); }
        }
        catch
        {
            // Auth state isn't critical for the layout to render — leave
            // the name/email empty and the display simply won't show.
        }
    }

    private void OnCurrentCompanyChanged()
    {
        UpdateCurrentPage();
        // Role is per-company — refresh the label whenever the active
        // company switches. Awaited inside InvokeAsync so the StateHasChanged
        // happens after the new label is computed.
        _ = InvokeAsync(async () =>
        {
            await RefreshRoleLabelAsync();
            StateHasChanged();
        });
    }

    // TEMP — see comment on _currentRoleLabel.
    private async Task RefreshRoleLabelAsync()
    {
        if (string.IsNullOrEmpty(_userEmail))
        {
            _currentRoleLabel = null;
            return;
        }

        // Job-function role from RPT_users.role_id (Manager, Loan Officer, etc.).
        string? functionRole = null;
        try
        {
            var user = await UserManagement.GetByEmailAsync(_userEmail);
            functionRole = user?.RoleName;
        }
        catch { /* non-fatal — leave functionRole null */ }

        // Per-company access type. Global admins win regardless of grants;
        // otherwise look up the grant for the active company. No active
        // company = no access type to show.
        string? accessType = null;
        if (_isAdmin)
        {
            accessType = "Admin (global)";
        }
        else if (CurrentCompany.IsSet && CurrentCompany.Id is Guid cid)
        {
            try
            {
                var access = await UserManagement.GetCompanyAccessAsync(_userEmail);
                accessType = access.FirstOrDefault(a => a.CompanyId == cid)?.Role;
            }
            catch { /* non-fatal — leave accessType null */ }
        }

        var parts = new List<string>();
        if (!string.IsNullOrEmpty(functionRole)) parts.Add(functionRole);
        if (!string.IsNullOrEmpty(accessType))   parts.Add(accessType);
        _currentRoleLabel = parts.Count > 0 ? string.Join(" · ", parts) : null;
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        UpdateCurrentPage();
        InvokeAsync(StateHasChanged);
    }

    // Notifications: open menu → load fresh items + open. State refresh
    // is wrapped so a service hiccup (DB blip, table missing pre-migration)
    // doesn't break the menu — UI just shows the empty state.
    private async Task ToggleNotificationMenu()
    {
        try
        {
            _notifications = await Notifications.GetForUserAsync(_userEmail, max: 15);
            _unreadCount = _notifications.Count(n => !n.IsRead);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Notifications fetch failed for {Email}", _userEmail);
            _notifications = new();
            _unreadCount = 0;
        }
        if (_notificationMenu is not null)
            await _notificationMenu.OpenMenuAsync(new MouseEventArgs());
    }

    private async Task OnNotificationClicked(NotificationRecord n)
    {
        // Mark read first so the badge updates immediately even if the
        // navigation kicks the circuit (e.g. forceLoad routes).
        if (!n.IsRead)
        {
            try { await Notifications.MarkReadAsync(n.Id); }
            catch (Exception ex) { Logger.LogWarning(ex, "Mark-read failed for {Id}", n.Id); }
            // Optimistic local update; next menu open re-fetches anyway.
            var idx = _notifications.IndexOf(n);
            if (idx >= 0) _notifications[idx] = n with { IsRead = true };
            _unreadCount = _notifications.Count(x => !x.IsRead);
        }
        if (!string.IsNullOrEmpty(n.LinkUrl))
        {
            Navigation.NavigateTo(n.LinkUrl);
        }
    }

    private async Task MarkAllNotificationsRead()
    {
        try { await Notifications.MarkAllReadAsync(_userEmail); }
        catch (Exception ex) { Logger.LogWarning(ex, "Mark-all-read failed for {Email}", _userEmail); }
        for (var i = 0; i < _notifications.Count; i++)
            _notifications[i] = _notifications[i] with { IsRead = true };
        _unreadCount = 0;
    }

    // Maps notification kind → icon. Unknown kinds get a generic bell so
    // producers can add new kinds without a UI change (the icon is just a
    // hint anyway; the title carries the actual message).
    private static string NotificationIcon(string kind) => kind switch
    {
        NotificationKinds.ReportShared       => Icons.Material.Filled.Share,
        NotificationKinds.ScheduleRan        => Icons.Material.Filled.Schedule,
        NotificationKinds.ScheduleFailed     => Icons.Material.Filled.ErrorOutline,
        NotificationKinds.AdminAnnouncement  => Icons.Material.Filled.Campaign,
        _                                    => Icons.Material.Filled.Notifications
    };

    private static string FormatRelativeTime(DateTime utc)
    {
        var delta = DateTime.UtcNow - utc;
        if (delta.TotalSeconds < 60) return "just now";
        if (delta.TotalMinutes < 60) return $"{(int)delta.TotalMinutes}m ago";
        if (delta.TotalHours < 24)   return $"{(int)delta.TotalHours}h ago";
        if (delta.TotalDays < 7)     return $"{(int)delta.TotalDays}d ago";
        return utc.ToLocalTime().ToString("MMM d, yyyy");
    }

    private async Task OpenHelp()
    {
        var path = new Uri(Navigation.Uri).AbsolutePath.Trim('/');
        var helpSection = path switch
        {
            "" => "master-dashboard",
            _ when path.StartsWith("master-dashboard/") => "master-dashboard",
            "reports" => "report-library",
            "builder" => "building-reports",
            _ when path.StartsWith("builder/") => "building-reports",
            _ when path.StartsWith("viewer/") && path.Contains("/detail") => "viewer",
            _ when path.StartsWith("viewer/") => "viewer",
            "grid-templates" => "grid-templates",
            _ when path.StartsWith("grid-templates/") => "grid-templates",
            "preferences" => "preferences",
            _ => "getting-started"
        };
        await JS.InvokeVoidAsync("open", $"/help/{helpSection}", "_blank");
    }

    // Builds the breadcrumb chain from the current URL path. Parents come from the
    // app's logical hierarchy, not the user's actual history — predictable and
    // survives refresh. The last crumb (current page) has no Url and isn't clickable.
    private void UpdateCurrentPage()
    {
        var uri = new Uri(Navigation.Uri);
        var path = uri.AbsolutePath.Trim('/');
        var crumbs = new List<Crumb>();
        // Reset each navigation — kiosk mode is opt-in per-page.
        _kioskMode = false;

        // Optional origin hint — pages that deep-link into the detail view
        // append ?from=dashboard so the breadcrumb can reflect that instead
        // of the default "Report Library → Report Viewer" chain.
        var fromQuery = Microsoft.AspNetCore.WebUtilities.QueryHelpers
            .ParseQuery(uri.Query)
            .TryGetValue("from", out var fromValues) ? fromValues.ToString() : null;

        switch (path)
        {
            case "":
                // Company picker — no breadcrumb, the picker itself is the
                // top of the hierarchy for signed-in users.
                break;

            case "reports":
                crumbs.Add(new("Report Library", null));
                break;

            case "builder":
                crumbs.Add(new("Report Library", "/reports"));
                crumbs.Add(new("New Report", null));
                break;

            case "grid-templates":
                crumbs.Add(new("Report Library", "/reports"));
                crumbs.Add(new("Grid Templates", null));
                break;

            case "preferences":
                crumbs.Add(new("Preferences", null));
                break;

            case "help":
                crumbs.Add(new("Help", null));
                break;

            case "admin":
                crumbs.Add(new("Admin", null));
                break;

            case "admin/schema-builder":
                crumbs.Add(new("Admin", "/admin"));
                crumbs.Add(new("Schema Builder", null));
                break;

            default:
                if (path.StartsWith("master-dashboard/"))
                {
                    // /master-dashboard/{companyCode}. Show an "All Companies"
                    // link back to the picker only when the user can actually
                    // pick something else — otherwise the link dead-ends on
                    // a one-item picker. The company label is taken from
                    // CurrentCompanyState (set by the dashboard page on load);
                    // until it's populated, fall back to the URL segment.
                    var label = !string.IsNullOrEmpty(CurrentCompany.Name)
                        ? CurrentCompany.Name
                        : path["master-dashboard/".Length..];
                    if (_accessibleCompanyCount > 1)
                    {
                        crumbs.Add(new("All Companies", "/?all=1"));
                        crumbs.Add(new(label, null));
                    }
                    // Single-company users see no breadcrumb — the chain
                    // would be meaningless.
                }
                else if (path.StartsWith("builder/"))
                {
                    crumbs.Add(new("Report Library", "/reports"));
                    crumbs.Add(new("Report Editor", null));
                }
                else if (path.StartsWith("viewer/") && path.Contains("/detail"))
                {
                    // /viewer/{reportId}/detail/{key}
                    // When ?from=dashboard is present the user came from the Master
                    // Dashboard tile click — lock the page down to "export + close tab"
                    // by enabling kiosk mode (hides breadcrumbs and nav chrome).
                    if (string.Equals(fromQuery, "dashboard", StringComparison.OrdinalIgnoreCase))
                    {
                        _kioskMode = true;
                    }
                    else
                    {
                        // Library Run jumps straight to /viewer/{id}/detail and
                        // we don't want the user to see (or visit) the tabbed
                        // Report Viewer as an intermediate step. Two crumbs
                        // only: Report Library → Detail View.
                        crumbs.Add(new("Report Library", "/reports"));
                        crumbs.Add(new("Detail View", null));
                    }
                }
                else if (path.StartsWith("viewer/"))
                {
                    crumbs.Add(new("Report Library", "/reports"));
                    crumbs.Add(new("Report Viewer", null));
                }
                else if (path.StartsWith("grid-templates/"))
                {
                    crumbs.Add(new("Report Library", "/reports"));
                    crumbs.Add(new("Grid Templates", "/grid-templates"));
                    crumbs.Add(new("Template Editor", null));
                }
                else if (path.StartsWith("help/"))
                {
                    crumbs.Add(new("Help", null));
                }
                else
                {
                    crumbs.Add(new(path, null));
                }
                break;
        }

        _crumbs = crumbs;
    }

    public void Dispose()
    {
        PreferenceState.OnChange -= StateHasChanged;
        CurrentCompany.OnChange -= OnCurrentCompanyChanged;
        Navigation.LocationChanged -= OnLocationChanged;
    }

