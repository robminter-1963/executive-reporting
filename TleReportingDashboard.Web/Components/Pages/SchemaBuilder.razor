    private int CountFieldsUsingDomain(string domain) =>
        _fields.Count(f => string.Equals(f.Domain, domain, StringComparison.OrdinalIgnoreCase));

    private void AddDomain()
    {
        var name = _newDomainName?.Trim();
        if (string.IsNullOrWhiteSpace(name)) return;
        if (_domainList.Any(d => string.Equals(d, name, StringComparison.OrdinalIgnoreCase)))
        {
            Snackbar.Add($"Field Section \"{name}\" already exists.", Severity.Warning);
            return;
        }
        _domainList.Add(name);
        _domainList = _domainList.OrderBy(d => d, StringComparer.OrdinalIgnoreCase).ToList();
        _newDomainName = string.Empty;
    }

    private void OnNewDomainKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") AddDomain();
    }

    private async Task RenameDomain(string oldName)
    {
        var parameters = new DialogParameters<RenameDialog>
        {
            { x => x.InitialValue, oldName },
            { x => x.Title, "Rename Field Section" },
            { x => x.Label, "Field Section name" }
        };
        var dlg = await DialogService.ShowAsync<RenameDialog>("Rename Field Section", parameters,
            DialogPresets.Locked(MaxWidth.ExtraSmall));
        var result = await dlg.Result;
        if (result is null || result.Canceled || result.Data is not string newName) return;
        newName = newName.Trim();
        if (string.IsNullOrWhiteSpace(newName) || string.Equals(newName, oldName, StringComparison.Ordinal)) return;

        if (_domainList.Any(d => string.Equals(d, newName, StringComparison.OrdinalIgnoreCase)
                                 && !string.Equals(d, oldName, StringComparison.Ordinal)))
        {
            Snackbar.Add($"Field Section \"{newName}\" already exists.", Severity.Warning);
            return;
        }

        var idx = _domainList.FindIndex(d => string.Equals(d, oldName, StringComparison.OrdinalIgnoreCase));
        if (idx < 0) return;
        _domainList[idx] = newName;
        _domainList = _domainList.OrderBy(d => d, StringComparer.OrdinalIgnoreCase).ToList();

        // Cascade: update every field currently using the old domain name.
        var renamedCount = 0;
        foreach (var f in _fields)
        {
            if (string.Equals(f.Domain, oldName, StringComparison.OrdinalIgnoreCase))
            {
                f.Domain = newName;
                renamedCount++;
            }
        }
        Snackbar.Add($"Renamed. Updated {renamedCount} field(s).", Severity.Success);
    }

    private async Task DeleteDomain(string name)
    {
        if (CountFieldsUsingDomain(name) > 0)
        {
            Snackbar.Add($"Can't delete \"{name}\" — fields still reference it. Move them first.", Severity.Warning);
            return;
        }
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Delete Field Section",
            $"Remove \"{name}\" from the Field Sections list?",
            yesText: "Delete", cancelText: "Cancel");
        if (confirmed != true) return;

        _domainList.RemoveAll(d => string.Equals(d, name, StringComparison.OrdinalIgnoreCase));
    }

    private async Task OpenSortDialog(FieldEntry field)
