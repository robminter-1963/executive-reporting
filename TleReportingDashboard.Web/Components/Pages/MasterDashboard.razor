@page "/master-dashboard/{CompanyCode}"
@rendermode InteractiveServer
@inject IMasterDashboardService MasterService
@inject IReportService ReportService
@inject ISharingService SharingService
@inject IQueryService QueryService
@inject IGridTemplateService GridTemplateService
@inject IExportService ExportService
@inject IUserPreferenceService PreferenceService
@inject IFavoriteService FavoriteSvc
@inject LandingGreetingState GreetingState
@inject IUserManagementService UserManagement
@inject IQueryScopeResolver ScopeResolver
@inject SchemaBuilderService SchemaBrowser
@inject ISchemaService SchemaService
@inject ICompanyRegistry CompanyRegistry
@inject IAdminService AdminService
@inject IAdminAccessService AdminAccess
@inject CurrentCompanyState CurrentCompany
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@inject IConfiguration Config
@inject ILogger<MasterDashboard> Logger
@implements IDisposable

<PageTitle>@(_initialized ? $"{_dashboardTitle} - Executive Reporting Suite" : "Executive Reporting Suite")</PageTitle>

@if (!_initialized)
{
    <MudMainContent Style="padding: 16px;">
        <div style="display: flex; flex-direction: column; align-items: center; justify-content: center;
                    min-height: 60vh; gap: 16px;">
            <img src="loading.gif" alt="Loading…"
                 style="max-width: 240px; height: auto;" />
            <MudText Typo="Typo.body2" Color="Color.Secondary">Loading your dashboard…</MudText>
        </div>
    </MudMainContent>
    return;
}

<MudMainContent Style="padding: 16px 16px 32px 16px; overflow-x: hidden; overflow-y: auto; height: calc(100vh - 64px);">
    <MudStack Spacing="3">
        @* ── Header ── *@
        <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
            <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                @* Back arrow goes to the company picker. Hidden for
                   single-company users — the picker auto-redirects them
                   right back here, so the arrow would do nothing useful.
                   ?all=1 bypasses the picker's auto-redirect to the user's
                   last-visited company so they actually see the list. *@
                @if (_accessibleCompanyCount > 1)
                {
                    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                                   OnClick="@(() => Navigation.NavigateTo("/?all=1"))"
                                   title="All companies" />
                }
                @if (_logoDataUri is not null)
                {
                    @* Gray letterbox background so light-on-transparent
                       logos (white text on a transparent PNG, low-alpha
                       exports) stay legible against the page chrome.
                       Small inset padding keeps the image from touching
                       the box edges. *@
                    @* Clickable letterbox when the company has a website_url.
                       target="_blank" + rel="noopener noreferrer" is the
                       standard safe outbound pattern (prevents the opened
                       page from hijacking window.opener). *@
                    @if (!string.IsNullOrEmpty(_companyWebsiteUrl))
                    {
                        <a href="@_companyWebsiteUrl" target="_blank" rel="noopener noreferrer"
                           title="@_companyWebsiteUrl"
                           style="background: #A9A9A9; border-radius: 4px;
                                  padding: 4px 8px; display: inline-flex;
                                  align-items: center; cursor: pointer;">
                            <img src="@_logoDataUri" alt=""
                                 style="height: 36px; max-width: 160px; object-fit: contain;" />
                        </a>
                    }
                    else
                    {
                        <div style="background: #A9A9A9; border-radius: 4px;
                                    padding: 4px 8px; display: inline-flex;
                                    align-items: center;">
                            <img src="@_logoDataUri" alt=""
                                 style="height: 36px; max-width: 160px; object-fit: contain;" />
                        </div>
                    }
                }
                @if (_editMode)
                {
                    <MudFileUpload T="IBrowserFile" Accept=".png,.jpg,.jpeg,.svg,.gif,.webp" FilesChanged="OnLogoUploaded"
                                   Style="margin: 0;">
                        <ActivatorContent>
                            <MudTooltip Text="@(_logoDataUri is not null ? "Change logo" : "Upload logo")" Placement="Placement.Bottom">
                                <MudIconButton Icon="@Icons.Material.Filled.Image" Size="Size.Small"
                                               Color="@(_logoDataUri is not null ? Color.Primary : Color.Default)" />
                            </MudTooltip>
                        </ActivatorContent>
                    </MudFileUpload>
                    @if (_logoDataUri is not null)
                    {
                        <MudTooltip Text="Remove logo" Placement="Placement.Bottom">
                            <MudIconButton Icon="@Icons.Material.Filled.HideImage" Size="Size.Small" Color="Color.Error"
                                           OnClick="RemoveLogo" />
                        </MudTooltip>
                    }
                }
                @* Title removed from the header — the company logo now
                   identifies the dashboard visually, and per-user rename
                   stopped making sense once dashboards became per-company.
                   _dashboardTitle is still set (to the company name) so the
                   browser tab / <PageTitle> stays informative. *@
            </MudStack>
            <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                @* Report Library shortcut. Visible to every role
                   except viewers with no shared reports — those would
                   land on an empty Library and have nothing to do
                   there, so the link disappears once their last share
                   is revoked. Editors / Schedulers / admins always
                   see the button; the Library handles their role-aware
                   tab/affordance gating internally. *@
                @if (_userRoleForCompany != UserRoles.Viewer || _hasAnyShares)
                {
                    <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.LibraryBooks"
                               OnClick="@(() => Navigation.NavigateTo("/reports"))">
                        @(_userRoleForCompany == UserRoles.Viewer ? "Shared Reports" : "Report Library")
                    </MudButton>
                }
                @* Edit is admin-only — the shared dashboard is the company's
                   canonical layout, and Editors/Viewers don't get to mutate
                   it. Phase 4 adds an approval queue so Editors can propose
                   tiles without direct edit rights. *@
                @if (_userRoleForCompany == UserRoles.Admin)
                {
                    @if (_editMode)
                    {
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Add" OnClick="OpenAddDialog">
                            Add Report
                        </MudButton>
                        <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Tab" OnClick="AddTab">
                            Add Tab
                        </MudButton>
                        <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.ViewModule" OnClick="AddSection"
                                   Disabled="@(ActiveTab is null || _sections.Count >= IMasterDashboardService.MaxSectionsPerTab)"
                                   title="@(_sections.Count >= IMasterDashboardService.MaxSectionsPerTab ? $"Maximum {IMasterDashboardService.MaxSectionsPerTab} sections per tab" : "Add a new section to this tab")">
                            Add Section
                        </MudButton>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Save" OnClick="SaveLayout">
                            Save Layout
                        </MudButton>
                    }
                    <MudButton Variant="@(_editMode ? Variant.Filled : Variant.Outlined)"
                               Color="@(_editMode ? Color.Warning : Color.Default)" Size="Size.Small"
                               StartIcon="@(_editMode ? Icons.Material.Filled.Check : Icons.Material.Filled.Edit)"
                               OnClick="ToggleEditMode">
                        @(_editMode ? "Done Editing" : "Edit Layout")
                    </MudButton>
                }
            </MudStack>
        </MudStack>

        @* Personalized landing strip — time-of-day greeting + a "what
           changed since last visit" delta. Renders as a fixed-position
           overlay (slides down on mount, slides up on dismiss) so the
           page layout doesn't shift. Once-per-circuit: the greeting slot
           is CLAIMED on first mount (see OnInitializedAsync), not on
           dismiss — so navigating from the picker to here mid-display
           doesn't re-show. _showGreeting is a local mount flag flipped
           off by the dismiss callback. Suppressed during edit mode and
           the initial layout load. *@
        @if (_showGreeting && !_editMode && !_loading)
        {
            <LandingGreeting DisplayName="@_userName"
                             LastSeenUtc="@_lastSeenUtc"
                             UpdatedSinceCount="@_updatedSinceLastVisit"
                             OnDismissed="HandleGreetingDismissed" />
        }

        @* Page-level "loading dashboard config" indicator. Tile data
           has its own per-tile QueryProgress below; this one only
           covers the layout/section/tile-list bootstrap. *@
        <QueryProgress Active="@_loading" />

        @* ── Pinned strip ──
           Personal shortcut bar of favorited reports. Distinct from the
           admin-curated tiles below (RPT_master_tiles): per-user, cross-
           company, hidden when the user has no favorites yet. Click → open
           the report in DetailViewer; the small × on each chip removes the
           favorite without leaving the page. *@
        @if (_favoriteReports.Count > 0 && !_editMode)
        {
            <MudPaper Elevation="0" Style="border: 1px solid var(--border-default, #DADCE0); border-radius: 8px; padding: 8px 12px; background: var(--surface-card, #FFFFFF);">
                <MudStack Row AlignItems="AlignItems.Center" Spacing="2" Style="flex-wrap: wrap;">
                    <MudStack Row AlignItems="AlignItems.Center" Spacing="1" Style="flex: 0 0 auto;">
                        <MudIcon Icon="@Icons.Material.Filled.Star" Size="Size.Small" Color="Color.Warning" />
                        <MudText Typo="Typo.caption" Style="font-weight: 600; color: var(--text-secondary, #5F6368); text-transform: uppercase; letter-spacing: 0.5px;">Pinned</MudText>
                    </MudStack>
                    @foreach (var fav in _favoriteReports)
                    {
                        var f = fav;
                        var label = string.IsNullOrWhiteSpace(f.InternalName) ? f.Name : f.InternalName!;
                        @* Pinned reports open in a new tab — the strip is a
                           shortcut bar, not a navigation primitive, so the
                           user keeps their dashboard context while popping
                           out the report. Href + Target turn the chip into
                           a real anchor so right-click "Open in new tab" /
                           middle-click also work as expected. *@
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                 Color="Color.Primary"
                                 Href="@($"/viewer/{f.Id}/detail")"
                                 Target="_blank"
                                 OnClose="@(() => UnfavoriteFromStripAsync(f.Id))"
                                 CloseIcon="@Icons.Material.Filled.Close"
                                 title="@label">
                            @label
                        </MudChip>
                    }
                </MudStack>
            </MudPaper>
        }

        @* ── Tabs ── *@
        @if (_tabs.Any())
        {
            <MudTabs ActivePanelIndex="_activeTabIndex" ActivePanelIndexChanged="OnTabChanged"
                     Elevation="0" Rounded ApplyEffectsToContainer
                     Class="dashboard-tabs">
                @foreach (var tab in _tabs)
                {
                    var t = tab;
                    var tIdx = _tabs.IndexOf(t);
                    <MudTabPanel>
                        <TabContent>
                            @* Tab header doubles as a drop target for two
                               drag flavors in edit mode: a tile (re-home
                               to another tab) and a sibling tab (reorder).
                               Sections are deliberately NOT droppable on
                               other tabs — they stay scoped to the tab
                               they were created in, and the predicate
                               below excludes _sectionDragSource. Plain
                               div wraps the MudStack because drag
                               directives (:preventDefault /
                               :stopPropagation) don't compose cleanly with
                               MudBlazor component parameters.
                               stopPropagation on drop prevents MudTabs
                               from treating the release as a tab-click. *@
                            <div style="@(_dropTargetTabId == t.Id
                                            ? "outline: 2px dashed #1A73E8; outline-offset: 2px; border-radius: 4px;"
                                            : "")"
                                 @ondragover:preventDefault
                                 @ondragover="@(() => { if (_editMode && (_dragSource >= 0 || (_tabDragSource >= 0 && _tabDragSource != tIdx))) _dropTargetTabId = t.Id; })"
                                 @ondragleave="@(() => { if (_dropTargetTabId == t.Id) _dropTargetTabId = 0; })"
                                 @ondrop="@(async () => await OnTabStripDrop(t.Id))"
                                 @ondrop:stopPropagation="true">
                                <MudStack Row AlignItems="AlignItems.Center" Spacing="1">
                                    @* Drag handle for tab reorder. Mirrors
                                       the section drag-indicator pattern —
                                       only the handle is draggable so
                                       clicking the rest of the tab still
                                       activates it normally. stopPropagation
                                       on click keeps a click on the handle
                                       from also triggering tab activation. *@
                                    @if (_editMode)
                                    {
                                        <span draggable="true"
                                              @ondragstart="@(() => _tabDragSource = tIdx)"
                                              @ondragend="@(() => { _tabDragSource = -1; _dropTargetTabId = 0; })"
                                              style="cursor: grab; display: inline-flex;"
                                              @onclick:stopPropagation="true"
                                              title="Drag to reorder tabs">
                                            <MudIcon Icon="@Icons.Material.Filled.DragIndicator" Size="Size.Small" Style="color: #5F6368;" />
                                        </span>
                                    }
                                    <span>@t.Label</span>
                                    @if (_editMode)
                                    {
                                        <MudTooltip Text="Rename tab">
                                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                                           Color="Color.Default" Style="padding: 2px;"
                                                           OnClick="@(() => RenameTab(t))" />
                                        </MudTooltip>
                                        @if (_tabs.Count > 1)
                                        {
                                            <MudTooltip Text="Remove tab">
                                                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                                               Color="Color.Error" Style="padding: 2px;"
                                                               OnClick="@(() => RemoveTab(t))" />
                                            </MudTooltip>
                                        }
                                    }
                                </MudStack>
                            </div>
                        </TabContent>
                        <ChildContent>
                            @* ── Tile reorder bar (edit mode) ── *@
                            @if (_editMode && _tiles.Any())
                            {
                                <MudPaper Elevation="0" Class="pa-2 mt-2" Style="border: 1px solid #E8EAED; border-radius: 4px;">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">
                                        Drag to reorder tiles:
                                    </MudText>
                                    <div style="display: flex; flex-wrap: wrap; gap: 4px; align-items: center;">
                                        @for (var i = 0; i < _tiles.Count; i++)
                                        {
                                            var idx = i;
                                            var tile = _tiles[i];
                                            <div @key="tile.Id"
                                                 style="@(_dragSource == idx ? "opacity: 0.3;" : "") position: relative;"
                                                 draggable="true"
                                                 @ondragstart="() => _dragSource = idx"
                                                 @ondragend="() => { _dragSource = -1; _dropTarget = -1; _dropTargetTabId = 0; }"
                                                 @ondragover:preventDefault
                                                 @ondragover="() => { if (_dragSource >= 0 && idx != _dragSource) _dropTarget = idx; }"
                                                 @ondrop="@(async () => await OnTileDrop(idx))">
                                                @if (_dropTarget == idx && _dragSource != idx)
                                                {
                                                    <div style="position: absolute; left: -2px; top: 2px; bottom: 2px; width: 3px; background: #1A73E8; border-radius: 2px; z-index: 10;"></div>
                                                }
                                                <MudChip T="string" Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                                                         Style="cursor: grab;">
                                                    @tile.ReportName
                                                </MudChip>
                                            </div>
                                        }
                                    </div>
                                </MudPaper>
                            }

                            @* ── Tile grid (and section strip when applicable) ──
                               Gate is `_tiles.Any() || _sections.Count > 0` so the section
                               strip renders even on a tab with zero tiles loaded — otherwise
                               re-adding sections to an empty tab would write to the DB but
                               render nothing, since the strip used to live entirely inside
                               the tiles-present branch. The truly-empty pad below stays
                               gated on both being empty. *@
                            @if (_tiles.Any() || _sections.Count > 0)
                            {
                                @* ── Section tab strip ──
                                   Renders only when this tab has at least one section. Each tab is
                                   clickable (switches active), drag-and-drop wired (reorder + cross-
                                   tab move + tile-drop assignment). The "(no section)" pseudo-tab
                                   surfaces only when at least one tile has SectionId = null —
                                   matches the v1 header semantics, just relocated into the strip. *@
                                @if (_sections.Count > 0)
                                {
                                    var sectionTabs = new List<(MasterDashboardSection? Section, string Label, int Key)>();
                                    foreach (var s in _sections) sectionTabs.Add((s, s.Label, s.Id));
                                    if (_tiles.Any(t => t.SectionId is null))
                                        sectionTabs.Add((null, "(no section)", 0));
                                    // Defense-in-depth: if the previously-active section was removed
                                    // out from under us (e.g. a stale cache), repoint to the first
                                    // available tab so rendering doesn't show an empty container.
                                    if (sectionTabs.Count > 0 && sectionTabs.All(st => st.Key != _activeSectionId))
                                    {
                                        _activeSectionId = sectionTabs[0].Key;
                                    }

                                    <div style="display: flex; gap: 4px; margin-top: 12px; border-bottom: 1px solid #DADCE0; flex-wrap: wrap;">
                                        @foreach (var st in sectionTabs)
                                        {
                                            var stLocal = st;
                                            var isActiveSec = _activeSectionId == stLocal.Key;
                                            var sIdx = stLocal.Section is null ? -2 : _sections.IndexOf(stLocal.Section);
                                            var isSecDropTarget = _editMode && _headerDropTargetIdx == sIdx
                                                && (_dragSource >= 0 || (_sectionDragSource >= 0 && _sectionDragSource != sIdx));
                                            var dropBg = _dragSource >= 0 ? "#FFF4E5" : "#E8F0FE";
                                            var dropOutline = _dragSource >= 0 ? "#F9AB00" : "#1A73E8";
                                            var tabBaseStyle = isActiveSec
                                                ? "background: #FFFFFF; border: 1px solid #DADCE0; border-bottom-color: #FFFFFF; position: relative; top: 1px;"
                                                : "background: #F1F3F4; border: 1px solid transparent;";
                                            var tabStyle = $"display: flex; align-items: center; gap: 4px; padding: 3px 12px; cursor: pointer; border-radius: 4px 4px 0 0; {tabBaseStyle} "
                                                         + (isSecDropTarget ? $"outline: 2px dashed {dropOutline}; background: {dropBg};" : string.Empty);

                                            <div style="@tabStyle"
                                                 @ondragover:preventDefault
                                                 @ondragover="@(() => { if (_editMode && (_sectionDragSource >= 0 || _dragSource >= 0)) _headerDropTargetIdx = sIdx; })"
                                                 @ondrop="@(async () => { if (_editMode) await OnHeaderDrop(stLocal.Section); })"
                                                 @onclick="@(() => SetActiveSection(stLocal.Key))">
                                                @if (_editMode && stLocal.Section is not null)
                                                {
                                                    <span draggable="true"
                                                          @ondragstart="@(() => _sectionDragSource = sIdx)"
                                                          @ondragend="@(() => { _sectionDragSource = -1; _headerDropTargetIdx = -1; })"
                                                          style="cursor: grab; display: inline-flex;"
                                                          @onclick:stopPropagation="true"
                                                          title="Drag to reorder sections">
                                                        <MudIcon Icon="@Icons.Material.Filled.DragIndicator" Size="Size.Small" Style="color: #5F6368;" />
                                                    </span>
                                                }
                                                @{
                                                    var stAlign = stLocal.Section is null
                                                        ? "left"
                                                        : (string.IsNullOrEmpty(stLocal.Section!.TitleAlign) ? "left" : stLocal.Section.TitleAlign);
                                                }
                                                <span style="@($"font-size: 0.875rem; font-weight: {(isActiveSec ? "600" : "500")}; color: #5F6368; text-align: {stAlign}; min-width: 60px;")">
                                                    @stLocal.Label
                                                </span>
                                            </div>
                                        }
                                    </div>

                                    @* Active section's edit-mode controls (rename / delete / align)
                                       — surfaces under the strip rather than crowding the active tab
                                       itself. Only renders for real sections; the "(no section)"
                                       virtual tab has nothing to rename / delete / align. *@
                                    @if (_editMode)
                                    {
                                        var activeSec = _sections.FirstOrDefault(s => s.Id == _activeSectionId);
                                        if (activeSec is not null)
                                        {
                                            var aSecAlign = string.IsNullOrEmpty(activeSec.TitleAlign) ? "left" : activeSec.TitleAlign;
                                            <div style="display: flex; align-items: center; gap: 6px; padding: 4px 6px; margin-top: 4px;">
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">Section options:</MudText>
                                                <MudTooltip Text="Align section title left">
                                                    <MudIconButton Icon="@Icons.Material.Filled.FormatAlignLeft" Size="Size.Small"
                                                                   Color="@(aSecAlign == "left" ? Color.Primary : Color.Default)"
                                                                   OnClick="@(() => SetSectionAlign(activeSec, "left"))" />
                                                </MudTooltip>
                                                <MudTooltip Text="Align section title center">
                                                    <MudIconButton Icon="@Icons.Material.Filled.FormatAlignCenter" Size="Size.Small"
                                                                   Color="@(aSecAlign == "center" ? Color.Primary : Color.Default)"
                                                                   OnClick="@(() => SetSectionAlign(activeSec, "center"))" />
                                                </MudTooltip>
                                                <MudTooltip Text="Align section title right">
                                                    <MudIconButton Icon="@Icons.Material.Filled.FormatAlignRight" Size="Size.Small"
                                                                   Color="@(aSecAlign == "right" ? Color.Primary : Color.Default)"
                                                                   OnClick="@(() => SetSectionAlign(activeSec, "right"))" />
                                                </MudTooltip>
                                                <MudTooltip Text="Rename section">
                                                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                                                   OnClick="@(() => RenameSection(activeSec))" />
                                                </MudTooltip>
                                                <MudTooltip Text="Delete section (tiles move to '(no section)')">
                                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                                   Color="Color.Error"
                                                                   OnClick="@(() => RemoveSection(activeSec))" />
                                                </MudTooltip>
                                            </div>
                                        }
                                    }
                                }

                                @* All tiles in the tab render, with non-active-section tiles hidden
                                   via display:none. This keeps DashboardView components mounted
                                   across section switches — without this, switching sections
                                   unmounts the active section's tiles + remounts the new section's
                                   tiles, and remounting a DashboardView re-renders the entire grid
                                   (7-10s on a 30k-row tile). The previous filter-on-activeIndices
                                   approach was correct for "tab-like" semantics but leaked the
                                   first-render cost on every section switch.
                                   The "(no section)" pseudo-section uses sectionId == null.
                                   When _sections is empty, every tile is visible (matches pre-
                                   sections layout exactly). *@
                                bool TileVisible(MasterDashboardTile t)
                                {
                                    if (_sections.Count == 0) return true;
                                    if (_activeSectionId == 0) return t.SectionId is null;
                                    return t.SectionId == _activeSectionId;
                                }

                                <div class="mt-2" style="display: flex; flex-wrap: wrap; gap: 16px; padding-bottom: 12px;">
                                    @for (var ti = 0; ti < _tiles.Count; ti++)
                                    {
                                        var idx = ti;
                                        var tl = _tiles[ti];
                                        var visible = TileVisible(tl);
                                        var isDragging = _editMode && _dragSource == idx;
                                        var isDropTarget = _editMode && _dropTarget == idx && _dragSource >= 0 && _dragSource != idx;
                                        var tileClass = "master-tile"
                                            + (_editMode ? " master-tile-edit" : string.Empty)
                                            + (isDragging ? " master-tile-dragging" : string.Empty)
                                            + (isDropTarget ? " master-tile-droptarget" : string.Empty);
                                        @* The inline width is the *preferred* width (ColSpan * 60).
                                           min-width: 0 + flex-shrink: 1 lets the tile shrink with its
                                           flex-row parent when there isn't enough horizontal room —
                                           which then unlocks the table-shrink chain inside. The old
                                           flex-shrink: 0 + min-width: auto combination was pinning
                                           the tile at ColSpan * 60 regardless of viewport / parent
                                           width, which then propagated down to the table. *@
                                        @* Right-click → "Show SQL" dialog
                                           is admin-only. For non-admins
                                           we don't bind the handler at all,
                                           so the browser's default context
                                           menu surfaces normally and there's
                                           no admin-only affordance to
                                           discover. (2026-05-05 policy.) *@
                                        <div @key="tl.Id" id="@($"master-tile-{tl.Id}")"
                                             class="@tileClass"
                                             style="@(visible ? string.Empty : "display: none; ")width: @(tl.ColSpan * 60)px; height: @(tl.Height)px; position: relative; min-width: 0; flex-shrink: 1;"
                                             @ondragover:preventDefault
                                             @ondragover="@(() => { if (_editMode && _dragSource >= 0 && idx != _dragSource) { _dropTarget = idx; } })"
                                             @ondrop="@(async () => await OnTileDrop(idx))"
                                             @oncontextmenu="@(() => { if (_userRoleForCompany == UserRoles.Admin) _ = ShowTileQuery(tl); })"
                                             @oncontextmenu:preventDefault="@(_userRoleForCompany == UserRoles.Admin)">
                                            <MudPaper Elevation="0" Style="border: 1px solid var(--border-subtle, #E8EAED); border-radius: 12px; height: 100%; display: flex; flex-direction: column; overflow: hidden; background: var(--surface-card, #FFFFFF); box-shadow: 7px 7px 9px rgba(0,0,0,0.20), 5px 5px 7px rgba(0,0,0,0.14);">
                                                @* Tile header — drag handle in edit mode; title is bold and per-tile alignable *@
                                                @{
                                                    var tileAlign = string.IsNullOrEmpty(tl.TitleAlign) ? "left" : tl.TitleAlign;
                                                }
                                                <div draggable="@(_editMode ? "true" : "false")"
                                                     @ondragstart="@(() => _dragSource = idx)"
                                                     @ondragend="@(() => { _dragSource = -1; _dropTarget = -1; _dropTargetTabId = 0; })"
                                                     style="@(_editMode ? "cursor: grab;" : "")">
                                                    <div style="display: flex; align-items: center; gap: 4px; padding: 6px 12px; border-bottom: 1px solid var(--border-subtle, #E8EAED); background: var(--dashboard-header-bg, #FFFFFF); color: var(--dashboard-header-text, #202124);">
                                                        @if (_editMode)
                                                        {
                                                            <MudIcon Icon="@Icons.Material.Filled.DragIndicator" Size="Size.Small"
                                                                     Style="color: #5F6368; font-size: 18px;" />
                                                        }
                                                        <span style="@($"flex: 1; min-width: 0; font-weight: var(--dashboard-header-weight, 700); font-style: var(--dashboard-header-style, normal); text-decoration: var(--dashboard-header-deco, none); font-family: var(--dashboard-header-font, inherit); font-size: var(--dashboard-header-size, 0.95rem); text-align: {tileAlign}; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;")"
                                                              title="@tl.ReportName">@tl.ReportName</span>
                                                        @if (_editMode)
                                                        {
                                                            <MudText Typo="Typo.caption" Color="Color.Secondary" Style="white-space: nowrap;">(@(tl.ColSpan * 60)w x @(tl.Height)h)</MudText>
                                                            <MudTooltip Text="Align left" Placement="Placement.Bottom">
                                                                <MudIconButton Icon="@Icons.Material.Filled.FormatAlignLeft" Size="Size.Small"
                                                                               Color="@(tileAlign == "left" ? Color.Primary : Color.Default)"
                                                                               OnClick="@(() => SetTileAlign(tl, "left"))" />
                                                            </MudTooltip>
                                                            <MudTooltip Text="Align center" Placement="Placement.Bottom">
                                                                <MudIconButton Icon="@Icons.Material.Filled.FormatAlignCenter" Size="Size.Small"
                                                                               Color="@(tileAlign == "center" ? Color.Primary : Color.Default)"
                                                                               OnClick="@(() => SetTileAlign(tl, "center"))" />
                                                            </MudTooltip>
                                                            <MudTooltip Text="Align right" Placement="Placement.Bottom">
                                                                <MudIconButton Icon="@Icons.Material.Filled.FormatAlignRight" Size="Size.Small"
                                                                               Color="@(tileAlign == "right" ? Color.Primary : Color.Default)"
                                                                               OnClick="@(() => SetTileAlign(tl, "right"))" />
                                                            </MudTooltip>
                                                            @* Move-to-section picker — only meaningful when the
                                                               tab actually has sections. The check icon marks
                                                               the tile's current bucket so admins can confirm
                                                               where it lives without opening another tab. *@
                                                            @if (_sections.Count > 0)
                                                            {
                                                                <MudTooltip Text="Move tile to a section" Placement="Placement.Bottom">
                                                                    <MudMenu Icon="@Icons.Material.Filled.ViewModule" Size="Size.Small"
                                                                             Dense AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                                                                        <MudMenuItem OnClick="@(() => MoveTileToSection(tl, null))">
                                                                            @if (tl.SectionId is null)
                                                                            {
                                                                                <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" Style="margin-right: 4px;" />
                                                                            }
                                                                            (no section)
                                                                        </MudMenuItem>
                                                                        @foreach (var s in _sections)
                                                                        {
                                                                            var sLocal = s;
                                                                            <MudMenuItem OnClick="@(() => MoveTileToSection(tl, sLocal.Id))">
                                                                                @if (tl.SectionId == sLocal.Id)
                                                                                {
                                                                                    <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" Style="margin-right: 4px;" />
                                                                                }
                                                                                @sLocal.Label
                                                                            </MudMenuItem>
                                                                        }
                                                                    </MudMenu>
                                                                </MudTooltip>
                                                            }
                                                        }
                                                        @* Hide the toggle when there's no data to chart — an empty
                                                           result set produces no bars/slices/points, so offering
                                                           "Show Chart" would just flip to a blank panel. *@
                                                        @if (_tileData.TryGetValue(tl.ReportId, out var tdHeader) && tdHeader.Config is not null
                                                             && !string.IsNullOrEmpty(tdHeader.Config.ChartType)
                                                             && tdHeader.Data is not null && tdHeader.Data.Rows.Count > 0)
                                                        {
                                                            <MudTooltip Text="@(_chartVisibleTiles.Contains(tl.Id) ? "Hide Chart" : "Show Chart")" Placement="Placement.Bottom">
                                                                <MudIconButton Icon="@(_chartVisibleTiles.Contains(tl.Id) ? Icons.Material.Filled.BarChart : Icons.Material.Outlined.BarChart)"
                                                                               Size="Size.Small"
                                                                               Color="@(_chartVisibleTiles.Contains(tl.Id) ? Color.Primary : Color.Default)"
                                                                               OnClick="@(() => ToggleChart(tl.Id))" />
                                                            </MudTooltip>
                                                        }
                                                        @* Tile export — same dropdown UX as the Detail Viewer
                                                           (Excel / CSV) but rendered as a compact icon button
                                                           so it doesn't crowd the header on small tiles. The
                                                           export bypasses the dashboard's aggregation and
                                                           writes the underlying detail rows, matching the
                                                           "All Records" view in the Detail Viewer. Disabled
                                                           until the tile finishes loading data. *@
                                                        @{
                                                            var tileLocal = tl;
                                                            var tileLoaded = _tileData.ContainsKey(tl.ReportId);
                                                        }
                                                        <ExportMenu IconOnly
                                                                    OnExportExcel="@(() => ExportTileDetailExcel(tileLocal))"
                                                                    OnExportCsv="@(() => ExportTileDetailCsv(tileLocal))"
                                                                    OnExportPdf="@(() => ExportTileDetailPdf(tileLocal))"
                                                                    Disabled="@(!tileLoaded)" />
                                                        @if (_editMode)
                                                        {
                                                            <MudTooltip Text="Remove tile">
                                                                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                                                               Color="Color.Error"
                                                                               OnClick="() => RemoveTile(tl)" />
                                                            </MudTooltip>
                                                        }
                                                    </div>
                                                </div>

                                                @* Tile content. min-width: 0 lets the flex chain inside
                                                   shrink horizontally with the tile (each flex container
                                                   defaults to min-width: auto = content intrinsic min,
                                                   which pegs the table's column widths). *@
                                                <div style="overflow: hidden; flex: 1; display: flex; flex-direction: column; min-width: 0;">
                                                    @if (_tileData.TryGetValue(tl.ReportId, out var td))
                                                    {
                                                        <DashboardView Data="td.Data" InitialConfig="td.Config"
                                                                       InitialHiddenColumns="td.HiddenColumns"
                                                                       TableCalcColumns="td.TableCalcColumns"
                                                                       ColumnLabelOverrides="td.CustomColumnLabels"
                                                                       ReadOnly="true" DetailFromDashboard="true" ReportId="tl.ReportId"
                                                                       DashboardTabName="@(ActiveTab?.Label)"
                                                                       GridHeight="@($"{Math.Max(150, tl.Height - 120)}px")"
                                                                       Compact="true"
                                                                       HideChart="@(!_chartVisibleTiles.Contains(tl.Id))" />
                                                    }
                                                    else if (_tileLoading.Contains(tl.ReportId))
                                                    {
                                                        @* Tile queries have tighter slowness thresholds than
                                                           full reports — a 6-second tile feels worse than a
                                                           6-second report viewer because the user is staring at
                                                           a card the size of a postage stamp. *@
                                                        <QueryProgress Active="true"
                                                                       SlowThresholdSeconds="5"
                                                                       VerySlowThresholdSeconds="12"
                                                                       VerySlowMessage="@($"Tile fetch is slow — check the report's connection or filters.")" />
                                                    }
                                                    else
                                                    {
                                                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="pa-4">
                                                            @(_tileErrors.TryGetValue(tl.ReportId, out var err)
                                                                ? err
                                                                : "Failed to load dashboard data.")
                                                        </MudText>
                                                    }
                                                </div>
                                                @* Tile footer band — small metadata strip at the bottom
                                                   of every loaded tile. Shows the row count for a quick
                                                   "how much data is in here" cue. Background + text
                                                   drive off the --dashboard-footer-* tokens; admins
                                                   can re-paint it via Admin → Theme. Only renders when
                                                   the tile actually has data — loading / error states
                                                   keep the tile body uncluttered. *@
                                                @if (_tileData.TryGetValue(tl.ReportId, out var tdFooter))
                                                {
                                                    <div style="display: flex; align-items: center; justify-content: flex-end; gap: 8px; padding: 4px 12px; border-top: 1px solid var(--border-subtle, #E8EAED); background: var(--dashboard-footer-bg, #FAFAFA); color: var(--dashboard-footer-text, #5F6368); font-weight: var(--dashboard-footer-weight, 400); font-style: var(--dashboard-footer-style, normal); text-decoration: var(--dashboard-footer-deco, none); font-family: var(--dashboard-footer-font, inherit); font-size: var(--dashboard-footer-size, 0.7rem);">
                                                        <span>@tdFooter.Data.Rows.Count.ToString("N0") rows</span>
                                                    </div>
                                                }
                                            </MudPaper>
                                            @if (_editMode)
                                            {
                                                <div class="tile-resize-handle"></div>
                                            }
                                        </div>
                                        }
                                    </div>
                            }
                            else if (!_loading)
                            {
                                <EmptyState Icon="@Icons.Material.Filled.DashboardCustomize"
                                            MinHeightPx="200"
                                            ContainerClass="mt-2"
                                            Heading="No tiles on this tab yet"
                                            Body="@(_editMode ? "Add reports as tiles to start building this dashboard." : "Switch to edit mode to add reports as tiles, or pick a different tab.")"
                                            CtaLabel="@(_editMode ? "Add report" : null)"
                                            CtaIcon="@Icons.Material.Filled.Add"
                                            OnCtaClick="OpenAddDialog" />
                            }
                        </ChildContent>
                    </MudTabPanel>
                }
            </MudTabs>
        }
        else if (!_loading)
        {
            @* Empty-state copy + CTA depends on whether the user can
               actually fix the empty state. Admins get an actionable
               "Create First Tab" button; viewers / editors land on a
               friendlier message that points back to the Library since
               they can't author dashboards themselves. *@
            @if (_userRoleForCompany == UserRoles.Admin)
            {
                <EmptyState Icon="@Icons.Material.Filled.DashboardCustomize"
                            Heading="Build your first dashboard tab"
                            Body="Tabs group related reports for a daily view. Add one to start pinning reports as tiles."
                            CtaLabel="Create First Tab"
                            CtaIcon="@Icons.Material.Filled.Tab"
                            OnCtaClick="AddTab" />
            }
            else
            {
                <EmptyState Icon="@Icons.Material.Filled.DashboardCustomize"
                            Heading="Nothing on this dashboard yet"
                            Body="An admin sets up the layout for this company. In the meantime you can run reports directly from the Library."
                            CtaLabel="Open Report Library"
                            CtaIcon="@Icons.Material.Filled.LibraryBooks"
                            OnCtaClick="@(() => Navigation.NavigateTo("/reports"))" />
            }
        }
    </MudStack>
</MudMainContent>

<style>
    /* Tab strip background — slightly darker than the page surface so
       the tabs read as a distinct band rather than blending into the
       toolbar above. Scoped via .dashboard-tabs so this doesn't bleed
       into MudTabs anywhere else in the app. */
    .dashboard-tabs .mud-tabs-toolbar {
        background-color: var(--surface-strip, #E8EAED);
    }

    .tile-resize-handle {
        position: absolute;
        right: 0;
        bottom: 0;
        width: 16px;
        height: 16px;
        cursor: nwse-resize;
        z-index: 20;
        background: linear-gradient(135deg, transparent 50%, #1A73E8 50%);
        border-radius: 0 0 4px 0;
        opacity: 0.6;
    }
    .tile-resize-handle:hover {
        opacity: 1;
    }
    .mud-tabs .mud-tab {
        text-transform: none !important;
        /* Tighten the tab strip — MudBlazor's default min-height is 48px,
           which feels tall on a dashboard where every pixel above the
           tiles is overhead. 36px keeps text + the active-tab underline
           comfortably visible without crowding the content below. */
        min-height: 36px !important;
        padding: 4px 12px !important;
    }
    .mud-tabs .mud-tabs-toolbar {
        min-height: 36px !important;
    }
    /* Don't constrain the inner bar — let it follow its content (the
       individual .mud-tab buttons sized above) instead of carrying its
       own default 48px floor that'd add unwanted vertical space. */
    .mud-tabs .mud-tabs-tabbar-inner {
        min-height: 0 !important;
    }
    /* Responsive: tiles can't exceed viewport width and shrink freely down
       to whatever their content's natural min-width is. The inline width
       (ColSpan * 60) is treated as the preferred width; max-width: 100%
       caps it to the available space. The 300px hard floor that used to
       live here was the chain-breaker preventing the inner table from
       shrinking past a certain point — removed so text columns can
       actually flex with the tile. The tile's title bar already
       ellipsises (flex: 1; min-width: 0; text-overflow: ellipsis). */
    .master-tile {
        max-width: 100%;
        /* Round the outer wrapper too so the edit-mode outline / resize-mode
           outline track the rounded inner MudPaper instead of cutting square
           corners across the rounded shadow underneath. */
        border-radius: 12px;
    }
    .master-tile-edit {
        outline: 2px dashed #DADCE0;
        outline-offset: -2px;
        border-radius: 12px;
    }
    .master-tile.tile-resizing {
        outline: 2px solid #1A73E8 !important;
        opacity: 0.9;
        border-radius: 12px;
    }
    .master-tile.master-tile-dragging {
        opacity: 0.4;
    }
    .master-tile.master-tile-droptarget {
        outline: 3px solid #1A73E8 !important;
        outline-offset: -3px;
    }
    /* Per-tile grid header row: dodger blue background, white text (including
       sort icons and the sortable header buttons MudDataGrid renders). Scoped
       to .master-tile so the Report Library and other grids aren't affected. */
    .master-tile thead th,
    .master-tile .mud-table-head th,
    .master-tile .mud-table-cell-header {
        font-weight: bold !important;
        white-space: nowrap !important;
    }
    .master-tile thead th .mud-button-root,
    .master-tile .mud-table-head .mud-button-root,
    .master-tile .mud-table-sort-label,
    .master-tile .mud-table-sort-label .mud-icon-root {
        color: #FFFFFF !important;
    }
    /* Body cells: nowrap + overflow: hidden + ellipsis so long data values
       truncate with the ellipsis character instead of wrapping over multiple rows.
       The ellipsis rule must also hit the inner MudText wrapper (rendered as p or
       span), otherwise the text overflows the inner element silently without
       producing the ellipsis. display: block + max-width: 100% makes text-overflow
       actually fire on the inner element. */
    .master-tile tbody td,
    .master-tile .mud-table-cell:not(.mud-table-cell-header) {
        white-space: nowrap !important;
        overflow: hidden !important;
        text-overflow: ellipsis !important;
        /* No max-width here — under table-layout: fixed the column widths come from
           the <col>/th definitions; max-width: 0 would override the explicit widths
           set on count/pct/measure/extras and collapse those cells to zero. */
    }
    .master-tile tbody td .mud-typography,
    .master-tile tbody td p,
    .master-tile tbody td span,
    .master-tile tbody td div {
        max-width: 100%;
        white-space: nowrap !important;
        overflow: hidden !important;
        text-overflow: ellipsis !important;
        text-align: inherit;   /* pick up text-align from the parent cell */
    }
    .master-tile tbody td .mud-typography,
    .master-tile tbody td p {
        display: block;
    }
    /* No horizontal scrollbar inside a tile — if content is wider than the tile,
       clip it silently. Combined with the ellipsis on body cells above, the
       Campaign column (or whichever is flexible) shrinks and cells truncate. */
    .master-tile .mud-table-container {
        overflow-x: hidden !important;
    }
    /* Excludes .dash-summary-table — that table needs table-layout: fixed
       to clip overflowing text columns; under auto layout it sizes to its
       widest content and overflows the wrap (no scrollbar, content clipped
       off the right edge). */
    .master-tile table:not(.dash-summary-table) {
        table-layout: auto;
        width: 100%;
    }
    /* Tighter cell padding inside tiles — 4px top/bottom, 6px left/right. */
    .master-tile .mud-table-cell {
        padding: 4px 6px !important;
    }
    /* Darker hover on tile data rows for better visual feedback. */
    .master-tile tbody tr:hover td {
        background-color: #E0E0E0 !important;
    }
</style>

@code {
    [Parameter] public string? CompanyCode { get; set; }

    private string _userId = "anonymous";
    private string _userEmail = string.Empty;
    private string _userName = string.Empty;
    // Last time the user landed on this Master Dashboard, read from
    // RPT_user_preferences. Drives the LandingGreeting strip's "X reports
    // updated since you last visited" copy. Null on first-ever visit.
    private DateTime? _lastSeenUtc;
    // Count of saved reports updated since _lastSeenUtc within the user's
    // accessible companies. Computed during OnInitializedAsync; static
    // for the page lifetime (we don't auto-refresh — the greeting is a
    // landing impression, not a live feed).
    private int _updatedSinceLastVisit;
    // Local "the greeting is currently mounted on this page" flag.
    // True only when this MasterDashboard claimed the once-per-circuit
    // slot in OnInitializedAsync. Flipped off by the dismiss callback
    // so the slide-up animation can complete before the component is
    // removed from the DOM.
    private bool _showGreeting;
    // Resolved from CompanyCode in OnInitializedAsync — used as the scope for
    // every MasterService call so dashboards are (user, company) keyed.
    private Guid _companyId;
    // Populated from RPT_companies.website_url when non-null — makes the
    // header logo a clickable link to the company's external site.
    private string? _companyWebsiteUrl;
    // The signed-in user's role for the current company. "Admin" when the
    // user is a global admin (who bypasses per-company roles entirely).
    // Drives per-role UI gating — e.g. hiding the Report Library shortcut
    // from Viewers, who aren't meant to leave the dashboard.
    private string _userRoleForCompany = string.Empty;
    // Drives whether the "Shared Reports" header button shows for
    // viewer-role users. Editor / Scheduler / Admin roles always see
    // the full Library, so this flag is only consulted on the viewer
    // branch. Refreshed on each page load — when an admin revokes a
    // share, the next time the viewer hits the dashboard the count
    // will reflect the change (the share cache was invalidated by
    // ReportDbService at revoke time).
    private bool _hasAnyShares;
    // Drives the back-arrow visibility: single-company users have no picker
    // to return to (CompanyPicker auto-redirects them straight here), so
    // showing the arrow would just dead-end them on a redirect loop.
    private int _accessibleCompanyCount;
    private bool _loading = true;
    private bool _initialized;
    private bool _editMode;
    private string _dashboardTitle = "Master Dashboard";
    private byte[]? _logoBytes;
    private string? _logoMimeType;
    private string? _logoDataUri;
    private List<MasterDashboardTab> _tabs = new();
    private int _activeTabIndex;
    private List<MasterDashboardTile> _tiles = new();
    private List<MasterDashboardTile> _pendingRemovals = new();
    // Per-tab snapshot of in-memory tile edits so switching tabs while editing
    // doesn't discard unsaved alignment / resize / removal changes on the prior tab.
    private Dictionary<int, List<MasterDashboardTile>> _tilesByTab = new();
    private Dictionary<int, List<MasterDashboardTile>> _pendingRemovalsByTab = new();
    // Sections for the active tab. Empty list = legacy "no sections" layout
    // → tiles render in a single un-headered group (byte-for-byte identical
    // to the pre-sections rendering). _sectionsByTab parallels _tilesByTab
    // so tab toggles in edit mode don't refetch sections from the DB.
    private List<MasterDashboardSection> _sections = new();
    private Dictionary<int, List<MasterDashboardSection>> _sectionsByTab = new();
    // Active section within the current tab. 0 = "(no section)" virtual tab
    // (also the default when no real sections exist). Positive int = a real
    // section's id. Mirrors the way _activeTabIndex governs which MudTabPanel
    // shows tile content, but scoped one level deeper.
    private int _activeSectionId;
    private Dictionary<Guid, TileLoadResult> _tileData = new();
    // Wall-clock UTC of each tile's most-recent successful load. Drives
    // the "updated 5m ago" footer caption — populated alongside the
    // _tileData write so the two stay in sync. Cleared when the tile
    // fails or gets removed so the footer doesn't render against stale
    // data.
    private Dictionary<Guid, DateTime> _tileLoadedAtUtc = new();
    private Dictionary<Guid, string> _tileErrors = new();
    // Captured query state when a tile errors out at execution. Lets the
    // right-click "Show query" dialog still render the SQL that was sent
    // (or attempted) so admins can debug invalid SQL / DB-side failures
    // without tailing logs.
    private Dictionary<Guid, FailedTileQuery> _tileFailedQuery = new();
    private HashSet<Guid> _tileLoading = new();
    private HashSet<int> _chartVisibleTiles = new();
    private DotNetObjectReference<MasterDashboard>? _dotNetRef;
    private int _dragSource = -1;
    private int _dropTarget = -1;
    // Tab id currently hovered as a cross-tab drop target. 0 = none (tab
    // ids are positive identity values, so 0 is a safe sentinel). Reset
    // on drag-end alongside the other drag state.
    private int _dropTargetTabId;

    private MasterDashboardTab? ActiveTab => _activeTabIndex >= 0 && _activeTabIndex < _tabs.Count ? _tabs[_activeTabIndex] : null;

    // User's favorited reports — drives the personal "Pinned" strip above
    // the tabs. Distinct from RPT_master_tiles (admin-curated, shared); this
    // is per-user and cross-company so the same shortcut bar follows the
    // user wherever they land. Resolved via parallel GetReportByIdAsync
    // calls, dropping ids that no longer match a live report (deleted /
    // revoked).
    private List<SavedReport> _favoriteReports = new();

    // 5-minute idle threshold. Caller code reads this constant via the JS
    // bridge so changing the timeout is a single edit.
    private const int IdleRefreshThresholdMs = 5 * 60 * 1000;
    private bool _idleWatcherStarted;

    // Snapshot of the edit-mode-relevant state at the most recent "clean"
    // point — when the user enters edit mode and after each successful
    // SaveLayout. Compared against the live state on navigation; mismatch
    // = dirty = prompt. Only consulted while _editMode is true (viewing
    // the dashboard never trips the guard). Serialized JSON rather than
    // a structural compare so we don't hand-enumerate every nested field.
    private string _dirtySnapshot = string.Empty;
    // Tracks the last-sent value of the JS-side beforeunload guard so we
    // don't thrash JS interop on every render.
    private bool _beforeUnloadArmed;
    // Disposable returned by RegisterLocationChangingHandler. Released
    // on Dispose so the handler doesn't leak across navigations.
    private IDisposable? _navHandlerRegistration;

    private string ComputeDirtySnapshot()
    {
        // Capture every edit-mode-mutable field. The active-tab edits
        // live in _tiles / _sections / _pendingRemovals; the per-tab
        // caches hold edits to tabs the user navigated away from while
        // still in edit mode. Tabs themselves can be reordered /
        // renamed / added / removed, so include the tab list too.
        try
        {
            var snap = new
            {
                Tabs = _tabs.Select(t => new { t.Id, t.Label, t.SortOrder }).ToList(),
                ActiveTiles = _tiles.Select(t => new { t.Id, t.ReportId, t.SortOrder, t.ColSpan, t.Height, t.SectionId }).ToList(),
                ActiveSections = _sections.Select(s => new { s.Id, s.Label, s.SortOrder }).ToList(),
                ActivePendingRemovals = _pendingRemovals.Select(t => t.Id).ToList(),
                TilesByTab = _tilesByTab.OrderBy(kv => kv.Key)
                    .Select(kv => new
                    {
                        TabId = kv.Key,
                        Tiles = kv.Value.Select(t => new { t.Id, t.ReportId, t.SortOrder, t.ColSpan, t.Height, t.SectionId }).ToList()
                    }).ToList(),
                SectionsByTab = _sectionsByTab.OrderBy(kv => kv.Key)
                    .Select(kv => new
                    {
                        TabId = kv.Key,
                        Sections = kv.Value.Select(s => new { s.Id, s.Label, s.SortOrder }).ToList()
                    }).ToList(),
                PendingRemovalsByTab = _pendingRemovalsByTab.OrderBy(kv => kv.Key)
                    .Select(kv => new
                    {
                        TabId = kv.Key,
                        TileIds = kv.Value.Select(t => t.Id).ToList()
                    }).ToList(),
                LogoBytesLen = _logoBytes?.Length ?? 0,
                LogoMime = _logoMimeType
            };
            return System.Text.Json.JsonSerializer.Serialize(snap);
        }
        catch
        {
            // Snapshot failure shouldn't crash the editor — fall back to
            // a sentinel that compares as dirty so the user is at least
            // asked rather than silently losing edits.
            return Guid.NewGuid().ToString();
        }
    }

    // Reset the baseline — call when entering edit mode and after a
    // successful save so the current state becomes the new "clean" ref.
    private void MarkClean() => _dirtySnapshot = ComputeDirtySnapshot();

    // Only dirty when actively editing. The dashboard is a viewing
    // surface most of the time, and a passive viewer should never see
    // the unsaved-changes prompt.
    private bool IsDirty => _editMode
        && !string.Equals(_dirtySnapshot, ComputeDirtySnapshot(), StringComparison.Ordinal);

    // Intercepts in-app navigation. The Blazor handler is awaited
    // before navigation actually proceeds, so we can prompt and call
    // PreventNavigation if the user picks Cancel. Save runs SaveLayout;
    // DontSave just lets nav proceed.
    private async ValueTask OnLocationChangingAsync(LocationChangingContext context)
    {
        if (!IsDirty) return;
        var choice = await UnsavedChangesPrompt.AskAsync(DialogService);
        switch (choice)
        {
            case UnsavedChangesResult.Save:
                await SaveLayout();
                // SaveLayout sets the new baseline; if it failed (snackbar
                // shown by SaveLayout), state is still dirty. Block the
                // navigation so the user can fix and retry rather than
                // silently leaving with unsaved layout edits.
                if (IsDirty) context.PreventNavigation();
                break;
            case UnsavedChangesResult.DontSave:
                // Disarm guards so the imminent unload doesn't double-prompt
                // (LocationChanging then beforeunload).
                MarkClean();
                break;
            case UnsavedChangesResult.Cancel:
                context.PreventNavigation();
                break;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Start the idle auto-refresh watcher once per page mount. The
        // JS side debounces activity events, so the cost here is just
        // one initial JS interop call. The watcher invokes
        // OnIdleRefresh below after IdleRefreshThresholdMs of no
        // activity (mouse / keyboard / scroll / touch).
        if (firstRender)
        {
            _dotNetRef ??= DotNetObjectReference.Create(this);
            try
            {
                await JS.InvokeVoidAsync("startIdleWatcher", _dotNetRef, IdleRefreshThresholdMs);
                _idleWatcherStarted = true;
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Failed to start idle-refresh watcher — auto-refresh disabled for this session.");
            }
        }

        if (_editMode && _tiles.Any())
        {
            _dotNetRef ??= DotNetObjectReference.Create(this);
            // Snapshot: the await below yields, and a concurrent OnTileDrop (or any other
            // handler that mutates _tiles) would otherwise invalidate the enumerator and
            // throw "Collection was modified" on the next iteration.
            var snapshot = _tiles.ToList();
            foreach (var tile in snapshot)
            {
                // Call every render — initTileResize is idempotent (data-resize-wired marker
                // on the handle element). A C# one-shot guard was too aggressive: if the handle
                // wasn't in DOM yet on the first call after entering edit mode, JS bailed and
                // we never retried.
                await JS.InvokeVoidAsync("initTileResize", tile.Id, _dotNetRef, 24);
            }
        }

        // Apply native-browser tooltips to any truncated <td> so the user can see the full
        // value on hover. Runs every render — cheap (measures existing DOM, no mutations
        // unless truncation state actually changed).
        if (_initialized && _tiles.Any())
        {
            try
            {
                await JS.InvokeVoidAsync("applyCellTooltips", ".master-tile");
            }
            catch { /* JS not ready on very first render — next render will catch up */ }
        }

        // Sync the JS-side beforeunload guard with the live dirty state
        // every render, but only invoke when it actually changed — saves
        // a JS-interop call per re-render of a clean page. IsDirty is
        // already gated on _editMode, so non-edit-mode renders are no-ops.
        var armNow = IsDirty;
        if (armNow != _beforeUnloadArmed)
        {
            try { await JS.InvokeVoidAsync("setBeforeUnloadGuard", armNow); }
            catch { /* circuit may be tearing down — drop silently */ }
            _beforeUnloadArmed = armNow;
        }
    }

    [JSInvokable]
    public void OnTileResized(int tileId, int colSpan, int height)
    {
        var tile = _tiles.FirstOrDefault(t => t.Id == tileId);
        if (tile is not null)
        {
            tile.ColSpan = colSpan;
            tile.Height = height;
            StateHasChanged();
        }
    }

    // Fired by idle-refresh.js after the configured threshold of no user
    // activity. Re-runs the active section's tile queries so admins
    // sitting on a dashboard see fresh numbers without manually
    // reloading the page. Skips when:
    //   * Edit mode is active (the admin is mid-layout-change; clobbering
    //     unsaved edits with a re-fetch would be hostile)
    //   * The page hasn't finished its initial bootstrap (_initialized)
    //   * The user already navigated away (the JS watcher should have
    //     stopped, but a race window during Dispose is possible)
    [JSInvokable]
    public async Task OnIdleRefresh()
    {
        if (_editMode || !_initialized) return;
        try
        {
            await LoadActiveSectionTiles();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Idle auto-refresh failed.");
        }
    }

    public void Dispose()
    {
        if (_idleWatcherStarted)
        {
            // Fire-and-forget; the circuit may already be torn down in
            // which case the JS call no-ops harmlessly.
            _ = JS.InvokeVoidAsync("stopIdleWatcher").AsTask().ContinueWith(_ => { });
        }
        _navHandlerRegistration?.Dispose();
        _navHandlerRegistration = null;
        // Clear the JS-side guard so the next page mount doesn't
        // inherit a stale "armed" state. Fire-and-forget — the
        // circuit is tearing down and there's no one to await us.
        if (_beforeUnloadArmed)
        {
            try { _ = JS.InvokeVoidAsync("setBeforeUnloadGuard", false).AsTask(); }
            catch { }
            _beforeUnloadArmed = false;
        }
        _dotNetRef?.Dispose();
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _userId = authState.User.FindFirst("oid")?.Value
                  ?? authState.User.Identity?.Name
                  ?? "anonymous";
        _userEmail = authState.User.FindFirst("preferred_username")?.Value ?? string.Empty;
        // Display name — try the standard "name" claim first, fall back
        // to email if the IdP didn't include one. Used by LandingGreeting
        // to extract a first name for "Good morning, X."
        _userName = authState.User.FindFirst("name")?.Value
                    ?? authState.User.Identity?.Name
                    ?? _userEmail;

        // Resolve the company from the URL segment. An invalid/unknown code
        // bounces back to the picker instead of rendering an empty dashboard.
        // Access check: admins see every company; non-admins need a row in
        // RPT_user_companies for this company. Both checks resolve via
        // UserManagementService's email-keyed access list so pre-provisioned
        // users work even before their first sign-in has bound user_id.
        CompanySummary? company = null;
        if (!string.IsNullOrEmpty(CompanyCode))
        {
            company = await CompanyRegistry.GetByCodeAsync(CompanyCode);
        }
        if (company is null)
        {
            Navigation.NavigateTo("/?all=1", replace: true);
            return;
        }

        var isAdmin = AdminService.IsAdmin(_userEmail);
        // Roles with any admin-section access (Administrator, System
        // Support, etc.) bypass the per-company grant check too — they
        // need to navigate into any company to do administrative work.
        // Same model as the picker; keeps the two surfaces consistent.
        var hasAdminAccess = isAdmin
            || await AdminAccess.HasAnyAdminAccessAsync(_userEmail);
        if (isAdmin)
        {
            // Sentinel role — admins bypass per-company grants entirely.
            // Used by UI gating to show every affordance regardless of role.
            _userRoleForCompany = UserRoles.Admin;
        }
        else if (hasAdminAccess)
        {
            // Section-scoped admin (System Support et al.). The user's
            // own role drives feature gating elsewhere; we don't elevate
            // them to UserRoles.Admin here. UI affordances that need
            // admin behavior should check AdminAccessService.CanAccess
            // for the specific section they care about.
            _userRoleForCompany = UserRoles.Editor;
        }
        // Per-company email override (RPT_user_companies.email). Falls back
        // to the auth/login email when the admin hasn't set an override.
        // Resolved in the same access-fetch the role check just did so we
        // don't burn a second round-trip; admins / admin-section users
        // skip the lookup if no grant exists and render under their login
        // email.
        string? activeEmail = _userEmail;
        if (!string.IsNullOrEmpty(_userEmail))
        {
            var access = await UserManagement.GetCompanyAccessAsync(_userEmail);
            var grant = access.FirstOrDefault(a => a.CompanyId == company.Id);
            if (!hasAdminAccess)
            {
                if (grant is null)
                {
                    // Route exists but the user has no grant — treat it the same
                    // as an unknown code: back to the picker. The picker's empty
                    // state handles the "no access anywhere" case.
                    Navigation.NavigateTo("/?all=1", replace: true);
                    return;
                }
                _userRoleForCompany = grant.Role;
                _accessibleCompanyCount = access.Count;
            }
            if (grant is not null && !string.IsNullOrWhiteSpace(grant.CompanyEmail))
                activeEmail = grant.CompanyEmail;

            // Resolve "does this user have any reports shared with
            // them right now?" — gates the Shared Reports header
            // button for viewer-role users so it disappears the
            // moment the last share is revoked. Quick query (one
            // join, indexed); cache invalidation is already wired
            // on the share create/delete and report mutation paths.
            try
            {
                var shares = await SharingService.GetSharedWithMeAsync(_userId);
                _hasAnyShares = shares.Count > 0;
            }
            catch
            {
                // Service hiccup shouldn't suppress the button on a
                // false negative — default to true so the user
                // always has a path to retry from the Library.
                _hasAnyShares = true;
            }
        }
        if (hasAdminAccess)
        {
            // Admins / admin-section users see every active company in the
            // picker; mirror that here so the back arrow stays available
            // unless there's literally only one company in the system.
            _accessibleCompanyCount = (await CompanyRegistry.GetActiveAsync()).Count;
        }

        _companyId = company.Id;
        _companyWebsiteUrl = company.WebsiteUrl;
        CurrentCompany.Set(company.Id, company.Code, company.Name, activeEmail);

        // Remember this as the user's last-visited company so /  auto-routes
        // them back here next time. Fire-and-forget: non-critical for render.
        if (!string.IsNullOrEmpty(_userEmail))
        {
            _ = UserManagement.SetLastVisitedCompanyAsync(_userEmail, company.Id);
        }

        // Header now reflects the active company — title = company name,
        // logo = company's uploaded logo. Falls back to per-user prefs when
        // the company has nothing uploaded yet, so a no-logo company still
        // renders something recognizable.
        var prefs = await PreferenceService.GetPreferencesAsync(_userId);

        // Greeting claim — only run the load + render path if this is
        // the first hosting page in the circuit. CompanyPicker may have
        // already claimed the slot if the user came from "All Companies."
        if (!GreetingState.HasShown)
        {
            GreetingState.HasShown = true;
            _showGreeting = true;
            // Capture the previous landing timestamp BEFORE bumping it —
            // the greeting reads the OLD value to compute "since your
            // last visit." Touch the new value asynchronously after
            // rendering so the user sees the delta on this page load and
            // the next visit reads from the now-updated row.
            _lastSeenUtc = prefs.LastMasterDashboardSeen;
            _updatedSinceLastVisit = await CountReportsUpdatedSinceAsync(_lastSeenUtc);
            // Fire-and-forget the touch — the bump only matters for the
            // NEXT visit, so we don't block this render on the round-
            // trip. Errors log silently; missing the bump means the next
            // visit's count will look stale, not a correctness issue.
            _ = PreferenceService.TouchLastMasterDashboardSeenAsync(_userId);
        }
        _dashboardTitle = company.Name;
        if (company.Logo is not null && company.Logo.Length > 0)
        {
            _logoBytes = company.Logo;
            _logoMimeType = company.LogoContentType;
        }
        else
        {
            _logoBytes = prefs.MasterDashboardLogo;
            _logoMimeType = prefs.MasterDashboardLogoType;
        }
        _logoDataUri = BuildLogoDataUri();

        // Keep the Report Library / Builder company filter in sync with the
        // dashboard the user just landed on. The design spec was: picking a
        // company anywhere in the app filters the rest of the session to it.
        // Only writes when the selection actually changed, to avoid clobbering
        // the updated_at timestamp on every navigation.
        if (prefs.ReportLibraryCompanyId != company.Id)
        {
            prefs.UserId = _userId;
            prefs.ReportLibraryCompanyId = company.Id;
            try { await PreferenceService.SavePreferencesAsync(prefs); }
            catch { /* non-fatal — the filter can be re-set manually */ }
        }

        await LoadTabs();
        await LoadFavoritesAsync();

        // Register the in-app navigation guard once init is past the
        // bulk of state setup, so an early bail-out above doesn't leak
        // a registered handler. Snapshot baseline AFTER the load so the
        // dashboard's own data isn't read as "dirty." IsDirty is also
        // gated on _editMode, so the baseline only matters once the
        // user enters edit mode (where MarkClean is called again).
        _navHandlerRegistration = Navigation.RegisterLocationChangingHandler(OnLocationChangingAsync);
        MarkClean();
        _initialized = true;
    }

    // Resolves the user's favorite-id list to live SavedReport rows so the
    // strip can render names + nav. Parallel by-id fetches; a missing id
    // (deleted / revoked) silently drops out so the strip never renders a
    // dead link. Re-called by ToggleFavoriteFromStripAsync after a remove
    // so the strip repaints without a full page reload.
    private async Task LoadFavoritesAsync()
    {
        try
        {
            var ids = await FavoriteSvc.GetReportIdsAsync(_userId);
            if (ids.Count == 0) { _favoriteReports = new(); return; }
            var tasks = ids.Select(id => ReportService.GetReportByIdAsync(id)).ToList();
            var rows = await Task.WhenAll(tasks);
            _favoriteReports = rows.Where(r => r is not null).Select(r => r!).ToList();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to load favorites for user {UserId} — strip will be empty.", _userId);
            _favoriteReports = new();
        }
    }

    private async Task UnfavoriteFromStripAsync(Guid reportId)
    {
        try
        {
            await FavoriteSvc.RemoveAsync(_userId, reportId);
            _favoriteReports = _favoriteReports.Where(r => r.Id != reportId).ToList();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Couldn't unfavorite: {ex.Message}", Severity.Warning);
        }
    }

    // Removes the greeting from this page after it slides up. The
    // once-per-circuit guarantee is enforced by GreetingState.HasShown,
    // which was set when we claimed the slot on init — that flag stays
    // true for the rest of the circuit so other hosting pages skip too.
    private void HandleGreetingDismissed()
    {
        _showGreeting = false;
        StateHasChanged();
    }

    // Counts reports in the active company whose UpdatedAt is more recent
    // than the supplied timestamp. Drives the LandingGreeting's "X reports
    // updated since your last visit" copy. Returns 0 on first visit
    // (sinceUtc is null) — the greeting suppresses the chip in that case
    // anyway. Scope-limited to the current company so non-admins don't
    // see counts that include cross-company reports they can't view.
    private async Task<int> CountReportsUpdatedSinceAsync(DateTime? sinceUtc)
    {
        if (sinceUtc is null) return 0;
        try
        {
            var all = await ReportService.GetAllReportsAsync();
            return all.Count(r => r.CompanyId == _companyId && r.UpdatedAt > sinceUtc.Value);
        }
        catch (Exception ex)
        {
            // Non-fatal — the greeting just hides the delta chip if we
            // can't compute it. Logged so a persistent failure shows up.
            Logger.LogWarning(ex, "Failed to compute updated-since-last-visit count.");
            return 0;
        }
    }

    private async Task LoadTabs()
    {
        _loading = true;
        try
        {
            _tabs = await MasterService.GetTabsAsync(_companyId);
            if (_tabs.Any())
            {
                _activeTabIndex = 0;
                await LoadTilesForActiveTab();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add(FriendlyError.FromException(ex, Logger, "loading dashboard"), Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadTilesForActiveTab()
    {
        var tab = ActiveTab;
        if (tab is null) { _tiles.Clear(); return; }

        try
        {
            // If we already have an in-memory snapshot for this tab (e.g. user is
            // toggling between tabs in edit mode), restore it instead of clobbering
            // their unsaved edits with a fresh DB fetch.
            if (_tilesByTab.TryGetValue(tab.Id, out var cachedTiles))
            {
                _tiles = cachedTiles;
            }
            else
            {
                _tiles = await MasterService.GetTilesAsync(_companyId, tab.Id);
            }
            // Sections track the same cached/fresh path as tiles so a tab
            // toggle in edit mode doesn't discard pending section edits or
            // burn an extra round-trip when the user already loaded them.
            if (_sectionsByTab.TryGetValue(tab.Id, out var cachedSections))
            {
                _sections = cachedSections;
            }
            else
            {
                _sections = await MasterService.GetSectionsAsync(tab.Id);
            }
            // Default the section-tab strip to the first real section (or 0
            // for the "(no section)" tab when none exist). Wrapped so any
            // future cross-call mutation can re-use the same fallback rules.
            _activeSectionId = ResolveDefaultActiveSectionId();
            _pendingRemovals = _pendingRemovalsByTab.TryGetValue(tab.Id, out var cachedRemovals)
                ? cachedRemovals
                : new List<MasterDashboardTile>();

            await LoadActiveSectionTiles();
        }
        catch (Exception ex)
        {
            Snackbar.Add(FriendlyError.FromException(ex, Logger, "loading dashboard tiles"), Severity.Error);
        }
    }

    // Fires queries for the tiles in the currently-active section. Lazy at
    // the section level — sections the admin doesn't visit don't pay any
    // cost. Always re-fetches on every entry rather than caching, so the
    // dashboard always shows live data; section switches re-run the
    // section's queries (cheap when each query is sub-second).
    private async Task LoadActiveSectionTiles()
    {
        var tab = ActiveTab;
        if (tab is null) return;

        var targetTiles = _sections.Count == 0
            ? _tiles.ToList()
            : _tiles.Where(t => (t.SectionId ?? 0) == _activeSectionId).ToList();
        if (targetTiles.Count == 0) return;

        await LoadTileDataFor(targetTiles);
    }

    private async Task OnTabChanged(int index)
    {
        // Snapshot the outgoing tab's in-memory tiles + pending removals so we can
        // restore them when the user comes back. Without this, switching tabs in
        // edit mode would lose alignment / resize / removal edits.
        var outgoing = ActiveTab;
        if (outgoing is not null)
        {
            _tilesByTab[outgoing.Id] = _tiles;
            _sectionsByTab[outgoing.Id] = _sections;
            _pendingRemovalsByTab[outgoing.Id] = _pendingRemovals;
        }
        _activeTabIndex = index;
        await LoadTilesForActiveTab();
    }

    // Loads tile data for a specific subset of tiles. Does NOT clear
    // _tileData — preserves entries for tiles outside the target subset
    // (e.g. tiles in another tab still in memory). Existing entries
    // for tiles in the target subset are overwritten as their fresh
    // results land.
    private async Task LoadTileDataFor(IList<MasterDashboardTile> targetTiles)
    {
        if (targetTiles.Count == 0) return;

        // Drop any prior loading/error/failure markers for these specific
        // tiles so a stale spinner from an earlier eviction doesn't stick.
        foreach (var tile in targetTiles)
        {
            _tileErrors.Remove(tile.ReportId);
            _tileFailedQuery.Remove(tile.ReportId);
            _tileLoading.Add(tile.ReportId);
        }
        StateHasChanged();

        // Collect results from parallel tasks, then merge into _tileData on the
        // main thread. Dictionary/HashSet are not thread-safe; direct concurrent
        // mutation was a race condition.
        var results = await Task.WhenAll(targetTiles.Select(async tile =>
        {
            try
            {
                var (result, failure) = await LoadReportDashboard(tile.ReportId);
                return (tile.ReportId, result, failure, (string?)null);
            }
            catch (Exception ex)
            {
                // Pre-execute failure (report not found, template fetch
                // failed, etc.). No request was even built — only an error
                // string to show. Right-click on these tiles falls through
                // to the "couldn't generate SQL" branch in ShowTileQuery.
                return (tile.ReportId, (TileLoadResult?)null, (FailedTileQuery?)null, (string?)ex.Message);
            }
        }));

        foreach (var (reportId, result, failure, error) in results)
        {
            if (result is not null)
            {
                _tileData[reportId] = result;
                _tileLoadedAtUtc[reportId] = DateTime.UtcNow;
            }
            if (failure is not null)
            {
                _tileErrors[reportId] = failure.Error;
                _tileFailedQuery[reportId] = failure;
                _tileLoadedAtUtc.Remove(reportId);
            }
            else if (error is not null)
            {
                _tileErrors[reportId] = error;
                _tileLoadedAtUtc.Remove(reportId);
            }
            _tileLoading.Remove(reportId);
        }
        StateHasChanged();
    }

    private async Task<(TileLoadResult? Result, FailedTileQuery? Failure)> LoadReportDashboard(Guid reportId)
    {
        // Shared-per-company dashboard (Phase 3): the tile's presence on this
        // company's dashboard *is* the authorization signal. The page-level
        // access check in OnInitializedAsync has already verified the user
        // can view the company, so we fetch the report directly without
        // owner/share scoping — otherwise Viewers and Editors who don't own
        // the report and don't have a share record get "Failed to load" on
        // every tile.
        var report = await ReportService.GetReportByIdAsync(reportId);
        if (report is null) return (null, null);

        // Resolve fields from a linked grid template if present, otherwise
        // fall back to the report's saved FieldIds. Template hidden-column
        // list is also captured here for the merged-hidden union below.
        var fieldIds = new List<string>();
        List<string>? templateHiddenColumns = null;
        Dictionary<string, string>? templateColumnLabels = null;
        if (report.GridTemplateId.HasValue)
        {
            var resolved = await GridTemplateService.ResolveTemplateAsync(report.GridTemplateId);
            if (resolved is not null)
            {
                fieldIds = resolved.FieldIds;
                templateHiddenColumns = resolved.HiddenColumns;
                templateColumnLabels = resolved.CustomColumnLabels;
            }
        }
        else if (!string.IsNullOrWhiteSpace(report.FieldIds))
        {
            fieldIds = System.Text.Json.JsonSerializer.Deserialize<List<string>>(report.FieldIds) ?? new();
        }
        if (!fieldIds.Any()) return (null, null);

        // Pull the bits the tile renderer needs from column_state — these
        // are NOT QueryRequest knobs so the factory doesn't surface them:
        //   • DashboardConfig — the tile UI's chart/group/dimension config
        //   • reportHiddenColumns — merged with template hidden below
        //   • tableCalcColumns — passed to the rendered tile so calc-column
        //     captions resolve and group-by lists include calc keys
        DashboardView.DashboardConfig? config = null;
        List<string>? reportHiddenColumns = null;
        List<TleReportingDashboard.Web.Models.TableCalcColumnDef>? tableCalcColumns = null;
        if (!string.IsNullOrWhiteSpace(report.ColumnState))
        {
            try
            {
                config = System.Text.Json.JsonSerializer.Deserialize<DashboardView.DashboardConfig>(
                    report.ColumnState, new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                using var doc = System.Text.Json.JsonDocument.Parse(report.ColumnState);
                if (doc.RootElement.TryGetProperty("HiddenColumns", out var hcEl))
                    reportHiddenColumns = System.Text.Json.JsonSerializer.Deserialize<List<string>>(hcEl.GetRawText());
                if (doc.RootElement.TryGetProperty("TableCalculatedColumns", out var tcEl))
                {
                    tableCalcColumns = System.Text.Json.JsonSerializer
                        .Deserialize<List<TleReportingDashboard.Web.Models.TableCalcColumnDef>>(tcEl.GetRawText());
                }
            }
            catch { }
        }

        // Pre-fetch PK columns of the report's primary table so QueryBuilder
        // can append them as silent tiebreakers for OFFSET stability — same
        // mechanism the editor uses. Best-effort: if the lookup fails (no
        // PK, locked-down account, parse failure) we ship null and fall
        // through to the legacy "first selected field" anchor.
        List<string>? pkColumns = null;
        if (!string.IsNullOrWhiteSpace(report.PrimaryTable))
        {
            try
            {
                var bare = report.PrimaryTable;
                var asIdx = bare.IndexOf(" AS ", StringComparison.OrdinalIgnoreCase);
                if (asIdx > 0) bare = bare[..asIdx].Trim();
                var dot = bare.IndexOf('.');
                string? schema = dot > 0 ? bare[..dot] : null;
                var table = dot > 0 ? bare[(dot + 1)..] : bare;
                // Effective lookup folds in admin-flagged IsUnique fields,
                // so accounts that can't read information_schema still get
                // a stable OFFSET tiebreaker.
                var schemaFields = await SchemaService.GetFieldConfigsAsync(report.ConnectionId);
                pkColumns = await SchemaBrowser.GetEffectivePrimaryKeyColumnsAsync(report.ConnectionId, schema, table, schemaFields);
            }
            catch { pkColumns = null; }
        }

        // Single source of truth for "QueryRequest from a SavedReport".
        // Same factory the Worker, Report Viewer, and Detail Viewer use —
        // every saved knob (filters with JsonElement unwrap, advanced
        // filters, sort priority chain, distinct, calc SQL, etc.) lands
        // automatically.
        var request = TleReportingDashboard.Web.Services.QueryRequestFactory
            .FromSavedReport(report, pageSize: 50000, fallbackSortColumns: pkColumns);

        // Per-surface overrides:
        //  • FieldIds — splice in the dashboard's ExtraGroupBy / ExtraDimension
        //    fields (a per-render concern, not a saved-report knob), and use
        //    the template-resolved set when one is linked.
        //  • AdvancedFilters — gated by Features:AdvancedFilters so an
        //    appsettings rollback also takes effect on the Master Dashboard.
        void AddExtraIds(IEnumerable<string>? ids)
        {
            if (ids is null) return;
            foreach (var extra in ids)
                if (!fieldIds.Contains(extra, StringComparer.OrdinalIgnoreCase))
                    fieldIds.Add(extra);
        }
        AddExtraIds(config?.ExtraGroupByFieldIds);
        AddExtraIds(config?.ExtraDimensionFieldIds);
        request.FieldIds = fieldIds;

        if (!Config.GetValue<bool>("Features:AdvancedFilters", false))
            request.AdvancedFilters = null;

        request.Scoping = await ScopeResolver.ResolveAsync(_userEmail, report.ConnectionId, report.PrimaryTable);

        // Union template-level and report-level hidden column lists so a
        // field marked hidden on the template is honored everywhere,
        // regardless of the individual report's saved override. Matches
        // the fix in ReportViewer + DetailViewer.
        var mergedHidden = ((templateHiddenColumns ?? new List<string>())
            .Union(reportHiddenColumns ?? new List<string>(), StringComparer.OrdinalIgnoreCase))
            .ToList();

        try
        {
            var data = await QueryService.ExecuteQueryAsync(request);
            return (new TileLoadResult(data, config, mergedHidden.Count > 0 ? mergedHidden : null, tableCalcColumns, templateColumnLabels), null);
        }
        catch (Exception ex)
        {
            // Execute failed (most often the source DB rejected the SQL).
            // Recover the SQL via the build-only path so the right-click
            // "Show query" dialog can still display what was attempted —
            // otherwise admins debugging a broken tile have no way to see
            // the generated SQL without tailing logs.
            try
            {
                var (sql, parameters) = await QueryService.BuildSqlAsync(request);
                return (null, new FailedTileQuery(
                    sql, parameters,
                    request.Scoping?.Reason,
                    request.Scoping?.ForceNoMatch == true,
                    ex.Message));
            }
            catch (Exception buildEx)
            {
                // Build phase also failed. No SQL to show — surface the
                // build error alongside the original execute error so the
                // dialog explains why both paths gave up.
                return (null, new FailedTileQuery(
                    string.Empty, new(),
                    request.Scoping?.Reason,
                    request.Scoping?.ForceNoMatch == true,
                    $"{ex.Message}\n\n(SQL couldn't be regenerated: {buildEx.Message})"));
            }
        }
    }

    // ── Tab management ──

    private async Task AddTab()
    {
        try
        {
            // Snapshot the outgoing tab's in-memory edits before switching focus.
            // Mirror OnTabChanged exactly — sections must be snapshotted too,
            // otherwise the new (empty) tab inherits the previous tab's
            // section bar visually until something forces a reload.
            var outgoing = ActiveTab;
            if (outgoing is not null)
            {
                _tilesByTab[outgoing.Id] = _tiles;
                _sectionsByTab[outgoing.Id] = _sections;
                _pendingRemovalsByTab[outgoing.Id] = _pendingRemovals;
            }
            var tab = await MasterService.AddTabAsync(_companyId, $"Tab {_tabs.Count + 1}", _userEmail);
            _tabs.Add(tab);
            _activeTabIndex = _tabs.Count - 1;
            _editMode = true;
            // Reset every per-tab collection for the brand-new tab —
            // tiles, sections, pending removals, active section. Without
            // resetting sections, the new tab still renders the previous
            // tab's section strip and the active-section pointer (stale
            // section id from the outgoing tab) makes the tile visibility
            // filter hide everything.
            _tiles = new List<MasterDashboardTile>();
            _sections = new List<MasterDashboardSection>();
            _pendingRemovals = new List<MasterDashboardTile>();
            _activeSectionId = ResolveDefaultActiveSectionId();
            StateHasChanged();
            await RenameTab(tab);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to add tab: {ex.Message}", Severity.Error);
        }
    }

    private async Task RenameTab(MasterDashboardTab tab)
    {
        var newName = await JS.InvokeAsync<string>("prompt", "Enter a new name for this tab:", tab.Label);
        if (!string.IsNullOrWhiteSpace(newName))
        {
            tab.Label = newName;
            StateHasChanged();
        }
    }

    private async Task RemoveTab(MasterDashboardTab tab)
    {
        if (_tabs.Count <= 1) return;
        try
        {
            await MasterService.RemoveTabAsync(tab.Id, _userEmail);
            _tabs.Remove(tab);
            _activeTabIndex = Math.Min(_activeTabIndex, _tabs.Count - 1);
            await LoadTilesForActiveTab();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to remove tab: {ex.Message}", Severity.Error);
        }
    }

    // ── Section management ──
    // Mirror of the tab CRUD pattern but scoped to the active tab. Section
    // drag state is independent from tile drag state (_dragSource/_dropTarget)
    // so the two interaction surfaces don't interfere.

    private int _sectionDragSource = -1;

    // Index of the tab whose drag-handle the user grabbed. Mirrors the
    // section drag-source pattern but for the top-level tab strip.
    // -1 means "no tab is being dragged." OnTabStripDrop dispatches to
    // OnTabDrop when this is set, separately from section / tile drag
    // sources so the three flavors don't interfere.
    private int _tabDragSource = -1;

    // First real section's id, falling back to 0 (= "(no section)") when
    // none exist. Used on tab load and after section deletes / moves.
    private int ResolveDefaultActiveSectionId() =>
        _sections.Count > 0 ? _sections[0].Id : 0;

    // Setter used by the section-tab click handlers — keeps the underlying
    // field private so future hooks (per-section preference persistence,
    // animation, etc.) have a single point to plug into.
    private async Task SetActiveSection(int sectionKey)
    {
        if (_activeSectionId == sectionKey) return;
        _activeSectionId = sectionKey;
        StateHasChanged();

        // Re-fetch the new section's tiles every time. Sections the admin
        // doesn't visit don't pay any cost (lazy); sections they do visit
        // always show live data (no caching across switches).
        if (ActiveTab is not null)
            await LoadActiveSectionTiles();
    }

    // Unified drop-target index for section headers. -1 = none.
    // -2 = the "(no section)" pseudo-header. Otherwise = index into
    // _sections. Used for both flavors of drag: section reorder
    // (existing) and tile-onto-header assignment (V2-3 / V2-6).
    private int _headerDropTargetIdx = -1;

    private async Task AddSection()
    {
        var tab = ActiveTab;
        if (tab is null) return;
        // Defense-in-depth: server enforces the same cap and will throw,
        // but stopping here keeps the snackbar UX consistent with other
        // client-side guard rails on this page.
        if (_sections.Count >= IMasterDashboardService.MaxSectionsPerTab)
        {
            Snackbar.Add(
                $"Maximum of {IMasterDashboardService.MaxSectionsPerTab} sections per tab reached.",
                Severity.Warning);
            return;
        }
        var label = await JS.InvokeAsync<string>("prompt", "Enter a name for the section:", $"Section {_sections.Count + 1}");
        if (string.IsNullOrWhiteSpace(label)) return;
        try
        {
            var section = await MasterService.AddSectionAsync(tab.Id, label.Trim(), _userEmail);
            _sections.Add(section);
            // Auto-switch the section-tab strip onto the new section so the
            // admin can immediately drop tiles into it / rename / etc.
            _activeSectionId = section.Id;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to add section: {ex.Message}", Severity.Error);
        }
    }

    private async Task SetSectionAlign(MasterDashboardSection section, string align)
    {
        if (string.Equals(section.TitleAlign, align, StringComparison.OrdinalIgnoreCase)) return;
        var previous = section.TitleAlign;
        section.TitleAlign = align;
        StateHasChanged();
        try
        {
            await MasterService.SetSectionAlignAsync(section.Id, align, _userEmail);
        }
        catch (Exception ex)
        {
            // Server rejected — revert the optimistic UI change so the
            // toolbar's checked button matches what's actually persisted.
            section.TitleAlign = previous;
            Snackbar.Add($"Failed to set section alignment: {ex.Message}", Severity.Error);
            StateHasChanged();
        }
    }

    private async Task RenameSection(MasterDashboardSection section)
    {
        var newName = await JS.InvokeAsync<string>("prompt", "Enter a new name for this section:", section.Label);
        if (string.IsNullOrWhiteSpace(newName) || newName.Trim() == section.Label) return;
        try
        {
            await MasterService.RenameSectionAsync(section.Id, newName.Trim(), _userEmail);
            section.Label = newName.Trim();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to rename section: {ex.Message}", Severity.Error);
        }
    }

    private async Task RemoveSection(MasterDashboardSection section)
    {
        var ok = await JS.InvokeAsync<bool>("confirm",
            $"Remove section \"{section.Label}\"? Tiles in this section will move to the \"(no section)\" group.");
        if (!ok) return;
        try
        {
            await MasterService.RemoveSectionAsync(section.Id, _userEmail);
            _sections.Remove(section);
            // Server cleared section_id on every tile that referenced this
            // section. Mirror that locally so the next render groups them
            // under "(no section)" without a refetch.
            foreach (var t in _tiles)
                if (t.SectionId == section.Id) t.SectionId = null;
            // If the deleted section was the active one, fall back to the
            // first remaining real section, or to "(no section)" (key = 0)
            // — which is what the orphaned tiles surface under, so the
            // admin sees them right where they landed.
            if (_activeSectionId == section.Id)
            {
                _activeSectionId = _sections.Count > 0 ? _sections[0].Id : 0;
            }
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to remove section: {ex.Message}", Severity.Error);
        }
    }

    // Unified drop handler for section headers. Branches based on which
    // drag flavor is currently active:
    //   • Section drag → delegate to OnSectionDrop (existing reorder).
    //   • Tile drag    → reassign the dragged tile's SectionId (or NULL
    //                    when dropped on the "(no section)" header).
    // Mutually exclusive in practice — tile and section drags can't run
    // concurrently because each starts only when its own drag handle is
    // grabbed. Resets _headerDropTargetIdx in all paths so a stale glow
    // doesn't linger on the next render.
    private async Task OnHeaderDrop(MasterDashboardSection? targetSection)
    {
        _headerDropTargetIdx = -1;
        if (_sectionDragSource >= 0 && targetSection is not null)
        {
            await OnSectionDrop(_sections.IndexOf(targetSection));
            return;
        }
        if (_dragSource >= 0 && _dragSource < _tiles.Count)
        {
            var tile = _tiles[_dragSource];
            var newSectionId = targetSection?.Id;
            _dragSource = -1;
            _dropTarget = -1;
            _dropTargetTabId = 0;
            await MoveTileToSection(tile, newSectionId);
        }
    }

    private async Task OnSectionDrop(int targetIndex)
    {
        if (_sectionDragSource < 0 || _sectionDragSource == targetIndex)
        {
            _sectionDragSource = -1;
            _headerDropTargetIdx = -1;
            return;
        }
        // Drop semantic: dragging RIGHT/DOWN drops AFTER the target section;
        // dragging LEFT/UP drops BEFORE. Both collapse to "insert at the
        // target's pre-removal index" — same reasoning as OnTileDrop. The
        // earlier `targetIndex - 1` adjustment made dropping on the last
        // section land the source second-to-last.
        var item = _sections[_sectionDragSource];
        _sections.RemoveAt(_sectionDragSource);
        var insertAt = Math.Clamp(targetIndex, 0, _sections.Count);
        _sections.Insert(insertAt, item);
        for (var i = 0; i < _sections.Count; i++) _sections[i].SortOrder = i;
        _sectionDragSource = -1;
        _headerDropTargetIdx = -1;
        try
        {
            await MasterService.UpdateSectionOrderAsync(_sections, _userEmail);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to save section order: {ex.Message}", Severity.Error);
        }
    }

    // ── Tile management ──

    private async Task OpenAddDialog()
    {
        var tab = ActiveTab;
        if (tab is null) return;

        List<SavedReport> available;
        Dictionary<Guid, List<string>> placedMap;
        try
        {
            available = await MasterService.GetAvailableReportsAsync(_companyId);
            // Reports placed on ANY of the user's tabs (not just the active
            // one) — prevents the same report from being pinned twice across
            // tabs. _tiles here would only give us current-tab state.
            placedMap = await MasterService.GetPlacedReportTabsAsync(_companyId);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load reports: {ex.Message}", Severity.Error);
            return;
        }

        var totalEligible = available.Count;
        var existingIds = placedMap.Keys.ToHashSet();
        available = available.Where(r => !existingIds.Contains(r.Id)).ToList();

        if (!available.Any())
        {
            // Distinguish "nothing marked ShowOnMaster" from "everything eligible
            // is already placed somewhere" so the admin knows what to do next.
            var msg = totalEligible == 0
                ? "No reports available. Enable 'Show on Master Dashboard' in a report's dashboard editor first."
                : "Every eligible report is already placed on one of your dashboard tabs.";
            Snackbar.Add(msg, Severity.Info);
            return;
        }

        var parameters = new DialogParameters
        {
            { "Reports", available },
            { "Sections", _sections }
        };
        var dialog = await DialogService.ShowAsync<AddTileDialog>("Add Report to Dashboard", parameters,
            new DialogOptions
            {
                MaxWidth = MaxWidth.Small,
                FullWidth = true,
                BackdropClick = false,
                CloseOnEscapeKey = false
            });

        var result = await dialog.Result;
        if (result is null || result.Canceled || result.Data is not AddTileDialog.AddTileResult tileResult) return;
        var reportId = tileResult.ReportId;

        try
        {
            await MasterService.AddTileAsync(_companyId, tab.Id, reportId, _userEmail, sectionId: tileResult.SectionId);

            var allTiles = await MasterService.GetTilesAsync(_companyId, tab.Id);
            var newTile = allTiles.FirstOrDefault(t => t.ReportId == reportId);
            if (newTile is not null)
            {
                _tiles.Add(newTile);
                try
                {
                    var (td, failure) = await LoadReportDashboard(newTile.ReportId);
                    if (td is not null) _tileData[newTile.ReportId] = td;
                    if (failure is not null)
                    {
                        _tileErrors[newTile.ReportId] = failure.Error;
                        _tileFailedQuery[newTile.ReportId] = failure;
                    }
                }
                catch { }
            }

            _editMode = true;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to add: {ex.Message}", Severity.Error);
        }
    }

    private void ToggleChart(int tileId)
    {
        if (!_chartVisibleTiles.Remove(tileId))
            _chartVisibleTiles.Add(tileId);
    }

    private async Task ToggleEditMode()
    {
        if (_editMode)
        {
            // Leaving edit mode discards unsaved per-tab edits — drop the snapshots
            // and reload the active tab from DB so the user sees persisted state.
            var hadDirtyState = _pendingRemovals.Any() || _pendingRemovalsByTab.Any() || _tilesByTab.Any();
            _pendingRemovals.Clear();
            _pendingRemovalsByTab.Clear();
            _tilesByTab.Clear();
            if (hadDirtyState)
                await LoadTilesForActiveTab();
            _editMode = false;
            // Discarding edits returns the page to a clean (viewing) state
            // — IsDirty would short-circuit on _editMode anyway, but keep
            // the snapshot in sync for clarity / consistency.
            MarkClean();
        }
        else
        {
            _editMode = true;
            // Baseline matches the current state at the moment editing
            // begins — anything mutated from here is "dirty."
            MarkClean();
        }
    }

    private void RemoveTile(MasterDashboardTile tile)
    {
        _tiles.Remove(tile);
        _pendingRemovals.Add(tile);
        _tileData.Remove(tile.ReportId);
        _tileLoadedAtUtc.Remove(tile.ReportId);
        Snackbar.Add($"{tile.ReportName} marked for removal. Click Save Layout to confirm.", Severity.Warning);
    }

    private async Task SaveLayout()
    {
        for (var i = 0; i < _tiles.Count; i++)
            _tiles[i].SortOrder = i;

        try
        {
            // Snapshot the currently-active tab's tiles into the cache so the save
            // loop below sees its edits alongside any cached tabs the user visited.
            var activeNow = ActiveTab;
            if (activeNow is not null)
            {
                _tilesByTab[activeNow.Id] = _tiles;
                _pendingRemovalsByTab[activeNow.Id] = _pendingRemovals;
            }

            // Delete removed tiles across all edited tabs
            foreach (var removalList in _pendingRemovalsByTab.Values)
                foreach (var tile in removalList)
                    await MasterService.RemoveTileAsync(tile.Id, _userEmail);
            _pendingRemovalsByTab.Clear();
            _pendingRemovals.Clear();

            // Update tiles for every tab the user touched in this session
            foreach (var tabTiles in _tilesByTab.Values)
            {
                // Keep sort order in sync with current list position
                for (var i = 0; i < tabTiles.Count; i++)
                    tabTiles[i].SortOrder = i;
                await MasterService.UpdateLayoutAsync(tabTiles, _userEmail);
            }
            _tilesByTab.Clear();

            // Update tab labels and order
            for (var i = 0; i < _tabs.Count; i++)
                _tabs[i].SortOrder = i;
            await MasterService.UpdateTabOrderAsync(_tabs, _userEmail);

            // Persist the logo upload (still user-scoped fallback for now —
            // Phase 3 will route logo uploads to RPT_companies instead so
            // every user sees the same company branding). Title is no
            // longer editable here, so we don't write it back.
            var prefs = await PreferenceService.GetPreferencesAsync(_userId);
            prefs.MasterDashboardLogo = _logoBytes;
            prefs.MasterDashboardLogoType = _logoMimeType;
            await PreferenceService.SavePreferencesAsync(prefs);

            // Save was the explicit clean point — re-baseline so the
            // next navigation away (without further edits) doesn't
            // re-prompt over the just-saved state. The user remains
            // in edit mode after Save Layout, so this only takes
            // effect for subsequent edits.
            MarkClean();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to save: {ex.Message}", Severity.Error);
        }
    }

    private async Task OnLogoUploaded(IBrowserFile file)
    {
        try
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 2 * 1024 * 1024); // 2MB max
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            _logoBytes = ms.ToArray();
            _logoMimeType = file.ContentType;
            _logoDataUri = BuildLogoDataUri();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to upload logo: {ex.Message}", Severity.Error);
        }
    }

    private void RemoveLogo()
    {
        _logoBytes = null;
        _logoMimeType = null;
        _logoDataUri = null;
    }

    private string? BuildLogoDataUri()
    {
        if (_logoBytes is null || _logoBytes.Length == 0) return null;
        var mime = _logoMimeType ?? "image/png";
        return $"data:{mime};base64,{Convert.ToBase64String(_logoBytes)}";
    }

    private void SetTileAlign(MasterDashboardTile tile, string align)
    {
        // Per-tile alignment. Persisted on Save Layout via UpdateLayoutAsync.
        tile.TitleAlign = align;
    }

    // Move a tile into a different section (or to "(no section)" when
    // sectionId is null). Persists immediately — unlike align/resize which
    // wait for Save Layout — because the tile visually jumps to a new
    // group, and a half-applied state would be confusing if the admin
    // toggles edit mode without saving.
    private async Task MoveTileToSection(MasterDashboardTile tile, int? sectionId)
    {
        if (tile.SectionId == sectionId) return;
        try
        {
            await MasterService.MoveTileToSectionAsync(tile.Id, sectionId, _userEmail);
            tile.SectionId = sectionId;
            // Follow the tile to its new home so the admin sees the move
            // confirmed visually. Without this auto-switch the tile would
            // just disappear from the active section's view (since only
            // one section's tiles render at a time), which feels like a
            // bug even when it's working correctly.
            _activeSectionId = sectionId ?? 0;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to move tile: {ex.Message}", Severity.Error);
        }
    }

    private async Task OnTileDrop(int targetIndex)
    {
        if (_dragSource < 0 || _dragSource == targetIndex)
        {
            _dragSource = -1; _dropTarget = -1; _dropTargetTabId = 0;
            return;
        }

        // Cross-section drag: when the source and target tiles live in
        // different sections, the source's SectionId follows the target's
        // BEFORE the local reorder. Persist immediately via the service
        // (sort_order is still pending until Save Layout — matches the
        // existing edit-mode pattern where structural changes are saved
        // as they happen but visual ordering waits for the button).
        var sourceTile = _tiles[_dragSource];
        var targetTile = targetIndex < _tiles.Count ? _tiles[targetIndex] : null;
        if (targetTile is not null && sourceTile.SectionId != targetTile.SectionId)
        {
            try
            {
                await MasterService.MoveTileToSectionAsync(sourceTile.Id, targetTile.SectionId, _userEmail);
                sourceTile.SectionId = targetTile.SectionId;
                // Match MoveTileToSection's behavior — follow the tile so
                // the admin sees the result of their drag.
                _activeSectionId = targetTile.SectionId ?? 0;
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Failed to move tile across sections: {ex.Message}", Severity.Error);
                _dragSource = -1; _dropTarget = -1; _dropTargetTabId = 0;
                return;
            }
        }

        _tiles.RemoveAt(_dragSource);
        // Drop semantic: dragging RIGHT/DOWN drops AFTER the target tile;
        // dragging LEFT/UP drops BEFORE. Both collapse to "insert at the
        // target's pre-removal index" — the RemoveAt above already
        // shifted everything past the source down by 1, which produces
        // the "after target" position naturally for forward drags. The
        // earlier `targetIndex - 1` over-correction made dropping on the
        // last tile land the source second-to-last, with the previous
        // last tile bumping back into place.
        var insertAt = Math.Clamp(targetIndex, 0, _tiles.Count);
        _tiles.Insert(insertAt, sourceTile);
        _dragSource = -1; _dropTarget = -1; _dropTargetTabId = 0;
    }

    // Unified tab-strip drop handler. The tab header accepts both flavors
    // of drag: a tile (existing behavior — moves the single tile) or a
    // section (V2-5 — moves the section AND every tile under it). Branch
    // based on which drag source is active.
    private async Task OnTabStripDrop(int targetTabId)
    {
        if (_tabDragSource >= 0)
        {
            await OnTabDrop(targetTabId);
            return;
        }
        if (_dragSource >= 0)
        {
            await OnTileDropOnTab(targetTabId);
            return;
        }
        // _sectionDragSource is intentionally not handled here — sections
        // can be reordered within their tab but cannot be moved to a
        // different tab. The predicate on the tab @ondragover excludes
        // section drags from highlighting the drop zone, and dropping
        // a section here is a no-op that just clears the highlight.
        _sectionDragSource = -1;
        _dropTargetTabId = 0;
    }

    // Tab reorder. Source is _tabDragSource (set by the drag handle in
    // edit mode); target is the tab the user dropped onto. Move the
    // dragged tab to the target's slot, recompute SortOrder, and
    // persist immediately so the order sticks even if the user closes
    // the browser before clicking Done Editing. Active-tab tracking
    // is by id through the move so the user stays on the same tab
    // they were viewing.
    private async Task OnTabDrop(int targetTabId)
    {
        var sourceIdx = _tabDragSource;
        _tabDragSource = -1;
        _dropTargetTabId = 0;

        if (sourceIdx < 0 || sourceIdx >= _tabs.Count) return;
        var targetIdx = _tabs.FindIndex(x => x.Id == targetTabId);
        if (targetIdx < 0 || targetIdx == sourceIdx) return;

        // Track the currently-active tab by id so we can re-resolve its
        // index after the reorder. Without this, dragging a tab past
        // the active one would silently switch the user to a different
        // panel.
        var activeTabId = ActiveTab?.Id;

        // Drop semantic — same as OnSectionDrop / OnTileDrop:
        // dragging RIGHT drops AFTER the target, dragging LEFT drops
        // BEFORE. Both collapse to "remove source, then insert at the
        // target's *pre-removal* index" — which after removal lands
        // the moved item in the visually-correct slot for either
        // direction. An earlier "-1" adjustment in this codebase
        // made right-drag-onto-last-tab land second-to-last instead
        // of last; don't reintroduce it.
        var moved = _tabs[sourceIdx];
        _tabs.RemoveAt(sourceIdx);
        var insertAt = Math.Clamp(targetIdx, 0, _tabs.Count);
        _tabs.Insert(insertAt, moved);
        for (var i = 0; i < _tabs.Count; i++) _tabs[i].SortOrder = i;

        if (activeTabId is int aid)
        {
            var newActive = _tabs.FindIndex(x => x.Id == aid);
            if (newActive >= 0) _activeTabIndex = newActive;
        }

        try
        {
            await MasterService.UpdateTabOrderAsync(_tabs, _userEmail);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to save tab order: {ex.Message}", Severity.Error);
        }
    }

    // Cross-tab move. Fired when the user drags a tile over a tab header
    // (not the active one) and releases. Updates the DB via the service,
    // removes the tile from the local list for the current tab, and
    // resets all drag state. No tab switch — the user stays where they
    // are; the tile is just gone from this view.
    private async Task OnTileDropOnTab(int targetTabId)
    {
        var activeId = ActiveTab?.Id ?? 0;
        // Snapshot the drag-source index before we clear state; async
        // handlers can re-enter after any await.
        var sourceIdx = _dragSource;
        _dragSource = -1; _dropTarget = -1; _dropTargetTabId = 0;

        if (sourceIdx < 0 || sourceIdx >= _tiles.Count) return;
        if (targetTabId == activeId) return;

        var tile = _tiles[sourceIdx];
        try
        {
            await MasterService.MoveTileToTabAsync(tile.Id, targetTabId, _userEmail);
            _tiles.RemoveAt(sourceIdx);
            _tileData.Remove(tile.ReportId);
            _tileLoadedAtUtc.Remove(tile.ReportId);
            var targetLabel = _tabs.FirstOrDefault(x => x.Id == targetTabId)?.Label ?? "another tab";
            Snackbar.Add($"Moved \"{tile.ReportName}\" to {targetLabel}.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to move tile: {ex.Message}", Severity.Error);
        }
    }

    // ── Tile export (matches Detail Viewer's "All Records" export) ──
    // Tiles render aggregated views (group-by, chart, totals); admins
    // periodically want the underlying detail rows out as a file. Same
    // dropdown affordance as the Detail Viewer, same export pipeline,
    // same filename shape. The data is whatever the tile already
    // fetched — no extra round-trip — minus any columns the admin
    // chose to hide on the dashboard config.
    private async Task ExportTileDetailExcel(MasterDashboardTile tile)
    {
        if (!_tileData.TryGetValue(tile.ReportId, out var td)) return;
        var data = BuildTileExportData(td);
        var name = tile.ReportName ?? "Report";
        var bytes = ExportService.ExportToExcel(data, name);
        await JS.InvokeVoidAsync("downloadFile",
            BuildTileExportFileName(tile, "xlsx"),
            Convert.ToBase64String(bytes),
            "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
    }

    private async Task ExportTileDetailCsv(MasterDashboardTile tile)
    {
        if (!_tileData.TryGetValue(tile.ReportId, out var td)) return;
        var data = BuildTileExportData(td);
        var bytes = ExportService.ExportToCsv(data);
        await JS.InvokeVoidAsync("downloadFile",
            BuildTileExportFileName(tile, "csv"),
            Convert.ToBase64String(bytes),
            "text/csv");
    }

    private async Task ExportTileDetailPdf(MasterDashboardTile tile)
    {
        if (!_tileData.TryGetValue(tile.ReportId, out var td)) return;
        var data = BuildTileExportData(td);
        var name = tile.ReportName ?? "Report";
