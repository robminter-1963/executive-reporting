@page "/viewer/{ReportId:guid}/detail"
@rendermode InteractiveServer
@inject IReportService ReportService
@inject ISharingService SharingService
@inject IQueryService QueryService
@inject IGridTemplateService GridTemplateService
@inject IExportService ExportService
@inject ISchemaService SchemaService
@inject IUserPreferenceService PreferenceService
@inject IAdminService AdminService
@inject IAdminAccessService AdminAccess
@inject IUserManagementService UserManagement
@inject IQueryScopeResolver ScopeResolver
@inject SchemaBuilderService SchemaBrowser
@inject AuthenticationStateProvider AuthStateProvider
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IJSRuntime JS
@inject IConfiguration Config
@inject ICompanyRegistry CompanyRegistry
@inject IColumnWidthDefaultsService ColumnWidthDefaultsSvc
@inject ILogger<DetailViewer> Logger

<PageTitle>@_title - Executive Reporting Suite</PageTitle>

@* Suppress the outer viewport scrollbar — the detail grid handles its own
   internal scrolling. HeadContent is automatically removed when this page
   unmounts, so other pages keep their normal scrolling. *@
<HeadContent>
    <style>
        html, body { overflow-y: hidden !important; }

        /* Grouped detail render — flat table mirroring the legacy
           /EmpowerDetails look (group-header / detail-row / group-footer
           rows interleaved). Kept scoped to the wrapper class so it can't
           bleed into other pages. */
        .grouped-detail-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.78rem;
        }
        /* No-wrap on every cell regardless of min-width. Long values
           expand the column to fit (table-layout: auto), pushing the
           overall table width up — the grouped-detail-wrap div's
           overflow: auto kicks in a horizontal scrollbar past the
           viewport. Min-width still sets the floor on header cells. */
        .grouped-detail-table th,
        .grouped-detail-table td {
            white-space: nowrap;
        }
        .grouped-detail-table thead th {
            position: sticky;
            top: 0;
            background: var(--table-header-bg, #F7F7F7);
            color: var(--text-primary, #202124);
            border-bottom: 1px solid var(--border-default, #DADCE0);
            padding: 6px 8px;
            text-align: left;
            font-weight: 600;
            z-index: 1;
        }
        .grouped-detail-table th.num,
        .grouped-detail-table td.num {
            text-align: right;
        }
        .grouped-detail-table tr.group-header td {
            background: var(--detail-group-header-bg, #FFEFD5);
            color: var(--detail-group-header-text, #202124);
            font-weight: var(--detail-group-header-weight, 700);
            font-style: var(--detail-group-header-style, normal);
            text-decoration: var(--detail-group-header-deco, none);
            font-family: var(--detail-group-header-font, inherit);
            font-size: var(--detail-group-header-size, inherit);
            padding: 6px 8px;
        }
        .grouped-detail-table tr.detail-row td {
            border-top: 1px solid var(--border-subtle, #F1F3F4);
            padding: 4px 8px;
        }
        .grouped-detail-table tr.group-footer td {
            background: var(--detail-group-footer-bg, #F5F5DC);
            color: var(--detail-group-footer-text, #202124);
            border-top: 1px solid var(--border-default, #DADCE0);
            border-bottom: 2px solid #BDC1C6;
            font-weight: var(--detail-group-footer-weight, 700);
            font-style: var(--detail-group-footer-style, normal);
            text-decoration: var(--detail-group-footer-deco, none);
            font-family: var(--detail-group-footer-font, inherit);
            font-size: var(--detail-group-footer-size, inherit);
            padding: 5px 8px;
        }

        /* Grand-total row pinned to the bottom of the scroll container so
           it stays visible regardless of how far down the admin has
           scrolled. Background + text + bold drive off theme tokens so
           admins can re-paint and reweight them via Admin → Theme. */
        .grouped-detail-table tfoot tr.grand-total td {
            position: sticky;
            bottom: 0;
            background: var(--detail-grand-total-bg, #F7F7F7);
            color: var(--detail-grand-total-text, #202124);
            font-weight: var(--detail-grand-total-weight, 700);
            font-style: var(--detail-grand-total-style, normal);
            text-decoration: var(--detail-grand-total-deco, none);
            font-family: var(--detail-grand-total-font, inherit);
            font-size: var(--detail-grand-total-size, inherit);
            padding: 8px;
            border-top: 2px solid #5F6368;
        }
    </style>
</HeadContent>

<MudMainContent Style="padding: 0; margin-left: 15px;">
    @* Drill-down detail loads can be expensive (no pagination on the
       grouped output), so the elapsed timer matters here even more
       than on the report list. QueryProgress upgrades to a slow-query
       warning past the configured threshold. *@
    <QueryProgress Active="@_isLoading" />

    <MudStack Spacing="3">
        <MudPaper Elevation="0" Style="padding: 4px 16px; border-bottom: 1px solid var(--border-subtle, #E8EAED);">
            <MudStack Spacing="2">
                @* Active company's logo — rendered statically (no link)
                   above the description + export row, so users always
                   know which company's data they're drilled into. Same
                   gray letterbox treatment the master dashboard uses.
                   Hidden when the company has no logo uploaded. *@
                @if (_logoDataUri is not null)
                {
                    <div style="background: #A9A9A9; border-radius: 4px;
                                padding: 4px 8px; display: inline-flex;
                                align-items: center; align-self: flex-start;">
                        <img src="@_logoDataUri" alt=""
                             style="height: 36px; max-width: 160px; object-fit: contain;" />
                    </div>
                }
                <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                        @* No back arrow — the detail screen is a modal-style
                           overlay; users exit via Close. A Back here invited
                           browser history navigation away from the parent
                           report, which dropped any unsaved drill-down state. *@
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.h5" Style="font-weight: 600;">@_title</MudText>
                            @if (!string.IsNullOrEmpty(_groupLabel) && !string.IsNullOrEmpty(GroupKey))
                            {
                                <MudStack Row AlignItems="AlignItems.Center" Spacing="1" Class="mt-1">
                                    <MudChip T="string" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small">
                                        @_groupLabel
                                    </MudChip>
                                    <MudText Typo="Typo.body1" Style="font-weight: 500;">
                                        @FormatGroupKeyForBanner(GroupKey)
                                    </MudText>
                                </MudStack>
                            }
                            else
                            {
                                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-1">All Records</MudText>
                            }
                        </MudStack>
                    </MudStack>
                    <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                        @if (_detailData is not null)
                        {
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                @_detailData.Rows.Count.ToString("N0") rows
                            </MudText>
                        }
                        @* Debug affordance — same dialog the master dashboard
                           tiles surface on right-click. Available to any user.
                           Labeled (not just an icon) so admins can discover it
                           when diagnosing why a drill-down view returned the
                           rows it did. *@
                        @* Show SQL is admin-only — exposes raw SQL +
                           bound parameters (per the 2026-05-05 policy). *@
                        @if (_isAdmin)
                        {
                            <MudTooltip Text="Show the SQL that produced this view">
                                <MudButton Variant="Variant.Outlined" Size="Size.Small"
                                           Color="Color.Default"
                                           StartIcon="@Icons.Material.Filled.Code"
                                           OnClick="ShowDetailQuery"
                                           Disabled="@(_detailData?.Sql is null)">
                                    Show SQL
                                </MudButton>
                            </MudTooltip>
                        }
                        <ExportMenu OnExportExcel="ExportExcel" OnExportCsv="ExportCsv"
                                    OnExportPdf="ExportPdf"
                                    Disabled="@(_detailData is null || !_detailData.Rows.Any())" />
                    </MudStack>
                </MudStack>
            </MudStack>
        </MudPaper>

        @if (_error is not null)
        {
            <MudAlert Severity="Severity.Error">@_error</MudAlert>
        }
        else if (_detailData is not null && _detailData.Rows.Any())
        {
            @* Same sort indicator pattern as the Report Viewer. *@
            @if (_liveSort is { Count: > 0 })
            {
                <MudStack Row AlignItems="AlignItems.Center" Spacing="1" Wrap="Wrap.Wrap" Class="mb-1">
                    <MudText Typo="Typo.overline" Color="Color.Secondary" Style="letter-spacing: 0.5px;">
                        Sort:
                    </MudText>
                    @for (var si = 0; si < _liveSort.Count; si++)
                    {
                        var priority = si + 1;
                        var step = _liveSort[si];
                        var label = GetFieldLabel(step.Field);
                        var isDesc = string.Equals(step.Direction, "desc", StringComparison.OrdinalIgnoreCase);
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary"
                                 Icon="@(isDesc ? Icons.Material.Filled.ArrowDownward : Icons.Material.Filled.ArrowUpward)">
                            @priority. @label
                        </MudChip>
                    }
                </MudStack>
            }
            @if (IsGroupedView)
            {
                @* Grouped render — matches the legacy /EmpowerDetails
                   pattern: flat table with inline group-header and
                   group-footer rows. Footer shows row count and sum of
                   every currency column. Export path is unchanged and
                   strips group rows because they aren't in QueryResponse. *@
                // Compute once per render. GetVisibleColumns() allocates
                // a HashSet + Dictionary and walks _detailData.Columns —
                // calling it from every cell template was the hot path
                // (10 groups × 200 rows × 20 cols ≈ 4,000 calls per
                // render). Hoisting to a local makes a grouped-view
                // first-paint go from seconds to milliseconds.
                var visibleCols = GetVisibleColumns();
                var visibleColCount = visibleCols.Count;
                <div class="grouped-detail-wrap"
                     style="max-height: calc(100vh - 210px); overflow: auto; border: 1px solid #DADCE0; border-radius: 4px;">
                    <table class="grouped-detail-table">
                        <thead>
                            <tr>
                                @foreach (var col in visibleCols)
                                {
                                    @* Effective min-width = max(explicit FieldDefinition.MinWidth,
                                       type-based wide-mode floor). The grouped-detail-table is
                                       table-layout: auto, so a min-width on a single header cell
                                       propagates down the whole column. Mirrors the wide-mode
                                       defaults in ReportGrid.TypeBasedWidths so the two viewer
                                       paths size non-text columns identically (currency, date,
                                       datetime, integer, etc.). *@
                                    var minW = EffectiveMinWidth(col);
                                    <th class="@(IsNumericColumn(col) ? "num" : "")"
                                        style="@(minW > 0 ? $"min-width: {minW}px;" : "")">@col.Label</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var group in BuildGroups())
                            {
                                <tr class="group-header">
                                    <td colspan="@visibleColCount">@FormatGroupLabel(group)</td>
                                </tr>
                                @foreach (var row in group.Rows)
                                {
                                    <tr class="detail-row">
                                        @foreach (var col in visibleCols)
                                        {
                                            <td class="@(IsNumericColumn(col) ? "num" : "")">
                                                @FormatCell(row, col)
                                            </td>
                                        }
                                    </tr>
                                }
                                <tr class="group-footer">
                                    @for (var ci = 0; ci < visibleColCount; ci++)
                                    {
                                        var col = visibleCols[ci];
                                        if (ci == 0)
                                        {
                                            <td>@group.Rows.Count Record(s)</td>
                                        }
                                        else if (IsCurrencyColumn(col))
                                        {
                                            <td class="num">@FormatCurrency(group.Totals[col.FieldId])</td>
                                        }
                                        else
                                        {
                                            <td></td>
                                        }
                                    }
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            @{
                                var grand = ComputeGrandTotals();
                                var totalRows = _detailData?.Rows.Count ?? 0;
                            }
                            <tr class="grand-total">
                                @for (var ci = 0; ci < visibleColCount; ci++)
                                {
                                    var col = visibleCols[ci];
                                    if (ci == 0)
                                    {
                                        <td>TOTAL &mdash; @totalRows Record(s)</td>
                                    }
                                    else if (IsCurrencyColumn(col) && grand.TryGetValue(col.FieldId, out var sum))
                                    {
                                        <td class="num">@FormatCurrency(sum)</td>
                                    }
                                    else
                                    {
                                        <td></td>
                                    }
                                }
                            </tr>
                        </tfoot>
                    </table>
                </div>
            }
            else
            {
                <ReportGrid Data="_detailData"
                            HonorFieldMinWidth="true"
                            InitialColumnWidths="_columnWidths"
                            InitialColumnOrder="_columnOrder"
                            InitialHiddenColumns="_hiddenColumns"
                            DefaultSortField="@_tableSortField"
                            DefaultSortDirection="@_tableSortDirection"
                            InitialSort="@_initialSortTuples"
                            CalcColumns="_tableCalcColumns"
                            ColumnLabelOverrides="_templateColumnLabels"
                            DisableUserSort="true"
                            ReadOnly="true"
                            FillViewport="true"
                            InitialPageSize="_initialPageSize"
                            OnPageSizeChangedCallback="HandlePageSizeChanged" />
            }
        }
        else if (!_isLoading)
        {
            <MudPaper Class="pa-8 d-flex flex-column align-center justify-center" Elevation="0"
                      Style="border: 1px dashed #DADCE0; min-height: 300px;">
                <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="Size.Large" Color="Color.Default" />
                <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mt-2">
                    No results found.
                </MudText>
            </MudPaper>
        }
    </MudStack>
</MudMainContent>

@code {
    [Parameter] public Guid ReportId { get; set; }
    // Group key lives in the query string (?group=...) rather than a path
    // segment — path segments reject characters like "+" at the request-filter
    // level (ERR_CONNECTION_RESET), query strings don't.
    [SupplyParameterFromQuery(Name = "group")]
    public string? GroupKey { get; set; }
    // Optional dashboard-tab label, set when the user opened the detail
    // view from a tile on a Master Dashboard tab. Prepended to _title so
    // the heading reads "TabName - ReportName" — gives admins the
    // context of which tab they drilled in from when several tabs share
    // similarly-named tiles. Plain query param (no encoding semantics
    // beyond the standard URL-decode that happens automatically).
    [SupplyParameterFromQuery(Name = "tab")]
    public string? DashboardTabName { get; set; }

    private string _title = "Detail";
    private string _companyName = string.Empty;
    // Data-URI form of the active company's logo. Rendered statically
    // (no link) below the page header so the user always sees which
    // company's data they're drilled into. Null when the company has
    // no logo uploaded.
    private string? _logoDataUri;
    private Guid? _connectionId;
    private string? _primaryTable;
    private string? _groupLabel;
    private string? _error;
    private bool _isLoading;
    // Admin-only Show SQL gate. Set during init so the action button
    // can hide for non-admins per the 2026-05-05 policy change.
    private bool _isAdmin;
    private QueryResponse? _detailData;
    private DashboardView.DashboardConfig? _dashConfig;
    // Per-report SQL calc columns. Hydrated from ColumnState so the
    // detail query SELECTs them and rows carry their values for the grid.
    private List<TleReportingDashboard.Web.Models.TableCalcColumnDef>? _tableCalcColumns;
    // Column-rename overrides from the linked grid template. Forwarded to
    // ReportGrid as ColumnLabelOverrides so the drilled-in detail grid
    // also renders the template's renamed headers.
    private Dictionary<string, string>? _templateColumnLabels;
    private string? _tableSortField;
    private string? _tableSortDirection;
    // Multi-column sort read from the report's ColumnState. Same semantics as
    // in ReportBuilder / ReportViewer — primary first, falls back to the
    // legacy single-field DefaultSort for reports saved before multi-sort.
    private List<(string Field, string Direction)>? _initialSortTuples;
    private List<(string Field, string Direction)> _liveSort = new();
    // Field id → human label lookup used by the sort indicator strip.
    private Dictionary<string, string> _fieldLabelsById = new(StringComparer.OrdinalIgnoreCase);
    private List<string>? _columnOrder;
    private Dictionary<string, int>? _columnWidths;
    private List<string>? _hiddenColumns;
    // Detail-view grouping, set in Report Builder and persisted on the report.
    // When _detailGroupByFieldId is set, render uses a custom grouped table
    // with inline header + sub-total rows instead of the MudDataGrid. Direction
    // sorts the groups themselves ("none", "asc", "desc").
    private string? _detailGroupByFieldId;
    private string _detailGroupByDirection = "asc";
    // Detail default sort. When a group-by field is set, this becomes the
    // secondary ORDER BY so rows inside each group follow this order.
    // Otherwise it's the primary ORDER BY.
    private string? _detailSortFieldId;
    private string _detailSortDirection = "asc";
    // Value → sort-index map pulled from the group field's lookup (populated
    // by SchemaService from the lookup CTE's ORDERBY column). When present,
    // groups sort by this index instead of alphabetically on the label —
    // e.g. status picks land in workflow order (Pre-Approval first, Cleared
    // later) rather than strict A–Z.
    private Dictionary<string, int>? _groupValueSortOrder;
    private string _userId = "anonymous";
    private UserPreference? _prefs;
    // Null on first load until the user's preferences return; then mirrors
    // DefaultPageSize so the grid opens at the saved value and persists new
    // choices back.
    private int? _initialPageSize;

    protected override async Task OnInitializedAsync()
    {
        _isLoading = true;
        try
        {
            // Load admin-configurable column-width defaults so EffectiveMinWidth
            // can consult them on every cell render without a per-row DB hit.
            // Non-fatal if it fails — Seed() is used as fallback.
            try { _columnWidthDefaults = await ColumnWidthDefaultsSvc.GetAsync(); }
            catch (Exception ex) { Logger.LogWarning(ex, "Loading column-width defaults failed; using seed."); }

            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            _userId = authState.User.FindFirst("oid")?.Value
                      ?? authState.User.Identity?.Name
                      ?? "anonymous";
            var userId = _userId;
            var userEmail = authState.User.FindFirst("preferred_username")?.Value ?? string.Empty;

            // Load the user's page-size preference for this report. Falls back
            // to their global DefaultPageSize, then to the grid's own default.
            try
            {
                _prefs = await PreferenceService.GetPreferencesAsync(_userId);
                if (_prefs.ReportPageSizes.TryGetValue(ReportId, out var reportSize) && reportSize > 0)
                    _initialPageSize = reportSize;
                else if (_prefs.DefaultPageSize > 0)
                    _initialPageSize = _prefs.DefaultPageSize;
            }
            catch { /* non-fatal — let the grid use its own default */ }

            // Phase 3 authorization: fetch the report directly, gate by
            // company access instead of owner/share scoping so users who
            // can view the company's shared dashboard can drill in.
            var report = await ReportService.GetReportByIdAsync(ReportId);
            if (report is null) { _error = "Report not found."; return; }

            var isAdmin = AdminService.IsAdmin(userEmail);
            _isAdmin = isAdmin;
            // Admin-section roles (System Support et al.) bypass the per-
            // company gate — they need cross-company visibility for support
            // work, same model the picker / Report Library use.
            var hasAdminAccess = isAdmin || await AdminAccess.HasAnyAdminAccessAsync(userEmail);
            if (!hasAdminAccess)
            {
                var access = await UserManagement.GetCompanyAccessAsync(userEmail);
                if (!access.Any(a => a.CompanyId == report.CompanyId))
                {
                    _error = "You don't have access to this report.";
                    return;
                }
            }

            // Prepend the originating dashboard tab when the user came
            // from a Master Dashboard tile — admins drilling in from
            // similarly-named tiles across several tabs benefit from the
            // tab context in the heading. Falls back to plain report name
            // for the Report-Viewer-launched detail flow.
            _title = string.IsNullOrWhiteSpace(DashboardTabName)
                ? report.Name
                : $"{DashboardTabName.Trim()} - {report.Name}";
            _connectionId = report.ConnectionId;
            _primaryTable = report.PrimaryTable;

            // Resolve the company name once so Excel / CSV exports can
            // prepend it to the filename. Empty string when lookup fails
            // — exports still work, just without the company prefix.
            try
            {
                var company = await CompanyRegistry.GetByIdAsync(report.CompanyId);
                _companyName = company?.Name ?? string.Empty;
                if (company?.Logo is { Length: > 0 } bytes)
                {
                    var mime = company.LogoContentType ?? "image/png";
                    _logoDataUri = $"data:{mime};base64,{Convert.ToBase64String(bytes)}";
                }
            }
            catch { _companyName = string.Empty; }

            // Parse column state
            if (!string.IsNullOrWhiteSpace(report.ColumnState))
            {
                try
                {
                    using var doc = System.Text.Json.JsonDocument.Parse(report.ColumnState);
                    if (doc.RootElement.TryGetProperty("TableSortField", out var tsfEl))
                        _tableSortField = tsfEl.GetString();
                    if (doc.RootElement.TryGetProperty("TableSortDirection", out var tsdEl))
                        _tableSortDirection = tsdEl.GetString();
                    if (doc.RootElement.TryGetProperty("TableColumnOrder", out var coEl))
                        _columnOrder = System.Text.Json.JsonSerializer.Deserialize<List<string>>(coEl.GetRawText());
                    if (doc.RootElement.TryGetProperty("ColumnWidths", out var cwEl))
                        _columnWidths = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, int>>(cwEl.GetRawText());
                    if (doc.RootElement.TryGetProperty("HiddenColumns", out var hcEl))
                        _hiddenColumns = System.Text.Json.JsonSerializer.Deserialize<List<string>>(hcEl.GetRawText());
                    if (doc.RootElement.TryGetProperty("DetailGroupByFieldId", out var dgfEl))
                        _detailGroupByFieldId = dgfEl.GetString();
                    if (doc.RootElement.TryGetProperty("DetailGroupByDirection", out var dgdEl))
                        _detailGroupByDirection = dgdEl.GetString() ?? "asc";
                    if (doc.RootElement.TryGetProperty("DetailSortFieldId", out var dsfEl))
                        _detailSortFieldId = dsfEl.GetString();
                    if (doc.RootElement.TryGetProperty("DetailSortDirection", out var dsdEl))
                        _detailSortDirection = dsdEl.GetString() ?? "asc";
                    // Per-report SQL calc columns. Hydrated so the drill-down
                    // grid renders calc-column captions and group-by lists
                    // include calc keys. The factory parses these again
                    // for the QueryRequest's TableCalcSqlColumns —
                    // duplication is intentional; this hydration is for
                    // the rendering layer, factory's is for the SELECT.
                    if (doc.RootElement.TryGetProperty("TableCalculatedColumns", out var tcEl))
                        _tableCalcColumns = System.Text.Json.JsonSerializer
                            .Deserialize<List<TleReportingDashboard.Web.Models.TableCalcColumnDef>>(tcEl.GetRawText());

                    // Multi-column sort (primary first). Wins over the legacy
                    // single-field TableSortField/Direction when populated.
                    if (doc.RootElement.TryGetProperty("TableSort", out var tsEl)
                        && tsEl.ValueKind == System.Text.Json.JsonValueKind.Array)
                    {
                        var list = new List<(string, string)>();
                        foreach (var item in tsEl.EnumerateArray())
                        {
                            var f = item.TryGetProperty("Field", out var fEl) ? fEl.GetString() : null;
                            var d = item.TryGetProperty("Direction", out var dEl) ? dEl.GetString() : "asc";
                            if (!string.IsNullOrWhiteSpace(f))
                                list.Add((f!, d ?? "asc"));
                        }
                        if (list.Count > 0) _initialSortTuples = list;
                    }

                    // Get group-by label from dashboard config
                    _dashConfig = System.Text.Json.JsonSerializer.Deserialize<DashboardView.DashboardConfig>(
                        report.ColumnState, AppJson.Compact);
                    if (_dashConfig is not null && !string.IsNullOrEmpty(_dashConfig.GroupByFieldId))
                    {
                        var fields = await SchemaService.GetFieldConfigsAsync(_connectionId);
                        var groupField = fields.FirstOrDefault(f => f.Id == _dashConfig.GroupByFieldId);
                        _groupLabel = groupField?.Label ?? _dashConfig.GroupByFieldId;
                    }
                }
                catch { }
            }

            // Fallback: if no multi-sort saved, seed a one-element list from
            // the legacy DefaultSort pair so pre-multi-sort reports still sort.
            if (_initialSortTuples is null && !string.IsNullOrEmpty(_tableSortField))
            {
                _initialSortTuples = new List<(string, string)>
                {
                    (_tableSortField!, _tableSortDirection ?? "asc")
                };
            }

            // Prime the indicator strip so it shows the saved sort immediately.
            if (_initialSortTuples is { Count: > 0 })
                _liveSort = new List<(string, string)>(_initialSortTuples);

            // Build label lookup for the sort indicator (field id → human label).
            // Also capture the group field's ValueSortOrder if present —
            // SchemaService auto-populates this from the lookup's ORDERBY
            // column, so grouped-view headers can follow the workflow order
            // (e.g. Pre-Approval → Pre-Docs → Cleared) rather than A–Z.
            try
            {
                var allFields = await SchemaService.GetFieldConfigsAsync(_connectionId);
                _fieldLabelsById = allFields.ToDictionary(f => f.Id, f => f.Label, StringComparer.OrdinalIgnoreCase);

                if (!string.IsNullOrEmpty(_detailGroupByFieldId))
                {
                    var groupField = allFields.FirstOrDefault(f =>
                        string.Equals(f.Id, _detailGroupByFieldId, StringComparison.OrdinalIgnoreCase));
                    _groupValueSortOrder = groupField?.ValueSortOrder is { Count: > 0 }
                        ? new Dictionary<string, int>(groupField.ValueSortOrder!, StringComparer.OrdinalIgnoreCase)
                        : null;
                }
            }
            catch { /* non-fatal — indicator falls back to raw field ids */ }

            // Resolve linked template or parse fields
            var fieldIds = new List<string>();
            if (report.GridTemplateId.HasValue)
            {
                var resolved = await GridTemplateService.ResolveTemplateAsync(report.GridTemplateId);
                if (resolved is not null)
                {
                    fieldIds = resolved.FieldIds;
                    _templateColumnLabels = resolved.CustomColumnLabels;
                    // Template-linked: template owns the column order and default sort so the
                    // detail grid stays in sync with the template. Per-report show/hide is
                    // preserved but trimmed to fields still in the template.
                    // Calcs are NOT in templates (per-report derivation), so weave the
                    // saved order's calc positions back in — otherwise the detail
                    // grid drops calc placement on every load.
                    var templateOrder = resolved.ColumnOrder is { Count: > 0 }
                        ? new List<string>(resolved.ColumnOrder)
                        : new List<string>(fieldIds);
                    _columnOrder = TleReportingDashboard.Web.Services.GridTemplateService
                        .WeaveCalcsIntoTemplateOrder(
                            templateOrder,
                            _columnOrder,
                            _tableCalcColumns?.Where(c => !string.IsNullOrEmpty(c.Key)).Select(c => c.Key));
                    if (!string.IsNullOrEmpty(resolved.DefaultSortField))
                    {
                        _tableSortField = resolved.DefaultSortField;
                        _tableSortDirection = resolved.DefaultSortDirection;
                    }
                    // Union template hidden list with the report's own, then
                    // filter to the template's field set. Previous code used
                    // `_hiddenColumns ?? resolved.HiddenColumns`, which let the
                    // report's saved list clobber new template-level hides.
                    var merged = (resolved.HiddenColumns ?? new List<string>())
                        .Union(_hiddenColumns ?? new List<string>(), StringComparer.OrdinalIgnoreCase)
                        .ToList();
                    _hiddenColumns = TleReportingDashboard.Web.Services.GridTemplateService
                        .FilterHiddenToTemplate(fieldIds, merged);
                }
            }
            else if (!string.IsNullOrWhiteSpace(report.FieldIds))
            {
                fieldIds = System.Text.Json.JsonSerializer.Deserialize<List<string>>(report.FieldIds) ?? new();
            }

            if (!fieldIds.Any()) { _error = "Report has no fields."; return; }

            // Include extra group-by fields (legacy) + extra dimension fields.
            void AddIds(IEnumerable<string>? ids)
            {
                if (ids is null) return;
                foreach (var extra in ids)
                    if (!fieldIds.Contains(extra, StringComparer.OrdinalIgnoreCase))
                        fieldIds.Add(extra);
            }
            AddIds(_dashConfig?.ExtraGroupByFieldIds);
            AddIds(_dashConfig?.ExtraDimensionFieldIds);

            // Detail view shows raw rows, so strip aggregate fields
            // (SUM/COUNT/AVG/etc). Leaving them in causes QueryBuilder to
            // auto-add GROUP BY — the query then returns the same
            // aggregated summary as the tile instead of individual records.
            // IsAggregateField only flags outer-level aggregates, so scalar-
            // subquery measures (which read as row-scalars) are preserved.
            try
            {
                var fieldCatalog = await SchemaService.GetFieldConfigsAsync(_connectionId);
                var byId = fieldCatalog.ToDictionary(f => f.Id, f => f, StringComparer.OrdinalIgnoreCase);
                fieldIds = fieldIds
                    .Where(id => !(byId.TryGetValue(id, out var fc)
                                   && TleReportingDashboard.Web.Services.QueryBuilder.IsAggregateField(fc)))
                    .ToList();
            }
            catch { /* non-fatal — if the catalog lookup fails, run unstripped */ }

            // Pre-fetch primary-table PKs so QueryBuilder can append silent
            // tiebreakers — same OFFSET-stability path the editor uses.
            // Best-effort: failures fall through to the legacy fallback.
            List<string>? pkColumns = null;
            if (!string.IsNullOrWhiteSpace(_primaryTable))
            {
                try
                {
                    var bare = _primaryTable;
                    var asIdx = bare.IndexOf(" AS ", StringComparison.OrdinalIgnoreCase);
                    if (asIdx > 0) bare = bare[..asIdx].Trim();
                    var dot = bare.IndexOf('.');
                    string? schema = dot > 0 ? bare[..dot] : null;
                    var table = dot > 0 ? bare[(dot + 1)..] : bare;
                    // Effective lookup folds in admin-flagged IsUnique
                    // fields so accounts that can't read information_schema
                    // still get a stable OFFSET tiebreaker.
                    var schemaFields = await SchemaService.GetFieldConfigsAsync(_connectionId);
                    pkColumns = await SchemaBrowser.GetEffectivePrimaryKeyColumnsAsync(_connectionId, schema, table, schemaFields);
                }
                catch { pkColumns = null; }
            }

            // Single source of truth for "QueryRequest from a SavedReport".
            // Same factory the Worker, Report Viewer, and Master Dashboard
            // tile use — keeps every saved knob in lockstep.
            var request = TleReportingDashboard.Web.Services.QueryRequestFactory
                .FromSavedReport(report, pageSize: 50000, fallbackSortColumns: pkColumns);

            // Per-surface overrides:
            //  • FieldIds — aggregate-stripped (detail wants raw rows) and
            //    template-resolved + ExtraGroupBy/Dimension splice-in.
            //  • Sort — detail view orders by Group By dropdown then Sort By
            //    dropdown, NOT TableSort header-clicks. Override the factory's
            //    default to preserve drill-down semantics.
            //  • AdvancedFilters — gated by Features:AdvancedFilters so an
            //    appsettings rollback also takes effect on the drill-down.
            request.FieldIds = fieldIds;

            string? primarySort = null, primaryDir = null;
            string? secondarySort = null, secondaryDir = null;
            if (!string.IsNullOrEmpty(_detailGroupByFieldId)
                && fieldIds.Contains(_detailGroupByFieldId, StringComparer.OrdinalIgnoreCase))
            {
                primarySort = _detailGroupByFieldId;
                // Map "none" to asc so SQL gets a legal direction — the
                // client-side group sort still runs with lookup awareness,
                // so the user's visual order isn't lost.
                primaryDir = _detailGroupByDirection == "desc" ? "desc" : "asc";
                if (!string.IsNullOrEmpty(_detailSortFieldId)
                    && !string.Equals(_detailSortFieldId, _detailGroupByFieldId, StringComparison.OrdinalIgnoreCase)
                    && fieldIds.Contains(_detailSortFieldId, StringComparer.OrdinalIgnoreCase))
                {
                    secondarySort = _detailSortFieldId;
                    secondaryDir = _detailSortDirection == "desc" ? "desc" : "asc";
                }
            }
            else if (!string.IsNullOrEmpty(_detailSortFieldId)
                && fieldIds.Contains(_detailSortFieldId, StringComparer.OrdinalIgnoreCase))
            {
                primarySort = _detailSortFieldId;
                primaryDir = _detailSortDirection == "desc" ? "desc" : "asc";
            }
            request.SortField = primarySort;
            request.SortDirection = primaryDir;
            request.SecondarySortField = secondarySort;
            request.SecondarySortDirection = secondaryDir;

            if (!Config.GetValue<bool>("Features:AdvancedFilters", false))
                request.AdvancedFilters = null;

            request.Scoping = await ScopeResolver.ResolveAsync(userEmail, _connectionId, _primaryTable);
            var fullData = await QueryService.ExecuteQueryAsync(request);

            // Filter rows by group key if provided
            var decodedGroup = GroupKey;
            List<Dictionary<string, object?>> rows;
            var groupFieldId = _dashConfig?.GroupByFieldId ?? string.Empty;

            if (!string.IsNullOrEmpty(decodedGroup) && !string.IsNullOrEmpty(groupFieldId))
            {
                if (decodedGroup == "(empty)")
                {
                    rows = fullData.Rows.Where(r =>
                    {
                        if (!r.TryGetValue(groupFieldId, out var v)) return true;
                        if (v is null || v is DBNull) return true;
                        return string.IsNullOrWhiteSpace(v.ToString());
                    }).ToList();
                }
                else
                {
                    rows = fullData.Rows.Where(r =>
                        r.TryGetValue(groupFieldId, out var v) && v is not null && v is not DBNull &&
                        string.Equals(v.ToString(), decodedGroup, StringComparison.OrdinalIgnoreCase))
                        .ToList();
                }

            }
            else
            {
                rows = fullData.Rows;
            }

            _detailData = new QueryResponse
            {
                Columns = fullData.Columns,
                Rows = rows,
                TotalCount = rows.Count,
                // Carry the query metadata over so the "Show query" button
                // has something to display. Without this, the in-memory
                // group-filtering re-wraps the data but loses the SQL.
                Sql = fullData.Sql,
                Parameters = fullData.Parameters,
                ScopingNote = fullData.ScopingNote,
                ScopingForceNoMatch = fullData.ScopingForceNoMatch
            };
        }
        catch (Exception ex)
        {
            _error = FriendlyError.FromException(ex, Logger, "loading drill-down detail");
        }
        finally
        {
            _isLoading = false;
        }
    }

    // Updates the sort indicator strip when the user clicks a header.
    private Task HandleSortChanged(List<(string Field, string Direction)> sort)
    {
        _liveSort = sort;
        return Task.CompletedTask;
    }

    private string GetFieldLabel(string fieldId) =>
        _fieldLabelsById.TryGetValue(fieldId, out var label) ? label : fieldId;

    // ── Grouped detail view helpers ──────────────────────────────────────

    private bool IsGroupedView =>
        !string.IsNullOrEmpty(_detailGroupByFieldId)
        && _detailData is not null
        && _detailData.Rows.Count > 0
        && (_detailData.Columns.Any(c => string.Equals(c.FieldId, _detailGroupByFieldId, StringComparison.OrdinalIgnoreCase))
            // SQL-mode calc keys aren't in Data.Columns (which only carries
            // real FieldConfig metadata), but their values ARE in every row
            // dict via the SELECT alias. Detect calc-key group-bys by
            // matching against the per-report calc list so the grouped
            // header / subtotal render kicks in.
            || (_tableCalcColumns?.Any(c =>
                    !string.IsNullOrWhiteSpace(c.SqlExpression)
                    && string.Equals(c.Key, _detailGroupByFieldId, StringComparison.OrdinalIgnoreCase)) ?? false));

    // Columns visible in the grouped render, honoring saved column order
    // and hidden-column settings. Mirrors the ReportGrid's visibility rules
    // so the grouped view lines up with the flat view's expectations.
    private List<ColumnMeta> GetVisibleColumns()
    {
        if (_detailData is null) return new();
        var byId = _detailData.Columns.ToDictionary(c => c.FieldId, StringComparer.OrdinalIgnoreCase);
        var hidden = _hiddenColumns is null
            ? new HashSet<string>(StringComparer.OrdinalIgnoreCase)
            : new HashSet<string>(_hiddenColumns, StringComparer.OrdinalIgnoreCase);

        // SQL-mode calc columns aren't in Data.Columns (which only carries
        // FieldConfig metadata) but their values are in every row dict via
        // the SELECT alias. Project them as synthetic ColumnMeta so the
        // grouped render iterates and displays them in the same slot the
        // saved combined order specifies.
        var calcsByKey = (_tableCalcColumns ?? new())
            .Where(c => !string.IsNullOrEmpty(c.Key) && !string.IsNullOrWhiteSpace(c.SqlExpression))
            .ToDictionary(c => c.Key, c => new ColumnMeta
            {
                FieldId = c.Key,
                Label = string.IsNullOrEmpty(c.Label) ? c.Key : c.Label,
                DataType = string.IsNullOrWhiteSpace(c.DataType) ? "text" : c.DataType,
                Format = c.Format
            }, StringComparer.OrdinalIgnoreCase);

        IEnumerable<ColumnMeta> ordered;
        if (_columnOrder is { Count: > 0 })
        {
            var seen = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
            var result = new List<ColumnMeta>();
            foreach (var id in _columnOrder)
            {
                if (byId.TryGetValue(id, out var c) && seen.Add(id)) result.Add(c);
                else if (calcsByKey.TryGetValue(id, out var calcCol) && seen.Add(id)) result.Add(calcCol);
            }
            // Append any data columns missing from the saved order so nothing
            // silently disappears (e.g. a new field was added post-save).
            foreach (var c in _detailData.Columns)
                if (seen.Add(c.FieldId)) result.Add(c);
            // Append any calcs not yet placed (defensive — newly-added calc
            // not yet in saved order lands at the end).
            foreach (var calcCol in calcsByKey.Values)
                if (seen.Add(calcCol.FieldId)) result.Add(calcCol);
            ordered = result;
        }
        else
        {
            ordered = _detailData.Columns.Concat(calcsByKey.Values);
        }

        // Apply grid-template column-rename overrides at the visible-
        // columns boundary so EVERY downstream consumer (the grouped
        // detail render's <th>, the inline detail row, group footers,
        // the grand-total row, and the ReportGrid no-grouping fallback)
        // sees the renamed labels. WithLabelOverrides clones each
        // ColumnMeta when an override is present and returns the source
        // ref otherwise, so this is cheap on un-templated reports.
        return ordered
            .Where(c => !hidden.Contains(c.FieldId))
            .WithLabelOverrides(_templateColumnLabels);
    }

    private bool IsCurrencyColumn(ColumnMeta c) =>
        string.Equals(c.DataType, "currency", StringComparison.OrdinalIgnoreCase);

    // Cached admin-configurable column-width defaults. Loaded once in
    // OnInitializedAsync; EffectiveMinWidth consults this snapshot.
    // Null briefly during first render — Seed() is used as fallback.
    private ColumnWidthDefaults? _columnWidthDefaults;

    // Effective column min-width for the grouped-detail-table header.
    // Field-level MinWidth is authoritative when set — it replaces the
    // type default outright (including the case where the override is
    // smaller). Falls back to the admin-configured WideMin from
    // ColumnWidthDefaults only when the field has no explicit MinWidth.
    // A field MinWidth of 0 is an explicit "no minimum" signal — different
    // from null (unset) and respected.
    private int EffectiveMinWidth(ColumnMeta col)
    {
        var defaults = _columnWidthDefaults ?? ColumnWidthDefaults.Seed();
        var entry = defaults.Resolve(col.DataType);
        return col.MinWidth ?? entry.WideMin;
    }

    // Right-align any numeric column, not just currency. Mirrors
    // ReportGrid.IsNumeric so the Builder's table preview and the detail
    // grid agree on alignment for int/decimal/percent fields. Currency
    // still gets its own formatter + total pass — this is only about
    // text-align.
    private static bool IsNumericColumn(ColumnMeta c) => c.DataType?.ToLowerInvariant() switch
    {
        "currency" or "money" or "smallmoney" => true,
        "percent" or "percentage" => true,
        "integer" or "int" or "bigint" or "smallint" or "tinyint" => true,
        "decimal" or "float" or "double" or "numeric" or "real" or "number" => true,
        _ => false
    };

    // Groups the rows by the picked field. Sorts groups per the direction
    // setting; within a group, rows keep whatever order the query returned.
    private IEnumerable<GroupBucket> BuildGroups()
    {
        if (_detailData is null || string.IsNullOrEmpty(_detailGroupByFieldId))
            yield break;

        var fieldId = _detailGroupByFieldId!;
        var groups = _detailData.Rows
            .GroupBy(r => GroupKeyFor(r, fieldId), StringComparer.OrdinalIgnoreCase)
            .Select(g => new GroupBucket(g.Key, g.ToList(), ComputeTotals(g)))
            .ToList();

        // When the group field has a lookup-backed ValueSortOrder, sort
        // groups by that integer key (workflow order) with the label as a
        // tiebreaker. Labels not present in the map get int.MaxValue so
        // unknown values sink to the end instead of jumbling with the
        // known ones.
        var useLookupOrder = _groupValueSortOrder is { Count: > 0 };
        int LookupOrderOf(string label) =>
            useLookupOrder && _groupValueSortOrder!.TryGetValue(label, out var o)
                ? o
                : int.MaxValue;

        groups = _detailGroupByDirection switch
        {
            "asc" when useLookupOrder => groups
                .OrderBy(g => LookupOrderOf(g.Label))
                .ThenBy(g => g.Label, StringComparer.OrdinalIgnoreCase)
                .ToList(),
            "desc" when useLookupOrder => groups
                .OrderByDescending(g => LookupOrderOf(g.Label))
                .ThenByDescending(g => g.Label, StringComparer.OrdinalIgnoreCase)
                .ToList(),
            "asc"  => groups.OrderBy(g => g.Label, StringComparer.OrdinalIgnoreCase).ToList(),
            "desc" => groups.OrderByDescending(g => g.Label, StringComparer.OrdinalIgnoreCase).ToList(),
            _      => groups  // "none" preserves insertion order regardless
        };

        foreach (var g in groups) yield return g;
    }

    // Grand totals — sum across every row, not just per-group. Used for the
    // sticky tfoot row so admins see the roll-up without scrolling.
    private Dictionary<string, decimal> ComputeGrandTotals()
    {
        if (_detailData is null) return new(StringComparer.OrdinalIgnoreCase);
        return ComputeTotals(_detailData.Rows);
    }

    private Dictionary<string, decimal> ComputeTotals(IEnumerable<Dictionary<string, object?>> rows)
    {
        var totals = new Dictionary<string, decimal>(StringComparer.OrdinalIgnoreCase);
        if (_detailData is null) return totals;
        // Materialize once so we can iterate twice (currency fields + calcs)
        // without re-enumerating the source. Detail rowsets are small (one
        // tile's drill-down), so this is cheap.
        var rowList = rows as IList<Dictionary<string, object?>> ?? rows.ToList();
        foreach (var col in _detailData.Columns)
        {
            if (!IsCurrencyColumn(col)) continue;
            decimal sum = 0m;
            foreach (var row in rowList)
            {
                if (row.TryGetValue(col.FieldId, out var v) && v is not null && v is not DBNull)
                {
                    try { sum += Convert.ToDecimal(v); } catch { /* skip non-numeric */ }
                }
            }
            totals[col.FieldId] = sum;
        }
        // Currency-typed SQL calcs participate in subtotals too — their
        // values land in the row dict under the calc Key just like real
        // currency columns. Match the same shape so the grouped render's
        // total row picks them up by FieldId (= calc Key).
        foreach (var calc in _tableCalcColumns ?? new())
        {
            if (string.IsNullOrEmpty(calc.Key)) continue;
            if (!string.Equals(calc.DataType, "currency", StringComparison.OrdinalIgnoreCase)) continue;
            decimal sum = 0m;
            foreach (var row in rowList)
            {
                if (row.TryGetValue(calc.Key, out var v) && v is not null && v is not DBNull)
                {
                    try { sum += Convert.ToDecimal(v); } catch { /* skip non-numeric */ }
                }
            }
            totals[calc.Key] = sum;
        }
        return totals;
    }

    private static string GroupKeyFor(Dictionary<string, object?> row, string fieldId)
    {
        if (!row.TryGetValue(fieldId, out var v) || v is null || v is DBNull)
            return "(empty)";
        return v.ToString() ?? "(empty)";
    }

    private string FormatCell(Dictionary<string, object?> row, ColumnMeta col)
    {
        if (!row.TryGetValue(col.FieldId, out var v) || v is null || v is DBNull)
            return string.Empty;
        if (!string.IsNullOrWhiteSpace(col.Format))
            return FieldFormatter.Format(v, col.Format, col.DataType);
        if (IsCurrencyColumn(col))
        {
            try { return Convert.ToDecimal(v).ToString("C0"); } catch { return v.ToString() ?? string.Empty; }
        }
        // DataType-aware default (e.g., date columns drop the time). When no
        // data-type default applies, falls through to value.ToString().
        return FieldFormatter.Format(v, format: null, col.DataType);
    }

    private static string FormatCurrency(decimal value) => value.ToString("C0");

    // The bucket's Label is the raw value's ToString — used as a stable
    // group key and as the sort key against ValueSortOrder, so we can't
    // change it. Re-derive the *display* by pulling the typed value out of
    // any row in the bucket and running it through the same FormatCell path
    // the data rows use. Without this, a date-typed group field renders as
    // "1/15/2024 12:00:00 AM" in the header even though the rows below it
    // honor the column's "MM/dd/yyyy" Format. "(empty)" is preserved so
    // null/blank groups read the same as before.
    private string FormatGroupLabel(GroupBucket group)
    {
        if (group.Label == "(empty)") return "(empty)";
        if (_detailData is null || string.IsNullOrEmpty(_detailGroupByFieldId)) return group.Label;
        var col = _detailData.Columns.FirstOrDefault(c =>
            string.Equals(c.FieldId, _detailGroupByFieldId, StringComparison.OrdinalIgnoreCase));
        if (col is null || group.Rows.Count == 0) return group.Label;
        return FormatCell(group.Rows[0], col);
    }

    // Drill-down banner at the top of DetailViewer renders @GroupKey
    // (the route-supplied raw value). Without formatting, a phone-typed
    // group field shows "5551234567" in the banner while the grouped
    // table below it shows "(555) 123-4567" — inconsistent and ugly.
    // Formats GroupKey with the group-by field's Format + DataType so
    // the banner matches the table cells. Falls back to the raw value
    // when the column meta isn't available (data not loaded yet, group
    // field not in the SELECT, etc.).
    private string FormatGroupKeyForBanner(string? groupKey)
    {
        if (string.IsNullOrEmpty(groupKey)) return string.Empty;
        if (groupKey == "(empty)") return "(empty)";
        var groupFieldId = _dashConfig?.GroupByFieldId;
        if (string.IsNullOrEmpty(groupFieldId) || _detailData is null) return groupKey;
        var col = _detailData.Columns.FirstOrDefault(c =>
            string.Equals(c.FieldId, groupFieldId, StringComparison.OrdinalIgnoreCase));
        if (col is null) return groupKey;
        if (string.IsNullOrWhiteSpace(col.Format)
            && !string.Equals(col.DataType, "phone", StringComparison.OrdinalIgnoreCase)
            && !string.Equals(col.DataType, "date", StringComparison.OrdinalIgnoreCase))
        {
            // Nothing the formatter would do — return raw to avoid a
            // round-trip through ToString that could shift the casing
            // / culture for plain text.
            return groupKey;
        }
        return FieldFormatter.Format(groupKey, col.Format, col.DataType);
    }

    private sealed record GroupBucket(string Label, List<Dictionary<string, object?>> Rows, Dictionary<string, decimal> Totals);

    // Called when the user picks a new rows-per-page in the grid's pager.
    // Persists it per-report on the user's preferences so this report opens
    // at the chosen size next time; other reports keep their own settings.
    private async Task HandlePageSizeChanged(int newSize)
    {
        if (newSize <= 0) return;
        try
        {
            _prefs ??= await PreferenceService.GetPreferencesAsync(_userId);
            _prefs.UserId = _userId;
            if (_prefs.ReportPageSizes.TryGetValue(ReportId, out var existing) && existing == newSize)
                return;  // no change
            _prefs.ReportPageSizes[ReportId] = newSize;
            await PreferenceService.SavePreferencesAsync(_prefs);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Could not save rows-per-page preference: {ex.Message}", Severity.Warning);
        }
    }

    // Opens the same "Show query" dialog the master-dashboard tiles surface
    // on right-click. Surfaces the generated SQL, bound parameters, the
    // scoping banner, plus a "client-side filter" note describing the in-
    // memory group narrowing this page applies after the query runs.
    private async Task ShowDetailQuery()
    {
        if (_detailData?.Sql is null)
        {
            Snackbar.Add("Query hasn't finished loading yet.", Severity.Info);
            return;
        }
        var parameters = new DialogParameters
        {
            { "Sql", _detailData.Sql },
            { "Parameters", _detailData.Parameters },
            { "ScopingNote", _detailData.ScopingNote },
            { "ScopingForceNoMatch", _detailData.ScopingForceNoMatch },
            { "ClientSideFilter", BuildClientSideFilterNote() }
        };
        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Large,
            FullWidth = true
        };
        await DialogService.ShowAsync<ShowQueryDialog>($"SQL — {_title}", parameters, options);
    }

    // Mirrors the in-memory group filter the page applies after the query
    // (see the `rows = fullData.Rows.Where(...)` block). Returns null when
    // nothing is narrowed — the dialog then hides the banner entirely.
    private string? BuildClientSideFilterNote()
    {
        var groupFieldId = _dashConfig?.GroupByFieldId;
        if (string.IsNullOrEmpty(groupFieldId) || string.IsNullOrEmpty(GroupKey))
            return null;

        var label = _fieldLabelsById.TryGetValue(groupFieldId, out var lbl) ? lbl : groupFieldId;
        return GroupKey == "(empty)"
            ? $"Showing only rows where {label} is empty or null."
            : $"Showing only rows where {label} = \"{GroupKey}\".";
    }

    private async Task ExportExcel()
    {
        if (_detailData is null) return;
        var name = _title ?? "Detail";
        var bytes = ExportService.ExportToExcel(BuildExportData(_detailData), name);
        await JS.DownloadAsync(BuildDetailExportFileName("xlsx"), bytes);
    }

    private async Task ExportCsv()
    {
        if (_detailData is null) return;
        var bytes = ExportService.ExportToCsv(BuildExportData(_detailData));
        await JS.DownloadAsync(BuildDetailExportFileName("csv"), bytes);
    }

    private async Task ExportPdf()
    {
        if (_detailData is null) return;
        var name = _title ?? "Detail";
        var bytes = ExportService.ExportToPdf(BuildExportData(_detailData), name);
        await JS.DownloadAsync(BuildDetailExportFileName("pdf"), bytes);
    }

    // Filename = "{Company} - {Title}-Detail.{ext}". Company prefix is
    // dropped when the lookup didn't resolve, so a bad CompanyId never
    // produces a leading " - " on the filename.
    private string BuildDetailExportFileName(string ext)
    {
        var name = _title ?? "Detail";
        var prefix = string.IsNullOrWhiteSpace(_companyName) ? string.Empty : $"{_companyName} - ";
        return $"{prefix}{name}-Detail.{ext}";
    }

    // Mirrors what the grid shows: drops columns hidden in the saved report so
    // the export reflects visible fields only. Rows are left untouched — the
    // export loop iterates Columns, so dropped fields never get emitted.
    private QueryResponse BuildExportData(QueryResponse source)
    {
        var hidden = _hiddenColumns is { Count: > 0 }
            ? new HashSet<string>(_hiddenColumns, StringComparer.OrdinalIgnoreCase)
            : null;
        var hasOverrides = _templateColumnLabels is { Count: > 0 };
        if (hidden is null && !hasOverrides) return source;
        var visibleColumns = (hidden is null
            ? source.Columns
            : source.Columns.Where(c => !hidden.Contains(c.FieldId)))
            .WithLabelOverrides(_templateColumnLabels);
        return new QueryResponse
        {
            Columns = visibleColumns,
            Rows = source.Rows,
            TotalCount = source.TotalCount
        };
    }

}
