@using TleReportingDashboard.Web.Services
@using TleReportingDashboard.Web.Models
@using MudBlazor
@inject IThemeService ThemeSvc
@inject ICompanyRegistry CompanyRegistry
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject ILogger<AdminThemeTab> Logger

<MudStack Spacing="3" Class="pa-2">
    @* Scope picker — choose which company's theme to edit. The first
       option is the global default (company_id NULL) used as the
       fallback for any company without a per-company override.
       Switching the picker reloads the editor with that scope's tokens
       so the admin sees what they're about to save against. *@
    <MudStack Row AlignItems="AlignItems.Center" Spacing="2" Wrap="Wrap.Wrap">
        <MudSelect T="Guid?" Value="_selectedCompanyId" ValueChanged="OnScopeChanged"
                   Label="Theme scope" Variant="Variant.Outlined" Margin="Margin.Dense" Dense
                   Style="min-width: 280px;"
                   ToStringFunc="@CompanyToLabel">
            <MudSelectItem T="Guid?" Value="@((Guid?)null)">— Global default —</MudSelectItem>
            @foreach (var c in _companies.OrderBy(c => c.Name, StringComparer.OrdinalIgnoreCase))
            {
                <MudSelectItem T="Guid?" Value="@((Guid?)c.Id)">@c.Name (@c.Code)</MudSelectItem>
            }
        </MudSelect>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Style="max-width: 540px;">
            @ScopeHelpText
        </MudText>
    </MudStack>

    <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
        <MudText Typo="Typo.body2" Color="Color.Secondary" Style="max-width: 720px;">
            Tune the color palette for the chosen scope. Changes save to
            <code>RPT_app_theme</code> (one row per company; the global
            row is the fallback when a company has no override) and apply
            on the next page load. Click any swatch to open the picker;
            <strong>Reset to defaults</strong> reverts every token to the
            seeded values without saving.
        </MudText>
        <MudStack Row Spacing="1">
            <MudButton Variant="Variant.Outlined" Color="Color.Default"
                       StartIcon="@Icons.Material.Outlined.RestartAlt"
                       OnClick="ResetToDefaults">
                Reset to defaults
            </MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Outlined.Save"
                       Disabled="@_saving"
                       OnClick="Save">
                @(_saving ? "Saving..." : "Save")
            </MudButton>
        </MudStack>
    </MudStack>

    @if (_loading)
    {
        <QueryProgress Active="true" />
    }
    else
    {
        @* Live preview — renders mock chrome for every themed surface
           using the in-memory _theme values, so swatch / font edits
           reflect instantly before the admin commits Save. Borders use
           the actual border-default token so even the framing changes
           with the palette. *@
        <MudPaper Elevation="0" Class="theme-preview-card"
                  Style="@($"border: 1px solid {_theme.BorderDefault}; border-radius: 4px; padding: 12px;")">
            <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Style="margin-bottom: 8px;">
                <MudText Typo="Typo.subtitle2">Live preview</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    Updates as you edit. Save to make these styles real.
                </MudText>
            </MudStack>

            @* Outer page surface — wraps the chrome / dashboard / detail
               mock-ups so the SurfacePage + TextPrimary tokens read in
               context, not on a white card. BorderSubtle separates the
               nested mock surfaces from this outer page band. *@
            <div class="theme-preview-page"
                 style="@($"background: {_theme.SurfacePage}; color: {_theme.TextPrimary}; border: 1px solid {_theme.BorderSubtle};")">

                @* Top app bar — surface-toolbar bg + text-on-toolbar.
                   Mirrors MainLayout's header chrome (logo on the left,
                   nav actions on the right). *@
                <div class="theme-preview-toolbar"
                     style="@($"background: {_theme.SurfaceToolbar}; color: {_theme.TextOnToolbar}; border-bottom: 1px solid {_theme.BorderDefault};")">
                    <div class="theme-preview-toolbar-left">
                        <span class="theme-preview-logo"
                              style="@($"background: {_theme.AccentPrimary};")">TLE</span>
                        <span style="font-weight: 600;">Executive Reporting</span>
                    </div>
                    <div class="theme-preview-toolbar-right">
                        <span class="theme-preview-toolbar-link">Dashboards</span>
                        <span class="theme-preview-toolbar-link">Library</span>
                        <span class="theme-preview-toolbar-link">Admin</span>
                    </div>
                </div>

                @* Tab strip — surface-strip bg + text-secondary text.
                   Mirrors the section-header / sub-tab strips used on
                   the Admin and Report Editor pages. *@
                <div class="theme-preview-strip"
                     style="@($"background: {_theme.SurfaceStrip}; color: {_theme.TextSecondary}; border-bottom: 1px solid {_theme.BorderDefault};")">
                    <span class="theme-preview-strip-tab theme-preview-strip-tab--active"
                          style="@($"color: {_theme.AccentPrimary}; border-bottom-color: {_theme.AccentPrimary};")">Loans</span>
                    <span class="theme-preview-strip-tab">Payments</span>
                    <span class="theme-preview-strip-tab">Activity</span>
                </div>

                @* Two-column body — dashboard tile on the left, detail
                   viewer on the right. Falls back to stacked on narrow
                   widths via the .theme-preview-body grid rule below. *@
                <div class="theme-preview-body">

                    @* Master Dashboard tile mock — surface-card frame
                       with header band, data grid (header / striped
                       rows / hover / totals footer), and tile-chrome
                       footer band. Text formatting flags drive the
                       weight / style / decoration / family / size on
                       each band. *@
                    <div class="theme-preview-tile"
                         style="@($"background: {_theme.SurfaceCard}; border: 1px solid {_theme.BorderDefault};")">
                        <div class="theme-preview-tile-header"
                             style="@BandStyle(_theme.DashboardHeaderBg, _theme.DashboardHeaderText,
                                                _theme.DashboardHeaderBold, _theme.DashboardHeaderItalic, _theme.DashboardHeaderUnderline,
                                                _theme.DashboardHeaderFontFamily, _theme.DashboardHeaderFontSize)">
                            <span>Loans by Status</span>
                            <span class="theme-preview-tile-header-meta"
                                  style="@($"color: {_theme.TextMuted};")">⋮</span>
                        </div>
                        <table class="theme-preview-grid">
                            <thead>
                                <tr>
                                    <th style="@BandStyle(_theme.DashboardGridHeaderBg, _theme.DashboardGridHeaderText,
                                                          _theme.DashboardGridHeaderBold, _theme.DashboardGridHeaderItalic, _theme.DashboardGridHeaderUnderline,
                                                          _theme.DashboardGridHeaderFontFamily, _theme.DashboardGridHeaderFontSize)">Status</th>
                                    <th style="@BandStyle(_theme.DashboardGridHeaderBg, _theme.DashboardGridHeaderText,
                                                          _theme.DashboardGridHeaderBold, _theme.DashboardGridHeaderItalic, _theme.DashboardGridHeaderUnderline,
                                                          _theme.DashboardGridHeaderFontFamily, _theme.DashboardGridHeaderFontSize)">Count</th>
                                    <th style="@BandStyle(_theme.DashboardGridHeaderBg, _theme.DashboardGridHeaderText,
                                                          _theme.DashboardGridHeaderBold, _theme.DashboardGridHeaderItalic, _theme.DashboardGridHeaderUnderline,
                                                          _theme.DashboardGridHeaderFontFamily, _theme.DashboardGridHeaderFontSize)">Amount</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr><td>Funded</td><td>42</td><td>$1,234,567</td></tr>
                                <tr style="@($"background: {_theme.TableRowStriped};")"><td>In review</td><td>17</td><td>$543,210</td></tr>
                                <tr style="@($"background: {_theme.TableRowHover};")"><td>Pending</td><td>9</td><td>$210,000</td></tr>
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td style="@BandStyle(_theme.DashboardGridFooterBg, _theme.DashboardGridFooterText,
                                                          _theme.DashboardGridFooterBold, _theme.DashboardGridFooterItalic, _theme.DashboardGridFooterUnderline,
                                                          _theme.DashboardGridFooterFontFamily, _theme.DashboardGridFooterFontSize)">Totals</td>
                                    <td style="@BandStyle(_theme.DashboardGridFooterBg, _theme.DashboardGridFooterText,
                                                          _theme.DashboardGridFooterBold, _theme.DashboardGridFooterItalic, _theme.DashboardGridFooterUnderline,
                                                          _theme.DashboardGridFooterFontFamily, _theme.DashboardGridFooterFontSize)">68</td>
                                    <td style="@BandStyle(_theme.DashboardGridFooterBg, _theme.DashboardGridFooterText,
                                                          _theme.DashboardGridFooterBold, _theme.DashboardGridFooterItalic, _theme.DashboardGridFooterUnderline,
                                                          _theme.DashboardGridFooterFontFamily, _theme.DashboardGridFooterFontSize)">$1,987,777</td>
                                </tr>
                            </tfoot>
                        </table>
                        <div class="theme-preview-tile-footer"
                             style="@BandStyle(_theme.DashboardFooterBg, _theme.DashboardFooterText,
                                                _theme.DashboardFooterBold, _theme.DashboardFooterItalic, _theme.DashboardFooterUnderline,
                                                _theme.DashboardFooterFontFamily, _theme.DashboardFooterFontSize)">
                            <span>3 rows</span>
                            <span>Refreshed 2 min ago</span>
                        </div>
                    </div>

                    @* Detail view mock — grouped data grid with header
                       (table-header-bg, the generic grid header), then
                       a group header band, detail rows, group footer
                       (subtotal), and the sticky grand-total band. *@
                    <div class="theme-preview-tile"
                         style="@($"background: {_theme.SurfaceCard}; border: 1px solid {_theme.BorderDefault};")">
                        <div class="theme-preview-tile-header"
                             style="@BandStyle(_theme.DashboardHeaderBg, _theme.DashboardHeaderText,
                                                _theme.DashboardHeaderBold, _theme.DashboardHeaderItalic, _theme.DashboardHeaderUnderline,
                                                _theme.DashboardHeaderFontFamily, _theme.DashboardHeaderFontSize)">
                            <span>Detail view — Loan Activity</span>
                        </div>
                        <table class="theme-preview-grid">
                            <thead>
                                <tr>
                                    <th style="@($"background: {_theme.TableHeaderBg}; color: {_theme.TextPrimary};")">Borrower</th>
                                    <th style="@($"background: {_theme.TableHeaderBg}; color: {_theme.TextPrimary};")">Count</th>
                                    <th style="@($"background: {_theme.TableHeaderBg}; color: {_theme.TextPrimary};")">Amount</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td colspan="3"
                                        style="@BandStyle(_theme.DetailGroupHeaderBg, _theme.DetailGroupHeaderText,
                                                          _theme.DetailGroupHeaderBold, _theme.DetailGroupHeaderItalic, _theme.DetailGroupHeaderUnderline,
                                                          _theme.DetailGroupHeaderFontFamily, _theme.DetailGroupHeaderFontSize)">
                                        Status = Funded
                                    </td>
                                </tr>
                                <tr><td>Acme Co.</td><td>12</td><td>$345,000</td></tr>
                                <tr style="@($"background: {_theme.TableRowStriped};")"><td>Beta LLC</td><td>8</td><td>$210,000</td></tr>
                                <tr>
                                    <td style="@BandStyle(_theme.DetailGroupFooterBg, _theme.DetailGroupFooterText,
                                                          _theme.DetailGroupFooterBold, _theme.DetailGroupFooterItalic, _theme.DetailGroupFooterUnderline,
                                                          _theme.DetailGroupFooterFontFamily, _theme.DetailGroupFooterFontSize)">Subtotal</td>
                                    <td style="@BandStyle(_theme.DetailGroupFooterBg, _theme.DetailGroupFooterText,
                                                          _theme.DetailGroupFooterBold, _theme.DetailGroupFooterItalic, _theme.DetailGroupFooterUnderline,
                                                          _theme.DetailGroupFooterFontFamily, _theme.DetailGroupFooterFontSize)">20</td>
                                    <td style="@BandStyle(_theme.DetailGroupFooterBg, _theme.DetailGroupFooterText,
                                                          _theme.DetailGroupFooterBold, _theme.DetailGroupFooterItalic, _theme.DetailGroupFooterUnderline,
                                                          _theme.DetailGroupFooterFontFamily, _theme.DetailGroupFooterFontSize)">$555,000</td>
                                </tr>
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td style="@BandStyle(_theme.DetailGrandTotalBg, _theme.DetailGrandTotalText,
                                                          _theme.DetailGrandTotalBold, _theme.DetailGrandTotalItalic, _theme.DetailGrandTotalUnderline,
                                                          _theme.DetailGrandTotalFontFamily, _theme.DetailGrandTotalFontSize)">Grand total</td>
                                    <td style="@BandStyle(_theme.DetailGrandTotalBg, _theme.DetailGrandTotalText,
                                                          _theme.DetailGrandTotalBold, _theme.DetailGrandTotalItalic, _theme.DetailGrandTotalUnderline,
                                                          _theme.DetailGrandTotalFontFamily, _theme.DetailGrandTotalFontSize)">68</td>
                                    <td style="@BandStyle(_theme.DetailGrandTotalBg, _theme.DetailGrandTotalText,
                                                          _theme.DetailGrandTotalBold, _theme.DetailGrandTotalItalic, _theme.DetailGrandTotalUnderline,
                                                          _theme.DetailGrandTotalFontFamily, _theme.DetailGrandTotalFontSize)">$1,987,777</td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>

                @* Accents + text samples row — the four accent buttons
                   render as filled chips so admins see what Primary /
                   Success / Warning / Error look like against the page
                   surface, and three text samples show Primary /
                   Secondary / Muted side-by-side. *@
                <div class="theme-preview-footer-row">
                    <div class="theme-preview-accents">
                        <span class="theme-preview-chip" style="@($"background: {_theme.AccentPrimary}; color: #fff;")">Primary</span>
                        <span class="theme-preview-chip" style="@($"background: {_theme.AccentSuccess}; color: #fff;")">Success</span>
                        <span class="theme-preview-chip" style="@($"background: {_theme.AccentWarning}; color: #fff;")">Warning</span>
                        <span class="theme-preview-chip" style="@($"background: {_theme.AccentError}; color: #fff;")">Error</span>
                    </div>
                    <div class="theme-preview-texts">
                        <span style="@($"color: {_theme.TextPrimary};")">Primary text</span>
                        <span style="@($"color: {_theme.TextSecondary};")">Secondary text</span>
                        <span style="@($"color: {_theme.TextMuted};")">Muted text</span>
                    </div>
                </div>
            </div>
        </MudPaper>

        @* Group the 14 tokens visually so the admin understands what
           each one paints. Each group is its own MudPaper card with a
           heading + a flex row of swatches. *@
        <MudPaper Elevation="0" Style="border: 1px solid #E8EAED; border-radius: 4px; padding: 12px;">
            <MudText Typo="Typo.subtitle2" Style="margin-bottom: 8px;">Surfaces</MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary" Style="display: block; margin-bottom: 12px;">
                Backgrounds for the page, top app bar, tiles/cards, and secondary strips (tab strips, section headers).
            </MudText>
            <div class="theme-token-grid">
                @TokenSwatch("Page background",     _theme.SurfacePage,     v => _theme.SurfacePage = v)
                @TokenSwatch("Top app bar",         _theme.SurfaceToolbar,  v => _theme.SurfaceToolbar = v)
                @TokenSwatch("Tile / card",         _theme.SurfaceCard,     v => _theme.SurfaceCard = v)
                @TokenSwatch("Strip (tabs, etc.)",  _theme.SurfaceStrip,    v => _theme.SurfaceStrip = v)
            </div>
        </MudPaper>

        <MudPaper Elevation="0" Style="border: 1px solid #E8EAED; border-radius: 4px; padding: 12px;">
            <MudText Typo="Typo.subtitle2" Style="margin-bottom: 8px;">Text</MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary" Style="display: block; margin-bottom: 12px;">
                Body text on light surfaces (primary), captions and labels (secondary), placeholders and hints (muted), and text + icons sitting inside the dark app bar.
            </MudText>
            <div class="theme-token-grid">
                @TokenSwatch("Primary",            _theme.TextPrimary,    v => _theme.TextPrimary = v)
                @TokenSwatch("Secondary",          _theme.TextSecondary,  v => _theme.TextSecondary = v)
                @TokenSwatch("Muted",              _theme.TextMuted,      v => _theme.TextMuted = v)
                @TokenSwatch("On top app bar",     _theme.TextOnToolbar,  v => _theme.TextOnToolbar = v)
            </div>
        </MudPaper>

        <MudPaper Elevation="0" Style="border: 1px solid #E8EAED; border-radius: 4px; padding: 12px;">
            <MudText Typo="Typo.subtitle2" Style="margin-bottom: 8px;">Borders &amp; dividers</MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary" Style="display: block; margin-bottom: 12px;">
                Card borders and dashed empty-state outlines (default), and lighter inline dividers (subtle).
            </MudText>
            <div class="theme-token-grid">
                @TokenSwatch("Default",            _theme.BorderDefault, v => _theme.BorderDefault = v)
                @TokenSwatch("Subtle",             _theme.BorderSubtle,  v => _theme.BorderSubtle = v)
            </div>
        </MudPaper>

        <MudPaper Elevation="0" Style="border: 1px solid #E8EAED; border-radius: 4px; padding: 12px;">
            <MudText Typo="Typo.subtitle2" Style="margin-bottom: 8px;">Accents</MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary" Style="display: block; margin-bottom: 12px;">
                Brand color (primary buttons, links, drag indicators) plus the three semantic state colors. Status chips that map to data states keep their built-in colors regardless.
            </MudText>
            <div class="theme-token-grid">
                @TokenSwatch("Primary",            _theme.AccentPrimary, v => _theme.AccentPrimary = v)
                @TokenSwatch("Success",            _theme.AccentSuccess, v => _theme.AccentSuccess = v)
                @TokenSwatch("Warning",            _theme.AccentWarning, v => _theme.AccentWarning = v)
                @TokenSwatch("Error",              _theme.AccentError,   v => _theme.AccentError = v)
            </div>
        </MudPaper>

        <MudPaper Elevation="0" Style="border: 1px solid #E8EAED; border-radius: 4px; padding: 12px;">
            <MudText Typo="Typo.subtitle2" Style="margin-bottom: 8px;">Data tables</MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary" Style="display: block; margin-bottom: 12px;">
                The header band, row striping, and hover tint shared by every grid in the app — Report Library, Report Viewer, Detail View, admin tables.
            </MudText>
            <div class="theme-token-grid">
                @TokenSwatch("Header band",        _theme.TableHeaderBg,   v => _theme.TableHeaderBg = v)
                @TokenSwatch("Row hover",          _theme.TableRowHover,   v => _theme.TableRowHover = v)
                @TokenSwatch("Striped row",        _theme.TableRowStriped, v => _theme.TableRowStriped = v)
            </div>
        </MudPaper>

        <MudPaper Elevation="0" Style="border: 1px solid #E8EAED; border-radius: 4px; padding: 12px;">
            <MudText Typo="Typo.subtitle2" Style="margin-bottom: 8px;">Master Dashboard — tile chrome</MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary" Style="display: block; margin-bottom: 12px;">
                Each tile's chrome — the title band at the top (report name + tile-level controls) and the metadata strip at the bottom (row count + freshness stamp). Independent from the data grid INSIDE the tile, which has its own pair below.
            </MudText>
            <div class="theme-token-grid">
                @TokenSwatch("Header bg",          _theme.DashboardHeaderBg,   v => _theme.DashboardHeaderBg = v)
                @TokenSwatch("Header text",        _theme.DashboardHeaderText, v => _theme.DashboardHeaderText = v)
                @TokenSwatch("Footer bg",          _theme.DashboardFooterBg,   v => _theme.DashboardFooterBg = v)
                @TokenSwatch("Footer text",        _theme.DashboardFooterText, v => _theme.DashboardFooterText = v)
            </div>
            @TextFormatPanel("Header text",
                () => _theme.DashboardHeaderBold,       b => _theme.DashboardHeaderBold = b,
                () => _theme.DashboardHeaderItalic,     b => _theme.DashboardHeaderItalic = b,
                () => _theme.DashboardHeaderUnderline,  b => _theme.DashboardHeaderUnderline = b,
                () => _theme.DashboardHeaderFontFamily, v => _theme.DashboardHeaderFontFamily = v,
                () => _theme.DashboardHeaderFontSize,   v => _theme.DashboardHeaderFontSize = v)
            @TextFormatPanel("Footer text",
                () => _theme.DashboardFooterBold,       b => _theme.DashboardFooterBold = b,
                () => _theme.DashboardFooterItalic,     b => _theme.DashboardFooterItalic = b,
                () => _theme.DashboardFooterUnderline,  b => _theme.DashboardFooterUnderline = b,
                () => _theme.DashboardFooterFontFamily, v => _theme.DashboardFooterFontFamily = v,
                () => _theme.DashboardFooterFontSize,   v => _theme.DashboardFooterFontSize = v)
        </MudPaper>

        <MudPaper Elevation="0" Style="border: 1px solid #E8EAED; border-radius: 4px; padding: 12px;">
            <MudText Typo="Typo.subtitle2" Style="margin-bottom: 8px;">Master Dashboard — tile data grid</MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary" Style="display: block; margin-bottom: 12px;">
                The data table rendered inside each tile. Header band paints the sortable column-header row; footer band paints the sticky totals row at the bottom. Defaults match the legacy <code>lightblue</code> / <code>cornsilk</code> palette.
            </MudText>
            <div class="theme-token-grid">
                @TokenSwatch("Grid header bg",      _theme.DashboardGridHeaderBg,   v => _theme.DashboardGridHeaderBg = v)
                @TokenSwatch("Grid header text",    _theme.DashboardGridHeaderText, v => _theme.DashboardGridHeaderText = v)
                @TokenSwatch("Grid footer bg",      _theme.DashboardGridFooterBg,   v => _theme.DashboardGridFooterBg = v)
                @TokenSwatch("Grid footer text",    _theme.DashboardGridFooterText, v => _theme.DashboardGridFooterText = v)
            </div>
            @TextFormatPanel("Grid header text",
                () => _theme.DashboardGridHeaderBold,       b => _theme.DashboardGridHeaderBold = b,
                () => _theme.DashboardGridHeaderItalic,     b => _theme.DashboardGridHeaderItalic = b,
                () => _theme.DashboardGridHeaderUnderline,  b => _theme.DashboardGridHeaderUnderline = b,
                () => _theme.DashboardGridHeaderFontFamily, v => _theme.DashboardGridHeaderFontFamily = v,
                () => _theme.DashboardGridHeaderFontSize,   v => _theme.DashboardGridHeaderFontSize = v)
            @TextFormatPanel("Grid footer text",
                () => _theme.DashboardGridFooterBold,       b => _theme.DashboardGridFooterBold = b,
                () => _theme.DashboardGridFooterItalic,     b => _theme.DashboardGridFooterItalic = b,
                () => _theme.DashboardGridFooterUnderline,  b => _theme.DashboardGridFooterUnderline = b,
                () => _theme.DashboardGridFooterFontFamily, v => _theme.DashboardGridFooterFontFamily = v,
                () => _theme.DashboardGridFooterFontSize,   v => _theme.DashboardGridFooterFontSize = v)
        </MudPaper>

        <MudPaper Elevation="0" Style="border: 1px solid #E8EAED; border-radius: 4px; padding: 12px;">
            <MudText Typo="Typo.subtitle2" Style="margin-bottom: 8px;">Detail view — group &amp; total rows</MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary" Style="display: block; margin-bottom: 12px;">
                The drill-down Detail View groups rows by a chosen field and renders a header band, group footer (subtotal) band, and a sticky grand-total row at the bottom. Each band has its own background and text color so admins can keep heavy-data screens readable.
            </MudText>
            <div class="theme-token-grid">
                @TokenSwatch("Group header bg",        _theme.DetailGroupHeaderBg,   v => _theme.DetailGroupHeaderBg = v)
                @TokenSwatch("Group header text",      _theme.DetailGroupHeaderText, v => _theme.DetailGroupHeaderText = v)
                @TokenSwatch("Group footer bg",        _theme.DetailGroupFooterBg,   v => _theme.DetailGroupFooterBg = v)
                @TokenSwatch("Group footer text",      _theme.DetailGroupFooterText, v => _theme.DetailGroupFooterText = v)
                @TokenSwatch("Grand total bg",         _theme.DetailGrandTotalBg,    v => _theme.DetailGrandTotalBg = v)
                @TokenSwatch("Grand total text",       _theme.DetailGrandTotalText,  v => _theme.DetailGrandTotalText = v)
            </div>
            @TextFormatPanel("Group header text",
                () => _theme.DetailGroupHeaderBold,       b => _theme.DetailGroupHeaderBold = b,
                () => _theme.DetailGroupHeaderItalic,     b => _theme.DetailGroupHeaderItalic = b,
                () => _theme.DetailGroupHeaderUnderline,  b => _theme.DetailGroupHeaderUnderline = b,
                () => _theme.DetailGroupHeaderFontFamily, v => _theme.DetailGroupHeaderFontFamily = v,
                () => _theme.DetailGroupHeaderFontSize,   v => _theme.DetailGroupHeaderFontSize = v)
            @TextFormatPanel("Group footer text",
                () => _theme.DetailGroupFooterBold,       b => _theme.DetailGroupFooterBold = b,
                () => _theme.DetailGroupFooterItalic,     b => _theme.DetailGroupFooterItalic = b,
                () => _theme.DetailGroupFooterUnderline,  b => _theme.DetailGroupFooterUnderline = b,
                () => _theme.DetailGroupFooterFontFamily, v => _theme.DetailGroupFooterFontFamily = v,
                () => _theme.DetailGroupFooterFontSize,   v => _theme.DetailGroupFooterFontSize = v)
            @TextFormatPanel("Grand total text",
                () => _theme.DetailGrandTotalBold,       b => _theme.DetailGrandTotalBold = b,
                () => _theme.DetailGrandTotalItalic,     b => _theme.DetailGrandTotalItalic = b,
                () => _theme.DetailGrandTotalUnderline,  b => _theme.DetailGrandTotalUnderline = b,
                () => _theme.DetailGrandTotalFontFamily, v => _theme.DetailGrandTotalFontFamily = v,
                () => _theme.DetailGrandTotalFontSize,   v => _theme.DetailGrandTotalFontSize = v)
        </MudPaper>

        <MudAlert Severity="Severity.Info" Dense Variant="Variant.Outlined">
            Theme changes apply on the next page load. Refresh your browser after saving to see them; other signed-in users see the new palette on their next navigation.
        </MudAlert>
    }
</MudStack>

<style>
    .theme-token-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
        gap: 12px;
    }
    /* Word-style text-format strip rendered under the swatch grid for
       bands that have themable text. Wraps when the row gets narrow so
       Bold / Italic / Underline collapse below the family/size inputs
       on a tighter container. Top border keeps the visual separation
       from the swatch grid above. */
    .theme-text-format {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 12px;
        margin-top: 12px;
        padding-top: 12px;
        border-top: 1px dashed #E8EAED;
    }
    .theme-text-format-label {
        font-size: 0.8rem;
        font-weight: 600;
        color: #5F6368;
        min-width: 110px;
    }
    .theme-token-card {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding: 8px 12px;
        border: 1px solid #E8EAED;
        border-radius: 4px;
        background: #FAFAFA;
    }
    .theme-token-meta { display: flex; flex-direction: column; min-width: 0; flex: 1; }
    .theme-token-label { font-size: 0.85rem; font-weight: 500; color: #202124; }
    .theme-token-hex   { font-family: monospace; font-size: 0.7rem; color: #5F6368; }

    /* Plain HTML button styled as a color swatch tile. Background
       drives off the inline `style` attribute (set per-token to the
       current hex). Hover lifts the border to hint clickability. */
    .theme-token-swatch-btn {
        width: 44px;
        height: 32px;
        padding: 0;
        border: 1px solid #DADCE0;
        border-radius: 4px;
        cursor: pointer;
        flex-shrink: 0;
        transition: border-color 80ms ease-in-out, transform 80ms ease-in-out;
    }
    .theme-token-swatch-btn:hover {
        border-color: #1A73E8;
        transform: scale(1.05);
    }
    .theme-token-swatch-btn:active {
        transform: scale(0.97);
    }
    .theme-token-swatch-btn:focus-visible {
        outline: 2px solid #1A73E8;
        outline-offset: 2px;
    }

    /* ── Live preview block ──
       Mock UI sitting at the top of the editor. Everything inside is
       a thin DOM analog of the real surfaces — top app bar, strip,
       dashboard tile chrome + grid, detail group/total bands, accents
       and text samples. All visual values come from inline styles
       bound to _theme, so editing a swatch repaints instantly without
       a save. CSS here is layout-only (sizes, spacing, borders); no
       color values, no font-family, no font-size — those are the
       admin's domain. */
    .theme-preview-card { background: #FFFFFF; }
    .theme-preview-page {
        border-radius: 4px;
        overflow: hidden;
        margin-top: 4px;
    }
    .theme-preview-toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 8px 14px;
        font-size: 0.9rem;
    }
    .theme-preview-toolbar-left {
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .theme-preview-logo {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 28px;
        height: 28px;
        border-radius: 4px;
        color: #fff;
        font-weight: 700;
        font-size: 0.7rem;
        letter-spacing: 0.5px;
    }
    .theme-preview-toolbar-right {
        display: flex;
        align-items: center;
        gap: 14px;
        font-size: 0.85rem;
    }
    .theme-preview-toolbar-link {
        cursor: default;
        opacity: 0.85;
    }
    .theme-preview-strip {
        display: flex;
        align-items: center;
        gap: 18px;
        padding: 6px 14px;
        font-size: 0.8rem;
    }
    .theme-preview-strip-tab {
        padding: 4px 2px;
        border-bottom: 2px solid transparent;
    }
    .theme-preview-strip-tab--active { font-weight: 600; }
    .theme-preview-body {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
        gap: 12px;
        padding: 12px;
    }
    @@media (max-width: 900px) {
        .theme-preview-body { grid-template-columns: minmax(0, 1fr); }
    }
    .theme-preview-tile {
        border-radius: 4px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
    }
    .theme-preview-tile-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 8px 12px;
        font-size: 0.9rem;
    }
    .theme-preview-tile-header-meta { font-size: 1.1rem; line-height: 1; }
    .theme-preview-tile-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 6px 12px;
        font-size: 0.75rem;
    }
    .theme-preview-grid {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.8rem;
    }
    .theme-preview-grid th,
    .theme-preview-grid td {
        padding: 6px 10px;
        text-align: left;
    }
    .theme-preview-grid td { border-top: 1px solid rgba(0,0,0,0.04); }
    .theme-preview-footer-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        padding: 10px 14px 12px;
        flex-wrap: wrap;
    }
    .theme-preview-accents { display: flex; gap: 8px; flex-wrap: wrap; }
    .theme-preview-chip {
        display: inline-flex;
        align-items: center;
        padding: 4px 10px;
        border-radius: 999px;
        font-size: 0.75rem;
        font-weight: 600;
    }
    .theme-preview-texts {
        display: flex;
        gap: 16px;
        font-size: 0.85rem;
        flex-wrap: wrap;
    }
</style>

@code {
    [Parameter] public string CurrentUserEmail { get; set; } = string.Empty;

    private AppTheme _theme = AppTheme.Default();
    private bool _loading = true;
    private bool _saving;
    // null = global default scope; otherwise the per-company override
    // for this company id. Persists across saves so the admin can edit
    // company A, save, then pick company B without re-navigating.
    private Guid? _selectedCompanyId;
    private List<CompanySummary> _companies = new();

    private string ScopeHelpText => _selectedCompanyId is null
        ? "The global default applies to every company that doesn't have its own theme."
        : "Saved changes apply only to this company. Other companies keep using the global default (or their own override)."
        ;

    private string CompanyToLabel(Guid? id)
    {
        if (id is null) return "— Global default —";
        var c = _companies.FirstOrDefault(x => x.Id == id);
        return c is null ? id.ToString()! : $"{c.Name} ({c.Code})";
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _companies = await CompanyRegistry.GetActiveAsync();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Company list load failed — admin can still edit the global theme.");
            _companies = new();
        }
        await LoadThemeForScopeAsync();
        _loading = false;
    }

    private async Task LoadThemeForScopeAsync()
    {
        try
        {
            // Pass the scope id straight through; the service handles
            // the fall-through to the global row when the per-company
            // row doesn't exist yet. Surface that case as a snackbar so
            // the admin knows they're starting from the global palette.
            _theme = await ThemeSvc.GetAsync(_selectedCompanyId);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Theme load failed in admin tab — showing defaults.");
            _theme = AppTheme.Default();
        }
    }

    private async Task OnScopeChanged(Guid? newScope)
    {
        _selectedCompanyId = newScope;
        _loading = true;
        await LoadThemeForScopeAsync();
        _loading = false;
        StateHasChanged();
    }

    // Inline-style builder for the live preview's themable bands.
    // Combines the bg/text color pair with the four formatting flags
    // (bold / italic / underline + font family + font size) so each
    // mock band reads exactly like AppTheme.ToCssBlock() would render
    // it at runtime. Empty family / size collapse to "inherit" — same
    // semantic as the CSS-variable path.
    private string BandStyle(string bg, string text,
                              bool bold, bool italic, bool underline,
                              string family, string size)
    {
        var weight = bold ? "700" : "400";
        var style  = italic ? "italic" : "normal";
        var deco   = underline ? "underline" : "none";
        var fam    = string.IsNullOrWhiteSpace(family) ? "inherit" : family;
        var sz     = string.IsNullOrWhiteSpace(size)   ? "inherit" : size;
        return $"background: {bg}; color: {text};"
             + $" font-weight: {weight}; font-style: {style}; text-decoration: {deco};"
             + $" font-family: {fam}; font-size: {sz};";
    }

    // RenderFragment helper for the per-band text formatting block —
    // five Word-style controls (Bold / Italic / Underline + free-form
    // font family + font size). Each maps to a CSS variable emitted
    // by AppTheme.ToCssBlock(); empty Family/Size collapse to
    // "inherit" so unconfigured bands look identical to before.
    // Getter/setter Funcs follow the same pattern TokenSwatch uses
    // so individual fields on _theme can be mutated without passing
    // _theme around as a `ref`.
    private RenderFragment TextFormatPanel(
        string label,
        Func<bool> getBold, Action<bool> setBold,
        Func<bool> getItalic, Action<bool> setItalic,
        Func<bool> getUnderline, Action<bool> setUnderline,
        Func<string> getFamily, Action<string> setFamily,
        Func<string> getSize, Action<string> setSize) => __builder =>
    {
        <div class="theme-text-format">
            <span class="theme-text-format-label">@label</span>
            <MudCheckBox T="bool" Value="@getBold()" ValueChanged="@(b => { setBold(b); StateHasChanged(); })"
                         Label="Bold" Dense Size="Size.Small" Color="Color.Primary" />
            <MudCheckBox T="bool" Value="@getItalic()" ValueChanged="@(b => { setItalic(b); StateHasChanged(); })"
                         Label="Italic" Dense Size="Size.Small" Color="Color.Primary" />
            <MudCheckBox T="bool" Value="@getUnderline()" ValueChanged="@(b => { setUnderline(b); StateHasChanged(); })"
                         Label="Underline" Dense Size="Size.Small" Color="Color.Primary" />
            <MudTextField T="string" Value="@getFamily()" ValueChanged="@(v => { setFamily(v ?? ""); StateHasChanged(); })"
                          Label="Font family" Placeholder="(inherit)"
                          Variant="Variant.Outlined" Margin="Margin.Dense"
                          Style="max-width: 200px;" />
            <MudTextField T="string" Value="@getSize()" ValueChanged="@(v => { setSize(v ?? ""); StateHasChanged(); })"
                          Label="Font size" Placeholder="(inherit)"
                          HelperText="0.875rem · 14px"
                          Variant="Variant.Outlined" Margin="Margin.Dense"
                          Style="max-width: 140px;" />
        </div>
    };

    // RenderFragment helper so each token row stays a one-liner in the
    // markup. The MudColorPicker is keyed off the live token value;
    // ValueChanged routes back through the supplied setter so each
    // swatch update mutates the right field on _theme.
    private RenderFragment TokenSwatch(string label, string value, Action<string> setter) => __builder =>
    {
        // Each tile is a button that opens the named-color picker
        // dialog. The dialog returns the picked hex (named or custom);
        // setter mutates the right field on _theme and StateHasChanged
        // refreshes the swatch + hex caption. Resolving the CSS name
        // for the current hex (when one matches) gives the user a
        // recognizable label — "DodgerBlue" reads better than "#1E90FF".
        var name = CssNamedColors.NameForHex(value);
        <div class="theme-token-card">
            <div class="theme-token-meta">
                <span class="theme-token-label">@label</span>
                <span class="theme-token-hex">@(name is null ? value : $"{name} ({value})")</span>
            </div>
            <button type="button" class="theme-token-swatch-btn"
                    style="@($"background: {value};")"
                    title="@($"Click to change — currently {(name is null ? value : $"{name} ({value})")}")"
                    @onclick="@(() => OpenColorPicker(label, value, setter))">
            </button>
        </div>
    };

    private async Task OpenColorPicker(string label, string current, Action<string> setter)
    {
        var dialogParams = new DialogParameters<NamedColorPickerDialog>
        {
            { x => x.CurrentHex, current },
            { x => x.Label, label }
        };
        var dialog = await DialogService.ShowAsync<NamedColorPickerDialog>($"Pick — {label}", dialogParams, DialogPresets.Locked(MaxWidth.Small));
        var result = await dialog.Result;
        if (result is null || result.Canceled) return;
        if (result.Data is string picked && !string.IsNullOrWhiteSpace(picked))
        {
            setter(picked);
            StateHasChanged();
        }
    }

    private async Task Save()
    {
        _saving = true;
        try
        {
            var scopeLabel = _selectedCompanyId is null
                ? "Global theme"
                : $"Theme for {CompanyToLabel(_selectedCompanyId)}";
            await Snackbar.RunAsync(Logger, "saving theme",
                () => ThemeSvc.SaveAsync(_theme, _selectedCompanyId, CurrentUserEmail),
                successMessage: $"{scopeLabel} saved. Refresh affected browsers to see the new palette.");
        }
        finally
        {
            _saving = false;
        }
    }

    // Reverts the editor to AppTheme.Default() WITHOUT saving — admins
    // confirm with Save if they actually want to commit. Lets them
    // preview the seed palette in the swatches first.
    private void ResetToDefaults()
    {
        _theme = AppTheme.Default();
    }
}
