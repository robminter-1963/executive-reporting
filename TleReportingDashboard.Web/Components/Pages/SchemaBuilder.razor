    }

    private async Task Save()
    {
        if (string.IsNullOrEmpty(_jsonPreview)) return;
        _savedMessage = null;

        // Final guard: if any duplicate field ids slipped through (e.g. a
        // schema was loaded with duplicates already in it and the admin
        // didn't fix them), block the persist. The same data would crash
        // ReportBuilder / GridTemplateEditor on the very next render of
        // any consumer that loads it.
        var dupes = FindDuplicateFieldIds();
        if (dupes.Count > 0)
        {
            _savedSeverity = Severity.Error;
            _savedMessage = $"Cannot save: duplicate field id(s) — {string.Join(", ", dupes)}. Each id must be unique across the schema.";
            Snackbar.Add(_savedMessage, Severity.Error);
            return;
        }

        try
        {
            // Deserialize the preview into a SchemaConfig and route through the
            // store. In live mode it persists to RPT_schema_config; in mock
            // mode it updates the in-memory copy only. Either way Current
            // hot-swaps so every circuit sees the new schema immediately.
            var parsed = System.Text.Json.JsonSerializer.Deserialize<TleReportingDashboard.Web.Configuration.SchemaConfig>(
                _jsonPreview,
                AppJson.Compact);
            if (parsed is null)
            {
                _savedSeverity = Severity.Error;
                _savedMessage = "Could not parse preview JSON as SchemaConfig.";
                Snackbar.Add("Save failed: invalid JSON preview.", Severity.Error);
                return;
            }

            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var updatedBy = authState.User.FindFirst("preferred_username")?.Value
                ?? authState.User.Identity?.Name ?? "schema-builder";

            if (_selectedConnectionId is not Guid targetConnectionId)
            {
                _savedSeverity = Severity.Error;
                _savedMessage = "Pick a connection before saving.";
                return;
            }
            await SchemaConfigStoreSvc.SaveAsync(parsed, targetConnectionId, updatedBy);

            // Belt-and-suspenders cache nuke. SchemaConfigStore.SaveAsync
            // already invalidates "SchemaService:" entries, but ColumnMeta
            // / FieldConfig / resolved-fields data can ripple through
            // several services (QueryService, ReportDbService, etc.) that
            // might cache derived state. Nuke everything so the next read
            // from any service hits the DB fresh and picks up changes
            // like updated MinWidth / Format / RolesRequired without
            // requiring an app pool restart.
            CacheSvc.InvalidateAll();

            // Save was the explicit clean point — re-baseline so a
            // navigation away that follows doesn't re-prompt over the
            // just-saved state.
            _guard?.MarkClean();

            // Success path — inline indicator flashes near the Save button.
            // _savedMessage is reserved for error display below.
            if (_saveIndicator is not null) _ = _saveIndicator.Flash("Saved");
        }
        catch (Exception ex)
        {
            _savedSeverity = Severity.Error;
            _savedMessage = $"Failed to save: {ex.Message}";
            Snackbar.Add($"Save failed: {ex.Message}", Severity.Error);
        }
    }

    private static string FormatLabel(string columnName)
    {
        // BORR_NAME → Borr Name, LOANAMT → Loanamt
        var parts = columnName.Split('_', StringSplitOptions.RemoveEmptyEntries);
        return string.Join(" ", parts.Select(p =>
            p.Length > 1
                ? char.ToUpper(p[0]) + p[1..].ToLower()
                : p.ToUpper()));
    }

    // Heuristic guesses for the Empower-era TLE schema. Only accepted if the
    // guessed domain is actually in the current connection's domain list —
    // otherwise we return empty so the user picks from their own list rather
    // than seeing a stray "Loan (legacy)" on every Postgres connection.
    private static string GuessDomain(string tableName, IEnumerable<string> availableDomains)
    {
        var guess = tableName.ToUpperInvariant() switch
        {
            _ when tableName.Contains("BORR", StringComparison.OrdinalIgnoreCase) => "Borrower",
            _ when tableName.Contains("PROP", StringComparison.OrdinalIgnoreCase) => "Property",
            _ when tableName.Contains("CONTACT", StringComparison.OrdinalIgnoreCase) => "Organization",
            _ when tableName.Contains("REGULAT", StringComparison.OrdinalIgnoreCase) => "Compliance",
            _ when tableName.Contains("INCOME", StringComparison.OrdinalIgnoreCase) => "Borrower",
            _ when tableName.Contains("CODES", StringComparison.OrdinalIgnoreCase) => "Loan",
            _ => "Loan"
        };
        return availableDomains.Any(d => string.Equals(d, guess, StringComparison.OrdinalIgnoreCase))
            ? guess
            : string.Empty;
    }

    public class FieldEntry
    {
        public string Id { get; set; } = string.Empty;
        public string Label { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public string Domain { get; set; } = string.Empty;
        // Comma-separated synonyms / search aliases that match the field
        // in the picker's search box. See FieldDefinition.SearchAliases
        // for the full rationale. Empty by default; admins author per field.
        public string? SearchAliases { get; set; }
        public string DataType { get; set; } = "text";
        public string FieldType { get; set; } = "Dimension";
        public int? MaxLength { get; set; }
        // Optional grid column min-width hint (px). Surfaces in FieldEditDialog
        // and gets serialized into schema_config.json. Honored at render time
        // by ReportGrid.GetColumnWidths.
        public int? MinWidth { get; set; }
        public int? CodeSetId { get; set; }
        public string AllowedAggregationsStr { get; set; } = string.Empty;
        public string SourceTable { get; set; } = string.Empty;
        public string SourceColumn { get; set; } = string.Empty;
        public string? SqlExpression { get; set; }
        public string? SqlPreamble { get; set; }
        public List<string>? JoinIds { get; set; }  // References to existing joins from the Joins tab
        public string? SqlJoin { get; set; }
        public List<string>? LookupIds { get; set; }

        // FK to a LookupTypeDefinition (the new "Lookup Types" tab in
        // Schema Builder). Drives the header-filter chip picker for this
        // field — the lookup type's SELECT populates the chips. Distinct
        // from CodeSetId (Empower SET_CODESETS) and from LookupIds (CTE
        // lookups for sort/join). Always paired with FilterPredicateSql
        // below — without one of the two set, the picker can't emit a
        // useful filter.
        public string? LookupTypeId { get; set; }

        // Admin-authored WHERE fragment emitted when the user filters on
        // this field via the LookupType picker. Two substitution modes:
        //   • Placeholder: predicate contains "{values}" — system
        //     substitutes "(@p0, @p1, ...)" bound to the user's picks.
        //   • Implicit: no placeholder — system AND-appends
        //     "AND <LookupType.SourceTableRef>.<ValueColumn> IN (@p0, ...)"
        //     after the admin's predicate.
        // Nothing about the predicate is hardcoded; admins author it
        // freely (joining the lookup table to the data, etc.).
        public string? FilterPredicateSql { get; set; }

        // Alternate column expression for filter comparison when bound to
        // a LookupType. Set to e.g. "c_30.CODEINT" on a field whose
        // SourceColumn is c_30.CODEDESC, so the picker can send CODENUMs
        // and the WHERE becomes "c_30.CODEINT IN (@p0, ...)" — same row,
        // just a different column on it. Distinct from FilterPredicateSql
        // (which handles cases needing a separate joined lookup table).
        public string? FilterColumn { get; set; }

        public string? RolesRequired { get; set; }
        public Dictionary<string, int>? ValueSortOrder { get; set; }
        // Display format — applied at render/export time, not in SQL.
        public string? Format { get; set; }
        // When true and the connection is Postgres with a display timezone
        // configured, the emitter wraps this field's expression with
        // `AT TIME ZONE '<tz>'`. Persisted to schema_config.json alongside
        // the rest of the field shape.
        public bool ApplyTimezoneConversion { get; set; }
        // Admin-asserted single-column uniqueness — bypasses the
        // information_schema constraint check, which can fail on locked-
        // down accounts. Drives the Sort By "(-)" marker and the OFFSET
        // pagination fallback when the live constraint lookup returns
        // nothing.
        public bool IsUnique { get; set; }
    }

    public class JoinEntry
    {
        public string Id { get; set; } = string.Empty;
        public string JoinType { get; set; } = "LEFT JOIN";
        public string TargetTable { get; set; } = string.Empty;
        public string Alias { get; set; } = string.Empty;
        public string OnClause { get; set; } = string.Empty;
        public string ExtraCondition { get; set; } = string.Empty;
        public bool UseRawSql { get; set; }
        public string RawSql { get; set; } = string.Empty;
        // Optional. The parent table this join depends on. When set, the
        // query builder picks this join in preference to others targeting
        // the same table whenever the report's primary table matches.
        public string SourceTable { get; set; } = string.Empty;
        public string SourceAlias { get; set; } = string.Empty;
        // Optional. Restricts this join to reports whose primary table
        // matches. Empty = generic (eligible for any primary), preserving
        // legacy behavior. When set, QueryBuilder filters out this join
        // for non-matching reports (PR-2) so a "lead → account" composite
        // doesn't collide with a generic "anything → account".
        public string PrimaryTable { get; set; } = string.Empty;
        public string PrimaryAlias { get; set; } = string.Empty;

        public string BuildSql()
        {
            if (UseRawSql && !string.IsNullOrWhiteSpace(RawSql))
                return RawSql;

            var target = string.IsNullOrWhiteSpace(Alias)
                ? TargetTable
                : $"{TargetTable} AS {Alias}";
            var sql = $"{JoinType} {target} ON {OnClause}";
            if (!string.IsNullOrWhiteSpace(ExtraCondition))
                sql += $" AND {ExtraCondition}";
            return sql;
        }
    }

    public enum TableType
    {
        LoanSingle,      // No WHICHBORR, no IDX — one row per loan
        LoanMultiple,    // IDX only — multiple rows per loan
        BorrowerSingle,  // WHICHBORR only — one row per borrower
        BorrowerMultiple // WHICHBORR + IDX — multiple rows per borrower
    }

