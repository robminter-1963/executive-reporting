@page "/help"
@page "/help/{Section}"
@rendermode InteractiveServer
@inject NavigationManager Navigation

<PageTitle>Help - Executive Reporting Suite</PageTitle>

<MudMainContent Style="padding: 0; max-width: 900px; margin-left: 15px;">
    <MudStack Spacing="3">
        <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
            <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                           OnClick="@(() => Navigation.NavigateTo("/"))" title="Back" />
            <MudText Typo="Typo.h5" Style="font-weight: 600;">Help</MudText>
        </MudStack>

        @* ── Table of Contents ── *@
        <MudPaper Elevation="0" Class="pa-4" Style="border: 1px solid #E8EAED; border-radius: 4px;">
            <MudText Typo="Typo.subtitle1" Style="font-weight: 600;" Class="mb-2">Contents</MudText>
            <MudStack Spacing="0">
                @foreach (var s in _sections)
                {
                    var sec = s;
                    <MudLink Href="@($"/help/{sec.Key}")" Typo="Typo.body2" Style="padding: 4px 0;"
                             Color="@(sec.Key == (Section ?? _sections[0].Key) ? Color.Primary : Color.Default)">
                        @sec.Title
                    </MudLink>
                }
            </MudStack>
        </MudPaper>

        @* ── Content ── *@
        @{
            var active = _sections.FirstOrDefault(s => s.Key == (Section ?? _sections[0].Key));
        }
        @if (active is not null)
        {
            <MudPaper Elevation="0" Class="pa-4" Style="border: 1px solid #E8EAED; border-radius: 4px;">
                <MudText Typo="Typo.h6" Style="font-weight: 600;" Class="mb-3">@active.Title</MudText>
                @((MarkupString)active.Html)
            </MudPaper>
        }
    </MudStack>
</MudMainContent>

@code {
    [Parameter] public string? Section { get; set; }

    private record HelpSection(string Key, string Title, string Html);

    private readonly List<HelpSection> _sections = new()
    {
        new("getting-started", "Getting Started", @"
<h4>Signing in</h4>
<p>The Executive Reporting Suite uses your organization's Entra ID (Microsoft) account. You'll be redirected to sign in the first time you visit. The user menu in the top-right shows your name and a <strong>Sign out</strong> option once you're signed in.</p>

<h4>What you'll see first</h4>
<ol>
<li>If you have access to a single company, you go straight to that company's <strong>Master Dashboard</strong>.</li>
<li>If you have access to more than one company (or you're an admin), you land on a <strong>company picker</strong> with one card per company. Click any card to enter that company's Master Dashboard.</li>
<li>Admins and System Support users see every active company; regular users see only the companies they've been granted access to.</li>
</ol>

<h4>Navigation map</h4>
<table style='width:100%; border-collapse:collapse; margin:12px 0;'>
<tr style='background:#F8F9FA;'><th style='text-align:left; padding:8px; border:1px solid #E8EAED;'>Where</th><th style='text-align:left; padding:8px; border:1px solid #E8EAED;'>How to get there</th></tr>
<tr><td style='padding:8px; border:1px solid #E8EAED;'>Master Dashboard</td><td style='padding:8px; border:1px solid #E8EAED;'>Pick a company from the picker, or click the Ralis logo when you have access to multiple companies.</td></tr>
<tr><td style='padding:8px; border:1px solid #E8EAED;'>Report Library</td><td style='padding:8px; border:1px solid #E8EAED;'>Click the back arrow on the Master Dashboard, or the chart icon on the user menu.</td></tr>
<tr><td style='padding:8px; border:1px solid #E8EAED;'>Report Builder</td><td style='padding:8px; border:1px solid #E8EAED;'>From the Library: <strong>+ New Report</strong> or click the edit pencil on any of your reports.</td></tr>
<tr><td style='padding:8px; border:1px solid #E8EAED;'>Admin</td><td style='padding:8px; border:1px solid #E8EAED;'>User menu (top-right) → <strong>Admin</strong>. Visible if your role grants access to at least one admin section.</td></tr>
<tr><td style='padding:8px; border:1px solid #E8EAED;'>User Preferences</td><td style='padding:8px; border:1px solid #E8EAED;'>User menu → <strong>User Preferences</strong>.</td></tr>
<tr><td style='padding:8px; border:1px solid #E8EAED;'>Notifications</td><td style='padding:8px; border:1px solid #E8EAED;'>Bell icon next to the user menu. The badge counts unread items.</td></tr>
<tr><td style='padding:8px; border:1px solid #E8EAED;'>Help</td><td style='padding:8px; border:1px solid #E8EAED;'>Question-mark icon at the far right of the top app bar.</td></tr>
</table>

<h4>The environment badge</h4>
<p>If you see a <strong>STAGING</strong> chip next to the Ralis logo, you're on the staging instance — changes there don't affect production. Production has a quiet <strong>PRODUCTION</strong> badge so admins always know which environment they're touching.</p>"),

        new("master-dashboard", "Master Dashboard", @"
<p>The Master Dashboard is the per-company home page. It shows multiple report tiles organized into <strong>tabs</strong> (top-level groups) and optional <strong>sections</strong> (visual groupings within a tab).</p>

<h4>Layout</h4>
<ul>
<li><strong>Tabs</strong> — Top-level groupings (e.g. ""Pipeline"", ""Funded Loans""). Click a tab to switch. Layout edits are preserved when you switch tabs — no need to save first.</li>
<li><strong>Sections</strong> — Sub-groupings inside a tab. When a tab has sections, a small section-tab strip appears below the tile area; click a section to focus its tiles.</li>
<li><strong>Tiles</strong> — One per report. Each tile renders as a card with a header band, a data area, and a small footer band.</li>
</ul>

<h4>Reading a tile</h4>
<ul>
<li><strong>Header band</strong> — Report name on the left; a chart-toggle button (when the report is configured for charts), an <strong>export</strong> button (download as Excel or CSV), and edit-mode controls on the right.</li>
<li><strong>Data area</strong> — Either a summary table or a chart, depending on the report's dashboard config. Numeric columns are right-aligned. Long values truncate with an ellipsis; hover to see the full text.</li>
<li><strong>Footer band</strong> — Row count on the left, freshness stamp on the right (""updated 3m ago"", ""2h ago"", etc.). Useful for spotting stale data at a glance.</li>
</ul>

<h4>Drilling into details</h4>
<ul>
<li>Click any <strong>row</strong> to open the underlying detail records in a new browser tab. The detail page heading reads ""<strong>Tab Name</strong> — <strong>Report Name</strong>"" so you remember where you came from.</li>
<li>Click the <strong>Totals</strong> footer row to see all records (no group filter applied).</li>
</ul>

<h4>Exporting from a tile</h4>
<p>The download icon in each tile's header opens the same Export menu as the Detail Viewer (Excel <code>.xlsx</code> or CSV). The exported file contains the underlying detail rows (not the aggregated dashboard view), formatted with proper Excel currency and date types where applicable.</p>

<h4>Auto-refresh</h4>
<p>If you sit on a dashboard for <strong>5 minutes with no activity</strong> (no mouse, keyboard, or scroll), the tiles silently re-fetch their data. This is paused while you're in edit mode so unsaved layout edits aren't disturbed.</p>

<h4>Edit mode</h4>
<ol>
<li>Click <strong>Edit Layout</strong> in the dashboard header to enter edit mode.</li>
<li><strong>Add report</strong> — Adds a tile from any report flagged ""Show on Master Dashboard"".</li>
<li><strong>Add tab / Add section</strong> — Create new groupings.</li>
<li><strong>Reorder tiles</strong> — Drag a tile by its header to a new position. A blue outline marks the drop target. Drop on the rightmost/bottom-most tile to land at the end.</li>
<li><strong>Reorder sections</strong> — Same drag handles on section header rows.</li>
<li><strong>Move tile across tabs</strong> — Drag onto the destination tab's header.</li>
<li><strong>Resize</strong> — Drag the blue triangle at the bottom-right of a tile.</li>
<li><strong>Tile title alignment</strong> — Use the left/center/right buttons that appear in each tile's header in edit mode.</li>
<li><strong>Move-to-section picker</strong> — Click the section icon in a tile's header to reassign it.</li>
<li><strong>Remove a tile</strong> — Click the X on a tile (batched until you save).</li>
<li><strong>Rename</strong> — Double-click a tab name or the company logo's title.</li>
<li><strong>Logo</strong> — Click the image icon to upload a new company logo.</li>
<li>Click <strong>Save Layout</strong> to persist all changes, or <strong>Cancel</strong> to discard.</li>
</ol>

<p><strong>Tip:</strong> Right-click a tile to see the SQL that produced its data. Useful for diagnosing unexpected numbers.</p>"),

        new("report-library", "Report Library", @"
<p>The <strong>Report Library</strong> is where saved reports live. Three tabs:</p>
<ul>
<li><strong>My Reports</strong> — Reports you own. Admins viewing in admin mode see this tab as ""All Reports"" and get every report in the system.</li>
<li><strong>Shared With Me</strong> — Reports other users explicitly shared with you.</li>
<li><strong>Recent</strong> — Your 10 most-recently-run reports.</li>
</ul>
<p>Reports within each tab are sorted alphabetically. The page you're on within each tab is remembered — opening a report from page 3 and coming back lands you on page 3, not page 1.</p>

<h4>Filtering and search</h4>
<p>The toolbar above the tabs has three filters that apply to all three tabs:</p>
<ul>
<li><strong>Search</strong> — Filters by report name (debounced as you type).</li>
<li><strong>Company</strong> — Filters reports to one company. Persisted per-user across sessions.</li>
<li><strong>Category</strong> — Free-text grouping admins set per-report (e.g. ""Operations"", ""Financial""). Visible only when at least one report has a category set. Pick ""— Uncategorized —"" to find reports without one.</li>
</ul>

<h4>Reading a report row</h4>
<ul>
<li><strong>Name</strong> — Display name. If the admin set a separate Internal Name, that's shown as the primary label and ""tile: PublicName"" appears below it.</li>
<li><strong>Category chip</strong> (Info-color, when set) — The report's category.</li>
<li><strong>Templated chip</strong> (Tertiary-color, when set) — The report inherits its column layout from a Grid Template. Editing the template updates every linked report on next render.</li>
<li><strong>Connection</strong> — Which data source this report queries.</li>
<li><strong>Fields</strong> — How many fields are selected.</li>
<li><strong>Last Run</strong> — When the report last produced data.</li>
<li><strong>Scheduled</strong> — A clock icon + the next run time, when a schedule is active.</li>
<li><strong>Dashboard</strong> — Whether the report is flagged ""Show on Master Dashboard"".</li>
</ul>

<h4>Per-row actions</h4>
<table style='width:100%; border-collapse:collapse; margin:12px 0;'>
<tr style='background:#F8F9FA;'><th style='padding:8px; border:1px solid #E8EAED;'>Icon</th><th style='padding:8px; border:1px solid #E8EAED;'>Action</th></tr>
<tr><td style='padding:8px; border:1px solid #E8EAED;'>&#9654; Play</td><td style='padding:8px; border:1px solid #E8EAED;'>Open in the Viewer (read-only run).</td></tr>
<tr><td style='padding:8px; border:1px solid #E8EAED;'>&#9998; Edit</td><td style='padding:8px; border:1px solid #E8EAED;'>Open in the Builder.</td></tr>
<tr><td style='padding:8px; border:1px solid #E8EAED;'>&#10064; Clone</td><td style='padding:8px; border:1px solid #E8EAED;'>Create a copy you own.</td></tr>
<tr><td style='padding:8px; border:1px solid #E8EAED;'>&#8599; Share</td><td style='padding:8px; border:1px solid #E8EAED;'>Share with a specific user (sends them a notification).</td></tr>
<tr><td style='padding:8px; border:1px solid #E8EAED;'>&#128197; Schedule</td><td style='padding:8px; border:1px solid #E8EAED;'>Set up recurring email exports.</td></tr>
<tr><td style='padding:8px; border:1px solid #E8EAED;'>&#128465; Delete</td><td style='padding:8px; border:1px solid #E8EAED;'>Owner-only.</td></tr>
</table>

<h4>Admin view toggle</h4>
<p>Admins see an <strong>Admin view</strong> switch in the toolbar. When on, the My Reports tab broadens to <em>every user's</em> reports and adds an Owner column. Edit and Delete still require ownership; the toggle only affects what's listed.</p>"),

        new("building-reports", "Building a Report", @"
<h4>Quick start</h4>
<ol>
<li>Go to the Report Library and click <strong>+ New Report</strong>.</li>
<li>Pick a <strong>Connection</strong> (the data source — locked once the report is saved).</li>
<li>Click fields in the <strong>Field Picker</strong> on the left to add them.</li>
<li>Click <strong>Run Query</strong>. The Table view fills in.</li>
<li>Optionally tune Sort By, Group By, custom filters, or set up a chart.</li>
<li>Type a name in the title bar (double-click to edit), optionally pick a Category and Internal Name, then click <strong>Save</strong>.</li>
</ol>

<h4>Naming and grouping fields</h4>
<ul>
<li><strong>Name</strong> — Public-facing label. Shown to end users.</li>
<li><strong>Internal Name</strong> — Admin-facing label, optional. Used in the Master Dashboard's ""Add Report"" picker to disambiguate same-named variants.</li>
<li><strong>Category</strong> — Optional admin-curated grouping. Shows as a filter dropdown and a chip in the Library.</li>
</ul>

<h4>Sort and pagination stability</h4>
<p>The <strong>Sort By</strong> dropdown picks the primary sort column. The <strong>Then By</strong> dropdown is a tiebreaker — required for stable pagination when the primary column isn't unique (e.g. Status). Without it, two rows with the same Status can swap places between pages on Postgres OFFSET queries. Pick a unique column (suffix ""(-)"") for the Then By to lock row order.</p>
<p>For LOOKUP-typed fields, ORDER BY uses the lookup's stored sort rank, not the raw value — so ordering by Status follows the LOOKUP's intended sequence, not alphabetical.</p>

<h4>From a Grid Template</h4>
<ol>
<li>Click <strong>+ New Report</strong>.</li>
<li>Click the <strong>Template</strong> button in the toolbar.</li>
<li>Pick a template, click <strong>Apply</strong>, then Run Query.</li>
<li>Save. The link is persisted; subsequent edits to the template flow through to this report on next load.</li>
</ol>

<h4>Template-linked reports</h4>
<p>When a report is linked to a template:</p>
<ul>
<li>Only the template's fields are shown — you can't add or remove fields.</li>
<li>Each field has an <strong>eye icon</strong> (show/hide) instead of a checkbox.</li>
<li>An amber banner reads: ""Fields locked to template [name].""</li>
<li>The template owns column order and default sort. The report can only customize column visibility.</li>
</ul>
<p>Click the <strong>unlink</strong> (chain-break) icon next to the template name to detach. The report keeps its current fields but becomes independent.</p>

<h4>Contextual help icons</h4>
<p>Look for small <strong>?</strong> icons next to confusing controls (Sort By, Then By, Group By, Distinct, Scope on the Roles tab). Hover for an explanation.</p>

<h4>Slow queries</h4>
<p>While a query is running, a progress bar shows the elapsed time. Past 8 seconds it turns amber (""Still running…""). Past 20 seconds it turns red (""Slow query — connection or schema config may be the cause"").</p>"),

        new("table-view", "Table View", @"
<h4>Sorting</h4>
<p>Click any <strong>column header</strong> to sort ascending/descending. The <strong>Sort By</strong> and <strong>Then By</strong> dropdowns above the grid set a persistent sort that saves with the report.</p>

<h4>Resizing columns</h4>
<p>Hover over the right edge of a column header until the resize cursor appears. Click and drag.</p>

<h4>Reordering and hiding columns</h4>
<p>The <strong>Selected Fields</strong> bar above the grid shows a chip per column. Drag a chip to reorder; drop near the rightmost chip (or its tail zone) to push it to the end. Click the eye icon on a chip to hide that column from the table without removing it from the query.</p>

<p>Hidden columns stay in the query so they're available for dashboard Group By, custom filters, and exports if you choose. Hidden columns are excluded from Excel/CSV exports unless you re-enable them.</p>

<h4>Calculated columns</h4>
<p>The <strong>+ Calc</strong> button (in the Selected Fields bar) opens a dialog to add a per-report calculated column. Two flavors:</p>
<ul>
<li><strong>Formula</strong> — Tiny client-side language: <code>+ - * /</code>, parens, unary minus, <code>[Field Name]</code> identifiers. Evaluated per row in the browser.</li>
<li><strong>SQL Expression</strong> — Raw SQL appended to the SELECT. Use for CASE, COALESCE, subqueries, function calls, lookups. Specify the join ids the expression needs so they're pulled into the FROM clause.</li>
</ul>"),

        new("chart-view", "Chart View", @"
<ol>
<li>Click the <strong>Chart</strong> tab after running a query.</li>
<li>Choose a chart type: <strong>Bar</strong>, <strong>Line</strong>, or <strong>Pie</strong>.</li>
<li>Pick an <strong>X-Axis</strong> (a dimension like Status, State, Month).</li>
<li>Pick a <strong>Y-Axis</strong> (typically a numeric measure).</li>
<li>The chart renders automatically.</li>
</ol>
<p>Fields with custom sort orders (Status, etc.) sort the chart in their lookup-defined sequence, not alphabetical.</p>"),

        new("dashboard-view", "Dashboard View", @"
<h4>Setting up</h4>
<ol>
<li>Click the <strong>Dashboard</strong> tab after running a query.</li>
<li>Pick a <strong>Group By</strong> field. The Group By dropdown lists every field on the connection, even ones not in the report — selecting one auto-adds it to the query while keeping it hidden from the detail grid.</li>
<li>Pick a <strong>Primary Measure</strong> (e.g. Loan Amount) and an <strong>Aggregation</strong> (Sum, Avg, Count, Min, Max).</li>
<li>Optionally add <strong>extra measures</strong> via the <strong>+ Measure</strong> button.</li>
<li>Pick a <strong>Chart</strong> type (Bar, Pie, Line, or None).</li>
</ol>

<h4>Customizing</h4>
<ul>
<li><strong>Rename headers</strong> — Double-click a column header.</li>
<li><strong>Reorder columns</strong> — Drag chips in the Columns bar.</li>
<li><strong>Toggle % of Total</strong>, <strong>Toggle Summary Cards</strong>, <strong>Default Sort</strong>.</li>
</ul>

<h4>Show on Master Dashboard</h4>
<p>Check <strong>Show on Master Dashboard</strong> to make this report available as a tile on the Master Dashboard's ""Add Report"" picker.</p>"),

        new("detail-view", "Detail View (Drill-down)", @"
<p>The Detail View opens when you click a row on a Dashboard view, a Master Dashboard tile, or a chart segment. It opens in a <strong>new browser tab</strong> so you don't lose your place.</p>

<h4>What you see</h4>
<ul>
<li><strong>Header band</strong> — Tab name (when launched from a Master Dashboard tile) + report name. The active company's logo sits below the header so you always know whose data you're looking at.</li>
<li><strong>Group banner</strong> — When the source dashboard had a Group By and you clicked a specific group's row, the banner reads ""Showing only rows where Status = Funded"" (or whichever filter applies). When you clicked the Totals row, it reads ""All Records"".</li>
<li><strong>Row count + Show SQL + Export</strong> — Top-right of the header.</li>
</ul>

<h4>Grouped layout</h4>
<p>When the source dashboard had a Group By, the detail rows are clustered by that field with a header band before each cluster, a footer (subtotal) band after each cluster, and a sticky <strong>grand total</strong> row pinned to the bottom of the scroll container.</p>

<h4>Show SQL</h4>
<p>The <strong>Show SQL</strong> button (top-right) opens a dialog with the exact query that produced this view, the parameters bound to it, and any row-level scoping that was applied. Useful for diagnosing unexpected numbers without tailing logs.</p>

<h4>Exporting</h4>
<p>The Export menu emits Excel (.xlsx) or CSV. Excel files use proper cell types — currency cells render as Currency, date cells as Date — so SUM, sort, and filter work natively in Excel. Hidden columns are excluded.</p>"),

        new("custom-filters", "Custom Filters", @"
<p>Custom filters are pre-defined query conditions an admin sets up per-connection. End users just toggle them on/off.</p>
<ol>
<li>Look for <strong>Custom Filters:</strong> below the regular filter bar in the Report Builder.</li>
<li>Click a chip to toggle it on (filled blue = active).</li>
<li>Click again to toggle off.</li>
<li>Click <strong>Run Query</strong> to apply.</li>
</ol>
<p>Active filter ids are saved with the report and apply in the Viewer and on Master Dashboard tiles too.</p>"),

        new("exporting", "Exporting Data", @"
<h4>Where the Export menu lives</h4>
<ul>
<li><strong>Report Builder / Report Viewer</strong> — Toolbar, ""Export"" outlined button.</li>
<li><strong>Detail Viewer</strong> — Top-right of the header bar.</li>
<li><strong>Master Dashboard tile</strong> — Compact download icon in the tile header.</li>
</ul>

<h4>Excel formatting</h4>
<p>Excel exports apply proper cell types so calculations work natively in the file:</p>
<ul>
<li><strong>Currency</strong> columns → Excel Currency format (<code>$#,##0.00</code>, red negatives).</li>
<li><strong>Date</strong> columns → Excel Date format (<code>mm/dd/yyyy</code> by default; respects the field's custom format when one is set).</li>
<li><strong>Integer</strong> columns → Excel Number with thousands separator.</li>
<li><strong>Phone</strong> columns → Formatted as text using the field's mask.</li>
</ul>

<h4>Visible columns only</h4>
<p>Hidden columns are excluded from the export. Re-enable them via the Selected Fields bar (eye icon) before exporting if you need them.</p>

<h4>Tile exports</h4>
<p>Exporting from a Master Dashboard tile gives you the underlying detail rows, not the aggregated dashboard projection. Equivalent to opening the tile's drill-down in ""All Records"" view and exporting from there — but without the navigation.</p>"),

        new("grid-templates", "Grid Templates", @"
<p>Grid templates define reusable field selections + column layouts. Linked reports inherit the template's settings.</p>

<h4>What the template controls</h4>
<ul>
<li><strong>Field list</strong> — Only the template's fields are available; reports can't add or remove fields.</li>
<li><strong>Column order</strong> — Templates own the order; admins reorder via drag-and-drop.</li>
<li><strong>Default sort</strong> — Template's default sort field + direction propagate.</li>
<li>Linked reports can only customize <strong>column visibility</strong> (eye icon per column).</li>
</ul>
<p>Editing the template updates every linked report on next render.</p>

<h4>Templates list page</h4>
<p>Templates are grouped by company on the templates list page. The first tab is <strong>All</strong> (with a Company column for cross-company context); subsequent tabs are per-company, labeled with a count. Companies with zero templates are hidden so the strip stays clean.</p>

<h4>Creating a template</h4>
<ol>
<li>Open the Grid Templates page from the Report Library admin toolbar.</li>
<li>Click <strong>New Template</strong>.</li>
<li>Enter a name and description; pick a connection.</li>
<li>Click field chips to select fields.</li>
<li><strong>Drag a row by its handle</strong> in the Column Order section to reorder.</li>
<li>Click the eye icon on any row to hide that column from the grid.</li>
<li>Set a default sort field + direction.</li>
<li>Check <strong>Share with all users</strong> if desired.</li>
<li>Click <strong>Save Template</strong>.</li>
</ol>

<h4>Cloning a template</h4>
<p>Use Clone on the templates list to duplicate a template — the dialog lets you retarget the clone to a different connection (across companies if needed).</p>"),

        new("viewer", "Running Reports (Viewer)", @"
<p>The Viewer is read-only. It runs the saved report, fixes connection + field selection, and shows Table, Chart, and Dashboard tabs.</p>
<ol>
<li>Click the <strong>Play</strong> icon on a report row in the Library.</li>
<li>The report runs and the three tabs render.</li>
<li>Click <strong>Refresh</strong> to re-run with the latest data.</li>
<li>Click <strong>Edit</strong> to open the report in the Builder.</li>
</ol>

<h4>Drill-down</h4>
<p>On the Dashboard tab, click any row to open the filtered detail records in a new browser tab.</p>

<h4>Filter changes</h4>
<p>Multi-select filter dropdowns are debounced — picking 5 items in a list fires one query at the end instead of five.</p>"),

        new("notifications", "Notifications", @"
<p>The bell icon next to the user menu shows in-app notifications. The badge counts unread items.</p>

<h4>What produces a notification</h4>
<ul>
<li><strong>Report shared with you</strong> — When another user (typically an admin) shares a report with you, a notification lands in your inbox with a link to open it.</li>
<li><strong>Scheduled report ran</strong> (when configured) — Drops a notification when a scheduled run completes.</li>
<li><strong>Admin announcements</strong> — Future capability for system-wide messages from admins.</li>
</ul>

<h4>Reading the inbox</h4>
<ul>
<li>Click the bell to open the dropdown. The 15 most recent items are listed.</li>
<li>Unread items are bold; read items are dim.</li>
<li>Click any item to navigate to its target (e.g. the shared report) and mark it read.</li>
<li><strong>Mark all read</strong> clears the unread badge without navigating.</li>
</ul>

<p>The dropdown re-fetches every time you open it so you always see the freshest state. Notifications persist across browser sessions.</p>"),

        new("preferences", "User Preferences", @"
<ol>
<li>Open the user menu (top-right) → <strong>User Preferences</strong>.</li>
<li><strong>Default Page Size</strong> — Rows per page in report grids.</li>
<li><strong>Report Library Rows Per Page</strong> — Rows per page on each Library tab.</li>
<li>Click <strong>Save Preferences</strong> to save and return to the Library.</li>
<li>Click <strong>Cancel</strong> to discard changes.</li>
</ol>
<p><strong>Note:</strong> The app theme (colors) is admin-controlled — see the Admin → Theme tab. There's no per-user light/dark toggle in this version.</p>"),

        new("admin", "Admin", @"
<p>The Admin area is gated by your role's <strong>admin sections</strong>. A global Administrator sees every tab; a System Support user (or any role with section-scoped access) sees only the sections their role explicitly grants.</p>

<h4>Admin tabs</h4>
<table style='width:100%; border-collapse:collapse; margin:12px 0;'>
<tr style='background:#F8F9FA;'><th style='text-align:left; padding:8px; border:1px solid #E8EAED;'>Tab</th><th style='text-align:left; padding:8px; border:1px solid #E8EAED;'>What it does</th></tr>
<tr><td style='padding:8px; border:1px solid #E8EAED;'><strong>Companies</strong></td><td style='padding:8px; border:1px solid #E8EAED;'>Add / edit companies, set logos, set the website URL the dashboard logo links to.</td></tr>
<tr><td style='padding:8px; border:1px solid #E8EAED;'><strong>DB Connections</strong></td><td style='padding:8px; border:1px solid #E8EAED;'>Per-company data-source connections (SQL Server, Postgres). Test each connection. Copy connections between companies.</td></tr>
<tr><td style='padding:8px; border:1px solid #E8EAED;'><strong>Users</strong></td><td style='padding:8px; border:1px solid #E8EAED;'>Add / edit users, assign roles, manage per-company access. Only Administrators can grant the Administrator role.</td></tr>
<tr><td style='padding:8px; border:1px solid #E8EAED;'><strong>Roles</strong></td><td style='padding:8px; border:1px solid #E8EAED;'>Define job-function roles. Administrator and System Support are built-in (can't be renamed or deleted). Other roles are custom; admins set their scope (All / Self / Team) and admin-section access.</td></tr>
<tr><td style='padding:8px; border:1px solid #E8EAED;'><strong>Team Builder</strong></td><td style='padding:8px; border:1px solid #E8EAED;'>Configure how teams are derived from a connection's data so team-scoped roles can filter rows correctly.</td></tr>
<tr><td style='padding:8px; border:1px solid #E8EAED;'><strong>Schema History</strong></td><td style='padding:8px; border:1px solid #E8EAED;'>Audit trail of schema-config edits per connection, with rollback.</td></tr>
<tr><td style='padding:8px; border:1px solid #E8EAED;'><strong>Schema Builder</strong></td><td style='padding:8px; border:1px solid #E8EAED;'>(Separate page, gated under this section's key.) The full schema-editing surface — fields, joins, lookups, custom filters.</td></tr>
<tr><td style='padding:8px; border:1px solid #E8EAED;'><strong>Promotion</strong></td><td style='padding:8px; border:1px solid #E8EAED;'>Export / import promotion packages between Staging and Production. See the Promotion section below.</td></tr>
<tr><td style='padding:8px; border:1px solid #E8EAED;'><strong>Theme</strong></td><td style='padding:8px; border:1px solid #E8EAED;'>App-wide color palette. See the Theme section below.</td></tr>
</table>

<h4>Built-in roles</h4>
<ul>
<li><strong>Administrator</strong> — Full access to every admin section. Sees every active company. Can grant the Administrator role to others.</li>
