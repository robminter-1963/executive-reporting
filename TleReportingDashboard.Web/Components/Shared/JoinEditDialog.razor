@using TleReportingDashboard.Web.Components.Pages
@using TleReportingDashboard.Web.Services
@inject IDialogService DialogService

<MudDialog>
    <TitleContent>
        <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Outlined.Link" />
            <MudText Typo="Typo.h6">@(IsNew ? "Add Join" : "Edit Join")</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudGrid Spacing="2" Style="min-width: 600px;">
            <MudItem xs="12" sm="8">
                <MudTextField @bind-Value="_edited.Id" Label="Join ID" Variant="Variant.Outlined" Margin="Margin.Dense"
                              HelperText="Unique identifier (e.g. borrinfo_join)" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudSwitch T="bool" @bind-Value="_edited.UseRawSql"
                           Label="Raw SQL mode" Color="Color.Primary" />
            </MudItem>

            @if (!_edited.UseRawSql)
            {
                <MudItem xs="12" sm="4">
                    <MudSelect T="string" @bind-Value="_edited.JoinType" Label="Type"
                               Variant="Variant.Outlined" Margin="Margin.Dense" Dense>
                        <MudSelectItem Value="@("INNER JOIN")">INNER JOIN</MudSelectItem>
                        <MudSelectItem Value="@("LEFT JOIN")">LEFT JOIN</MudSelectItem>
                    </MudSelect>
                </MudItem>
                @* Source picker — optional but strongly recommended. Drives
                   primary-table precedence in JoinResolver: when the report's
                   primary table matches this source, this join wins over any
                   alternative with the same target. Leaving blank falls back
                   to legacy "first match" behavior with a soft server warning
                   at query time. *@
                <MudItem xs="12" sm="8">
                    <MudSelect T="string" Value="_selectedSourceKey" ValueChanged="OnSourcePicked"
                               Label="Source Table"
                               Variant="Variant.Outlined" Margin="Margin.Dense" Clearable
                               HelperText="Optional. Picks this join when the report's primary table matches.">
                        @foreach (var entry in _effectiveSourceAliases.OrderBy(BuildAliasLabel, StringComparer.OrdinalIgnoreCase))
                        {
                            var key = BuildAliasKey(entry);
                            <MudSelectItem T="string" Value="@key">@BuildAliasLabel(entry)</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudTextField Value="_edited.SourceAlias" Label="Source Alias"
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  ReadOnly
                                  HelperText="Set by the picked Source entry." />
                </MudItem>
                <MudItem xs="12" sm="8">
                    @* Target Table is now driven by the connection's Table
                       Aliases catalog — joins can only point at curated
                       pairs so aliases stay consistent throughout the
                       schema. Free-form entry lives in Raw SQL mode. *@
                    <MudSelect T="string" Value="_selectedAliasKey" ValueChanged="OnAliasPicked"
                               Label="Target Table"
                               Variant="Variant.Outlined" Margin="Margin.Dense"
                               Required RequiredError="Pick a table from the catalog"
                               Error="@string.IsNullOrWhiteSpace(_edited.TargetTable)"
                               HelperText="@TargetTableHelperText">
                        @foreach (var entry in _effectiveAliases.OrderBy(BuildAliasLabel, StringComparer.OrdinalIgnoreCase))
                        {
                            var key = BuildAliasKey(entry);
                            <MudSelectItem T="string" Value="@key">@BuildAliasLabel(entry)</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudTextField Value="_edited.Alias" Label="Target Alias"
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  ReadOnly
                                  HelperText="Set by the picked Table Alias entry." />
                </MudItem>
                @* Soft validation. SourceAlias == TargetAlias is almost
                   always a typo — a join targeting the same alias as its
                   source produces a self-referential ON clause that won't
                   match anything. Surfaced as info-level so the admin can
                   override if they really meant it. *@
                @if (!string.IsNullOrWhiteSpace(_edited.SourceAlias)
                     && !string.IsNullOrWhiteSpace(_edited.Alias)
                     && string.Equals(_edited.SourceAlias, _edited.Alias, StringComparison.OrdinalIgnoreCase))
                {
                    <MudItem xs="12">
                        <MudAlert Severity="Severity.Warning" Dense Variant="Variant.Outlined">
                            Source and Target alias are the same (<strong>@_edited.Alias</strong>) — likely a typo.
                            A join targeting the same alias as its source can't form a valid ON clause.
                        </MudAlert>
                    </MudItem>
                }
                <MudItem xs="12">
                    <MudTextField @bind-Value="_edited.OnClause" Label="ON clause"
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Placeholder="@OnClausePlaceholder" />
                    @* Declared-key hint + one-click fill. Reads the source
                       and target's PrimaryColumn from the Table Aliases
                       catalog and either confirms the current ON clause
                       references both, or offers a "Use declared keys"
                       button that writes the suggested clause. Hidden when
                       either side hasn't declared a primary column. *@
                    @if (SuggestedOnClause is not null)
                    {
                        <MudStack Row AlignItems="AlignItems.Center" Spacing="2" Class="mt-1"
                                  Style="flex-wrap: wrap;">
                            <MudIcon Icon="@OnClauseValidationIcon"
                                     Color="@OnClauseValidationColor"
                                     Size="Size.Small" />
                            <MudText Typo="Typo.caption" Color="Color.Secondary"
                                     Style="line-height: 1.3;">
                                @OnClauseValidationMessage
                            </MudText>
                            @* Always shown when both sides have a declared
                               primary column — even when the current ON
                               clause already matches. Clicking overwrites
                               whatever's in the field with the suggested
                               clause, so admins can re-seed if they've
                               edited it manually. *@
                            @* No title= here: a title attribute on a MudBlazor
                               component inside this dialog reintroduces the
                               input-freeze bug. The suggested clause is already
                               shown in the caption to the left, so the tooltip
                               was redundant anyway. *@
                            <MudButton Variant="Variant.Outlined" Size="Size.Small"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Outlined.AutoFixHigh"
                                       OnClick="FillSuggestedOnClause">
                                Use declared keys
                            </MudButton>
                        </MudStack>
                    }
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_edited.ExtraCondition" Label="AND condition (optional)"
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Placeholder="@ExtraPlaceholder" />
                    @* Quick-pick chip row for the target's declared
                       AdditionalKeyColumns. Each chip appends a starter
                       "<targetAlias>.<col> = " token to the AND field so
                       admins finish with the value. Hidden when the target
                       has no additional keys declared. *@
                    @if (TargetAdditionalKeys.Count > 0)
                    {
                        <MudStack Row AlignItems="AlignItems.Center" Spacing="1" Class="mt-1"
                                  Style="flex-wrap: wrap;">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                Target additional keys:
                            </MudText>
                            @* MudButton instead of MudChip — standalone MudChips
                               with OnClick (outside a MudChipSet) were freezing
                               input on the rest of the dialog. Small outlined
                               buttons read the same visually for this use case. *@
                            @foreach (var col in TargetAdditionalKeys)
                            {
                                var c = col;
                                <MudButton Size="Size.Small"
                                           Variant="Variant.Outlined"
                                           Color="Color.Default"
                                           OnClick="@(() => AppendExtraConditionToken(c))">
                                    @c
                                </MudButton>
                            }
                        </MudStack>
                    }
                </MudItem>
            }
            else
            {
                <MudItem xs="12">
                    <MudTextField @bind-Value="_edited.RawSql" Label="Raw SQL Join"
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Lines="8" Style="font-family: monospace; font-size: 0.85rem;"
                                  Placeholder="@RawSqlPlaceholder"
                                  HelperText="Full join SQL including nested joins. Pasted as-is into the query." />
                </MudItem>
            }

            @* PR-3. Restrict-to-Primary picker. Applies in BOTH structured
               and Raw SQL modes — a primary scope is independent of how
               the join's SQL was authored. Empty selection ("Any primary")
               clears the scope and the join behaves as a generic. *@
            <MudItem xs="12">
                <MudSelect T="string" Value="_selectedPrimaryKey" ValueChanged="OnPrimaryPicked"
                           Label="Restrict to Primary"
                           Variant="Variant.Outlined" Margin="Margin.Dense" Clearable
                           HelperText="Optional. When set, this join is only used by reports whose primary table matches. Blank = generic (any primary).">
                    <MudSelectItem T="string" Value="@string.Empty">Any primary (generic)</MudSelectItem>
                    @foreach (var entry in _effectivePrimaryAliases.OrderBy(BuildAliasLabel, StringComparer.OrdinalIgnoreCase))
                    {
                        var key = BuildAliasKey(entry);
                        <MudSelectItem T="string" Value="@key">@BuildAliasLabel(entry)</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

            <MudItem xs="12">
                <MudPaper Elevation="0" Class="pa-2" Style="background: #F8F9FA; border: 1px solid #E8EAED; border-radius: 4px;">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Preview:</MudText>
                    <MudText Typo="Typo.body2" Style="font-family: monospace; font-size: 0.8rem; white-space: pre-wrap;">@_edited.BuildSql()</MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="TryCancelAsync">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Ok"
                   Disabled="@(!IsValid)">
            OK
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance? MudDialog { get; set; }
    [Parameter] public SchemaBuilder.JoinEntry? Join { get; set; }
    [Parameter] public bool IsNew { get; set; }
    [Parameter] public string? ConnectionType { get; set; }

    // Admin-curated table/alias pairs from the Admin → Table Aliases tab,
    // scoped to this connection. Drives the Target Table dropdown so joins
    // can only point at entries that are already registered. Includes
    // primaries — IsPrimary just means "valid report root", not "can't
    // be joined".
    [Parameter] public IEnumerable<CustomPrimaryTableRecord>? AvailableAliases { get; set; }
    // Distinct parameter for the Source picker so the two can diverge in
    // the future (e.g. if Target ever needs filtering again). Today both
    // receive the same full catalog from SchemaBuilder.OpenJoinDialog.
    [Parameter] public IEnumerable<CustomPrimaryTableRecord>? AvailableSourceAliases { get; set; }
    // Primary-scope picker (PR-3). Only entries marked IsPrimary in the
    // Table Aliases catalog appear here — they're the valid report roots
    // a join can be scoped to. Null/empty list disables the picker.
    [Parameter] public IEnumerable<CustomPrimaryTableRecord>? AvailablePrimaryAliases { get; set; }

    private SchemaBuilder.JoinEntry _edited = new();
    private string _originalRef = string.Empty;

    // JSON snapshot at OnInitialized — IsDirty compares a fresh snapshot
    // against this to drive the unsaved-changes prompt.
    private string _initialSnapshot = string.Empty;

    // Effective list shown in the dropdown. Starts with AvailableAliases; if
    // the join being edited has a (table, alias) not in the catalog (legacy
    // row), we insert a synthetic entry so the value stays visible/editable.
    private List<CustomPrimaryTableRecord> _effectiveAliases = new();
    private string _selectedAliasKey = string.Empty;
    // Source picker — usually drawn from the FULL alias catalog (NOT
    // _effectiveAliases, which excludes primaries — sources are typically
    // primary tables). Falls back to whatever AvailableAliases provides
    // when no full source list is supplied.
    private List<CustomPrimaryTableRecord> _effectiveSourceAliases = new();
    private string _selectedSourceKey = string.Empty;
    // Primary-scope picker. Empty key = "Any primary (generic)" — the
    // first MudSelectItem below — which clears PrimaryTable / PrimaryAlias.
    private List<CustomPrimaryTableRecord> _effectivePrimaryAliases = new();
    private string _selectedPrimaryKey = string.Empty;

    private string TargetTableHelperText =>
        _effectiveAliases.Count == 0
            ? "No Table Aliases defined for this connection. Add some in Admin → Table Aliases or use Raw SQL mode."
            : "Pick from the connection's Table Aliases catalog.";

    private static string BuildAliasKey(CustomPrimaryTableRecord e) =>
        $"{e.TableName}|{e.Alias ?? string.Empty}";

    private static string BuildAliasLabel(CustomPrimaryTableRecord e) =>
        string.IsNullOrEmpty(e.Alias) ? e.TableName : $"{e.TableName} AS {e.Alias}";

    private void OnAliasPicked(string? key)
    {
        _selectedAliasKey = key ?? string.Empty;
        if (string.IsNullOrEmpty(key))
        {
            _edited.TargetTable = string.Empty;
            _edited.Alias = string.Empty;
            return;
        }
        var match = _effectiveAliases.FirstOrDefault(e => BuildAliasKey(e) == key);
        if (match is not null)
        {
            _edited.TargetTable = match.TableName;
            _edited.Alias = match.Alias ?? string.Empty;
        }
    }

    private void OnSourcePicked(string? key)
    {
        _selectedSourceKey = key ?? string.Empty;
        if (string.IsNullOrEmpty(key))
        {
            _edited.SourceTable = string.Empty;
            _edited.SourceAlias = string.Empty;
            return;
        }
        var match = _effectiveSourceAliases.FirstOrDefault(e => BuildAliasKey(e) == key);
        if (match is not null)
        {
            _edited.SourceTable = match.TableName;
            _edited.SourceAlias = match.Alias ?? string.Empty;
        }
    }

    private void OnPrimaryPicked(string? key)
    {
        _selectedPrimaryKey = key ?? string.Empty;
        if (string.IsNullOrEmpty(key))
        {
            // "Any primary (generic)" — preserves legacy behavior.
            _edited.PrimaryTable = string.Empty;
            _edited.PrimaryAlias = string.Empty;
            return;
        }
        var match = _effectivePrimaryAliases.FirstOrDefault(e => BuildAliasKey(e) == key);
        if (match is not null)
        {
            _edited.PrimaryTable = match.TableName;
            _edited.PrimaryAlias = match.Alias ?? string.Empty;
        }
    }

    // ── Declared-key validator + suggester ─────────────────────────────
    // Pulls the source/target Table-Aliases records (which carry the
    // admin-declared PrimaryColumn + AdditionalKeyColumns) and uses them
    // to validate and pre-fill the ON clause / AND condition. The intent
    // is to make the Join editor "dummy-proof": admins who already typed
    // their keys once on the Table Aliases tab shouldn't have to retype
    // them here.

    // The source-side and target-side records (when found in the catalog).
    private CustomPrimaryTableRecord? CurrentSourceRecord =>
        FindAliasRecord(_edited.SourceAlias, _effectiveSourceAliases);
    private CustomPrimaryTableRecord? CurrentTargetRecord =>
        FindAliasRecord(_edited.Alias, _effectiveAliases);

    private static CustomPrimaryTableRecord? FindAliasRecord(
        string? alias, IEnumerable<CustomPrimaryTableRecord> pool)
    {
        if (string.IsNullOrWhiteSpace(alias)) return null;
        return pool.FirstOrDefault(r =>
            !string.IsNullOrWhiteSpace(r.Alias)
            && string.Equals(r.Alias, alias, StringComparison.OrdinalIgnoreCase));
    }

    // The natural "<target>.<targetPK> = <source>.<sourcePK>" clause when
    // both sides have a primary column declared. Null when either side is
    // missing the data — we don't guess.
    private string? SuggestedOnClause
    {
        get
        {
            var src = CurrentSourceRecord;
            var tgt = CurrentTargetRecord;
            if (src is null || tgt is null) return null;
            if (string.IsNullOrWhiteSpace(src.PrimaryColumn) ||
                string.IsNullOrWhiteSpace(tgt.PrimaryColumn))
                return null;
            // Prefer alias prefixes when both rows have an alias — they're
            // the tokens that actually appear in the emitted SQL and the
            // resolver's adjacency map.
            var srcRef = !string.IsNullOrWhiteSpace(src.Alias) ? src.Alias! : src.TableName;
            var tgtRef = !string.IsNullOrWhiteSpace(tgt.Alias) ? tgt.Alias! : tgt.TableName;
            return $"{tgtRef}.{tgt.PrimaryColumn} = {srcRef}.{src.PrimaryColumn}";
        }
    }

    // True when the user's ON clause already contains references to both
    // sides' declared primary columns. Case-insensitive substring check
    // (rather than tokenized SQL parsing) keeps it cheap and tolerant of
    // whitespace / qualifier styles.
    private bool OnClauseUsesDeclaredKeys
    {
        get
        {
            var src = CurrentSourceRecord;
            var tgt = CurrentTargetRecord;
            if (src is null || tgt is null) return false;
            if (string.IsNullOrWhiteSpace(src.PrimaryColumn) ||
                string.IsNullOrWhiteSpace(tgt.PrimaryColumn))
                return false;
            var sql = _edited.OnClause ?? string.Empty;
            return sql.Contains(src.PrimaryColumn, StringComparison.OrdinalIgnoreCase)
                && sql.Contains(tgt.PrimaryColumn, StringComparison.OrdinalIgnoreCase);
        }
    }

    private string OnClauseValidationMessage =>
        OnClauseUsesDeclaredKeys
            ? "ON clause references the declared primary columns."
            : $"Suggested from declared keys: {SuggestedOnClause}";

    private string OnClauseValidationIcon =>
        OnClauseUsesDeclaredKeys
            ? Icons.Material.Outlined.CheckCircle
            : Icons.Material.Outlined.Lightbulb;

    private Color OnClauseValidationColor =>
        OnClauseUsesDeclaredKeys ? Color.Success : Color.Info;

    // Writes the suggested ON clause into the input. Trim-replaces; admins
    // can still edit further. Snackbar not needed since the input changes
    // live.
    private void FillSuggestedOnClause()
    {
        if (SuggestedOnClause is null) return;
        _edited.OnClause = SuggestedOnClause;
    }

    // Target's AdditionalKeyColumnsList — drives the chip row under the
    // AND condition input. Returns empty when the target isn't declared
    // or has no additional keys.
    private IReadOnlyList<string> TargetAdditionalKeys =>
        CurrentTargetRecord?.AdditionalKeyColumnsList ?? Array.Empty<string>();

    private string ResolveTargetAliasOrTable()
    {
        var t = CurrentTargetRecord;
        if (t is null) return _edited.Alias ?? _edited.TargetTable ?? string.Empty;
        return !string.IsNullOrWhiteSpace(t.Alias) ? t.Alias! : t.TableName;
    }

    // Appends a "<targetAlias>.<col> = " starter to the AND condition.
    // If the field already has content, ANDs the new starter on; if it's
    // empty, just writes the bare starter.
    private void AppendExtraConditionToken(string column)
    {
        if (string.IsNullOrWhiteSpace(column)) return;
        var prefix = ResolveTargetAliasOrTable();
        var starter = $"{prefix}.{column} = ";
        if (string.IsNullOrWhiteSpace(_edited.ExtraCondition))
        {
            _edited.ExtraCondition = starter;
        }
        else
        {
            // Avoid double-AND or stray whitespace mishaps when admins
            // chain a few keys together (e.g. IDX + WHICHBORR).
            var existing = _edited.ExtraCondition!.TrimEnd();
            var sep = existing.EndsWith("AND", StringComparison.OrdinalIgnoreCase) ? " " : " AND ";
            _edited.ExtraCondition = existing + sep + starter;
        }
    }

    // Dialect-aware examples so Postgres admins don't see Empower SQL
    // Server table names in every placeholder.
    private bool IsPostgres => string.Equals(ConnectionType, "postgres", StringComparison.OrdinalIgnoreCase);
    private string TargetTablePlaceholder => IsPostgres ? "salesforce.lead" : "EMPOWER.LN_BORRINFO";
    private string AliasPlaceholder       => IsPostgres ? "lead_primary"    : "LN_CODES_30";
    private string OnClausePlaceholder    => IsPostgres
        ? "public.accounts.id = salesforce.lead.account_id"
        : "EMPOWER.LN_MTGTERMS.LNKEY = EMPOWER.LN_BORRINFO.LNKEY";
    private string ExtraPlaceholder       => IsPostgres ? "lead.is_active = true" : "LN_CODES_30.IDX=30";
    private string RawSqlPlaceholder      => IsPostgres
        ? "LEFT JOIN salesforce.lead l ON l.account_id = public.accounts.id\n    LEFT JOIN salesforce.opportunity o ON o.account_id = public.accounts.id"
        : "LEFT JOIN EMPOWER.LN_CONTACTS C WITH (NOLOCK)\n    LEFT JOIN EMPOWER.U_SET_TEAMMEMBERS STM WITH (NOLOCK)\n        LEFT JOIN EMPOWER.U_SET_TEAMS ST WITH (NOLOCK) ON ST.TEAMID=STM.TEAMID\n        ON STM.TEAM_MEMBERID = C.LOAN_OFFICER_USERID\n    ON C.LNKEY=DB.LNKEY";

    private bool IsValid => !string.IsNullOrWhiteSpace(_edited.Id) &&
        (_edited.UseRawSql
            ? !string.IsNullOrWhiteSpace(_edited.RawSql)
            : !string.IsNullOrWhiteSpace(_edited.TargetTable) && !string.IsNullOrWhiteSpace(_edited.OnClause));

    protected override void OnInitialized()
    {
        if (Join is not null)
        {
            _edited = new SchemaBuilder.JoinEntry
            {
                Id = Join.Id,
                JoinType = Join.JoinType,
                TargetTable = Join.TargetTable,
                Alias = Join.Alias,
                OnClause = Join.OnClause,
                ExtraCondition = Join.ExtraCondition,
                UseRawSql = Join.UseRawSql,
                RawSql = Join.RawSql,
                SourceTable = Join.SourceTable,
                SourceAlias = Join.SourceAlias,
                PrimaryTable = Join.PrimaryTable,
                PrimaryAlias = Join.PrimaryAlias
            };
            _originalRef = !string.IsNullOrWhiteSpace(Join.Alias) ? Join.Alias : Join.TargetTable;
        }

        // Seed the effective list from the catalog, then inject the join's
        // current (table, alias) if it's not already represented — keeps
        // legacy rows editable even when the catalog has moved on.
        _effectiveAliases = AvailableAliases is null
            ? new List<CustomPrimaryTableRecord>()
            : AvailableAliases.ToList();
        // Source picker pulls from the FULL Table Aliases catalog
        // (AvailableSourceAliases) — primaries included, since a join's
        // source is typically a primary. Falls back to the target list if
        // the caller didn't pass a separate source catalog.
        _effectiveSourceAliases = AvailableSourceAliases is not null
            ? AvailableSourceAliases.ToList()
            : new List<CustomPrimaryTableRecord>(_effectiveAliases);

        if (!IsNew && !string.IsNullOrWhiteSpace(_edited.TargetTable))
        {
            var tableKey = _edited.TargetTable;
            var aliasKey = _edited.Alias ?? string.Empty;
            var exists = _effectiveAliases.Any(a =>
                string.Equals(a.TableName, tableKey, StringComparison.OrdinalIgnoreCase)
                && string.Equals(a.Alias ?? string.Empty, aliasKey, StringComparison.OrdinalIgnoreCase));
            if (!exists)
            {
                _effectiveAliases.Insert(0, new CustomPrimaryTableRecord
                {
                    Id = Guid.Empty,
                    TableName = tableKey,
                    Alias = aliasKey
                });
            }
            _selectedAliasKey = $"{tableKey}|{aliasKey}";
        }

        // Primary-scope picker. Filter is applied caller-side
        // (AvailablePrimaryAliases is already primary-flagged-only); the
        // dialog just renders. Synthesize a synthetic entry for the saved
        // primary if it's missing from the catalog so legacy rows stay
        // editable, mirroring the source/target patterns.
        _effectivePrimaryAliases = AvailablePrimaryAliases is null
            ? new List<CustomPrimaryTableRecord>()
            : AvailablePrimaryAliases.ToList();
        if (!IsNew && !string.IsNullOrWhiteSpace(_edited.PrimaryTable))
        {
            var pTableKey = _edited.PrimaryTable;
            var pAliasKey = _edited.PrimaryAlias ?? string.Empty;
            var pExists = _effectivePrimaryAliases.Any(a =>
                string.Equals(a.TableName, pTableKey, StringComparison.OrdinalIgnoreCase)
                && string.Equals(a.Alias ?? string.Empty, pAliasKey, StringComparison.OrdinalIgnoreCase));
            if (!pExists)
            {
                _effectivePrimaryAliases.Insert(0, new CustomPrimaryTableRecord
                {
                    Id = Guid.Empty,
                    TableName = pTableKey,
                    Alias = pAliasKey
                });
            }
            _selectedPrimaryKey = $"{pTableKey}|{pAliasKey}";
        }

        // Mirror the legacy-row injection for the Source picker: if the
        // join's SourceTable / SourceAlias don't appear in the source list,
        // synthesize an entry so the saved value survives editing.
        if (!IsNew && !string.IsNullOrWhiteSpace(_edited.SourceTable))
        {
            var srcTableKey = _edited.SourceTable;
            var srcAliasKey = _edited.SourceAlias ?? string.Empty;
            var srcExists = _effectiveSourceAliases.Any(a =>
                string.Equals(a.TableName, srcTableKey, StringComparison.OrdinalIgnoreCase)
                && string.Equals(a.Alias ?? string.Empty, srcAliasKey, StringComparison.OrdinalIgnoreCase));
            if (!srcExists)
            {
                _effectiveSourceAliases.Insert(0, new CustomPrimaryTableRecord
                {
                    Id = Guid.Empty,
                    TableName = srcTableKey,
                    Alias = srcAliasKey
                });
            }
            _selectedSourceKey = $"{srcTableKey}|{srcAliasKey}";
        }

        _initialSnapshot = BuildSnapshot();
    }

    private string BuildSnapshot() =>
        System.Text.Json.JsonSerializer.Serialize(new
        {
            _edited.Id,
            _edited.JoinType,
            _edited.TargetTable,
            _edited.Alias,
            _edited.OnClause,
            _edited.ExtraCondition,
            _edited.UseRawSql,
            _edited.RawSql,
            _edited.SourceTable,
            _edited.SourceAlias,
            _edited.PrimaryTable,
            _edited.PrimaryAlias
        });

    private bool IsDirty =>
        !string.Equals(_initialSnapshot, BuildSnapshot(), StringComparison.Ordinal);

    // Routes Cancel through the unsaved-changes prompt. Save only re-enters
    // Ok() when the dialog is currently in a valid state (IsValid).
    private async Task TryCancelAsync() =>
        await UnsavedChangesPrompt.TryCancelAsync(DialogService, MudDialog, IsDirty,
            saveAsync: () =>
            {
                if (IsValid) Ok();
                return Task.CompletedTask;
            });

    private void Ok()
    {
        var newRef = _edited.UseRawSql
            ? _edited.TargetTable  // keep whatever was parsed for display
            : !string.IsNullOrWhiteSpace(_edited.Alias) ? _edited.Alias : _edited.TargetTable;
        var result = new JoinEditResult
        {
            Edited = _edited,
            OriginalRef = _originalRef,
            NewRef = newRef
        };
        MudDialog?.Close(DialogResult.Ok(result));
    }

    public class JoinEditResult
    {
        public SchemaBuilder.JoinEntry Edited { get; set; } = new();
        public string OriginalRef { get; set; } = string.Empty;
