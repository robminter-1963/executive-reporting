@using MudBlazor
@implements IDisposable

@* Bottom-right toast — slides up from the bottom edge, lives for
   AutoDismissSeconds, then slides back down. Doesn't take flow space so
   the page doesn't shift around the toast. The close X is still here for
   users who want to dismiss before the timer fires.

   Dismissal: a close X or the auto-timer; either path fires OnDismissed
   so the parent can flip its once-per-session flag and stop re-rendering
   on subsequent page mounts. *@
<div class="@($"landing-greeting {( _visible ? "visible" : "hidden")}")">
    <MudPaper Elevation="6" Class="pa-3"
              Style="border: 1px solid var(--border-default, #E2E8F0); border-radius: 10px; background: var(--surface-card, #FFFFFF); position: relative; min-width: 280px;">
        <MudIconButton Icon="@Icons.Material.Filled.Close"
                       Size="Size.Small"
                       Style="position: absolute; top: 4px; right: 4px;"
                       title="Dismiss"
                       OnClick="DismissAsync" />
        <MudStack Spacing="1" Style="padding-right: 28px;">
            <MudText Typo="Typo.subtitle1" Style="font-weight: 600; line-height: 1.2;">
                @GreetingText
            </MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary">
                @SubText
            </MudText>
            @if (UpdatedSinceCount > 0)
            {
                <MudChip T="string" Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                         Icon="@Icons.Material.Filled.Bolt" Class="mt-1">
                    @UpdatedSinceCount @(UpdatedSinceCount == 1 ? "report updated" : "reports updated")
                </MudChip>
            }
        </MudStack>
    </MudPaper>
</div>

<style>
    /* Bottom-right toast — anchored to the viewport so it doesn't move
       with page scroll. Starts off-screen below (translateY(120%));
       .visible swaps to translateY(0). On dismiss the class is removed
       and the same transition runs in reverse, sliding it back down. */
    .landing-greeting {
        position: fixed;
        bottom: 16px;
        right: 16px;
        max-width: 360px;
        z-index: 1100;
        transform: translateY(120%);
        opacity: 0;
        pointer-events: none;
        transition: transform 280ms cubic-bezier(0.2, 0.7, 0.3, 1), opacity 220ms ease-out;
    }
    .landing-greeting.visible {
        transform: translateY(0);
        opacity: 1;
        pointer-events: auto;
    }
    @@media (prefers-reduced-motion: reduce) {
        .landing-greeting { transition: opacity 120ms ease-out; transform: none; }
        .landing-greeting.visible { transform: none; }
    }
</style>

@code {
    [Parameter] public string DisplayName { get; set; } = string.Empty;
    [Parameter] public DateTime? LastSeenUtc { get; set; }
    [Parameter] public int UpdatedSinceCount { get; set; }
    [Parameter] public EventCallback OnDismissed { get; set; }
    [Parameter] public int AutoDismissSeconds { get; set; } = 4;

    private bool _visible;
    private CancellationTokenSource? _dismissCts;
    private bool _dismissed;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Two-phase reveal: render at translateY(-120%) on first
            // pass, then flip to .visible on the next frame so the
            // browser actually animates the transform. Without this
            // delay the element appears already in-position with no
            // slide. ~16ms is one frame at 60Hz; small enough not to
            // be noticed, large enough for the CSS class swap to
            // register as a transition.
            await Task.Delay(16);
            _visible = true;
            StateHasChanged();

            _dismissCts = new CancellationTokenSource();
            _ = AutoDismissAsync(_dismissCts.Token);
        }
    }

    private async Task AutoDismissAsync(CancellationToken ct)
    {
        try
        {
            await Task.Delay(TimeSpan.FromSeconds(Math.Max(1, AutoDismissSeconds)), ct);
            await DismissAsync();
        }
        catch (TaskCanceledException) { /* manual dismiss won the race */ }
    }

    private async Task DismissAsync()
    {
        if (_dismissed) return;
        _dismissed = true;
        _dismissCts?.Cancel();
        _visible = false;          // CSS slides up
        StateHasChanged();
        // Wait for the transform animation to finish before notifying
        // the parent — once the parent flips its dismissed flag and
        // re-renders, this component is removed from the DOM and the
        // slide-up animation would be cut short mid-flight.
        await Task.Delay(300);
        if (OnDismissed.HasDelegate)
            await OnDismissed.InvokeAsync();
    }

    public void Dispose()
    {
        _dismissCts?.Cancel();
        _dismissCts?.Dispose();
    }

    private string GreetingText
    {
        get
        {
            var hour = DateTime.Now.Hour;
            var partOfDay = hour switch
            {
                >= 5 and < 12 => "Good morning",
                >= 12 and < 17 => "Good afternoon",
                >= 17 and < 21 => "Good evening",
                _ => "Welcome back"
            };
            var name = string.IsNullOrWhiteSpace(DisplayName) ? string.Empty : ExtractFirstName(DisplayName);
            return string.IsNullOrEmpty(name) ? $"{partOfDay}." : $"{partOfDay}, {name}.";
        }
    }

    private string SubText
    {
        get
        {
            if (LastSeenUtc is null)
                return "Welcome to your dashboard.";
            var local = LastSeenUtc.Value.ToLocalTime();
            var span = DateTime.Now - local;
            string when = span switch
            {
                { TotalMinutes: < 1 } => "moments ago",
                { TotalMinutes: < 60 } => $"{(int)span.TotalMinutes}m ago",
                { TotalHours: < 12 } => $"{(int)span.TotalHours}h ago",
                { TotalDays: < 1 } => "earlier today",
                { TotalDays: < 2 } => "yesterday",
                { TotalDays: < 7 } => $"{(int)span.TotalDays} days ago",
                _ => local.ToString("MMM d")
            };
            return $"Last visit: {when}.";
        }
    }

    private static string ExtractFirstName(string raw)
    {
        var trimmed = raw.Trim();
        if (trimmed.Contains('@')) return trimmed;
        var space = trimmed.IndexOf(' ');
        return space > 0 ? trimmed[..space] : trimmed;
    }
}
