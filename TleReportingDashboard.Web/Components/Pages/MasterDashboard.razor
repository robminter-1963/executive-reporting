            // Resolve "can this user manage tab visibility?" — admins (global
            // or per-company) always can; System Support is granted the same
            // privilege so they can curate other users' tab views as part of
            // troubleshooting. Other admin-section roles (e.g. report curators)
            // are intentionally excluded — tab visibility isn't part of their
            // bag. Cached lookup; cheap.
            if (_userRoleForCompany == UserRoles.Admin)
            {
                _canManageTabs = true;
            }
            else if (!string.IsNullOrEmpty(_userEmail))
            {
                try
                {
                    var userRec = await UserManagement.GetByEmailAsync(_userEmail);
                    _canManageTabs = string.Equals(userRec?.RoleName, RoleRecord.SystemSupportName, StringComparison.OrdinalIgnoreCase);
                }
                catch (Exception ex)
                {
                    Logger.LogWarning(ex, "Resolving System Support role failed for {Email} — tab management gated off", _userEmail);
                    _canManageTabs = false;
                }
            }

