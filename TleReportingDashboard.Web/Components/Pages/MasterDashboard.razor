            _activeSectionId = ResolveDefaultActiveSectionId();
            _pendingRemovals = _pendingRemovalsByTab.TryGetValue(tab.Id, out var cachedRemovals)
                ? cachedRemovals
                : new List<MasterDashboardTile>();

