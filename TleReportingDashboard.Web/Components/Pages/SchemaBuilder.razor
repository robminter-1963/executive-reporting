    private object BuildFieldOutput(FieldEntry f)
    {
        var result = new Dictionary<string, object?>
        {
            ["Id"] = f.Id,
            ["Label"] = f.Label,
            ["Description"] = f.Description,
            ["Domain"] = f.Domain,
            ["DataType"] = f.DataType,
            ["FieldType"] = f.FieldType
        };

        // Synonyms / search aliases — omit when blank so the JSON
        // stays clean for fields without custom aliases.
        if (!string.IsNullOrWhiteSpace(f.SearchAliases))
            result["SearchAliases"] = f.SearchAliases;

        if (f.MaxLength.HasValue) result["MaxLength"] = f.MaxLength.Value;
        if (f.MinWidth.HasValue) result["MinWidth"] = f.MinWidth.Value;

        if (!string.IsNullOrWhiteSpace(f.AllowedAggregationsStr))
            result["AllowedAggregations"] = f.AllowedAggregationsStr.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

        if (f.CodeSetId.HasValue) result["CodeSetId"] = f.CodeSetId.Value;

        if (f.ValueSortOrder is not null && f.ValueSortOrder.Count > 0)
            result["ValueSortOrder"] = f.ValueSortOrder;

        result["SourceTable"] = f.SourceTable;
        result["SourceColumn"] = f.SourceColumn;

        if (!string.IsNullOrWhiteSpace(f.SqlExpression))
        {
            result["SqlExpression"] = f.SqlExpression;
            if (!string.IsNullOrWhiteSpace(f.SqlPreamble))
                result["SqlPreamble"] = f.SqlPreamble;
        }
        // JoinIds and SqlJoin apply regardless of inline-SQL mode: a plain
        // SourceTable/SourceColumn field can still need a JOIN (e.g. column on a
        // joined table). Both contribute at query time.
        if (f.JoinIds is not null && f.JoinIds.Count > 0)
            result["JoinIds"] = f.JoinIds;
        if (!string.IsNullOrWhiteSpace(f.SqlJoin))
            result["SqlJoin"] = f.SqlJoin;
        // LookupIds can exist on any field (e.g. a plain SourceTable/Column field
        // that uses a lookup CTE for custom sort order) — not just SqlExpression fields.
        if (f.LookupIds is not null && f.LookupIds.Count > 0)
            result["LookupIds"] = f.LookupIds;

        // Lookup-type binding for the chip picker. LookupTypeId points at
        // a row in the Lookup Types tab (admin-authored SELECT + value /
        // display columns). FilterPredicateSql is the WHERE fragment that
        // gets emitted when the user filters via that picker (with
        // {values} placeholder substitution or implicit IN append). Both
        // serialize only when non-empty so legacy field rows stay clean.
        if (!string.IsNullOrWhiteSpace(f.LookupTypeId))
            result["LookupTypeId"] = f.LookupTypeId;
        if (!string.IsNullOrWhiteSpace(f.FilterPredicateSql))
            result["FilterPredicateSql"] = f.FilterPredicateSql;
        if (!string.IsNullOrWhiteSpace(f.FilterColumn))
            result["FilterColumn"] = f.FilterColumn;

        if (!string.IsNullOrWhiteSpace(f.RolesRequired))
        {
            result["RolesRequired"] = f.RolesRequired;
            result["DefaultRedactionValue"] = "'*** REDACTED ***'";
        }

        if (!string.IsNullOrWhiteSpace(f.Format))
            result["Format"] = f.Format;

        if (f.ApplyTimezoneConversion)
            result["ApplyTimezoneConversion"] = true;

        if (f.IsUnique)
            result["IsUnique"] = true;

        return result;
    }

    private async Task DownloadJson()
    {
        if (string.IsNullOrEmpty(_jsonPreview)) return;
        var bytes = System.Text.Encoding.UTF8.GetBytes(_jsonPreview);
        await JS.DownloadAsync("schema_config.json", bytes);
    }

    private async Task CopyToClipboard()
    {
