@page "/preferences"
@rendermode InteractiveServer
@implements IDisposable
@inject IUserPreferenceService PreferenceService
@inject UserPreferenceState PreferenceState
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IJSRuntime JS

<PageTitle>Preferences - Executive Reporting Suite</PageTitle>

<MudMainContent Style="padding: 16px; max-width: 700px; margin: 0 auto;">
    <MudStack Spacing="3">
        <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
            <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                           OnClick="GoBack"
                           title="Back" />
            <MudText Typo="Typo.h5" Style="font-weight: 600;">Preferences</MudText>
        </MudStack>

        @if (_loading)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
        }
        else
        {
            @* ── Page Sizes ── *@
            <MudPaper Elevation="0" Class="pa-4" Style="border: 1px solid #E8EAED; border-radius: 4px;">
                <MudStack Spacing="2">
                    <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">Data Grid</MudText>

                    <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body1">Default Page Size</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                Number of rows shown per page in report grids
                            </MudText>
                        </MudStack>
                        <MudSelect T="int" Value="_pref.DefaultPageSize" ValueChanged="OnPageSizeChanged"
                                   Variant="Variant.Outlined" Margin="Margin.Dense" Dense
                                   Style="max-width: 120px;">
                            <MudSelectItem Value="10">10</MudSelectItem>
                            <MudSelectItem Value="20">20</MudSelectItem>
                            <MudSelectItem Value="30">30</MudSelectItem>
                            <MudSelectItem Value="40">40</MudSelectItem>
                            <MudSelectItem Value="50">50</MudSelectItem>
                            <MudSelectItem Value="60">60</MudSelectItem>
                            <MudSelectItem Value="70">70</MudSelectItem>
                            <MudSelectItem Value="80">80</MudSelectItem>
                            <MudSelectItem Value="90">90</MudSelectItem>
                            <MudSelectItem Value="100">100</MudSelectItem>
                        </MudSelect>
                    </MudStack>

                    <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body1">Report Library Rows Per Page</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                Rows shown on each tab of the Report Library
                            </MudText>
                        </MudStack>
                        <MudSelect T="int" Value="_pref.ReportLibraryPageSize" ValueChanged="OnLibraryPageSizeChanged"
                                   Variant="Variant.Outlined" Margin="Margin.Dense" Dense
                                   Style="max-width: 120px;">
                            <MudSelectItem Value="10">10</MudSelectItem>
                            <MudSelectItem Value="20">20</MudSelectItem>
                            <MudSelectItem Value="30">30</MudSelectItem>
                            <MudSelectItem Value="40">40</MudSelectItem>
                            <MudSelectItem Value="50">50</MudSelectItem>
                            <MudSelectItem Value="60">60</MudSelectItem>
                            <MudSelectItem Value="70">70</MudSelectItem>
                            <MudSelectItem Value="80">80</MudSelectItem>
                            <MudSelectItem Value="90">90</MudSelectItem>
                            <MudSelectItem Value="100">100</MudSelectItem>
                        </MudSelect>
                    </MudStack>
                </MudStack>
            </MudPaper>

            @* ── Save ──
               Cancel + Save both navigate to "/" — the company picker
               page, which auto-redirects to the user's last-visited
               company dashboard when PrefersCompanyPicker is false.
               This sends users back to their working surface (the
               dashboard they came from) rather than dumping them in
               the Report Library, which a viewer-only user may not
               even need. *@
            <MudStack Row Justify="Justify.FlexEnd" Spacing="2">
                <MudButton Variant="Variant.Text" Color="Color.Default"
                           OnClick="@(() => Navigation.NavigateTo("/"))">
                    Cancel
                </MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Save"
                           OnClick="Save" Disabled="_saving">
                    @(_saving ? "Saving..." : "Save Preferences")
                </MudButton>
            </MudStack>
        }
    </MudStack>
</MudMainContent>

@code {
    private UserPreference _pref = new();
    private bool _loading = true;
    private bool _saving;
    private string _userId = "anonymous";

    // ── Unsaved-changes guard ──
    private string _dirtySnapshot = string.Empty;
    private bool _beforeUnloadArmed;
    private IDisposable? _navHandlerRegistration;

    private string ComputeDirtySnapshot()
    {
        try
        {
            var snap = new
            {
                _pref.DefaultPageSize,
                _pref.ReportLibraryPageSize
            };
            return System.Text.Json.JsonSerializer.Serialize(snap);
        }
        catch { return Guid.NewGuid().ToString(); }
    }

    private void MarkClean() => _dirtySnapshot = ComputeDirtySnapshot();

    private bool IsDirty =>
        !string.Equals(_dirtySnapshot, ComputeDirtySnapshot(), StringComparison.Ordinal);

    private async ValueTask OnLocationChangingAsync(LocationChangingContext context)
    {
        if (!IsDirty) return;
        var choice = await TleReportingDashboard.Web.Components.Shared.UnsavedChangesPrompt.AskAsync(DialogService);
        switch (choice)
        {
            case TleReportingDashboard.Web.Components.Shared.UnsavedChangesResult.Save:
                await Save(navigateAfter: false);
                if (IsDirty) context.PreventNavigation();
                break;
            case TleReportingDashboard.Web.Components.Shared.UnsavedChangesResult.DontSave:
                MarkClean();
                break;
            case TleReportingDashboard.Web.Components.Shared.UnsavedChangesResult.Cancel:
                context.PreventNavigation();
                break;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _userId = authState.User.FindFirst("oid")?.Value
                  ?? authState.User.Identity?.Name
                  ?? "anonymous";

        _pref = await PreferenceService.GetPreferencesAsync(_userId);
        _pref.UserId = _userId;
        _loading = false;

        _navHandlerRegistration = Navigation.RegisterLocationChangingHandler(OnLocationChangingAsync);
        MarkClean();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        var armNow = IsDirty;
        if (armNow != _beforeUnloadArmed)
        {
            try { await JS.InvokeVoidAsync("setBeforeUnloadGuard", armNow); }
            catch { }
            _beforeUnloadArmed = armNow;
        }
    }

    public void Dispose()
    {
        _navHandlerRegistration?.Dispose();
        _navHandlerRegistration = null;
        if (_beforeUnloadArmed)
        {
            try { _ = JS.InvokeVoidAsync("setBeforeUnloadGuard", false).AsTask(); }
            catch { }
            _beforeUnloadArmed = false;
        }
    }

    // Always go "home" — the company picker at "/", which auto-redirects
    // to the user's last-visited company dashboard when PrefersCompanyPicker
    // is false. We deliberately skip browser-history back here because the
    // most common entry path is "user menu → Preferences" from any page,
    // and a viewer-only user landing back on /reports (or any other
    // hands-off surface they were just on) wasn't useful — they want to
    // get back to their dashboard. Mirrors the Cancel / Save destinations.
    private void GoBack()
    {
        Navigation.NavigateTo("/");
    }

    private void OnPageSizeChanged(int size)
    {
        _pref.DefaultPageSize = size;
    }

    private void OnLibraryPageSizeChanged(int size)
    {
        _pref.ReportLibraryPageSize = size;
    }

    private async Task Save() => await Save(navigateAfter: true);

    private async Task Save(bool navigateAfter)
    {
        _saving = true;
        try
        {
            await PreferenceService.SavePreferencesAsync(_pref);
            PreferenceState.Set(_pref);
            MarkClean();
            // Land back on the picker, which redirects to the user's
            // last-visited company dashboard. Same destination Cancel
            // / Back use, so the page has one consistent exit target.
            // Skipped when invoked from the unsaved-changes prompt's
            // Save branch — the originating navigation will resume on
            // its own.
            if (navigateAfter) Navigation.NavigateTo("/");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to save: {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }
}
