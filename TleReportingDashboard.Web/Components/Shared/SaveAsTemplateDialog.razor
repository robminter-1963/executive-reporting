<MudDialog>
    <DialogContent>
        <MudStack Spacing="2">
            <MudTextField @bind-Value="_name" Label="Template Name" Variant="Variant.Outlined"
                          Required RequiredError="Template name is required." Immediate />
            <MudText Typo="Typo.caption" Color="Color.Secondary">
                Templates are visible to all users in the Templates tab and can be cloned.
            </MudText>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Save"
                   Disabled="@string.IsNullOrWhiteSpace(_name)">
            Save Template
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance? MudDialog { get; set; }
    [Parameter] public string DefaultName { get; set; } = string.Empty;

    private string _name = string.Empty;

    protected override void OnInitialized()
    {
        _name = DefaultName;
    }

    private void Cancel() => MudDialog?.Cancel();
    private void Save() => MudDialog?.Close(DialogResult.Ok(_name));
}
