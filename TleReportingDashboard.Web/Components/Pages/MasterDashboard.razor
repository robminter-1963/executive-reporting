            // them right now?" — gates the Shared Reports header
            // button for viewer-role users so it disappears the
            // moment the last share is revoked. Quick query (one
            // join, indexed); cache invalidation is already wired
            // on the share create/delete and report mutation paths.
            try
            {
                // Both lists fan out in parallel — they hit different
                // tables (RPT_saved_reports for owner, joined RPT_report_shares
                // for shares) so there's no contention. Cache backs both.
                var sharesTask = SharingService.GetSharedWithMeAsync(_userId);
                var ownedTask = ReportService.GetReportsAsync(_userId);
                await Task.WhenAll(sharesTask, ownedTask);
                var shares = sharesTask.Result;
                var owned = ownedTask.Result;

                _hasAnyShares = shares.Count > 0;

                // Build the quick-access list. Owned reports take precedence
                // when a report appears in both (owner sharing with themselves
                // is theoretically possible). Label prefers InternalName so
                // admin-curated naming wins over the user-facing Name when
                // both exist (matches the Report Library's DisplayLabel).
                static string Label(SavedReport r) =>
                    string.IsNullOrWhiteSpace(r.InternalName) ? r.Name : r.InternalName!;
                var seen = new HashSet<Guid>();
                var combined = new List<QuickReportEntry>(owned.Count + shares.Count);
                foreach (var r in owned)
                {
                    if (seen.Add(r.Id))
                        combined.Add(new QuickReportEntry(r.Id, Label(r), IsShared: false));
                }
                foreach (var r in shares)
                {
                    if (seen.Add(r.Id))
                        combined.Add(new QuickReportEntry(r.Id, Label(r), IsShared: true));
                }
                _quickReports = combined
                    .OrderBy(q => q.Label, StringComparer.OrdinalIgnoreCase)
                    .ToList();
            }
            catch
            {
                // Service hiccup shouldn't suppress the button on a
                // false negative — default to true so the user
                // always has a path to retry from the Library. The
                // quick-reports dropdown just stays empty (hidden).
                _hasAnyShares = true;
                _quickReports = new();
            }
        }
        if (hasAdminAccess)
        {
            // Admins / admin-section users see every active company in the
            // picker; mirror that here so the back arrow stays available
            // unless there's literally only one company in the system.
            _accessibleCompanyCount = (await CompanyRegistry.GetActiveAsync()).Count;
        }

        _companyId = company.Id;
        _companyWebsiteUrl = company.WebsiteUrl;
        CurrentCompany.Set(company.Id, company.Code, company.Name, activeEmail);

        // Remember this as the user's last-visited company so /  auto-routes
        // them back here next time. Fire-and-forget: non-critical for render.
        if (!string.IsNullOrEmpty(_userEmail))
        {
            _ = UserManagement.SetLastVisitedCompanyAsync(_userEmail, company.Id);
        }

        // Header now reflects the active company — title = company name,
        // logo = company's uploaded logo. Falls back to per-user prefs when
        // the company has nothing uploaded yet, so a no-logo company still
        // renders something recognizable.
        var prefs = await PreferenceService.GetPreferencesAsync(_userId);

        // Greeting claim — only run the load + render path if this is
        // the first hosting page in the circuit. CompanyPicker may have
        // already claimed the slot if the user came from "All Companies."
        if (!GreetingState.HasShown)
        {
            GreetingState.HasShown = true;
            _showGreeting = true;
            // Capture the previous landing timestamp BEFORE bumping it —
            // the greeting reads the OLD value to compute "since your
            // last visit." Touch the new value asynchronously after
            // rendering so the user sees the delta on this page load and
            // the next visit reads from the now-updated row.
            _lastSeenUtc = prefs.LastMasterDashboardSeen;
            _updatedSinceLastVisit = await CountReportsUpdatedSinceAsync(_lastSeenUtc);
            // Unread bell count for the greeting chip. Best-effort —
            // a notifications-table miss or DB blip just leaves the chip
            // hidden rather than failing the rest of the landing.
            try
            {
                if (!string.IsNullOrEmpty(_userEmail))
                    _unreadNotificationCount = await Notifications.GetUnreadCountAsync(_userEmail);
            }
            catch (Exception nex)
            {
                Logger.LogDebug(nex, "Unread notification count fetch failed on MasterDashboard");
            }
            // Fire-and-forget the touch — the bump only matters for the
            // NEXT visit, so we don't block this render on the round-
            // trip. Errors log silently; missing the bump means the next
            // visit's count will look stale, not a correctness issue.
            _ = PreferenceService.TouchLastMasterDashboardSeenAsync(_userId);
        }
        _dashboardTitle = company.Name;
        if (company.Logo is not null && company.Logo.Length > 0)
        {
            _logoBytes = company.Logo;
            _logoMimeType = company.LogoContentType;
        }
        else
        {
            _logoBytes = prefs.MasterDashboardLogo;
            _logoMimeType = prefs.MasterDashboardLogoType;
        }
        _logoDataUri = BuildLogoDataUri();

        // Keep the Report Library / Builder company filter in sync with the
        // dashboard the user just landed on. The design spec was: picking a
        // company anywhere in the app filters the rest of the session to it.
        // Only writes when the selection actually changed, to avoid clobbering
        // the updated_at timestamp on every navigation.
        if (prefs.ReportLibraryCompanyId != company.Id)
        {
            prefs.UserId = _userId;
            prefs.ReportLibraryCompanyId = company.Id;
            try { await PreferenceService.SavePreferencesAsync(prefs); }
            catch { /* non-fatal — the filter can be re-set manually */ }
        }

        await LoadTabs();
        await LoadFavoritesAsync();

        // No initial MarkClean needed — ComputeDirtySnapshot returns ""
        // when !_editMode, matching the guard's empty baseline, so the
        // viewer-mode dashboard is never reported dirty. The MarkClean
        // calls in ToggleEditMode() establish the baseline when the
        // user actually enters edit mode.
        _initialized = true;
    }

    // Resolves the user's favorite-id list to live SavedReport rows so the
    // strip can render names + nav. Parallel by-id fetches; a missing id
    // (deleted / revoked) silently drops out so the strip never renders a
    // dead link. Re-called by ToggleFavoriteFromStripAsync after a remove
    // so the strip repaints without a full page reload.
    private async Task LoadFavoritesAsync()
    {
        try
        {
            var ids = await FavoriteSvc.GetReportIdsAsync(_userId);
            if (ids.Count == 0) { _favoriteReports = new(); return; }
            var tasks = ids.Select(id => ReportService.GetReportByIdAsync(id)).ToList();
            var rows = await Task.WhenAll(tasks);
            _favoriteReports = rows.Where(r => r is not null).Select(r => r!).ToList();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to load favorites for user {UserId} — strip will be empty.", _userId);
            _favoriteReports = new();
        }
    }

    private async Task UnfavoriteFromStripAsync(Guid reportId)
    {
        try
        {
            await FavoriteSvc.RemoveAsync(_userId, reportId);
            _favoriteReports = _favoriteReports.Where(r => r.Id != reportId).ToList();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Couldn't unfavorite: {ex.Message}", Severity.Warning);
        }
    }

    // Removes the greeting from this page after it slides up. The
    // once-per-circuit guarantee is enforced by GreetingState.HasShown,
    // which was set when we claimed the slot on init — that flag stays
    // true for the rest of the circuit so other hosting pages skip too.
    private void HandleGreetingDismissed()
    {
        _showGreeting = false;
        StateHasChanged();
    }

    // Counts reports in the active company whose UpdatedAt is more recent
    // than the supplied timestamp. Drives the LandingGreeting's "X reports
    // updated since your last visit" copy. Returns 0 on first visit
    // (sinceUtc is null) — the greeting suppresses the chip in that case
    // anyway. Scope-limited to the current company so non-admins don't
    // see counts that include cross-company reports they can't view.
    private async Task<int> CountReportsUpdatedSinceAsync(DateTime? sinceUtc)
    {
        if (sinceUtc is null) return 0;
        try
        {
            var all = await ReportService.GetAllReportsAsync();
            return all.Count(r => r.CompanyId == _companyId && r.UpdatedAt > sinceUtc.Value);
        }
        catch (Exception ex)
        {
            // Non-fatal — the greeting just hides the delta chip if we
            // can't compute it. Logged so a persistent failure shows up.
            Logger.LogWarning(ex, "Failed to compute updated-since-last-visit count.");
            return 0;
        }
    }

    private async Task LoadTabs()
    {
        _loading = true;
        try
        {
            // KPI band is per-company, not per-tab — load alongside tabs so
            // the band renders on the first paint instead of popping in
            // after the active tab's tiles finish.
            await LoadKpisAsync();
            _tabs = await MasterService.GetTabsAsync(_companyId);
            // Per-user hidden-tab filter. Loaded alongside the shared tabs so
            // the first render can already filter; admins flipping into edit
            // mode bypass the filter at render time without a reload.
            _hiddenTabIds = await MasterService.GetHiddenTabIdsAsync(_userId, _companyId);
            if (_tabs.Any())
            {
                // Active-tab index is computed against the VISIBLE list so the
                // initial selection doesn't land on a hidden tab. Falls back to
                // the first tab overall if every tab is hidden (the empty-view
                // case — user sees a "no visible tabs" hint with a way back).
                var firstVisible = _tabs.FindIndex(t => !_hiddenTabIds.Contains(t.Id));
                _activeTabIndex = firstVisible >= 0 ? firstVisible : 0;
                await LoadTilesForActiveTab();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add(FriendlyError.FromException(ex, Logger, "loading dashboard"), Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadTilesForActiveTab()
    {
        var tab = ActiveTab;
        if (tab is null) { _tiles.Clear(); return; }

        try
        {
            // If we already have an in-memory snapshot for this tab (e.g. user is
            // toggling between tabs in edit mode), restore it instead of clobbering
            // their unsaved edits with a fresh DB fetch.
            if (_tilesByTab.TryGetValue(tab.Id, out var cachedTiles))
            {
                _tiles = cachedTiles;
            }
            else
            {
                _tiles = await MasterService.GetTilesAsync(_companyId, tab.Id);
            }

            // Append the current user's personal pins to the active tab.
            // Personal tiles carry IsPersonal=true so the render path can
            // surface the Unpin overlay and SaveLayout can filter them
            // out of UpdateLayoutAsync (the layout-save SQL targets the
            // shared tile table only — sending personal-tile ids there
            // would update the wrong rows because both id columns are
            // separate IDENTITYs that can overlap).
            try
            {
                var personal = await MasterService.GetPersonalTilesAsync(_userId, _companyId, tab.Id);
                if (personal.Count > 0) _tiles.AddRange(personal);
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Loading personal dashboard tiles failed — showing shared only.");
            }

            // Recompute the personal-pin candidate count for the new tab.
            // Drives the "Pin to my view" button's visibility — the button
            // is hidden when there's nothing the user could actually pin
            // (so they don't open an empty dialog). Cheap: every underlying
            // service call is cached.
            _personalPinCandidateCount = (await ComputePersonalPinCandidatesAsync()).Count;
            // Sections track the same cached/fresh path as tiles so a tab
            // toggle in edit mode doesn't discard pending section edits or
            // burn an extra round-trip when the user already loaded them.
            if (_sectionsByTab.TryGetValue(tab.Id, out var cachedSections))
            {
                _sections = cachedSections;
            }
            else
            {
                _sections = await MasterService.GetSectionsAsync(tab.Id);
            }
            // Default the section-tab strip to the first real section (or 0
            // for the "(no section)" tab when none exist). Wrapped so any
            // future cross-call mutation can re-use the same fallback rules.
            _activeSectionId = ResolveDefaultActiveSectionId();
            _pendingRemovals = _pendingRemovalsByTab.TryGetValue(tab.Id, out var cachedRemovals)
                ? cachedRemovals
                : new List<MasterDashboardTile>();

            await LoadActiveSectionTiles();
        }
        catch (Exception ex)
        {
            Snackbar.Add(FriendlyError.FromException(ex, Logger, "loading dashboard tiles"), Severity.Error);
        }
    }

    // Fires queries for the tiles in the currently-active section. Lazy at
    // the section level — sections the admin doesn't visit don't pay any
    // cost. Always re-fetches on every entry rather than caching, so the
    // dashboard always shows live data; section switches re-run the
    // section's queries (cheap when each query is sub-second).
    private async Task LoadActiveSectionTiles()
    {
        var tab = ActiveTab;
        if (tab is null) return;

        var targetTiles = _sections.Count == 0
            ? _tiles.ToList()
            : _tiles.Where(t => (t.SectionId ?? 0) == _activeSectionId).ToList();
        if (targetTiles.Count == 0) return;

        await LoadTileDataFor(targetTiles);
    }

    private async Task OnTabChanged(int index)
    {
        // Snapshot the outgoing tab's in-memory tiles + pending removals so we can
        // restore them when the user comes back. Without this, switching tabs in
        // edit mode would lose alignment / resize / removal edits.
        var outgoing = ActiveTab;
        if (outgoing is not null)
        {
            _tilesByTab[outgoing.Id] = _tiles;
            _sectionsByTab[outgoing.Id] = _sections;
            _pendingRemovalsByTab[outgoing.Id] = _pendingRemovals;
        }
        _activeTabIndex = index;
        // Exit personal-edit mode on tab switch. Personal-tile changes
        // already persist immediately, so there's nothing to lose; but
        // leaving the mode on would mean the user lands on the next tab
        // with resize handles already showing on any personal pins there,
        // which they may not be ready to edit.
        _personalEditMode = false;
        await LoadTilesForActiveTab();
    }

    // Loads tile data for a specific subset of tiles. Does NOT clear
    // _tileData — preserves entries for tiles outside the target subset
    // (e.g. tiles in another tab still in memory). Existing entries
    // for tiles in the target subset are overwritten as their fresh
    // results land.
    //
    // Progressive reveal: every tile loads in parallel but each one
    // re-renders the page the moment ITS query finishes — not at the
    // end of the batch. A 10-tile load where nine queries take 800ms
    // and one takes 12s now paints the nine immediately instead of
    // holding all ten spinners for 12 seconds.
    //
    // Thread safety: the dictionaries (_tileData / _tileErrors /
    // _tileLoading) are not thread-safe, so the merge runs on the
    // renderer's sync context via InvokeAsync. Blazor serializes work
    // on that context, so the per-tile merges can't race even when
    // their async DB calls return in any order. (The earlier
    // "collect-then-merge" pattern solved the same race differently;
    // this swap preserves the safety guarantee while enabling
    // progressive rendering.)
    private async Task LoadTileDataFor(IList<MasterDashboardTile> targetTiles)
    {
        if (targetTiles.Count == 0) return;

        // Drop any prior loading/error/failure markers for these specific
        // tiles so a stale spinner from an earlier eviction doesn't stick.
        foreach (var tile in targetTiles)
        {
            _tileErrors.Remove(tile.ReportId);
            _tileFailedQuery.Remove(tile.ReportId);
            _tileLoading.Add(tile.ReportId);
        }
        StateHasChanged();

        var tasks = targetTiles.Select(async tile =>
        {
            // Async DB work happens OFF the sync context — multiple tiles
            // hit the database in parallel here, exactly as before.
            TileLoadResult? result = null;
            FailedTileQuery? failure = null;
            string? error = null;
            try
            {
                (result, failure) = await LoadReportDashboard(tile.ReportId);
            }
            catch (Exception ex)
            {
                // Pre-execute failure (report not found, template fetch
                // failed, etc.). No request was even built — only an error
                // string to show. Right-click on these tiles falls through
                // to the "couldn't generate SQL" branch in ShowTileQuery.
                error = ex.Message;
            }

            // Marshal the merge + re-render onto the renderer's sync
            // context. Each tile takes the context briefly when it
            // resolves, which is what makes the fast tiles paint
            // without waiting for the slow one in the batch.
            await InvokeAsync(() =>
            {
                if (result is not null)
                {
                    _tileData[tile.ReportId] = result;
                    _tileLoadedAtUtc[tile.ReportId] = DateTime.UtcNow;
                }
                if (failure is not null)
                {
                    _tileErrors[tile.ReportId] = failure.Error;
                    _tileFailedQuery[tile.ReportId] = failure;
                    _tileLoadedAtUtc.Remove(tile.ReportId);
                }
                else if (error is not null)
                {
                    _tileErrors[tile.ReportId] = error;
                    _tileLoadedAtUtc.Remove(tile.ReportId);
                }
                _tileLoading.Remove(tile.ReportId);
                StateHasChanged();
            });
        }).ToList();

        // Still await the whole batch so callers can observe completion
        // (e.g. OnIdleRefresh's logging, OnTabChanged's chaining) — but the
        // user-visible reveal has already happened tile-by-tile above.
        await Task.WhenAll(tasks);

        // Stamp the refresh time once the full batch is in. Used by the
        // header indicator so users can see how fresh the data is. Set
        // here (not inside the per-tile InvokeAsync) so the timestamp
        // tracks the slowest tile — the user's visual cue should match
        // the latest data they could be looking at.
        _lastRefreshedAt = DateTime.Now;
        StateHasChanged();
    }

    // ── KPI band loading + compute ──
    // Loads the company's KPI definitions, visibility flag, and the
    // connection catalog (used by the Manage KPIs dialog), then fans out
    // one aggregation query per KPI. Errors are swallowed per-KPI so a
    // single broken query (e.g. a renamed field) doesn't hide the rest
    // of the band — the offending card just renders an em-dash.
    private async Task LoadKpisAsync()
    {
        try
        {
            var bandTask = KpiSvc.IsBandVisibleAsync(_companyId);
            var kpisTask = KpiSvc.GetByCompanyAsync(_companyId);
            var connsTask = ConnectionSvc.GetByCompanyAsync(_companyId);
            await Task.WhenAll(bandTask, kpisTask, connsTask);
            _kpiBandVisible = bandTask.Result;
            _kpis = kpisTask.Result;
            _kpiConnections = connsTask.Result;
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "KPI band metadata load failed for company {CompanyId}", _companyId);
            _kpis = new();
            _kpiBandVisible = false;
            _kpiConnections = new();
            return;
        }
        // Short-circuit when there's nothing to render — saves a fan-out
        // of queries that would produce no visible output anyway.
        if (!_kpiBandVisible || _kpis.Count == 0)
        {
            _kpiResults = new();
            _kpiQuery = new();
            StateHasChanged();
            return;
        }
        await RecomputeKpiResultsAsync();
        // Belt-and-suspenders: RecomputeKpiResultsAsync already calls
        // StateHasChanged at the end, but doing it here too guarantees a
        // post-load re-render on the path where the dialog closed and
        // we re-entered LoadKpisAsync from OpenManageKpisDialog. Cheap.
        StateHasChanged();
    }

    // Fans out one (or two) aggregation queries per KPI in parallel.
    // Called from LoadKpisAsync on first load and from the Manage KPIs
    // dialog's close handler so the band refreshes immediately when an
    // admin edits, adds, or removes a card. Also captures the SQL +
    // params for the right-click "Show SQL" dialog.
    private async Task RecomputeKpiResultsAsync()
    {
        var pairs = await Task.WhenAll(_kpis.Select(async k =>
        {
            try
            {
                var (current, info) = await ComputeKpiAsync(k, previousPeriod: false);
                decimal? previous = null;
                if (k.ComparePrevious
                    && !string.IsNullOrEmpty(k.Period)
                    && !string.IsNullOrEmpty(k.DateFieldId))
                {
                    (previous, _) = await ComputeKpiAsync(k, previousPeriod: true);
                }
                decimal? delta = null;
                if (current is decimal c && previous is decimal p && p != 0m)
                {
                    delta = (c - p) / p;
                }
                return (k.Id, new KpiResult(current, previous, delta, info?.Error), info);
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "KPI compute failed for {Id}", k.Id);
                return (k.Id, KpiResult.FromError(ex.Message),
                    (KpiQueryInfo?)new KpiQueryInfo(
                        "/* SQL couldn't be generated — see error message */",
                        null,
                        ex.Message));
            }
        }));
        _kpiResults = pairs.ToDictionary(p => p.Id, p => p.Item2);
        _kpiQuery = pairs.Where(p => p.Item3 is not null)
                         .ToDictionary(p => p.Id, p => p.Item3!);
        StateHasChanged();
    }

    // Runs a single SELECT <agg>(<field>) aggregation against the KPI's
    // connection + primary table. previousPeriod = true shifts the date
    // window to the immediately-preceding span of the same length so the
    // delta chip has a baseline to compare against. Returns (value, info)
    // — info carries the SQL/params for the Show SQL dialog. If the
    // execute path throws, info contains the build-only SQL + error.
    private async Task<(decimal? Value, KpiQueryInfo Info)> ComputeKpiAsync(CompanyKpi kpi, bool previousPeriod)
    {
        var request = new QueryRequest
        {
            ConnectionId = kpi.ConnectionId,
            PrimaryTable = kpi.PrimaryTable,
            FieldIds = new List<string> { kpi.FieldId },
            Aggregations = new Dictionary<string, string>
            {
                [kpi.FieldId] = KpiAggregations.ToSqlOp(kpi.Aggregation)
            },
            // PageSize=1 because an aggregation with no GROUP BY columns
            // collapses to one row. We never need more than that.
            PageSize = 1,
            DisableDefaultSort = true,
            // Layer the KPI's authored predicates on top of the date window.
            // SqlEmitter combines Filters + CustomFilterIds + date filter
            // with AND, so the aggregation runs over the narrowed slice.
            Filters = kpi.Filters is { Count: > 0 }
                ? new Dictionary<string, object?>(kpi.Filters)
                : new Dictionary<string, object?>(),
            CustomFilterIds = kpi.CustomFilterIds is { Count: > 0 }
                ? new List<string>(kpi.CustomFilterIds)
                : null
        };

        if (!string.IsNullOrEmpty(kpi.Period) && !string.IsNullOrEmpty(kpi.DateFieldId))
        {
            DateTime from, to;
            if (string.Equals(kpi.Period, KpiPeriods.Custom, StringComparison.OrdinalIgnoreCase))
            {
                // Custom-range KPIs carry explicit DateFrom/DateTo. Skip
                // entirely when either is missing — the dialog requires
                // both, but defend against bad data on the read path.
                if (kpi.DateFrom is null || kpi.DateTo is null)
                {
                    // No date filter applied; fall through.
                    request.DateFieldId = null;
                    goto AfterDate;
                }
                from = kpi.DateFrom.Value;
                to = kpi.DateTo.Value;
                if (previousPeriod)
                {
                    var len = to - from;
                    to = from;
                    from = from - len;
                }
            }
            else
            {
                var now = DateTime.UtcNow;
                (from, to) = previousPeriod
                    ? KpiPeriods.ResolvePrevious(kpi.Period!, now)
                    : KpiPeriods.Resolve(kpi.Period!, now);
            }
            request.DateFieldId = kpi.DateFieldId;
            request.DateFrom = from;
            request.DateTo = to;
            // DateFilterTranslator short-circuits when DateOperatorId is
            // blank — we need to set it explicitly to "custom_range" so the
            // BuildCustomRange path emits "<col> >= @DateFrom AND <col> <= @DateTo".
            // KPIs resolve their own (from, to) bounds; we never use the
            // schema's named relative operators (mtd/qtd/etc. are local to
            // the KPI feature, not the SchemaConfig's RelativeDateOperators).
            request.DateOperatorId = "custom_range";
        }
        AfterDate:;

        try
        {
            // IQueryPipeline (SqlEmitter) is the path that actually honors
            // request.Aggregations and the date-filter inputs. The legacy
            // IQueryService.ExecuteQueryAsync path was producing raw SELECTs
            // with no SUM/GROUP BY and no date predicate, because it uses
            // QueryBuilder which doesn't read request.Aggregations.
            // Admin-level KPIs run with no role-based redaction.
            var roles = new[] { UserRoles.Admin };
            var response = await KpiPipeline.ExecuteAsync(request, roles);
            var info = new KpiQueryInfo(response?.Sql ?? string.Empty,
                                        response?.Parameters, null);
            if (response?.Rows is null || response.Rows.Count == 0)
                return (null, info);

            var first = response.Rows[0];
            // The aggregation result column is keyed by the field id;
            // older emitters may key by uppercase, so fall back to a
            // case-insensitive lookup if the literal key misses.
            object? raw = null;
            if (!first.TryGetValue(kpi.FieldId, out raw) || raw is null)
            {
                var match = first.Keys.FirstOrDefault(k =>
                    string.Equals(k, kpi.FieldId, StringComparison.OrdinalIgnoreCase));
                if (match is not null) raw = first[match];
            }
            if (raw is null) return (null, info);

            try { return (Convert.ToDecimal(raw), info); }
            catch { return (null, info); }
        }
        catch (TleReportingDashboard.Web.Services.QueryPipeline.QueryExecutionException qex)
        {
            // SQL was built but the DB rejected it. Pull the SQL + bound
            // parameters off the exception so the Show SQL dialog has the
            // exact text that failed (most useful debug surface — admin
            // sees the actual emitted SQL with the actual filter values).
            return (null, new KpiQueryInfo(qex.Sql, qex.Parameters, qex.Message));
        }
        catch (Exception ex)
        {
            // Build-time failure (schema lookup, join resolution, unknown
            // field id, etc.) — no SQL was emitted. Surface a placeholder
            // so the dialog still opens and the user sees the error.
            return (null, new KpiQueryInfo(
                "/* SQL couldn't be generated — see error message */",
                null,
                ex.Message));
        }
    }

    // Right-click handler for KPI cards. Opens the same ShowQueryDialog
    // the tile right-click uses so admins debug both surfaces the same way.
    private async Task ShowKpiQuery(CompanyKpi kpi)
    {
        if (!_kpiQuery.TryGetValue(kpi.Id, out var info))
        {
            Snackbar.Add("This KPI hasn't loaded yet — wait for it to finish.", Severity.Info);
            return;
        }
        var label = string.IsNullOrWhiteSpace(kpi.Label) ? kpi.FieldId : kpi.Label!;
        var dialogParams = new DialogParameters
        {
            { "Sql", info.Sql },
            { "Parameters", info.Parameters },
            { "ScopingNote", (string?)null },
            { "ScopingForceNoMatch", false },
            { "ErrorMessage", info.Error }
        };
        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Large,
            FullWidth = true
        };
        await DialogService.ShowAsync<ShowQueryDialog>($"SQL — {label}", dialogParams, options);
    }

    // Opens the Manage KPIs dialog. If anything was changed (KPI added,
    // removed, reordered, edited, or band visibility toggled), refetch
    // and recompute so the band reflects the new state immediately.
    private async Task OpenManageKpisDialog()
    {
        var parameters = new DialogParameters<ManageKpisDialog>
        {
            { x => x.CompanyId, _companyId },
            { x => x.Connections, _kpiConnections }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dlg = await DialogService.ShowAsync<ManageKpisDialog>("Manage KPIs", parameters, options);
        var result = await dlg.Result;
        var dirty = result?.Data is bool b && b;
        if (dirty)
        {
            await LoadKpisAsync();
        }
    }

    private async Task<(TileLoadResult? Result, FailedTileQuery? Failure)> LoadReportDashboard(Guid reportId)
    {
        // Shared-per-company dashboard (Phase 3): the tile's presence on this
        // company's dashboard *is* the authorization signal. The page-level
        // access check in OnInitializedAsync has already verified the user
        // can view the company, so we fetch the report directly without
        // owner/share scoping — otherwise Viewers and Editors who don't own
        // the report and don't have a share record get "Failed to load" on
        // every tile.
        var report = await ReportService.GetReportByIdAsync(reportId);
        if (report is null) return (null, null);

        // Resolve fields from a linked grid template if present, otherwise
        // fall back to the report's saved FieldIds. Template hidden-column
        // list is also captured here for the merged-hidden union below.
        var fieldIds = new List<string>();
        List<string>? templateHiddenColumns = null;
        Dictionary<string, string>? templateColumnLabels = null;
        if (report.GridTemplateId.HasValue)
        {
            var resolved = await GridTemplateService.ResolveTemplateAsync(report.GridTemplateId);
            if (resolved is not null)
            {
                fieldIds = resolved.FieldIds;
                templateHiddenColumns = resolved.HiddenColumns;
                templateColumnLabels = resolved.CustomColumnLabels;
            }
        }
        else if (!string.IsNullOrWhiteSpace(report.FieldIds))
        {
            fieldIds = System.Text.Json.JsonSerializer.Deserialize<List<string>>(report.FieldIds) ?? new();
        }
        if (!fieldIds.Any()) return (null, null);

        // Pull the bits the tile renderer needs from column_state — these
        // are NOT QueryRequest knobs so the factory doesn't surface them:
        //   • DashboardConfig — the tile UI's chart/group/dimension config
        //   • reportHiddenColumns — merged with template hidden below
        //   • tableCalcColumns — passed to the rendered tile so calc-column
        //     captions resolve and group-by lists include calc keys
        DashboardView.DashboardConfig? config = null;
        List<string>? reportHiddenColumns = null;
        List<TleReportingDashboard.Web.Models.TableCalcColumnDef>? tableCalcColumns = null;
        if (!string.IsNullOrWhiteSpace(report.ColumnState))
        {
            try
            {
                config = System.Text.Json.JsonSerializer.Deserialize<DashboardView.DashboardConfig>(
                    report.ColumnState, AppJson.Compact);
                using var doc = System.Text.Json.JsonDocument.Parse(report.ColumnState);
                if (doc.RootElement.TryGetProperty("HiddenColumns", out var hcEl))
                    reportHiddenColumns = System.Text.Json.JsonSerializer.Deserialize<List<string>>(hcEl.GetRawText());
                if (doc.RootElement.TryGetProperty("TableCalculatedColumns", out var tcEl))
                {
                    tableCalcColumns = System.Text.Json.JsonSerializer
                        .Deserialize<List<TleReportingDashboard.Web.Models.TableCalcColumnDef>>(tcEl.GetRawText());
                }
            }
            catch { }
        }

        // Pre-fetch PK columns of the report's primary table so QueryBuilder
        // can append them as silent tiebreakers for OFFSET stability — same
        // mechanism the editor uses. Best-effort: if the lookup fails (no
        // PK, locked-down account, parse failure) we ship null and fall
        // through to the legacy "first selected field" anchor.
        List<string>? pkColumns = null;
        if (!string.IsNullOrWhiteSpace(report.PrimaryTable))
        {
            try
            {
                var bare = report.PrimaryTable;
                var asIdx = bare.IndexOf(" AS ", StringComparison.OrdinalIgnoreCase);
                if (asIdx > 0) bare = bare[..asIdx].Trim();
                var dot = bare.IndexOf('.');
                string? schema = dot > 0 ? bare[..dot] : null;
                var table = dot > 0 ? bare[(dot + 1)..] : bare;
                // Effective lookup folds in admin-flagged IsUnique fields,
                // so accounts that can't read information_schema still get
                // a stable OFFSET tiebreaker.
                var schemaFields = await SchemaService.GetFieldConfigsAsync(report.ConnectionId);
                pkColumns = await SchemaBrowser.GetEffectivePrimaryKeyColumnsAsync(report.ConnectionId, schema, table, schemaFields);
            }
            catch { pkColumns = null; }
        }

        // Single source of truth for "QueryRequest from a SavedReport".
        // Same factory the Worker, Report Viewer, and Detail Viewer use —
        // every saved knob (filters with JsonElement unwrap, advanced
        // filters, sort priority chain, distinct, calc SQL, etc.) lands
        // automatically.
        var request = TleReportingDashboard.Web.Services.QueryRequestFactory
            .FromSavedReport(report, pageSize: 50000, fallbackSortColumns: pkColumns);

        // Per-surface overrides:
        //  • FieldIds — splice in the dashboard's ExtraGroupBy / ExtraDimension
        //    fields (a per-render concern, not a saved-report knob), and use
        //    the template-resolved set when one is linked.
        //  • AdvancedFilters — gated by Features:AdvancedFilters so an
        //    appsettings rollback also takes effect on the Master Dashboard.
        void AddExtraIds(IEnumerable<string>? ids)
        {
            if (ids is null) return;
            foreach (var extra in ids)
                if (!fieldIds.Contains(extra, StringComparer.OrdinalIgnoreCase))
                    fieldIds.Add(extra);
        }
        AddExtraIds(config?.ExtraGroupByFieldIds);
        AddExtraIds(config?.ExtraDimensionFieldIds);
        request.FieldIds = fieldIds;

        if (!Config.GetValue<bool>("Features:AdvancedFilters", false))
            request.AdvancedFilters = null;

        request.Scoping = await ScopeResolver.ResolveAsync(_userEmail, report.ConnectionId, report.PrimaryTable);

        // Union template-level and report-level hidden column lists so a
        // field marked hidden on the template is honored everywhere,
        // regardless of the individual report's saved override. Matches
        // the fix in ReportViewer + DetailViewer.
        var mergedHidden = ((templateHiddenColumns ?? new List<string>())
            .Union(reportHiddenColumns ?? new List<string>(), StringComparer.OrdinalIgnoreCase))
            .ToList();

        try
        {
            var data = await QueryService.ExecuteQueryAsync(request);
            return (new TileLoadResult(data, config, mergedHidden.Count > 0 ? mergedHidden : null, tableCalcColumns, templateColumnLabels), null);
        }
        catch (Exception ex)
        {
            // Execute failed (most often the source DB rejected the SQL).
            // Recover the SQL via the build-only path so the right-click
            // "Show query" dialog can still display what was attempted —
            // otherwise admins debugging a broken tile have no way to see
            // the generated SQL without tailing logs.
            try
            {
                var (sql, parameters) = await QueryService.BuildSqlAsync(request);
                return (null, new FailedTileQuery(
                    sql, parameters,
                    request.Scoping?.Reason,
                    request.Scoping?.ForceNoMatch == true,
                    ex.Message));
            }
            catch (Exception buildEx)
            {
                // Build phase also failed. No SQL to show — surface the
                // build error alongside the original execute error so the
                // dialog explains why both paths gave up.
                return (null, new FailedTileQuery(
                    string.Empty, new(),
                    request.Scoping?.Reason,
                    request.Scoping?.ForceNoMatch == true,
                    $"{ex.Message}\n\n(SQL couldn't be regenerated: {buildEx.Message})"));
            }
        }
    }

    // ── Tab management ──

    private async Task AddTab()
    {
        try
        {
            // Snapshot the outgoing tab's in-memory edits before switching focus.
            // Mirror OnTabChanged exactly — sections must be snapshotted too,
            // otherwise the new (empty) tab inherits the previous tab's
            // section bar visually until something forces a reload.
            var outgoing = ActiveTab;
            if (outgoing is not null)
            {
                _tilesByTab[outgoing.Id] = _tiles;
                _sectionsByTab[outgoing.Id] = _sections;
                _pendingRemovalsByTab[outgoing.Id] = _pendingRemovals;
            }
            var tab = await MasterService.AddTabAsync(_companyId, $"Tab {_tabs.Count + 1}", _userEmail);
            _tabs.Add(tab);
            _activeTabIndex = _tabs.Count - 1;
            _editMode = true;
            // Reset every per-tab collection for the brand-new tab —
            // tiles, sections, pending removals, active section. Without
            // resetting sections, the new tab still renders the previous
            // tab's section strip and the active-section pointer (stale
            // section id from the outgoing tab) makes the tile visibility
            // filter hide everything.
            _tiles = new List<MasterDashboardTile>();
            _sections = new List<MasterDashboardSection>();
            _pendingRemovals = new List<MasterDashboardTile>();
            _activeSectionId = ResolveDefaultActiveSectionId();
            StateHasChanged();
            await RenameTab(tab);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to add tab: {ex.Message}", Severity.Error);
        }
    }

    private async Task RenameTab(MasterDashboardTab tab)
    {
        var newName = await JS.InvokeAsync<string>("prompt", "Enter a new name for this tab:", tab.Label);
        if (!string.IsNullOrWhiteSpace(newName))
        {
            tab.Label = newName;
            StateHasChanged();
        }
    }

    private async Task RemoveTab(MasterDashboardTab tab)
    {
        if (_tabs.Count <= 1) return;
        if (await Snackbar.RunAsync(Logger, "removing dashboard tab",
                () => MasterService.RemoveTabAsync(tab.Id, _userEmail)))
        {
            _tabs.Remove(tab);
            _activeTabIndex = Math.Min(_activeTabIndex, _tabs.Count - 1);
            await LoadTilesForActiveTab();
        }
    }

    // ── Section management ──
    // Mirror of the tab CRUD pattern but scoped to the active tab. Section
    // drag state is independent from tile drag state (_dragSource/_dropTarget)
    // so the two interaction surfaces don't interfere.

    private int _sectionDragSource = -1;

    // Index of the tab whose drag-handle the user grabbed. Mirrors the
    // section drag-source pattern but for the top-level tab strip.
    // -1 means "no tab is being dragged." OnTabStripDrop dispatches to
    // OnTabDrop when this is set, separately from section / tile drag
    // sources so the three flavors don't interfere.
    private int _tabDragSource = -1;

    // First real section's id, falling back to 0 (= "(no section)") when
    // none exist. Used on tab load and after section deletes / moves.
    private int ResolveDefaultActiveSectionId() =>
        _sections.Count > 0 ? _sections[0].Id : 0;

    // Setter used by the section-tab click handlers — keeps the underlying
    // field private so future hooks (per-section preference persistence,
    // animation, etc.) have a single point to plug into.
    private async Task SetActiveSection(int sectionKey)
    {
        if (_activeSectionId == sectionKey) return;
        _activeSectionId = sectionKey;
        StateHasChanged();

        // Re-fetch the new section's tiles every time. Sections the admin
        // doesn't visit don't pay any cost (lazy); sections they do visit
        // always show live data (no caching across switches).
        if (ActiveTab is not null)
            await LoadActiveSectionTiles();
    }

    // Unified drop-target index for section headers. -1 = none.
    // -2 = the "(no section)" pseudo-header. Otherwise = index into
    // _sections. Used for both flavors of drag: section reorder
    // (existing) and tile-onto-header assignment (V2-3 / V2-6).
    private int _headerDropTargetIdx = -1;

    private async Task AddSection()
    {
        var tab = ActiveTab;
        if (tab is null) return;
        // Defense-in-depth: server enforces the same cap and will throw,
        // but stopping here keeps the snackbar UX consistent with other
        // client-side guard rails on this page.
        if (_sections.Count >= IMasterDashboardService.MaxSectionsPerTab)
        {
            Snackbar.Add(
                $"Maximum of {IMasterDashboardService.MaxSectionsPerTab} sections per tab reached.",
                Severity.Warning);
            return;
        }
        var label = await JS.InvokeAsync<string>("prompt", "Enter a name for the section:", $"Section {_sections.Count + 1}");
        if (string.IsNullOrWhiteSpace(label)) return;
        var (ok, section) = await Snackbar.RunAsync(Logger, "creating section",
            () => MasterService.AddSectionAsync(tab.Id, label.Trim(), _userEmail));
        if (ok && section is not null)
        {
            _sections.Add(section);
            // Auto-switch the section-tab strip onto the new section so the
            // admin can immediately drop tiles into it / rename / etc.
            _activeSectionId = section.Id;
            StateHasChanged();
        }
    }

    private async Task SetSectionAlign(MasterDashboardSection section, string align)
    {
        if (string.Equals(section.TitleAlign, align, StringComparison.OrdinalIgnoreCase)) return;
        var previous = section.TitleAlign;
        section.TitleAlign = align;
        StateHasChanged();
        try
        {
            await MasterService.SetSectionAlignAsync(section.Id, align, _userEmail);
        }
        catch (Exception ex)
        {
            // Server rejected — revert the optimistic UI change so the
            // toolbar's checked button matches what's actually persisted.
            section.TitleAlign = previous;
            Snackbar.Add($"Failed to set section alignment: {ex.Message}", Severity.Error);
            StateHasChanged();
        }
    }

    private async Task RenameSection(MasterDashboardSection section)
    {
        var newName = await JS.InvokeAsync<string>("prompt", "Enter a new name for this section:", section.Label);
        if (string.IsNullOrWhiteSpace(newName) || newName.Trim() == section.Label) return;
        if (await Snackbar.RunAsync(Logger, "renaming section",
                () => MasterService.RenameSectionAsync(section.Id, newName.Trim(), _userEmail)))
        {
            section.Label = newName.Trim();
            StateHasChanged();
        }
    }

    private async Task RemoveSection(MasterDashboardSection section)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm",
            $"Remove section \"{section.Label}\"? Tiles in this section will move to the \"(no section)\" group.");
        if (!confirmed) return;
        if (await Snackbar.RunAsync(Logger, "removing section",
                () => MasterService.RemoveSectionAsync(section.Id, _userEmail)))
        {
            _sections.Remove(section);
            // Server cleared section_id on every tile that referenced this
            // section. Mirror that locally so the next render groups them
            // under "(no section)" without a refetch.
            foreach (var t in _tiles)
                if (t.SectionId == section.Id) t.SectionId = null;
            // If the deleted section was the active one, fall back to the
            // first remaining real section, or to "(no section)" (key = 0)
            // — which is what the orphaned tiles surface under, so the
            // admin sees them right where they landed.
            if (_activeSectionId == section.Id)
            {
                _activeSectionId = _sections.Count > 0 ? _sections[0].Id : 0;
            }
            StateHasChanged();
        }
    }

    // Unified drop handler for section headers. Branches based on which
    // drag flavor is currently active:
    //   • Section drag → delegate to OnSectionDrop (existing reorder).
    //   • Tile drag    → reassign the dragged tile's SectionId (or NULL
    //                    when dropped on the "(no section)" header).
    // Mutually exclusive in practice — tile and section drags can't run
    // concurrently because each starts only when its own drag handle is
    // grabbed. Resets _headerDropTargetIdx in all paths so a stale glow
    // doesn't linger on the next render.
    private async Task OnHeaderDrop(MasterDashboardSection? targetSection)
    {
        _headerDropTargetIdx = -1;
        if (_sectionDragSource >= 0 && targetSection is not null)
        {
            await OnSectionDrop(_sections.IndexOf(targetSection));
            return;
        }
        if (_dragSource >= 0 && _dragSource < _tiles.Count)
        {
            var tile = _tiles[_dragSource];
            var newSectionId = targetSection?.Id;
            _dragSource = -1;
            _dropTarget = -1;
            _dropTargetTabId = 0;
            await MoveTileToSection(tile, newSectionId);
        }
    }

    private async Task OnSectionDrop(int targetIndex)
    {
        if (_sectionDragSource < 0 || _sectionDragSource == targetIndex)
        {
            _sectionDragSource = -1;
            _headerDropTargetIdx = -1;
            return;
        }
        // Drop semantic: dragging RIGHT/DOWN drops AFTER the target section;
        // dragging LEFT/UP drops BEFORE. Both collapse to "insert at the
        // target's pre-removal index" — same reasoning as OnTileDrop. The
        // earlier `targetIndex - 1` adjustment made dropping on the last
        // section land the source second-to-last.
        var item = _sections[_sectionDragSource];
        _sections.RemoveAt(_sectionDragSource);
        var insertAt = Math.Clamp(targetIndex, 0, _sections.Count);
        _sections.Insert(insertAt, item);
        for (var i = 0; i < _sections.Count; i++) _sections[i].SortOrder = i;
        _sectionDragSource = -1;
        _headerDropTargetIdx = -1;
        if (await Snackbar.RunAsync(Logger, "saving section order",
                () => MasterService.UpdateSectionOrderAsync(_sections, _userEmail)))
        {
            StateHasChanged();
        }
    }

    // ── Tile management ──

    // Cached count of personal-pin candidates for the current tab+company.
    // Drives the "Pin to my view" button's visibility — the button only
    // renders when there's something the user could actually pin (no
    // candidates → no button, per the explicit product rule). Recomputed
    // every time tiles load so the count tracks the dashboard's current
    // state without an extra round-trip from the button render.
    private int _personalPinCandidateCount;

    // Source of truth for both the candidate count and the dialog's
    // picker list. Applies three filters on top of GetAvailableReportsAsync:
    //   1. Already on a shared tab (anyone in the company pinned it canonically).
    //   2. Already pinned personally by this user (any tab).
    //   3. Authored by an admin — admins curate their reports onto the
    //      shared layout; surfacing them in the personal-pin picker is
    //      noise for non-admins. Admins who want their own personal pin
    //      can still get there via the dialog's "Pin to my view" toggle,
    //      they just don't see other admins' reports in this candidate set.
    // Returns an empty list when _userId / _companyId aren't ready so the
    // caller never has to null-check the result.
    private async Task<List<SavedReport>> ComputePersonalPinCandidatesAsync()
    {
        if (string.IsNullOrEmpty(_userId) || _companyId == Guid.Empty)
            return new List<SavedReport>();
        try
        {
            var available = await MasterService.GetAvailableReportsAsync(_companyId, _userId);
            if (available.Count == 0) return available;
            var sharedPlaced = await MasterService.GetPlacedReportTabsAsync(_companyId);
            var personalPlaced = await MasterService.GetPersonalPlacedReportIdsAsync(_userId);
            var adminEmails = (await AdminService.GetAdminsAsync())
                .Where(a => !string.IsNullOrWhiteSpace(a.Email))
                .Select(a => a.Email)
                .ToHashSet(StringComparer.OrdinalIgnoreCase);

            return available
                .Where(r => !sharedPlaced.ContainsKey(r.Id))
                .Where(r => !personalPlaced.Contains(r.Id))
                .Where(r => string.IsNullOrEmpty(r.OwnerEmail) || !adminEmails.Contains(r.OwnerEmail))
                .ToList();
        }
        catch (Exception ex)
        {
            // Stay quiet — a failure here just hides the button. Better
            // than surfacing an error toast for a feature the user might
            // not even be trying to use.
            Logger.LogDebug(ex, "Computing personal-pin candidates failed; treating as empty.");
            return new List<SavedReport>();
        }
    }

    // Admin shared-tile add. Opens the picker without the personal-pin
    // toggle (AllowPersonalPin=false) — this surface is intentionally
    // shared-only since it's wired to the admin's "Add Report" button
    // in edit mode. The non-admin / "pin to my own view" path lives in
    // OpenPersonalPinDialog below.
    private Task OpenAddDialog() => OpenAddTileDialog(allowPersonal: false, forcePersonal: false);

    // "Pin to my view" affordance available to every user with company
    // access. AllowPersonalPin=true renders the toggle inside the dialog;
    // ForcePersonalPin=true checks it on and disables for non-admins so
    // they can only create personal pins. For admins the toggle is enabled
    // and pre-checked here (they invoked the "Pin to my view" path
    // explicitly), but they can flip it off mid-dialog to land a shared
    // tile via the same picker.
    private Task OpenPersonalPinDialog() => OpenAddTileDialog(allowPersonal: true,
        forcePersonal: _userRoleForCompany != UserRoles.Admin);

    private async Task OpenAddTileDialog(bool allowPersonal, bool forcePersonal)
    {
        var tab = ActiveTab;
        if (tab is null) return;

        List<SavedReport> available;
        int totalEligible;
        try
        {
            if (allowPersonal)
            {
                // Personal-pin flow: use the same filtered set the
                // header-button visibility check uses, so the dialog never
                // disagrees with the button (i.e., you don't see a button
                // only to open an empty picker). The helper applies the
                // ShowOnMaster + share + already-placed + admin-author
                // filters in one pass.
                available = await ComputePersonalPinCandidatesAsync();
                totalEligible = available.Count;
            }
            else
            {
                // Admin shared-tile flow: original behavior unchanged.
                // Pass _userId so the picker surfaces reports shared
                // directly with this admin too. Filter out reports already
                // placed on ANY of the user's tabs so the same report can't
                // be pinned twice across tabs.
                available = await MasterService.GetAvailableReportsAsync(_companyId, _userId);
                var placedMap = await MasterService.GetPlacedReportTabsAsync(_companyId);
                totalEligible = available.Count;
                var existingIds = placedMap.Keys.ToHashSet();
                available = available.Where(r => !existingIds.Contains(r.Id)).ToList();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load reports: {ex.Message}", Severity.Error);
            return;
        }

        if (!available.Any())
        {
            var msg = totalEligible == 0
                ? "No reports available. Enable 'Show on Master Dashboard' in a report's dashboard editor first."
                : "Every eligible report is already placed on one of your dashboard tabs.";
            Snackbar.Add(msg, Severity.Info);
            return;
        }

        var parameters = new DialogParameters
        {
            { "Reports", available },
            { "Sections", _sections },
            { "AllowPersonalPin", allowPersonal },
            { "ForcePersonalPin", forcePersonal }
        };
        var dialog = await DialogService.ShowAsync<AddTileDialog>("Add Report to Dashboard", parameters,
            DialogPresets.Locked(MaxWidth.Small));

        var result = await dialog.Result;
        if (result is null || result.Canceled || result.Data is not AddTileDialog.AddTileResult tileResult) return;
        var reportId = tileResult.ReportId;

        try
        {
            MasterDashboardTile? newTile;
            if (tileResult.IsPersonal)
            {
                // Personal-pin path. AddPersonalTileAsync is idempotent
                // (MERGE on user+tab+report) so re-pinning the same report
                // returns the existing row. Doesn't enforce admin; the
                // user is just managing their own view.
                newTile = await MasterService.AddPersonalTileAsync(
                    _userId, _companyId, tab.Id, reportId, sectionId: tileResult.SectionId);
                _tiles.Add(newTile);
            }
            else
            {
                // Shared-tile path. AddTileAsync EnsureCompanyAdmin's
                // server-side; non-admins reaching this branch (somehow)
                // get an exception caught below.
                await MasterService.AddTileAsync(_companyId, tab.Id, reportId, _userEmail, sectionId: tileResult.SectionId);
                var allTiles = await MasterService.GetTilesAsync(_companyId, tab.Id);
                newTile = allTiles.FirstOrDefault(t => t.ReportId == reportId);
                if (newTile is not null) _tiles.Add(newTile);
            }

            if (newTile is not null)
            {
                try
                {
                    var (td, failure) = await LoadReportDashboard(newTile.ReportId);
                    if (td is not null) _tileData[newTile.ReportId] = td;
                    if (failure is not null)
                    {
                        _tileErrors[newTile.ReportId] = failure.Error;
                        _tileFailedQuery[newTile.ReportId] = failure;
                    }
                }
                catch { }
            }

            // Personal-pin path lands the tile and goes — don't pop the
            // admin into edit mode. The shared-tile path keeps the
            // historical "drop the admin into edit mode after add" UX.
            if (!tileResult.IsPersonal) _editMode = true;

            // After a successful pin (either path), refresh the candidate
            // count so the button reflects what's still available — and
            // hides itself when nothing's left.
            _personalPinCandidateCount = (await ComputePersonalPinCandidatesAsync()).Count;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to add: {ex.Message}", Severity.Error);
        }
    }

    private void ToggleChart(int tileId)
    {
        if (!_chartVisibleTiles.Remove(tileId))
            _chartVisibleTiles.Add(tileId);
    }

    // Visible tabs respects the per-user hidden-tab filter in view mode and
    // bypasses it entirely in edit mode (admin needs the full canonical
    // layout to manage it). Computed each render — cheap; _tabs is short.
    private List<MasterDashboardTab> VisibleTabs =>
        _editMode ? _tabs : _tabs.Where(t => !_hiddenTabIds.Contains(t.Id)).ToList();

    private async Task ToggleEditMode()
    {
        // Capture the currently-active tab id BEFORE the visible list changes
        // size (toggling edit mode swaps the filter in/out), so we can find it
        // again in the post-toggle list and keep the user on the same tab.
        var activeTabId = VisibleTabs.ElementAtOrDefault(_activeTabIndex)?.Id;

        if (_editMode)
        {
            // Leaving edit mode discards unsaved per-tab edits — drop the snapshots
            // and reload the active tab from DB so the user sees persisted state.
            var hadDirtyState = _pendingRemovals.Any() || _pendingRemovalsByTab.Any() || _tilesByTab.Any();
            _pendingRemovals.Clear();
            _pendingRemovalsByTab.Clear();
            _tilesByTab.Clear();
            if (hadDirtyState)
                await LoadTilesForActiveTab();
            _editMode = false;
            // Discarding edits returns the page to a clean (viewing) state.
            // ComputeDirtySnapshot returns "" when !_editMode, so the
            // guard short-circuits to !IsDirty regardless — but call
            // MarkClean to re-baseline explicitly for clarity.
            _guard?.MarkClean();
        }
        else
        {
            _editMode = true;
            // Baseline matches the current state at the moment editing
            // begins — anything mutated from here is "dirty."
            _guard?.MarkClean();
        }

        // Re-anchor the active index against the new visible list. If the
        // previously-active tab isn't in the new list (e.g. they were on a
        // hidden tab somehow), fall back to the first visible tab.
        if (activeTabId.HasValue)
        {
            var newIdx = VisibleTabs.FindIndex(t => t.Id == activeTabId.Value);
            _activeTabIndex = newIdx >= 0 ? newIdx : 0;
        }
    }

    // Opens the admin-curated "manage tabs" dialog. Loads the company's
    // user list just-in-time (not on every dashboard mount; admins rarely
    // open this) and pre-selects the signed-in admin so the dialog opens
    // ready-to-use on their own view. When the dialog closes, re-pulls
    // THIS user's hidden set (the admin may have edited their own row)
    // and re-anchors the active tab if its visibility changed.
    private async Task OpenManageTabsDialogAsync()
    {
        List<ManageTabsDialog.UserOption> users;
        try
        {
            // All users in the directory, filtered to those with access to
            // the active company plus global admins (who have implicit
            // access). Sort by display name + email for predictable picker
            // order. ~one round-trip per user is acceptable here — admins
            // open this rarely and the directory is small at this scale.
            var allUsers = await UserManagement.GetAllAsync();
            var pairs = new List<(UserRecord User, bool HasAccess)>();
            foreach (var u in allUsers)
            {
                if (u.IsAdmin)
                {
                    pairs.Add((u, true));
                    continue;
                }
                try
                {
                    var access = await UserManagement.GetCompanyAccessAsync(u.Email);
                    pairs.Add((u, access.Any(a => a.CompanyId == _companyId)));
                }
                catch { pairs.Add((u, false)); }
            }
            users = pairs
                .Where(p => p.HasAccess)
                .Select(p => new ManageTabsDialog.UserOption(
                    UserId: !string.IsNullOrEmpty(p.User.UserId) ? p.User.UserId : p.User.Email,
                    Label: string.IsNullOrWhiteSpace(p.User.DisplayName)
                        ? p.User.Email
                        : $"{p.User.DisplayName} ({p.User.Email})"))
                .OrderBy(o => o.Label, StringComparer.OrdinalIgnoreCase)
                .ToList();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Loading user list for Manage Tabs dialog failed");
            Snackbar.Add("Couldn't load the user list. Try again or check the connection to ConfigDb.", Severity.Error);
            return;
        }

        // Pre-select the signed-in admin so the dialog opens on their own
        // view. Falls back to the first user in the list if the admin
        // isn't in it (e.g. global admin without a RPT_users row).
        var initial = users.FirstOrDefault(u => string.Equals(u.UserId, _userId, StringComparison.OrdinalIgnoreCase))
                      ?? users.FirstOrDefault();

        var parameters = new DialogParameters
        {
            ["Tabs"] = _tabs,
            ["Users"] = users,
            ["CompanyId"] = _companyId,
            ["InitialUser"] = initial
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<ManageTabsDialog>("Manage Tabs", parameters, options);
        var result = await dialog.Result;
        if (result is null || result.Canceled || result.Data is not true) return;

        // Capture the active tab id BEFORE we replace the hidden set so we
        // can land back on the same tab if it's still visible.
        var activeTabId = VisibleTabs.ElementAtOrDefault(_activeTabIndex)?.Id;
        try
        {
            _hiddenTabIds = await MasterService.GetHiddenTabIdsAsync(_userId, _companyId);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Reloading hidden tabs after Manage Tabs dialog failed");
        }
        if (activeTabId.HasValue)
        {
            var newIdx = VisibleTabs.FindIndex(t => t.Id == activeTabId.Value);
            _activeTabIndex = newIdx >= 0 ? newIdx : 0;
        }
        StateHasChanged();
    }

    private void RemoveTile(MasterDashboardTile tile)
    {
        _tiles.Remove(tile);
        _pendingRemovals.Add(tile);
        _tileData.Remove(tile.ReportId);
        _tileLoadedAtUtc.Remove(tile.ReportId);
        Snackbar.Add($"{tile.ReportName} marked for removal. Click Save Layout to confirm.", Severity.Warning);
    }

    // Unpin a personal tile immediately. Bypasses the admin pending-removal
    // queue (which gates on Save Layout, an admin-only edit-mode action) so
    // the user controlling their own pin doesn't need to enter edit mode at
    // all. Idempotent on the server — same id from a different user is a
    // silent no-op there too.
    // Opens the report's detail viewer in a new browser window so the
    // dashboard stays put. window.open with _blank target — same pattern
    // the Detail Viewer's "Open in new window" affordance uses elsewhere.
    // The new window goes straight to the detail route (/viewer/{id}/detail)
    // rather than the run route, matching what the dropdown promises.
    private async Task OpenReportDetailInNewWindow(Guid reportId)
    {
        try
        {
            await JS.InvokeVoidAsync("open", $"/viewer/{reportId}/detail", "_blank");
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Failed to open report detail window for {ReportId}", reportId);
            Snackbar.Add("Couldn't open the report in a new window. Check that pop-ups are allowed.", Severity.Warning);
        }
    }

    private async Task UnpinPersonalTile(MasterDashboardTile tile)
    {
        if (!tile.IsPersonal) return;
        try
        {
            await MasterService.RemovePersonalTileAsync(_userId, tile.Id);
            _tiles.Remove(tile);
            _tileData.Remove(tile.ReportId);
            _tileLoadedAtUtc.Remove(tile.ReportId);
            _tileErrors.Remove(tile.ReportId);
            _tileFailedQuery.Remove(tile.ReportId);
            _tileLoading.Remove(tile.ReportId);
            Snackbar.Add($"Unpinned {tile.ReportName} from your view.", Severity.Success);
            // The unpinned report is now a candidate again (it's no longer
            // "already personal-pinned"). Refresh the count so the button
            // reappears if it had gone away.
            _personalPinCandidateCount = (await ComputePersonalPinCandidatesAsync()).Count;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add(FriendlyError.FromException(ex, Logger, "unpinning personal tile"), Severity.Error);
        }
    }

    private async Task SaveLayout()
    {
        for (var i = 0; i < _tiles.Count; i++)
            _tiles[i].SortOrder = i;

        try
        {
            // Snapshot the currently-active tab's tiles into the cache so the save
            // loop below sees its edits alongside any cached tabs the user visited.
            var activeNow = ActiveTab;
            if (activeNow is not null)
            {
                _tilesByTab[activeNow.Id] = _tiles;
                _pendingRemovalsByTab[activeNow.Id] = _pendingRemovals;
            }

            // Delete removed tiles across all edited tabs. Route per-tile
            // by IsPersonal: shared rows go to RemoveTileAsync (admin-only
            // gate inside the service); personal rows go to
            // RemovePersonalTileAsync (user-scoped, no admin requirement).
            foreach (var removalList in _pendingRemovalsByTab.Values)
                foreach (var tile in removalList)
                {
                    if (tile.IsPersonal)
                        await MasterService.RemovePersonalTileAsync(_userId, tile.Id);
                    else
                        await MasterService.RemoveTileAsync(tile.Id, _userEmail);
                }
            _pendingRemovalsByTab.Clear();
            _pendingRemovals.Clear();

            // Update tiles for every tab the user touched in this session.
            // UpdateLayoutAsync targets RPT_master_dashboard_tiles (shared);
            // personal tiles live in a different table with a separate
            // IDENTITY, so passing them here would update the wrong rows.
            // Filter to shared-only before saving. Personal-tile reordering
            // is intentionally out of scope for v1 — they always land at the
            // end of the tab in insertion order.
            foreach (var tabTiles in _tilesByTab.Values)
            {
                var sharedOnly = tabTiles.Where(t => !t.IsPersonal).ToList();
                // Keep sort order in sync with current list position
                for (var i = 0; i < sharedOnly.Count; i++)
                    sharedOnly[i].SortOrder = i;
                await MasterService.UpdateLayoutAsync(sharedOnly, _userEmail);
            }
            _tilesByTab.Clear();

            // Update tab labels and order
            for (var i = 0; i < _tabs.Count; i++)
                _tabs[i].SortOrder = i;
            await MasterService.UpdateTabOrderAsync(_tabs, _userEmail);

            // Persist the logo upload (still user-scoped fallback for now —
            // Phase 3 will route logo uploads to RPT_companies instead so
            // every user sees the same company branding). Title is no
            // longer editable here, so we don't write it back.
            var prefs = await PreferenceService.GetPreferencesAsync(_userId);
            prefs.MasterDashboardLogo = _logoBytes;
            prefs.MasterDashboardLogoType = _logoMimeType;
            await PreferenceService.SavePreferencesAsync(prefs);

            // Save was the explicit clean point — re-baseline so the
            // next navigation away (without further edits) doesn't
            // re-prompt over the just-saved state. The user remains
            // in edit mode after Save Layout, so this only takes
            // effect for subsequent edits.
            _guard?.MarkClean();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to save: {ex.Message}", Severity.Error);
        }
    }

    private async Task OnLogoUploaded(IBrowserFile file)
    {
        await Snackbar.RunAsync(Logger, "uploading logo", async () =>
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 2 * 1024 * 1024); // 2MB max
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            _logoBytes = ms.ToArray();
            _logoMimeType = file.ContentType;
            _logoDataUri = BuildLogoDataUri();
        });
    }

    private void RemoveLogo()
    {
        _logoBytes = null;
        _logoMimeType = null;
        _logoDataUri = null;
    }

    private string? BuildLogoDataUri()
    {
        if (_logoBytes is null || _logoBytes.Length == 0) return null;
        var mime = _logoMimeType ?? "image/png";
        return $"data:{mime};base64,{Convert.ToBase64String(_logoBytes)}";
    }

    private async Task SetTileAlign(MasterDashboardTile tile, string align)
    {
        // Per-tile alignment. Personal pins persist immediately (no Save
        // Layout flow); shared tiles wait for the admin's Save Layout
        // batch via UpdateLayoutAsync.
        tile.TitleAlign = align;
        StateHasChanged();

        if (tile.IsPersonal && !string.IsNullOrEmpty(_userId))
        {
            try
            {
                await MasterService.UpdatePersonalTileLayoutAsync(
                    _userId, tile.Id, tile.ColSpan, tile.Height, align);
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Failed to persist personal-tile align for tile {TileId}", tile.Id);
            }
        }
    }

    // Move a tile into a different section (or to "(no section)" when
    // sectionId is null). Persists immediately — unlike align/resize which
    // wait for Save Layout — because the tile visually jumps to a new
    // group, and a half-applied state would be confusing if the admin
    // toggles edit mode without saving.
    private async Task MoveTileToSection(MasterDashboardTile tile, int? sectionId)
    {
        if (tile.SectionId == sectionId) return;
        if (await Snackbar.RunAsync(Logger, "moving tile",
                () => MasterService.MoveTileToSectionAsync(tile.Id, sectionId, _userEmail)))
        {
            tile.SectionId = sectionId;
            // Follow the tile to its new home so the admin sees the move
            // confirmed visually. Without this auto-switch the tile would
            // just disappear from the active section's view (since only
            // one section's tiles render at a time), which feels like a
            // bug even when it's working correctly.
            _activeSectionId = sectionId ?? 0;
            StateHasChanged();
        }
    }

    private async Task OnTileDrop(int targetIndex)
    {
        if (_dragSource < 0 || _dragSource == targetIndex)
        {
            _dragSource = -1; _dropTarget = -1; _dropTargetTabId = 0;
            return;
        }

        // Cross-section drag: when the source and target tiles live in
        // different sections, the source's SectionId follows the target's
        // BEFORE the local reorder. Persist immediately via the service
        // (sort_order is still pending until Save Layout — matches the
        // existing edit-mode pattern where structural changes are saved
        // as they happen but visual ordering waits for the button).
        var sourceTile = _tiles[_dragSource];
        var targetTile = targetIndex < _tiles.Count ? _tiles[targetIndex] : null;
        if (targetTile is not null && sourceTile.SectionId != targetTile.SectionId)
        {
            try
            {
                await MasterService.MoveTileToSectionAsync(sourceTile.Id, targetTile.SectionId, _userEmail);
                sourceTile.SectionId = targetTile.SectionId;
                // Match MoveTileToSection's behavior — follow the tile so
                // the admin sees the result of their drag.
                _activeSectionId = targetTile.SectionId ?? 0;
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Failed to move tile across sections: {ex.Message}", Severity.Error);
                _dragSource = -1; _dropTarget = -1; _dropTargetTabId = 0;
                return;
            }
        }

        _tiles.RemoveAt(_dragSource);
        // Drop semantic: dragging RIGHT/DOWN drops AFTER the target tile;
        // dragging LEFT/UP drops BEFORE. Both collapse to "insert at the
        // target's pre-removal index" — the RemoveAt above already
        // shifted everything past the source down by 1, which produces
        // the "after target" position naturally for forward drags. The
        // earlier `targetIndex - 1` over-correction made dropping on the
        // last tile land the source second-to-last, with the previous
        // last tile bumping back into place.
        var insertAt = Math.Clamp(targetIndex, 0, _tiles.Count);
        _tiles.Insert(insertAt, sourceTile);
        _dragSource = -1; _dropTarget = -1; _dropTargetTabId = 0;
    }

    // Unified tab-strip drop handler. The tab header accepts both flavors
    // of drag: a tile (existing behavior — moves the single tile) or a
    // section (V2-5 — moves the section AND every tile under it). Branch
    // based on which drag source is active.
    private async Task OnTabStripDrop(int targetTabId)
    {
        if (_tabDragSource >= 0)
        {
            await OnTabDrop(targetTabId);
            return;
        }
        if (_dragSource >= 0)
        {
            await OnTileDropOnTab(targetTabId);
            return;
        }
        // _sectionDragSource is intentionally not handled here — sections
        // can be reordered within their tab but cannot be moved to a
        // different tab. The predicate on the tab @ondragover excludes
        // section drags from highlighting the drop zone, and dropping
        // a section here is a no-op that just clears the highlight.
        _sectionDragSource = -1;
        _dropTargetTabId = 0;
    }

    // Tab reorder. Source is _tabDragSource (set by the drag handle in
    // edit mode); target is the tab the user dropped onto. Move the
    // dragged tab to the target's slot, recompute SortOrder, and
    // persist immediately so the order sticks even if the user closes
    // the browser before clicking Done Editing. Active-tab tracking
    // is by id through the move so the user stays on the same tab
    // they were viewing.
    private async Task OnTabDrop(int targetTabId)
    {
        var sourceIdx = _tabDragSource;
        _tabDragSource = -1;
        _dropTargetTabId = 0;

        if (sourceIdx < 0 || sourceIdx >= _tabs.Count) return;
        var targetIdx = _tabs.FindIndex(x => x.Id == targetTabId);
        if (targetIdx < 0 || targetIdx == sourceIdx) return;

        // Track the currently-active tab by id so we can re-resolve its
        // index after the reorder. Without this, dragging a tab past
        // the active one would silently switch the user to a different
        // panel.
        var activeTabId = ActiveTab?.Id;

        // Drop semantic — same as OnSectionDrop / OnTileDrop:
        // dragging RIGHT drops AFTER the target, dragging LEFT drops
        // BEFORE. Both collapse to "remove source, then insert at the
        // target's *pre-removal* index" — which after removal lands
        // the moved item in the visually-correct slot for either
        // direction. An earlier "-1" adjustment in this codebase
        // made right-drag-onto-last-tab land second-to-last instead
        // of last; don't reintroduce it.
        var moved = _tabs[sourceIdx];
        _tabs.RemoveAt(sourceIdx);
        var insertAt = Math.Clamp(targetIdx, 0, _tabs.Count);
        _tabs.Insert(insertAt, moved);
        for (var i = 0; i < _tabs.Count; i++) _tabs[i].SortOrder = i;

        if (activeTabId is int aid)
        {
            var newActive = _tabs.FindIndex(x => x.Id == aid);
            if (newActive >= 0) _activeTabIndex = newActive;
        }

        if (await Snackbar.RunAsync(Logger, "saving tab order",
                () => MasterService.UpdateTabOrderAsync(_tabs, _userEmail)))
        {
            StateHasChanged();
        }
    }

    // Cross-tab move. Fired when the user drags a tile over a tab header
    // (not the active one) and releases. Updates the DB via the service,
    // removes the tile from the local list for the current tab, and
    // resets all drag state. No tab switch — the user stays where they
    // are; the tile is just gone from this view.
    private async Task OnTileDropOnTab(int targetTabId)
    {
        var activeId = ActiveTab?.Id ?? 0;
        // Snapshot the drag-source index before we clear state; async
        // handlers can re-enter after any await.
        var sourceIdx = _dragSource;
        _dragSource = -1; _dropTarget = -1; _dropTargetTabId = 0;

        if (sourceIdx < 0 || sourceIdx >= _tiles.Count) return;
        if (targetTabId == activeId) return;

        var tile = _tiles[sourceIdx];
        var targetLabel = _tabs.FirstOrDefault(x => x.Id == targetTabId)?.Label ?? "another tab";
        if (await Snackbar.RunAsync(Logger, "moving tile across tabs",
                () => MasterService.MoveTileToTabAsync(tile.Id, targetTabId, _userEmail),
                successMessage: $"Moved \"{tile.ReportName}\" to {targetLabel}."))
        {
            _tiles.RemoveAt(sourceIdx);
            _tileData.Remove(tile.ReportId);
            _tileLoadedAtUtc.Remove(tile.ReportId);
        }
    }

    // ── Tile export (matches Detail Viewer's "All Records" export) ──
    // Tiles render aggregated views (group-by, chart, totals); admins
    // periodically want the underlying detail rows out as a file. Same
    // dropdown affordance as the Detail Viewer, same export pipeline,
    // same filename shape. The data is whatever the tile already
    // fetched — no extra round-trip — minus any columns the admin
    // chose to hide on the dashboard config.
    private async Task ExportTileDetailExcel(MasterDashboardTile tile)
    {
        if (!_tileData.TryGetValue(tile.ReportId, out var td)) return;
        if (!await ConfirmExportIfEmptyAsync(td)) return;
        var data = BuildTileExportData(td);
        var name = tile.ReportName ?? "Report";
        var bytes = ExportService.ExportToExcel(data, name);
        await JS.DownloadAsync(BuildTileExportFileName(tile, "xlsx"), bytes);
    }

    private async Task ExportTileDetailCsv(MasterDashboardTile tile)
    {
        if (!_tileData.TryGetValue(tile.ReportId, out var td)) return;
        if (!await ConfirmExportIfEmptyAsync(td)) return;
        var data = BuildTileExportData(td);
        var bytes = ExportService.ExportToCsv(data);
        await JS.DownloadAsync(BuildTileExportFileName(tile, "csv"), bytes);
    }

    private async Task ExportTileDetailPdf(MasterDashboardTile tile)
    {
        if (!_tileData.TryGetValue(tile.ReportId, out var td)) return;
        if (!await ConfirmExportIfEmptyAsync(td)) return;
        var data = BuildTileExportData(td);
        var name = tile.ReportName ?? "Report";
        var bytes = ExportService.ExportToPdf(data, name);
        await JS.DownloadAsync(BuildTileExportFileName(tile, "pdf"), bytes);
    }

    // Confirm with the user before exporting an empty result set.
    // Returning false aborts the export. The headers-only file still
    // has a legitimate use (template scaffold), so this is a prompt,
    // not a block.
    private async Task<bool> ConfirmExportIfEmptyAsync(TileLoadResult td)
    {
        if (td.Data.Rows.Count > 0) return true;
        var result = await DialogService.ShowMessageBoxAsync(new MessageBoxOptions
        {
            Title = "Nothing to export",
            Message = "This report doesn't have any records right now. Do you still want to download the file?",
            YesText = "Download anyway",
            CancelText = "Cancel"
        });
        return result == true;
    }

    // Drops any columns the dashboard config marked hidden so the
    // exported file matches what users see in the Detail Viewer.
    // Mirrors DetailViewer.BuildExportData — same shape, same intent.
    private static QueryResponse BuildTileExportData(TileLoadResult td)
    {
        var hidden = td.HiddenColumns is { Count: > 0 }
            ? new HashSet<string>(td.HiddenColumns, StringComparer.OrdinalIgnoreCase)
            : null;
        var hasOverrides = td.CustomColumnLabels is { Count: > 0 };
        if (hidden is null && !hasOverrides) return td.Data;
        var visibleColumns = (hidden is null
            ? td.Data.Columns
            : td.Data.Columns.Where(c => !hidden.Contains(c.FieldId)))
            .WithLabelOverrides(td.CustomColumnLabels);
        return new QueryResponse
        {
            Columns = visibleColumns,
            Rows = td.Data.Rows,
            TotalCount = td.Data.TotalCount
        };
    }

    private string BuildTileExportFileName(MasterDashboardTile tile, string ext)
    {
        var name = tile.ReportName ?? "Report";
        var prefix = string.IsNullOrWhiteSpace(_dashboardTitle) ? string.Empty : $"{_dashboardTitle} - ";
        return $"{prefix}{name}-Detail.{ext}";
    }

    private record TileLoadResult(
        QueryResponse Data,
        DashboardView.DashboardConfig? Config,
        List<string>? HiddenColumns,
        List<TleReportingDashboard.Web.Models.TableCalcColumnDef>? TableCalcColumns,
        // Per-template column-rename overrides — forwarded to the tile's
        // DashboardView (drill-down detail) and applied to its export so
        // the spreadsheet headers match the renamed columns admins see
        // on screen.
        Dictionary<string, string>? CustomColumnLabels);

    // Renders a wall-clock UTC stamp as a relative phrase ("just now",
    // "5m ago", "2h ago"). Falls back to the absolute date for anything
    // older than a week — past that, "10d ago" stops being useful and
    // the actual date answers the freshness question better. Returns
    // "—" for default(DateTime), which is what _tileLoadedAtUtc returns
    // when no successful load has happened yet.
    private static string FormatTileFooterTime(DateTime utc)
    {
        if (utc == default) return "—";
        var delta = DateTime.UtcNow - utc;
        if (delta.TotalSeconds < 30)  return "just now";
        if (delta.TotalMinutes < 60)  return $"{(int)delta.TotalMinutes}m ago";
        if (delta.TotalHours   < 24)  return $"{(int)delta.TotalHours}h ago";
        if (delta.TotalDays    < 7)   return $"{(int)delta.TotalDays}d ago";
        return utc.ToLocalTime().ToString("MMM d, yyyy");
    }

    private record FailedTileQuery(
        string Sql,
        Dictionary<string, object?> Parameters,
        string? ScopingNote,
        bool ScopingForceNoMatch,
        string Error);

    // Right-click on any tile opens the SQL debug dialog. Unfiltered by
    // role — any user can see what query produced their tile, which is
    // what makes the "why am I seeing zero rows?" investigation tractable
    // (reveals whether row-level scoping injected `1 = 0` or an `=` pred).
    // Also opens for tiles whose execution failed: the SQL is recovered
    // via QueryService.BuildSqlAsync so admins can still see what was
    // sent (or what was attempted, when even the build phase failed).
    private async Task ShowTileQuery(MasterDashboardTile tile)
    {
        string sql;
        Dictionary<string, object?>? parameters;
        string? scopingNote;
        bool scopingForceNoMatch;
        string? errorMessage = null;

        if (_tileData.TryGetValue(tile.ReportId, out var result)
            && !string.IsNullOrEmpty(result.Data.Sql))
        {
            sql = result.Data.Sql!;
            parameters = result.Data.Parameters;
            scopingNote = result.Data.ScopingNote;
            scopingForceNoMatch = result.Data.ScopingForceNoMatch;
        }
        else if (_tileFailedQuery.TryGetValue(tile.ReportId, out var failure))
        {
            sql = string.IsNullOrEmpty(failure.Sql)
                ? "/* SQL couldn't be generated — see error message above */"
                : failure.Sql;
            parameters = failure.Parameters;
            scopingNote = failure.ScopingNote;
            scopingForceNoMatch = failure.ScopingForceNoMatch;
            errorMessage = failure.Error;
        }
        else
        {
            Snackbar.Add("This tile hasn't loaded yet — wait for the data to finish.", Severity.Info);
            return;
        }

        var dialogParams = new DialogParameters
        {
            { "Sql", sql },
            { "Parameters", parameters },
            { "ScopingNote", scopingNote },
            { "ScopingForceNoMatch", scopingForceNoMatch },
            { "ErrorMessage", errorMessage }
        };
        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Large,
            FullWidth = true
        };
        await DialogService.ShowAsync<ShowQueryDialog>($"SQL — {tile.ReportName}", dialogParams, options);
    }
}
